set shell := ["sh", "-eu", "-c"]
set quiet := true

release_dir := source_directory()
project_root := canonicalize(release_dir + "/..")
tmp_dir := project_root + "/tmp"
export TMPDIR := tmp_dir

bump target:
    uv run --project "{{ release_dir }}" txing-release bump "{{ target }}"

check:
    uv run --project "{{ release_dir }}" txing-release check

build:
    uv build --project "{{ release_dir }}"

@default:
    @just --list
