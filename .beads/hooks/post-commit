#!/usr/bin/env sh
set -eu

# Close Beads issues named in a Beads-Close trailer, export the updated
# JSONL state, and amend the just-created commit so code and issue state
# land in the same final commit.
#
# Example:
#   feat: wire rig endpoint autodiscovery
#
#   Beads-Close: txing-123 txing-123.1
#
# The amend changes the commit SHA once. Guard against recursively
# re-entering the hook on the amend commit.

if [ "${BEADS_POST_COMMIT_AMEND:-}" = "1" ]; then
  exit 0
fi

if ! command -v bd >/dev/null 2>&1; then
  exit 0
fi

if ! command -v git >/dev/null 2>&1; then
  exit 0
fi

commit_sha="$(git rev-parse --verify HEAD 2>/dev/null || true)"
if [ -z "$commit_sha" ]; then
  exit 0
fi

commit_message="$(git show -s --format=%B "$commit_sha" 2>/dev/null || true)"
if [ -z "$commit_message" ]; then
  exit 0
fi

issue_ids="$(
  printf '%s' "$commit_message" |
    git interpret-trailers --parse 2>/dev/null |
    awk '
      BEGIN { IGNORECASE = 1 }
      index(tolower($0), "beads-close:") == 1 {
        sub(/^[^:]*:[[:space:]]*/, "", $0)
        gsub(/,/, " ", $0)
        n = split($0, parts, /[[:space:]]+/)
        for (i = 1; i <= n; i++) {
          if (parts[i] != "") {
            print parts[i]
          }
        }
      }
    ' |
    awk '!seen[$0]++'
)"

if [ -z "$issue_ids" ]; then
  exit 0
fi

# shellcheck disable=SC2086
set -- $issue_ids
if ! bd close "$@" --reason "Closed by Beads-Close trailer"; then
  echo >&2 "beads: failed to close issue(s) from Beads-Close trailer on commit $commit_sha"
  exit 0
fi

if ! bd export -o .beads/issues.jsonl; then
  echo >&2 "beads: failed to export .beads/issues.jsonl after closing issue(s) for commit $commit_sha"
  exit 0
fi

if ! git add .beads/issues.jsonl; then
  echo >&2 "beads: failed to stage .beads/issues.jsonl after closing issue(s) for commit $commit_sha"
  exit 0
fi

if git diff --cached --quiet -- .beads/issues.jsonl; then
  exit 0
fi

# Avoid interactive signing prompts inside a post-commit hook.
if ! BEADS_POST_COMMIT_AMEND=1 git -c commit.gpgsign=false commit --amend --no-edit --no-verify >/dev/null; then
  echo >&2 "beads: failed to amend commit $commit_sha with exported Beads state"
fi

exit 0
