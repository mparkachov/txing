set shell := ["bash", "-eu", "-o", "pipefail", "-c"]
set quiet := true

witness_dir := source_directory()

@test:
    cd "{{witness_dir}}" && go test -tags lambda.norpc ./...

build:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{witness_dir}}"
    GOOS=linux GOARCH=arm64 CGO_ENABLED=0 go build -trimpath -tags lambda.norpc -ldflags="-s -w" -o target/release/txing-witness-lambda ./cmd/txing-witness-lambda

deploy:
    @echo "Direct per-function deploy is disabled. Use: just aws::deploy-local-lambda txing-witness-lambda" >&2
    @exit 1

@default:
    @just --list
