set shell := ["sh", "-eu", "-c"]
set quiet := true

office_dir := source_directory()
project_root := canonicalize(office_dir + "/..")
tmp_dir := project_root + "/tmp"
export TMPDIR := tmp_dir
root_justfile := project_root + "/justfile"
aws_lib := project_root + "/shared/aws/scripts/aws_lib.sh"
stack_name := ""
office_dist_dir := office_dir + "/dist"

@install:
    cd "{{office_dir}}"
    bun install

dev:
    #!/bin/sh
    set -eu
    cd "{{office_dir}}"
    bun run dev

build:
    #!/bin/sh
    set -eu
    cd "{{office_dir}}"
    bun --bun run build

deploy stack_name=stack_name office_dist_dir=office_dist_dir:
    #!/bin/sh
    set -eu
    cd "{{office_dir}}"

    if [ ! -d "{{office_dist_dir}}" ]; then
      echo "Office build output {{office_dist_dir}} not found. Run just build first." >&2
      exit 1
    fi

    echo "Production office deployment is managed by Cloudflare Pages."
    echo "Project: txing-office"
    echo "Root directory: office"
    echo "Build command: bun install --frozen-lockfile && bun --bun run build"
    echo "Deploy command: leave empty; Cloudflare Pages publishes the dist directory"
    echo "Build output directory: dist"
    echo "Domain: office.txing.dev"

@lint:
    cd "{{office_dir}}"
    bun run lint

write-env sparkplug_group_id='' town_thing_name='' stack_name=stack_name:
    #!/bin/sh
    set -eu
    cd "{{office_dir}}"

    . "{{aws_lib}}"
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env town "{{stack_name}}")"
    txing_aws_init
    region="$TXING_AWS_REGION"

    cognito_domain="$(stack_parameter WebCognitoDomain)"
    cognito_client_id="$(stack_parameter WebCognitoUserPoolClientId)"
    cognito_user_pool_id="$(stack_parameter WebCognitoUserPoolId)"
    cognito_identity_pool_id="$(stack_parameter WebCognitoIdentityPoolId)"
    web_iot_policy_name="$(stack_parameter WebIotPolicyName)"
    admin_email="$(stack_parameter WebExpectedAdminEmail)"

    if [ "$cognito_domain" = "None" ] || [ "$cognito_client_id" = "None" ] || [ "$cognito_user_pool_id" = "None" ] || [ "$cognito_identity_pool_id" = "None" ] || [ "$web_iot_policy_name" = "None" ] || [ "$admin_email" = "None" ]; then
      echo "Required office parameters are missing under /txing/stack. Run just aws::deploy first." >&2
      exit 1
    fi

    current_sparkplug_group_id="$SPARKPLUG_GROUP_ID"
    current_town_thing_name="$TXING_TOWN_ID"

    if [ -n "{{sparkplug_group_id}}" ]; then
      current_sparkplug_group_id="{{sparkplug_group_id}}"
    fi
    if [ -n "{{town_thing_name}}" ]; then
      current_town_thing_name="{{town_thing_name}}"
    fi

    printf '%s\n' \
      "VITE_AWS_REGION=$region" \
      "VITE_TOWN_THING_NAME=$current_town_thing_name" \
      "VITE_SPARKPLUG_GROUP_ID=$current_sparkplug_group_id" \
      "VITE_COGNITO_DOMAIN=$cognito_domain" \
      "VITE_COGNITO_CLIENT_ID=$cognito_client_id" \
      "VITE_COGNITO_USER_POOL_ID=$cognito_user_pool_id" \
      "VITE_COGNITO_IDENTITY_POOL_ID=$cognito_identity_pool_id" \
      "VITE_IOT_POLICY_NAME=$web_iot_policy_name" \
      "VITE_COGNITO_SCOPE=openid email profile" \
      "VITE_ADMIN_EMAIL=$admin_email" \
      > .env.local

    echo "Wrote {{office_dir}}/.env.local from /txing/stack parameters."
