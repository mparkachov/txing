set shell := ["bash", "-eu", "-o", "pipefail", "-c"]
set quiet := true

mcu_dir := source_directory()
project_root := mcu_dir + "/../../.."
uv_cache_dir := project_root + "/zephyr/.uv-cache"
script := mcu_dir + "/scripts/weather_mcu.py"
nrf_bm_justfile := project_root + "/devices/common/mcu/nrf-bm/justfile"

@check:
    cd "{{mcu_dir}}" && UV_CACHE_DIR="{{uv_cache_dir}}" uv run --project "{{project_root}}/zephyr" --no-sync python "{{script}}" check

@build: check

@bm-check:
    just --justfile "{{nrf_bm_justfile}}" build-weather

@bm-install:
    just --justfile "{{nrf_bm_justfile}}" install

@bm-flash thing_id:
    just --justfile "{{nrf_bm_justfile}}" flash-weather "{{thing_id}}"

@bm-flash-app:
    just --justfile "{{nrf_bm_justfile}}" flash-weather-advertising

@bm-flash-softdevice:
    just --justfile "{{nrf_bm_justfile}}" flash-weather-softdevice

@bm-rtt:
    just --justfile "{{nrf_bm_justfile}}" rtt-weather

@bm-paths:
    just --justfile "{{nrf_bm_justfile}}" paths

@flash thing_id:
    cd "{{mcu_dir}}" && UV_CACHE_DIR="{{uv_cache_dir}}" uv run --project "{{project_root}}/zephyr" --no-sync python "{{script}}" flash "{{thing_id}}"

@verify thing_id='':
    cd "{{mcu_dir}}" && UV_CACHE_DIR="{{uv_cache_dir}}" uv run --project "{{project_root}}/zephyr" --no-sync python "{{script}}" verify "{{thing_id}}"

@clean:
    rm -rf "{{mcu_dir}}/build"

@default:
    @just --list
