set shell := ["bash", "-eu", "-o", "pipefail", "-c"]
set quiet := true

mcu_dir := source_directory()
project_root := mcu_dir + "/../../.."
uv_cache_dir := project_root + "/zephyr/.uv-cache"
script := mcu_dir + "/scripts/weather_mcu.py"

@check:
    cd "{{mcu_dir}}" && UV_CACHE_DIR="{{uv_cache_dir}}" uv run --project "{{project_root}}/zephyr" --no-sync python "{{script}}" check

@build: check

@bm-check:
    test -n "${NRF_BM_ROOT:-}" || { echo "Set NRF_BM_ROOT to an sdk-nrf-bm workspace, for example /path/to/nrf-bm/v2.0.0"; exit 2; }
    test -n "${ZEPHYR_SDK_INSTALL_DIR:-}" || { echo "Set ZEPHYR_SDK_INSTALL_DIR to a Zephyr SDK install, for example /path/to/zephyr-sdk-0.17.4"; exit 2; }
    cd "${NRF_BM_ROOT}" && env "Zephyr-sdk_DIR=${ZEPHYR_SDK_INSTALL_DIR}/cmake" west build -p always -b bm_nrf54l15dk/nrf54l15/cpuapp/s115_softdevice "{{mcu_dir}}/baremetal" -d "{{mcu_dir}}/build/baremetal-advertising" -- -DCMAKE_FIND_USE_PACKAGE_REGISTRY=FALSE

@flash thing_id:
    cd "{{mcu_dir}}" && UV_CACHE_DIR="{{uv_cache_dir}}" uv run --project "{{project_root}}/zephyr" --no-sync python "{{script}}" flash "{{thing_id}}"

@verify thing_id='':
    cd "{{mcu_dir}}" && UV_CACHE_DIR="{{uv_cache_dir}}" uv run --project "{{project_root}}/zephyr" --no-sync python "{{script}}" verify "{{thing_id}}"

@clean:
    rm -rf "{{mcu_dir}}/build"

@default:
    @just --list
