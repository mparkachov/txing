menu "txing weather BLE debug SoftDevice firmware"

config TXING_WEATHER_FACTORY_DATA_ADDR
	hex "Weather factory data flash address"
	default 0x000f0000

config TXING_WEATHER_ADV_INTERVAL_625US
	int "Advertising interval in 625 us units"
	default 160
	help
	  160 is 100 ms.

config TXING_WEATHER_ADV_TX_POWER_DBM
	int "Advertising transmit power in dBm"
	default 8

config TXING_WEATHER_SCAN_REQ_NOTIFY
	bool "Enable scan request events"
	default n
	help
	  Enable only when debugging advertisement/scanner behavior. Scan request
	  events wake the application and generate logs while advertising.

config TXING_WEATHER_ACTIVE_CONN_INTERVAL_MS
	int "Connected active connection interval in milliseconds"
	default 100
	help
	  Requested BLE connection interval while REDCON is active.

config TXING_WEATHER_ACTIVE_CONN_LATENCY
	int "Connected active peripheral latency"
	default 0

config TXING_WEATHER_ACTIVE_CONN_SUPERVISION_TIMEOUT_MS
	int "Connected active supervision timeout in milliseconds"
	default 10000
	help
	  Requested BLE supervision timeout while REDCON is active.

config TXING_WEATHER_IDLE_CONN_INTERVAL_MS
	int "Connected idle connection interval in milliseconds"
	default 100
	help
	  Requested minimum and maximum BLE connection interval after GATT setup.
	  The value must map exactly to BLE 1.25 ms interval units.

config TXING_WEATHER_IDLE_CONN_LATENCY
	int "Connected idle peripheral latency"
	default 0

config TXING_WEATHER_IDLE_CONN_SUPERVISION_TIMEOUT_MS
	int "Connected idle supervision timeout in milliseconds"
	default 6000
	help
	  Requested BLE supervision timeout after GATT setup. The value must map
	  exactly to BLE 10 ms timeout units.

config TXING_WEATHER_IDLE_CONN_PARAM_FALLBACK_DELAY_MS
	int "Connected idle connection parameter fallback delay in milliseconds"
	default 10000
	help
	  Fallback delay before requesting the idle connection parameters when the
	  central has not subscribed to all debug notifications yet.

config TXING_WEATHER_IDLE_CONN_PARAM_INITIAL_DELAY_MS
	int "Connected idle connection parameter initial delay in milliseconds"
	default 250
	help
	  Delay after connection before requesting the selected debug connection
	  parameters even if GATT discovery has not finished yet. This gives Linux
	  BlueZ a longer supervision timeout before service discovery can time out
	  on a weak link. Set negative to disable the initial request and use only
	  the GATT-ready or fallback paths.

config TXING_WEATHER_IDLE_DIAG_ENABLE
	bool "Enable periodic idle diagnostics"
	default n
	help
	  Keep disabled for current measurements. Periodic diagnostics wake the CPU
	  and keep log traffic alive while the device is otherwise idle.

config TXING_WEATHER_IDLE_BATTERY_REPORT_ENABLE
	bool "Sample and notify battery periodically while idle"
	default n
	help
	  Keep disabled for current measurements. Battery is still sampled during
	  active REDCON measurement streaming.

config TXING_WEATHER_IDLE_LOG_FLUSH_ENABLE
	bool "Flush deferred logs from the idle loop"
	default n
	help
	  Enable only when watching RTT logs. Disabled by default so connected idle
	  can sleep until a BLE interrupt instead of waking only to drain logs.

config TXING_WEATHER_SYSTEM_OFF_TEST
	bool "Run floor-current System OFF test instead of BLE firmware"
	default n
	help
	  Build a measurement-only image that does not start SoftDevice, BLE,
	  BME280, battery ADC, or advertising. It waits briefly after boot with
	  the board power output off, then enters nRF54 System OFF.

config TXING_WEATHER_SYSTEM_OFF_TEST_DELAY_MS
	int "Delay before entering System OFF in the floor-current test"
	default 5000
	depends on TXING_WEATHER_SYSTEM_OFF_TEST

config TXING_WEATHER_INVALID_NAME
	string "Fallback local name when factory data is invalid"
	default "TxingWeatherInvalid"

module=TXING_WEATHER_BLE_DEBUG
module-str=txing weather BLE debug SoftDevice firmware
source "$(ZEPHYR_BASE)/subsys/logging/Kconfig.template.log_config"

endmenu

source "Kconfig.zephyr"
