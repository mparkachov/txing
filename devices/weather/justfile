set shell := ["sh", "-eu", "-c"]
set quiet := true

weather_dir := source_directory()
project_root := canonicalize(weather_dir + "/../..")
tmp_dir := project_root + "/tmp"
export TMPDIR := tmp_dir
test_manifest := weather_dir + "/test/Cargo.toml"

mod mcu 'mcu/justfile'

test repetitions="1" name="weather-test" *args:
    #!/bin/sh
    set -eu
    repetitions="{{repetitions}}"
    case "$repetitions" in ''|*[!0-9]*) echo "repetitions must be a positive integer" >&2; exit 2 ;; esac
    if [ "$repetitions" -lt 1 ]; then
      echo "repetitions must be a positive integer" >&2
      exit 2
    fi
    write_logs=0
    output_dir=""
    forward_args_text=""
    append_forward_arg() {
      if [ -z "$forward_args_text" ]; then
        forward_args_text="$1"
      else
        forward_args_text="$forward_args_text $1"
      fi
    }
    set -- {{args}}
    while [ "$#" -gt 0 ]; do
      token="$1"
      shift
      case "$token" in
        --logs)
          write_logs=1
          ;;
        --output-dir=*)
          write_logs=1
          output_dir="${token#--output-dir=}"
          append_forward_arg "$token"
          ;;
        --output-dir)
          write_logs=1
          if [ "$#" -eq 0 ]; then
            echo "--output-dir requires a value" >&2
            exit 2
          fi
          output_dir="$1"
          shift
          append_forward_arg "$token"
          append_forward_arg "$output_dir"
          ;;
        *)
          append_forward_arg "$token"
          ;;
      esac
    done
    echo "weather physical BLE REDCON 4 suite: $repetitions test(s)"
    if [ "$write_logs" -eq 1 ]; then
      mkdir -p "$TMPDIR"
      root="$TMPDIR/weather-device-test-results"
      mkdir -p "$root"
      if [ -n "$output_dir" ]; then
        run_dir="$output_dir"
        mkdir -p "$run_dir"
      else
        run_dir="$(mktemp -d "$root/$(date +%Y%m%d-%H%M%S)-XXXXXX")"
      fi
      echo "outputDir=$run_dir"
      echo "log=$run_dir/cycle.log"
      : > "$run_dir/cycle.log"
      WEATHER_DEVICE_TEST_WRITE_LOGS="$write_logs" \
      WEATHER_DEVICE_TEST_REPETITIONS="$repetitions" \
      WEATHER_DEVICE_TEST_NAME="{{name}}" \
      WEATHER_DEVICE_TEST_ARGS="$forward_args_text" \
      WEATHER_DEVICE_TEST_RUN_OUTPUT_DIR="$run_dir" \
        cargo test --quiet --manifest-path "{{test_manifest}}" weather_ble_ -- --ignored --format terse --test-threads=1 --nocapture
    else
      echo "logs=disabled (use --logs or --output-dir DIR for cycle.log artifacts)"
      WEATHER_DEVICE_TEST_WRITE_LOGS="$write_logs" \
      WEATHER_DEVICE_TEST_REPETITIONS="$repetitions" \
      WEATHER_DEVICE_TEST_NAME="{{name}}" \
      WEATHER_DEVICE_TEST_ARGS="$forward_args_text" \
        cargo test --quiet --manifest-path "{{test_manifest}}" weather_ble_ -- --ignored --format terse --test-threads=1 --nocapture
    fi

@check:
    cargo test --manifest-path "{{test_manifest}}"

@default:
    @just --list
