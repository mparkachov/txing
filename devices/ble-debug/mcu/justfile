set shell := ["bash", "-eu", "-o", "pipefail", "-c"]
set quiet := true

mcu_dir := source_directory()
firmware_script := mcu_dir + "/scripts/firmware.py"

@install:
    python3 "{{firmware_script}}" install

@submodules:
    python3 "{{firmware_script}}" submodules

@check profile="low-current":
    python3 "{{firmware_script}}" check "{{profile}}"

@build profile="low-current":
    python3 "{{firmware_script}}" build "{{profile}}"

@flash profile="low-current":
    python3 "{{firmware_script}}" flash "{{profile}}"

@flash-check profile="low-current":
    python3 "{{firmware_script}}" flash-check "{{profile}}"

@paths profile="low-current":
    python3 "{{firmware_script}}" paths "{{profile}}"

@clean:
    python3 "{{firmware_script}}" clean

@default:
    @just --list
