set shell := ["bash", "-eu", "-o", "pipefail", "-c"]
set quiet := true

rig_dir := source_directory()
python_executable := env_var_or_default("BLE_DEBUG_RIG_PYTHON", "python3.13")

@default:
    @just --list

@install:
    cd "{{rig_dir}}" && uv sync --python "{{python_executable}}" --no-managed-python --no-python-downloads

@test repetitions="1" name="weather-q8zbgb" *args:
    cd "{{rig_dir}}" && uv run --python "{{python_executable}}" --no-managed-python --no-python-downloads ble-debug-rig-test "{{repetitions}}" --name "{{name}}" {{args}}

@overnight name="weather-q8zbgb" *args:
    cd "{{rig_dir}}" && uv run --python "{{python_executable}}" --no-managed-python --no-python-downloads ble-debug-rig-overnight --name "{{name}}" {{args}}
