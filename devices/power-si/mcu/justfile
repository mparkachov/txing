set shell := ["sh", "-eu", "-c"]
set quiet

mcu_dir := source_directory()
project_root := canonicalize(mcu_dir + "/../../..")
tmp_dir := project_root + "/tmp"
export TMPDIR := tmp_dir
common_mcu_dir := canonicalize(project_root + "/devices/common/mcu")
zephyr_python := env_var_or_default("TXING_MCU_ZEPHYR_PYTHON", "python3")
zephyr_script := common_mcu_dir + "/scripts/stock_zephyr_mcu.py"
serial_python := common_mcu_dir + "/.venv/bin/python"
device_type := "power-si"

@build:
    "{{ zephyr_python }}" "{{ zephyr_script }}" --device "{{ device_type }}" build

@build-debug:
    "{{ zephyr_python }}" "{{ zephyr_script }}" --device "{{ device_type }}" build-debug

@flash profile='release':
    @case "{{ profile }}" in \
      release) "{{ zephyr_python }}" "{{ zephyr_script }}" --device "{{ device_type }}" flash ;; \
      debug) "{{ zephyr_python }}" "{{ zephyr_script }}" --device "{{ device_type }}" --debug flash ;; \
      *) echo "usage: just power-si::mcu::flash [release|debug]" >&2; exit 2 ;; \
    esac

@log port='' baud='115200':
    @if [ -z "{{ port }}" ]; then \
      "{{ serial_python }}" -m serial.tools.list_ports; \
      echo "usage: just power-si::mcu::log <serial-port> [baud]" >&2; \
    else \
      "{{ serial_python }}" -m serial.tools.miniterm "{{ port }}" "{{ baud }}"; \
    fi

@clean:
    "{{ zephyr_python }}" "{{ zephyr_script }}" --device "{{ device_type }}" clean

@default:
    @just --list
