set shell := ["bash", "-eu", "-o", "pipefail", "-c"]
set quiet := true

rig_dir := source_directory()

@default:
    @just --list

@check:
    cargo test --manifest-path "{{rig_dir}}/Cargo.toml"

@sim-test repetitions="1" name="weather-q8zbgb" *args:
    cargo run --manifest-path "{{rig_dir}}/Cargo.toml" -- sim-test --repetitions "{{repetitions}}" --name "{{name}}" {{args}}

@sim-overnight name="weather-q8zbgb" *args:
    cargo run --manifest-path "{{rig_dir}}/Cargo.toml" -- sim-overnight --name "{{name}}" {{args}}

@test repetitions="5" name="weather-q8zbgb" *args:
    #!/usr/bin/env bash
    set -euo pipefail
    repetitions="{{repetitions}}"
    if ! [[ "$repetitions" =~ ^[0-9]+$ ]] || [ "$repetitions" -lt 1 ]; then
      echo "repetitions must be a positive integer" >&2
      exit 2
    fi
    cli_args=({{args}})
    profiles=()
    for ((i = 0; i < ${#cli_args[@]}; i++)); do
      token="${cli_args[$i]}"
      case "$token" in
        --conn-profile=*)
          profiles+=("${token#--conn-profile=}")
          ;;
        --conn-profile)
          i=$((i + 1))
          if [ "$i" -ge "${#cli_args[@]}" ]; then
            echo "--conn-profile requires a value" >&2
            exit 2
          fi
          profiles+=("${cli_args[$i]}")
          ;;
      esac
    done
    if [ "${#profiles[@]}" -eq 0 ]; then
      profiles=("fast-50-0-20")
    fi
    profiles_csv="$(IFS=,; echo "${profiles[*]}")"
    root="/tmp/rust-debug-rig-test-results"
    mkdir -p "$root"
    run_dir="$(mktemp -d "$root/$(date +%Y%m%d-%H%M%S)-XXXXXX")"
    echo "rust-debug physical BLE suite: $repetitions test(s) per conn-profile"
    echo "connProfiles=$profiles_csv"
    echo "default outputDir=$run_dir"
    RUST_DEBUG_RIG_RUN_OUTPUT_DIR="$run_dir" \
      RUST_DEBUG_RIG_TEST_REPETITIONS="$repetitions" \
      RUST_DEBUG_RIG_TEST_PROFILES="$profiles_csv" \
      RUST_DEBUG_RIG_NAME="{{name}}" \
      RUST_DEBUG_RIG_TEST_ARGS="{{args}}" \
      cargo test --manifest-path "{{rig_dir}}/Cargo.toml" --features ble-real physical_ble_ -- --ignored --nocapture --test-threads=1

@run-test repetitions="5" name="weather-q8zbgb" *args:
    cargo run --manifest-path "{{rig_dir}}/Cargo.toml" --features ble-real -- test --repetitions "{{repetitions}}" --name "{{name}}" {{args}}

@overnight name="weather-q8zbgb" *args:
    cargo run --manifest-path "{{rig_dir}}/Cargo.toml" --features ble-real -- overnight --name "{{name}}" {{args}}

@overnight-wall-clock name="weather-q8zbgb" *args:
    cargo run --manifest-path "{{rig_dir}}/Cargo.toml" --features ble-real -- overnight --name "{{name}}" {{args}}

@component adapter_id="rust-debug-ble-main" *args:
    bash "{{rig_dir}}/scripts/check-greengrass-sdk-prereqs.sh"
    bash "{{rig_dir}}/scripts/check-greengrass-runtime-prereqs.sh"
    cargo run --manifest-path "{{rig_dir}}/Cargo.toml" --features greengrass-sdk -- component --adapter-id "{{adapter_id}}" {{args}}

@mock-component adapter_id="rust-debug-ble-main" *args:
    cargo run --manifest-path "{{rig_dir}}/Cargo.toml" -- mock-component --adapter-id "{{adapter_id}}" {{args}}

@greengrass-doctor *args:
    cargo run --manifest-path "{{rig_dir}}/Cargo.toml" -- greengrass-doctor {{args}}
