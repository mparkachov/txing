[private]
_ensure-aws-sdk-submodule:
    test -f "{{aws_kvs_sdk_dir}}/CMakeLists.txt" || { echo "missing AWS KVS WebRTC SDK submodule. Run: just unit::board::submodules" >&2; exit 1; }

@_check-kvs-system-dependencies:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ "$(uname -s)" != "Linux" ]; then
        exit 0
    fi

    missing=()
    for pc in openssl libcurl libwebsockets zlib; do
        if ! pkg-config --exists "$pc"; then
            missing+=("$pc")
        fi
    done

    for header in usrsctp.h srtp2/srtp.h; do
        if ! printf '#include <%s>\nint main(void) { return 0; }\n' "$header" | cc -x c - -fsyntax-only >/dev/null 2>&1; then
            missing+=("$header")
        fi
    done
    if ! printf '#include <log4cplus/logger.h>\nint main() { return 0; }\n' | c++ -x c++ - -fsyntax-only >/dev/null 2>&1; then
        missing+=("log4cplus/logger.h")
    fi

    for library in srtp2 usrsctp log4cplus curl websockets z ssl crypto; do
        path="$(cc -print-file-name="lib${library}.so")"
        if [ "$path" = "lib${library}.so" ] || [ ! -f "$path" ]; then
            missing+=("lib${library}.so")
        fi
    done

    if [ "${#missing[@]}" -gt 0 ]; then
        printf 'Missing system KVS dependency/dependencies: %s\n' "${missing[*]}" >&2
        printf 'Install distro packages, for example:\n' >&2
        printf '  sudo apt install -y libssl-dev libcurl4-openssl-dev liblog4cplus-dev libsrtp2-dev libusrsctp-dev libwebsockets-dev zlib1g-dev\n' >&2
        exit 1
    fi

@sync:
    cd "{{board_dir}}" && uv sync --python "{{python_executable}}" --no-managed-python --no-python-downloads

build:
    #!/usr/bin/env bash
    set -euo pipefail
    eval "$(just --justfile "{{root_justfile}}" _project-version-env)"
    cd "{{board_dir}}" && uv sync --frozen --no-editable --compile-bytecode --python "{{python_executable}}" --no-managed-python --no-python-downloads --refresh-package board --reinstall-package board --refresh-package aws --reinstall-package aws
    test -x "{{built_board}}"
    test -x "{{built_board_video_sender}}"
    test -x "{{built_board_motor_raw}}"

[positional-arguments]
aws *args:
    #!/usr/bin/env bash
    set -euo pipefail
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env device)"
    command aws "$@"

check thing_name='' region=region aws_profile=aws_profile:
    #!/usr/bin/env bash
    set -euo pipefail
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env device "{{region}}" "{{aws_profile}}")"
    thing_name="$THING_NAME"
    if [ -n "{{thing_name}}" ]; then
      thing_name="{{thing_name}}"
    fi

    uv run --project "{{project_root}}/shared/aws/python" \
      python -m aws.check \
      --scope device \
      --thing-name "$thing_name"

@submodules:
    git -C "{{project_root}}" submodule update --init --recursive -- devices/common/board/aws-kvs-webrtc-sdk

@build-aws-sdk: _ensure-aws-sdk-submodule
    #!/usr/bin/env bash
    set -euo pipefail
    just --justfile "{{board_justfile}}" _check-kvs-system-dependencies
    if [ "$(uname -s)" != "Linux" ]; then
        echo "build-aws-sdk uses apt/distro system dependencies and must run on the Linux board host." >&2
        exit 1
    fi
    rm -rf "{{aws_kvs_sdk_build_dir}}" "{{aws_kvs_sdk_install_dir}}" "{{aws_kvs_sdk_system_deps_dir}}"
    mkdir -p "{{aws_kvs_sdk_system_deps_dir}}/lib" "{{aws_kvs_sdk_system_deps_dir}}/include"
    cmake_args=( \
        -S "{{aws_kvs_sdk_dir}}" \
        -B "{{aws_kvs_sdk_build_dir}}" \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX="{{aws_kvs_sdk_install_dir}}" \
        -DOPEN_SRC_INSTALL_PREFIX="{{aws_kvs_sdk_system_deps_dir}}" \
        -DBUILD_DEPENDENCIES=OFF \
        -DBUILD_SAMPLE=OFF \
        -DBUILD_TEST=OFF \
        -DBUILD_BENCHMARK=OFF \
        -DBUILD_STATIC_LIBS=ON \
        -DUSE_OPENSSL=ON \
        -DUSE_MBEDTLS=OFF \
    )
    if [ "$(uname -s)" = "Linux" ]; then
        openssl_libdir="$(pkg-config --variable=libdir openssl)"
        openssl_includedir="$(pkg-config --variable=includedir openssl)"
        openssl_ssl_library="$openssl_libdir/libssl.so"
        openssl_crypto_library="$openssl_libdir/libcrypto.so"
        if [ ! -f "$openssl_ssl_library" ] || [ ! -f "$openssl_crypto_library" ]; then
            echo "Expected shared OpenSSL libraries were not found under $openssl_libdir" >&2
            exit 1
        fi
        cmake_args+=( -DOPENSSL_USE_STATIC_LIBS=FALSE )
        cmake_args+=( -DOPENSSL_INCLUDE_DIR="$openssl_includedir" )
        cmake_args+=( -DOPENSSL_SSL_LIBRARY="$openssl_ssl_library" )
        cmake_args+=( -DOPENSSL_CRYPTO_LIBRARY="$openssl_crypto_library" )

        for library in srtp2 usrsctp log4cplus curl websockets z ssl crypto; do
            library_path="$(cc -print-file-name="lib${library}.so")"
            if [ "$library_path" = "lib${library}.so" ] || [ ! -f "$library_path" ]; then
                echo "System lib${library}.so not found; install the matching distro development package" >&2
                exit 1
            fi
            ln -s "$library_path" "{{aws_kvs_sdk_system_deps_dir}}/lib/lib${library}.so"
            ln -s "$library_path" "{{aws_kvs_sdk_system_deps_dir}}/lib${library}.so"
        done
    fi
    cmake "${cmake_args[@]}"
    cmake --build "{{aws_kvs_sdk_build_dir}}" --config Release
    cmake --install "{{aws_kvs_sdk_build_dir}}" --config Release
    if [ ! -f "{{aws_kvs_sdk_system_deps_dir}}/include/com/amazonaws/kinesis/video/common/Include.h" ]; then
        echo "Expected AWS SDK support headers were not built under {{aws_kvs_sdk_system_deps_dir}}/include" >&2
        exit 1
    fi
    cp -a "{{aws_kvs_sdk_system_deps_dir}}/include/com" "{{aws_kvs_sdk_install_dir}}/include/"
    for aws_library in kvsCommonLws kvspicUtils kvspicState; do
        source_library="{{aws_kvs_sdk_system_deps_dir}}/lib/lib${aws_library}.a"
        if [ ! -f "$source_library" ]; then
            echo "Expected AWS SDK support library was not built: $source_library" >&2
            exit 1
        fi
        cp -a "$source_library" "{{aws_kvs_sdk_install_dir}}/lib/"
    done
    sdk_head="$(git -C "{{aws_kvs_sdk_dir}}" rev-parse HEAD)"
    printf 'sdk_head=%s\nbuild_dependencies=OFF\ndependency_source=system\n' "$sdk_head" > "{{aws_kvs_sdk_state_file}}"

@ensure-aws-sdk: _ensure-aws-sdk-submodule
    #!/usr/bin/env bash
    set -euo pipefail
    sdk_head="$(git -C "{{aws_kvs_sdk_dir}}" rev-parse HEAD)"
    if [ ! -f "{{aws_kvs_sdk_install_header}}" ] || [ ! -f "{{aws_kvs_sdk_install_common_header}}" ] || [ ! -f "{{aws_kvs_sdk_install_library}}" ] || [ ! -f "{{aws_kvs_sdk_install_dir}}/lib/libkvsCommonLws.a" ] || [ ! -f "{{aws_kvs_sdk_install_dir}}/lib/libkvspicUtils.a" ] || [ ! -f "{{aws_kvs_sdk_install_dir}}/lib/libkvspicState.a" ] || [ ! -f "{{aws_kvs_sdk_state_file}}" ]; then
        just --justfile "{{board_justfile}}" build-aws-sdk
    elif ! grep -Fqx "sdk_head=$sdk_head" "{{aws_kvs_sdk_state_file}}"; then
        just --justfile "{{board_justfile}}" build-aws-sdk
    elif ! grep -Fqx "build_dependencies=OFF" "{{aws_kvs_sdk_state_file}}"; then
        just --justfile "{{board_justfile}}" build-aws-sdk
    elif ! grep -Fqx "dependency_source=system" "{{aws_kvs_sdk_state_file}}"; then
        just --justfile "{{board_justfile}}" build-aws-sdk
    elif [ "$(uname -s)" = "Linux" ] && { [ ! -f "{{aws_kvs_sdk_flags_file}}" ] || grep -Eq 'KVS_CA_CERT_PATH=|CMAKE_DETECTED_CACERT_PATH' "{{aws_kvs_sdk_flags_file}}"; }; then
        just --justfile "{{board_justfile}}" build-aws-sdk
    fi

@clean-native:
    rm -rf "{{native_kvs_master_build_dir}}" "{{native_kvs_master_test_build_dir}}"

@clean-aws-sdk:
    rm -rf "{{aws_kvs_sdk_build_dir}}" "{{aws_kvs_sdk_install_dir}}" "{{aws_kvs_sdk_system_deps_dir}}"

@clean:
    just --justfile "{{board_justfile}}" clean-native
    just --justfile "{{board_justfile}}" clean-aws-sdk

@distclean:
    just --justfile "{{board_justfile}}" clean

@build-native:
    if [ "$(uname -s)" = "Linux" ]; then \
        just --justfile "{{board_justfile}}" _check-kvs-system-dependencies; \
        just --justfile "{{board_justfile}}" ensure-aws-sdk; \
    fi; \
    native_cmake_args=( \
        -S "{{native_kvs_master_dir}}" \
        -B "{{native_kvs_master_build_dir}}" \
        -DCMAKE_BUILD_TYPE=Release \
        -DBUILD_TESTING=OFF \
        -DTXING_KVS_SYSTEM_CA_CERT_PATH="{{default_system_ca_cert_path}}" \
        -DTXING_KVS_WEBRTC_SDK_DIR="{{aws_kvs_sdk_dir}}" \
        -DTXING_KVS_WEBRTC_SDK_INSTALL_DIR="{{aws_kvs_sdk_install_dir}}" \
    ); \
    if [ "$(uname -s)" = "Linux" ]; then \
        openssl_libdir="$(pkg-config --variable=libdir openssl)"; \
        openssl_includedir="$(pkg-config --variable=includedir openssl)"; \
        native_cmake_args+=( -DOPENSSL_USE_STATIC_LIBS=FALSE ); \
        native_cmake_args+=( -DOPENSSL_INCLUDE_DIR="$openssl_includedir" ); \
        native_cmake_args+=( -DOPENSSL_SSL_LIBRARY="$openssl_libdir/libssl.so" ); \
        native_cmake_args+=( -DOPENSSL_CRYPTO_LIBRARY="$openssl_libdir/libcrypto.so" ); \
    fi; \
    cmake "${native_cmake_args[@]}"; \
    cmake --build "{{native_kvs_master_build_dir}}" --config Release; \
    test -x "{{built_native_kvs_master}}"

@test-native:
    cmake -S "{{native_kvs_master_dir}}" -B "{{native_kvs_master_test_build_dir}}" -DCMAKE_BUILD_TYPE=Debug -DTXING_KVS_REAL_SDK=OFF -DTXING_KVS_SYSTEM_CA_CERT_PATH="{{default_system_ca_cert_path}}"
    cmake --build "{{native_kvs_master_test_build_dir}}" --config Debug --target txing-board-kvs-master-tests
    ctest --test-dir "{{native_kvs_master_test_build_dir}}" --output-on-failure

