set shell := ["bash", "-eu", "-o", "pipefail", "-c"]

board_dir := source_directory()
python_executable := "python3"
built_board := board_dir + "/.venv/bin/board"
built_board_video_sender := board_dir + "/.venv/bin/board-video-sender"
built_board_motor_raw := board_dir + "/.venv/bin/board-motor-raw"
project_root := board_dir + "/../../.."
root_justfile := project_root + "/justfile"
native_kvs_master_dir := board_dir + "/kvs_master"
native_kvs_master_build_dir := native_kvs_master_dir + "/build"
native_kvs_master_test_build_dir := native_kvs_master_dir + "/build-tests"
built_native_kvs_master := native_kvs_master_build_dir + "/txing-board-kvs-master"
aws_kvs_sdk_dir := board_dir + "/aws-kvs-webrtc-sdk"
aws_kvs_sdk_build_dir := aws_kvs_sdk_dir + "/build"
aws_kvs_sdk_install_dir := aws_kvs_sdk_dir + "/install"
aws_kvs_sdk_install_header := aws_kvs_sdk_install_dir + "/include/com/amazonaws/kinesis/video/webrtcclient/Include.h"
aws_kvs_sdk_install_library := aws_kvs_sdk_install_dir + "/lib/libkvsWebrtcClient.a"
aws_kvs_sdk_flags_file := aws_kvs_sdk_build_dir + "/CMakeFiles/kvsWebrtcSignalingClient.dir/flags.make"
aws_kvs_sdk_state_file := aws_kvs_sdk_install_dir + "/.txing-sdk-build-state"
default_aws_kvs_sdk_repository := env_var_or_default("TXING_BOARD_AWS_KVS_WEBRTC_SDK_REPOSITORY", "https://github.com/awslabs/amazon-kinesis-video-streams-webrtc-sdk-c.git")
default_aws_kvs_sdk_ref := env_var_or_default("TXING_BOARD_AWS_KVS_WEBRTC_SDK_REF", "main")
default_system_ca_cert_path := env_var_or_default("TXING_BOARD_KVS_SYSTEM_CA_CERT_PATH", "/etc/ssl/certs/Starfield_Services_Root_Certificate_Authority_-_G2.pem")
systemd_unit := "/etc/systemd/system/board.service"
region := ""
aws_profile := ""
aws_shared_credentials_file := ""
default_kvs_use_system_dependencies := env_var_or_default("TXING_BOARD_KVS_USE_SYSTEM_DEPENDENCIES", "ON")

@sync:
    cd "{{board_dir}}" && uv sync --python "{{python_executable}}" --no-managed-python --no-python-downloads

@build:
    cd "{{board_dir}}" && uv sync --frozen --no-editable --compile-bytecode --python "{{python_executable}}" --no-managed-python --no-python-downloads --refresh-package board --reinstall-package board --refresh-package aws --reinstall-package aws
    test -x "{{built_board}}"
    test -x "{{built_board_video_sender}}"
    test -x "{{built_board_motor_raw}}"

[positional-arguments]
@aws *args:
    #!/usr/bin/env bash
    set -euo pipefail
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env device)"
    command aws "$@"

@check thing_name='' region=region aws_profile=aws_profile:
    #!/usr/bin/env bash
    set -euo pipefail
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env device "{{region}}" "{{aws_profile}}")"
    thing_name="$THING_NAME"
    if [ -n "{{thing_name}}" ]; then
      thing_name="{{thing_name}}"
    fi

    uv run --project "{{project_root}}/shared/aws/python" \
      python -m aws.check \
      --scope device \
      --thing-name "$thing_name"

@clone-aws-sdk:
    if [ ! -d "{{aws_kvs_sdk_dir}}/.git" ]; then \
        git clone --branch "{{default_aws_kvs_sdk_ref}}" --depth 1 "{{default_aws_kvs_sdk_repository}}" "{{aws_kvs_sdk_dir}}"; \
    else \
        git -C "{{aws_kvs_sdk_dir}}" remote set-url origin "{{default_aws_kvs_sdk_repository}}"; \
        git -C "{{aws_kvs_sdk_dir}}" fetch --force --tags origin; \
        if git -C "{{aws_kvs_sdk_dir}}" show-ref --verify --quiet "refs/remotes/origin/{{default_aws_kvs_sdk_ref}}"; then \
            git -C "{{aws_kvs_sdk_dir}}" checkout -B "{{default_aws_kvs_sdk_ref}}" "origin/{{default_aws_kvs_sdk_ref}}"; \
            git -C "{{aws_kvs_sdk_dir}}" reset --hard "origin/{{default_aws_kvs_sdk_ref}}"; \
        else \
            git -C "{{aws_kvs_sdk_dir}}" checkout "{{default_aws_kvs_sdk_ref}}"; \
        fi; \
    fi

@build-aws-sdk:
    just clone-aws-sdk
    build_dependencies=ON; \
    cmake_args=( \
        -S "{{aws_kvs_sdk_dir}}" \
        -B "{{aws_kvs_sdk_build_dir}}" \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX="{{aws_kvs_sdk_install_dir}}" \
        -DBUILD_SAMPLE=OFF \
        -DBUILD_TEST=OFF \
        -DBUILD_BENCHMARK=OFF \
        -DBUILD_STATIC_LIBS=ON \
        -DUSE_OPENSSL=ON \
        -DUSE_MBEDTLS=OFF \
    ); \
    if [ "{{default_kvs_use_system_dependencies}}" = "ON" ]; then \
        build_dependencies=OFF; \
        if [ "$(uname -s)" = "Linux" ]; then \
            if ! pkg-config --exists openssl; then \
                echo "OpenSSL pkg-config metadata not found; install libssl-dev" >&2; \
                exit 1; \
            fi; \
            openssl_libdir="$(pkg-config --variable=libdir openssl)"; \
            openssl_includedir="$(pkg-config --variable=includedir openssl)"; \
            openssl_ssl_library="$openssl_libdir/libssl.so"; \
            openssl_crypto_library="$openssl_libdir/libcrypto.so"; \
            if [ ! -f "$openssl_ssl_library" ] || [ ! -f "$openssl_crypto_library" ]; then \
                echo "Expected shared OpenSSL libraries were not found under $openssl_libdir" >&2; \
                exit 1; \
            fi; \
            cmake_args+=( -DOPENSSL_USE_STATIC_LIBS=FALSE ); \
            cmake_args+=( -DOPENSSL_INCLUDE_DIR="$openssl_includedir" ); \
            cmake_args+=( -DOPENSSL_SSL_LIBRARY="$openssl_ssl_library" ); \
            cmake_args+=( -DOPENSSL_CRYPTO_LIBRARY="$openssl_crypto_library" ); \
        fi; \
    fi; \
    cmake_args+=( -DOPEN_SRC_INSTALL_PREFIX="{{aws_kvs_sdk_install_dir}}" ); \
    cmake_args+=( -DBUILD_DEPENDENCIES="$build_dependencies" ); \
    cmake "${cmake_args[@]}"; \
    cmake --build "{{aws_kvs_sdk_build_dir}}" --config Release; \
    cmake --install "{{aws_kvs_sdk_build_dir}}" --config Release; \
    sdk_head="$(git -C "{{aws_kvs_sdk_dir}}" rev-parse HEAD)"; \
    printf 'sdk_head=%s\nbuild_dependencies=%s\n' "$sdk_head" "$build_dependencies" > "{{aws_kvs_sdk_state_file}}"

@ensure-aws-sdk:
    just clone-aws-sdk
    expected_build_dependencies=ON; \
    if [ "{{default_kvs_use_system_dependencies}}" = "ON" ]; then \
        expected_build_dependencies=OFF; \
    fi; \
    sdk_head="$(git -C "{{aws_kvs_sdk_dir}}" rev-parse HEAD)"; \
    if [ ! -f "{{aws_kvs_sdk_install_header}}" ] || [ ! -f "{{aws_kvs_sdk_install_library}}" ] || [ ! -f "{{aws_kvs_sdk_state_file}}" ]; then \
        just build-aws-sdk; \
    elif ! grep -Fqx "sdk_head=$sdk_head" "{{aws_kvs_sdk_state_file}}"; then \
        just build-aws-sdk; \
    elif ! grep -Fqx "build_dependencies=$expected_build_dependencies" "{{aws_kvs_sdk_state_file}}"; then \
        just build-aws-sdk; \
    elif [ "$(uname -s)" = "Linux" ] && { [ ! -f "{{aws_kvs_sdk_flags_file}}" ] || grep -Eq 'KVS_CA_CERT_PATH=|CMAKE_DETECTED_CACERT_PATH' "{{aws_kvs_sdk_flags_file}}"; }; then \
        just build-aws-sdk; \
    fi

@clean-native:
    rm -rf "{{native_kvs_master_build_dir}}" "{{native_kvs_master_test_build_dir}}"

@clean-aws-sdk:
    rm -rf "{{aws_kvs_sdk_build_dir}}" "{{aws_kvs_sdk_install_dir}}"

@clean:
    just clean-native
    just clean-aws-sdk

@distclean:
    just clean
    rm -rf "{{aws_kvs_sdk_dir}}"

@build-native:
    if [ "$(uname -s)" = "Linux" ]; then \
        just ensure-aws-sdk; \
    fi
    native_cmake_args=( \
        -S "{{native_kvs_master_dir}}" \
        -B "{{native_kvs_master_build_dir}}" \
        -DCMAKE_BUILD_TYPE=Release \
        -DBUILD_TESTING=OFF \
        -DTXING_KVS_USE_SYSTEM_DEPENDENCIES="{{default_kvs_use_system_dependencies}}" \
        -DTXING_KVS_SYSTEM_CA_CERT_PATH="{{default_system_ca_cert_path}}" \
        -DTXING_KVS_WEBRTC_SDK_DIR="{{aws_kvs_sdk_dir}}" \
        -DTXING_KVS_WEBRTC_SDK_INSTALL_DIR="{{aws_kvs_sdk_install_dir}}" \
    ); \
    if [ "$(uname -s)" = "Linux" ] && [ "{{default_kvs_use_system_dependencies}}" = "ON" ]; then \
        if ! pkg-config --exists openssl; then \
            echo "OpenSSL pkg-config metadata not found; install libssl-dev" >&2; \
            exit 1; \
        fi; \
        openssl_libdir="$(pkg-config --variable=libdir openssl)"; \
        openssl_includedir="$(pkg-config --variable=includedir openssl)"; \
        native_cmake_args+=( -DOPENSSL_USE_STATIC_LIBS=FALSE ); \
        native_cmake_args+=( -DOPENSSL_INCLUDE_DIR="$openssl_includedir" ); \
        native_cmake_args+=( -DOPENSSL_SSL_LIBRARY="$openssl_libdir/libssl.so" ); \
        native_cmake_args+=( -DOPENSSL_CRYPTO_LIBRARY="$openssl_libdir/libcrypto.so" ); \
    fi; \
    cmake "${native_cmake_args[@]}"
    cmake --build "{{native_kvs_master_build_dir}}" --config Release
    test -x "{{built_native_kvs_master}}"

@test-native:
    cmake -S "{{native_kvs_master_dir}}" -B "{{native_kvs_master_test_build_dir}}" -DCMAKE_BUILD_TYPE=Debug -DTXING_KVS_REAL_SDK=OFF -DTXING_KVS_USE_SYSTEM_DEPENDENCIES="{{default_kvs_use_system_dependencies}}" -DTXING_KVS_SYSTEM_CA_CERT_PATH="{{default_system_ca_cert_path}}"
    cmake --build "{{native_kvs_master_test_build_dir}}" --config Debug --target txing-board-kvs-master-tests
    ctest --test-dir "{{native_kvs_master_test_build_dir}}" --output-on-failure

@run:
    #!/usr/bin/env bash
    set -euo pipefail
    test -x "{{built_board}}" || { \
        echo "Missing built board executable at {{built_board}}. Run 'just build' first." >&2; \
        exit 1; \
    }
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env device "{{region}}" "{{aws_profile}}")"
    cd "{{board_dir}}" && "{{built_board}}"

@once:
    #!/usr/bin/env bash
    set -euo pipefail
    test -x "{{built_board}}" || { \
        echo "Missing built board executable at {{built_board}}. Run 'just build' first." >&2; \
        exit 1; \
    }
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env device "{{region}}" "{{aws_profile}}")"
    cd "{{board_dir}}" && "{{built_board}}" --once

@dev:
    #!/usr/bin/env bash
    set -euo pipefail
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env device "{{region}}" "{{aws_profile}}")"
    cd "{{board_dir}}" && uv run board

@once-dev:
    #!/usr/bin/env bash
    set -euo pipefail
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env device "{{region}}" "{{aws_profile}}")"
    cd "{{board_dir}}" && uv run board --once

@motor-raw left='' right='' duration='' region=region aws_profile=aws_profile:
    #!/usr/bin/env bash
    set -euo pipefail
    test -x "{{built_board_motor_raw}}" || { \
        echo "Missing built board-motor-raw executable at {{built_board_motor_raw}}. Run 'just build' first." >&2; \
        exit 1; \
    }
    if [ -z "{{left}}" ] || [ -z "{{right}}" ]; then \
        echo "Both left and right are required. Example: just board::motor-raw 240 240" >&2; \
        exit 1; \
    fi
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env device "{{region}}" "{{aws_profile}}")"
    preserve_env=(
        BOARD_DRIVE_RAW_MAX_SPEED
        BOARD_DRIVE_PWM_HZ
        BOARD_DRIVE_PWM_CHIP
        BOARD_DRIVE_LEFT_PWM_CHANNEL
        BOARD_DRIVE_RIGHT_PWM_CHANNEL
        BOARD_DRIVE_GPIO_CHIP
        BOARD_DRIVE_LEFT_DIR_GPIO
        BOARD_DRIVE_RIGHT_DIR_GPIO
        BOARD_DRIVE_LEFT_INVERTED
        BOARD_DRIVE_RIGHT_INVERTED
    )
    preserve_env_csv="$(IFS=,; printf '%s' "${preserve_env[*]}")"
    command=(sudo "--preserve-env=$preserve_env_csv" "{{built_board_motor_raw}}" --left "{{left}}" --right "{{right}}")
    if [ -n "{{duration}}" ]; then \
        command+=(--duration "{{duration}}"); \
    fi
    "${command[@]}"

@motor-stop region=region aws_profile=aws_profile:
    #!/usr/bin/env bash
    set -euo pipefail
    just motor-raw 0 0 0.25 "{{region}}" "{{aws_profile}}"

@install-service video_sender_command='' thing_name='' schema_file='' video_region='' region=region aws_profile=aws_profile aws_shared_credentials_file=aws_shared_credentials_file:
    #!/usr/bin/env bash
    set -euo pipefail
    test -x "{{built_board}}" || { \
        echo "Missing built board executable at {{built_board}}. Run 'just build' first." >&2; \
        exit 1; \
    }
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env device "{{region}}" "{{aws_profile}}" "" "" "" "{{aws_shared_credentials_file}}")"
    project_root="$TXING_PROJECT_ROOT"
    env_file="$AWS_ENV_FILE"
    thing_name="$THING_NAME"
    region="$AWS_REGION"
    aws_profile="$AWS_SELECTED_PROFILE"
    aws_shared_credentials_file="$AWS_SHARED_CREDENTIALS_FILE"
    sudo systemctl enable NetworkManager-wait-online.service
    service_env=(); \
    if [ -n "{{thing_name}}" ]; then \
        thing_name="{{thing_name}}"; \
    fi; \
    if [ -n "$thing_name" ]; then \
        service_env+=("Environment=\"THING_NAME=$thing_name\""); \
    fi; \
    if [ -n "{{schema_file}}" ]; then \
        service_env+=("Environment=\"SCHEMA_FILE={{schema_file}}\""); \
    fi; \
    if [ -n "{{video_region}}" ]; then \
        service_env+=("Environment=\"BOARD_VIDEO_REGION={{video_region}}\""); \
    fi; \
    if [ -n "{{video_sender_command}}" ]; then \
        service_env+=("Environment=\"BOARD_VIDEO_SENDER_COMMAND={{video_sender_command}}\""); \
    fi; \
    if [ -n "{{region}}" ] && [ -n "$region" ]; then \
        service_env+=("Environment=\"AWS_REGION=$region\""); \
    fi; \
    if [ -n "$aws_profile" ]; then \
        service_env+=("Environment=\"AWS_PROFILE=$aws_profile\""); \
        service_env+=("Environment=\"AWS_DEFAULT_PROFILE=$aws_profile\""); \
    fi; \
    if [ -n "{{aws_shared_credentials_file}}" ] && [ -n "$aws_shared_credentials_file" ]; then \
        service_env+=("Environment=\"AWS_SHARED_CREDENTIALS_FILE=$aws_shared_credentials_file\""); \
    fi; \
    { \
        printf '%s\n' \
            '[Unit]' \
            'Description=board runtime control' \
            'Wants=network-online.target systemd-time-wait-sync.service' \
            'After=network-online.target systemd-time-wait-sync.service time-sync.target' \
            '' \
            '[Service]' \
            'Type=simple' \
            "WorkingDirectory=$project_root" \
            "EnvironmentFile=$env_file"; \
        printf '%s\n' "${service_env[@]}"; \
        printf '%s\n' \
            'ExecStart={{built_board}} --heartbeat-seconds 60' \
            'Restart=always' \
            'RestartSec=5' \
            '' \
            '[Install]' \
            'WantedBy=multi-user.target'; \
    } | sudo tee "{{systemd_unit}}" >/dev/null
    sudo systemctl daemon-reload
    sudo systemctl enable --now board
