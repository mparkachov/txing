motor-raw left='' right='' duration='' region=region aws_profile=aws_profile:
    #!/usr/bin/env bash
    set -euo pipefail
    test -x "{{built_board_motor_raw}}" || { \
        echo "Missing built board-motor-raw executable at {{built_board_motor_raw}}. Run 'just build' first." >&2; \
        exit 1; \
    }
    if [ -z "{{left}}" ] || [ -z "{{right}}" ]; then \
        echo "Both left and right are required. Example: just unit::board::motor-raw 240 240" >&2; \
        exit 1; \
    fi
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env device "{{region}}" "{{aws_profile}}")"
    preserve_env=(
        BOARD_DRIVE_RAW_MAX_SPEED
        BOARD_DRIVE_PWM_HZ
        BOARD_DRIVE_PWM_CHIP
        BOARD_DRIVE_LEFT_PWM_CHANNEL
        BOARD_DRIVE_RIGHT_PWM_CHANNEL
        BOARD_DRIVE_GPIO_CHIP
        BOARD_DRIVE_LEFT_DIR_GPIO
        BOARD_DRIVE_RIGHT_DIR_GPIO
        BOARD_DRIVE_LEFT_INVERTED
        BOARD_DRIVE_RIGHT_INVERTED
    )
    preserve_env_csv="$(IFS=,; printf '%s' "${preserve_env[*]}")"
    command=(sudo "--preserve-env=$preserve_env_csv" "{{built_board_motor_raw}}" --left "{{left}}" --right "{{right}}")
    if [ -n "{{duration}}" ]; then \
        command+=(--duration "{{duration}}"); \
    fi
    "${command[@]}"

motor-stop region=region aws_profile=aws_profile:
    #!/usr/bin/env bash
    set -euo pipefail
    just --justfile "{{board_justfile}}" motor-raw 0 0 0.25 "{{region}}" "{{aws_profile}}"

install-service video_sender_command='' thing_name='' schema_file='' video_region='' region=region aws_profile=aws_profile aws_shared_credentials_file=aws_shared_credentials_file:
    #!/usr/bin/env bash
    set -euo pipefail
    test -x "{{built_board}}" || { \
        echo "Missing built board executable at {{built_board}}. Run 'just build' first." >&2; \
        exit 1; \
    }
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env device "{{region}}" "{{aws_profile}}" "" "" "" "{{aws_shared_credentials_file}}")"
    project_root="$TXING_PROJECT_ROOT"
    txing_version="$TXING_VERSION"
    thing_name="$THING_NAME"
    schema_file="$SCHEMA_FILE"
    video_region="$BOARD_VIDEO_REGION"
    video_sender_command="$BOARD_VIDEO_SENDER_COMMAND"
    region="$AWS_REGION"
    aws_profile="$AWS_SELECTED_PROFILE"
    aws_shared_credentials_file="$AWS_SHARED_CREDENTIALS_FILE"
    sudo systemctl enable NetworkManager-wait-online.service
    service_env=(); \
    if [ -n "{{thing_name}}" ]; then \
        thing_name="{{thing_name}}"; \
    fi; \
    if [ -n "$thing_name" ]; then \
        service_env+=("Environment=\"THING_NAME=$thing_name\""); \
    fi; \
    if [ -n "$txing_version" ]; then \
        service_env+=("Environment=\"TXING_VERSION=$txing_version\""); \
    fi; \
    if [ -n "{{schema_file}}" ]; then \
        schema_file="{{schema_file}}"; \
    fi; \
    if [ -n "$schema_file" ]; then \
        service_env+=("Environment=\"SCHEMA_FILE=$schema_file\""); \
    fi; \
    if [ -n "{{video_region}}" ]; then \
        video_region="{{video_region}}"; \
    fi; \
    if [ -n "$video_region" ]; then \
        service_env+=("Environment=\"BOARD_VIDEO_REGION=$video_region\""); \
    fi; \
    if [ -n "{{video_sender_command}}" ]; then \
        video_sender_command="{{video_sender_command}}"; \
    fi; \
    if [ -n "$video_sender_command" ]; then \
        service_env+=("Environment=\"BOARD_VIDEO_SENDER_COMMAND=$video_sender_command\""); \
    fi; \
    if [ -n "$region" ]; then \
        service_env+=("Environment=\"AWS_REGION=$region\""); \
        service_env+=("Environment=\"AWS_DEFAULT_REGION=$region\""); \
    fi; \
    if [ -n "$aws_profile" ]; then \
        service_env+=("Environment=\"AWS_PROFILE=$aws_profile\""); \
        service_env+=("Environment=\"AWS_DEFAULT_PROFILE=$aws_profile\""); \
    fi; \
    if [ -n "$aws_shared_credentials_file" ]; then \
        service_env+=("Environment=\"AWS_SHARED_CREDENTIALS_FILE=$aws_shared_credentials_file\""); \
    fi; \
    for env_name in \
        KVS_DUALSTACK_ENDPOINTS \
        BOARD_DRIVE_RAW_MAX_SPEED \
        BOARD_DRIVE_CMD_RAW_MIN_SPEED \
        BOARD_DRIVE_CMD_RAW_MAX_SPEED \
        BOARD_DRIVE_PWM_HZ \
        BOARD_DRIVE_PWM_CHIP \
        BOARD_DRIVE_LEFT_PWM_CHANNEL \
        BOARD_DRIVE_RIGHT_PWM_CHANNEL \
        BOARD_DRIVE_GPIO_CHIP \
        BOARD_DRIVE_LEFT_DIR_GPIO \
        BOARD_DRIVE_RIGHT_DIR_GPIO \
        BOARD_DRIVE_LEFT_INVERTED \
        BOARD_DRIVE_RIGHT_INVERTED; do \
        env_value="${!env_name:-}"; \
        if [ -n "$env_value" ]; then \
            service_env+=("Environment=\"$env_name=$env_value\""); \
        fi; \
    done; \
    { \
        printf '%s\n' \
            '[Unit]' \
            'Description=board runtime control' \
            'Wants=network-online.target systemd-time-wait-sync.service' \
            'After=network-online.target systemd-time-wait-sync.service time-sync.target' \
            '' \
            '[Service]' \
            'Type=simple' \
            "WorkingDirectory=$project_root"; \
        printf '%s\n' "${service_env[@]}"; \
        printf '%s\n' \
            'ExecStart={{built_board}} --heartbeat-seconds 60' \
            'Restart=always' \
            'RestartSec=5' \
            '' \
            '[Install]' \
            'WantedBy=multi-user.target'; \
    } | sudo tee "{{systemd_unit}}" >/dev/null
    sudo systemctl daemon-reload
    sudo systemctl enable --now board

start:
    #!/usr/bin/env bash
    set -euo pipefail
    if ! systemctl cat "{{systemd_service}}" >/dev/null 2>&1; then \
        echo "Board service {{systemd_service}} is not installed. Run 'just board::install-service' first." >&2; \
        exit 1; \
    fi
    sudo systemctl reset-failed "{{systemd_service}}" || true
    sudo systemctl start "{{systemd_service}}"
    sudo systemctl --no-pager --full status "{{systemd_service}}"

stop:
    #!/usr/bin/env bash
    set -euo pipefail
    if ! systemctl cat "{{systemd_service}}" >/dev/null 2>&1; then \
        echo "Board service {{systemd_service}} is not installed. Run 'just board::install-service' first." >&2; \
        exit 1; \
    fi
    sudo systemctl stop "{{systemd_service}}"
    sudo systemctl --no-pager --full status "{{systemd_service}}" || true

@restart: stop start

log lines='200' follow='true':
    #!/usr/bin/env bash
    set -euo pipefail
    case "{{lines}}" in
      ''|*[!0-9]*)
        echo "lines must be a positive integer." >&2
        exit 1
        ;;
    esac
    if [ "{{lines}}" -le 0 ]; then
      echo "lines must be a positive integer." >&2
      exit 1
    fi
    if ! systemctl cat "{{systemd_service}}" >/dev/null 2>&1; then \
        echo "Board service {{systemd_service}} is not installed. Run 'just board::install-service' first." >&2; \
        exit 1; \
    fi
    journal_flags=(-a -n "{{lines}}")
    case "{{follow}}" in
      true|1|yes|on)
        journal_flags+=(-f)
        ;;
      false|0|no|off)
        journal_flags+=(--no-pager)
        ;;
      *)
        echo "follow must be true or false." >&2
        exit 1
        ;;
    esac
    printf 'showing board logs for units:\n'
    printf '  %s\n' "{{systemd_service}}"
    sudo journalctl "${journal_flags[@]}" -u "{{systemd_service}}"
