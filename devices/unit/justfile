set shell := ["bash", "-eu", "-o", "pipefail", "-c"]

unit_dir := source_directory()
project_root := unit_dir + "/../.."

mod board 'board/justfile'
mod mcu 'mcu/justfile'

@processes:
    cd "{{project_root}}" && uv run --project rig rig-device-process --device-type unit list

@run-process process:
    #!/usr/bin/env bash
    set -euo pipefail
    eval "$(just --justfile "{{project_root}}/justfile" _project-aws-env rig)"
    cd "{{project_root}}" && uv run --project rig rig-device-process --device-type unit run --process "{{process}}"

@default:
    @just --list
