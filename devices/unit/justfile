set shell := ["bash", "-eu", "-o", "pipefail", "-c"]
set quiet := true

unit_dir := source_directory()

mod board 'board/justfile'
mod daemon 'daemon/justfile'
mod mcu 'mcu/justfile'

@default:
    @just --list

cert thing_id='' region='' profile='' config_dir='':
    #!/usr/bin/env bash
    set -euo pipefail
    just --justfile "{{unit_dir}}/justfile" daemon::cert "{{thing_id}}" "{{region}}" "{{profile}}" "{{config_dir}}"
