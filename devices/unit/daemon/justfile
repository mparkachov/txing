role-policy thing_id='':
    #!/bin/sh
    set -eu
    requested_thing_name="{{thing_id}}"
    case "$requested_thing_name" in *=*) echo "Do not pass just recipe arguments as name=value. Use: just unit::daemon::role-policy <thing-id>" >&2; exit 2 ;; esac
    if [ -n "$requested_thing_name" ]; then
      export TXING_THING_ID="$requested_thing_name"
    fi
    . "{{aws_lib}}"
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env device)"
    txing_aws_init
    effective_thing_name="${requested_thing_name:-$THING_NAME}"
    case "$effective_thing_name" in *=*) echo "Invalid Thing ID '$effective_thing_name'. Use positional just arguments, for example: just unit::daemon::role-policy unit-bl95f2" >&2; exit 2 ;; esac
    if ! printf '%s\n' "$effective_thing_name" | grep -E -q '^[a-zA-Z0-9:_-]+$'; then
      echo "Invalid Thing ID '$effective_thing_name'. Allowed characters: letters, digits, colon, underscore, hyphen." >&2
      exit 2
    fi
    account_id="$(aws sts get-caller-identity --query Account --output text)"
    caller_arn="$(aws sts get-caller-identity --query Arn --output text)"
    partition="$(printf '%s\n' "$caller_arn" | cut -d: -f2)"
    daemon_role_name="txing-daemon-$effective_thing_name"
    if ! aws iam get-role --role-name "$daemon_role_name" >/dev/null 2>&1; then
      echo "Daemon IAM role $daemon_role_name does not exist. Run just aws::cert <thing-id> first." >&2
      exit 1
    fi
    cloudwatch_log_group="txing/${TXING_TOWN_ID}/${TXING_RIG_ID}/${effective_thing_name}"
    credential_policy_file="$(mktemp "${TMPDIR:-/tmp}/txing-daemon-credential-policy.XXXXXX")"
    cleanup() {
      rm -f "$credential_policy_file"
    }
    trap cleanup EXIT
    jq -n \
      --arg iotShadowArn "arn:${partition}:iot:${TXING_AWS_REGION}:${account_id}:thing/${effective_thing_name}/sparkplug" \
      --arg cloudwatchLogGroupArn "arn:${partition}:logs:${TXING_AWS_REGION}:${account_id}:log-group:${cloudwatch_log_group}" \
      --arg cloudwatchLogStreamArn "arn:${partition}:logs:${TXING_AWS_REGION}:${account_id}:log-group:${cloudwatch_log_group}:log-stream:*" \
      --arg kvsChannelArn "arn:${partition}:kinesisvideo:${TXING_AWS_REGION}:${account_id}:channel/${effective_thing_name}-board-video/*" \
      '{Version: "2012-10-17", Statement: [
        {Sid: "DaemonSparkplugShadowRead", Effect: "Allow", Action: "iot:GetThingShadow", Resource: $iotShadowArn},
        {Sid: "DaemonCloudWatchLogsWrite", Effect: "Allow", Action: ["logs:CreateLogGroup", "logs:CreateLogStream", "logs:DescribeLogStreams", "logs:PutRetentionPolicy", "logs:PutLogEvents"], Resource: [$cloudwatchLogGroupArn, $cloudwatchLogStreamArn]},
        {Sid: "DaemonBoardVideoMaster", Effect: "Allow", Action: ["kinesisvideo:DescribeSignalingChannel", "kinesisvideo:GetSignalingChannelEndpoint", "kinesisvideo:GetIceServerConfig", "kinesisvideo:ConnectAsMaster"], Resource: $kvsChannelArn}
      ]}' \
      >"$credential_policy_file"
    aws iam put-role-policy \
      --role-name "$daemon_role_name" \
      --policy-name txing-daemon-own-thing \
      --policy-document "file://$credential_policy_file"
    printf 'refreshed daemon IAM role policy\n'
    printf '  thing: %s\n' "$effective_thing_name"
    printf '  role: %s\n' "$daemon_role_name"
    printf '  video region: %s\n' "$TXING_AWS_REGION"

test:
    cd "{{daemon_dir}}" && go test ./...

run:
    #!/bin/sh
    set -eu
    cd "{{daemon_dir}}"
    go run ./cmd/txing-unit-daemon

docker-builder-image rust_toolchain="stable":
    #!/bin/sh
    set -eu

    rust_toolchain="{{rust_toolchain}}"
    image="{{docker_builder_image}}"
    dockerfile="{{docker_builder_dockerfile}}"

    case "$rust_toolchain" in *=*) echo "Do not pass just recipe arguments as name=value. Use positional arguments." >&2; exit 2 ;; esac
    command -v docker >/dev/null || {
      echo "docker is required to build the board binaries builder image." >&2
      exit 1
    }
    if [ ! -r "$dockerfile" ]; then
      echo "Missing Docker builder Dockerfile: $dockerfile" >&2
      exit 1
    fi

    mkdir -p "$TMPDIR"
    empty_context="$(mktemp -d "${TMPDIR:-/tmp}/txing-board-binaries-builder-context.XXXXXX")"
    cleanup() {
      rm -rf "$empty_context"
    }
    trap cleanup EXIT

    docker build \
      --build-arg "RUST_TOOLCHAIN=$rust_toolchain" \
      -f "$dockerfile" \
      -t "$image" \
      "$empty_context"

docker-builder-shell:
    #!/bin/sh
    set -eu

    project_root="{{project_root}}"
    image="{{docker_builder_image}}"

    command -v docker >/dev/null || {
      echo "docker is required to run the board binaries builder shell." >&2
      exit 1
    }
    if ! docker image inspect "$image" >/dev/null 2>&1; then
      echo "Missing Docker builder image: $image" >&2
      echo "Run: just unit::daemon::docker-builder-image" >&2
      exit 1
    fi

    docker volume create "{{docker_cargo_registry_volume}}" >/dev/null
    docker volume create "{{docker_cargo_git_volume}}" >/dev/null
    docker volume create "{{docker_target_volume}}" >/dev/null

    exec docker run --rm -it \
      --mount "type=bind,source=$project_root,target=$project_root,readonly" \
      --mount "type=volume,source={{docker_cargo_registry_volume}},target=/opt/cargo/registry" \
      --mount "type=volume,source={{docker_cargo_git_volume}},target=/opt/cargo/git" \
      --mount "type=volume,source={{docker_target_volume}},target=/target" \
      -e CARGO_TARGET_DIR=/target \
      -w "$project_root" \
      "$image" \
      sh

@_kvs-check-system-dependencies:
    #!/bin/sh
    set -eu
    if [ "$(uname -s)" != "Linux" ]; then
        exit 0
    fi

    missing=""
    add_missing() {
        if [ -z "$missing" ]; then
            missing="$1"
        else
            missing="$missing $1"
        fi
    }
    for pc in openssl libcurl libwebsockets zlib protobuf grpc++; do
        if ! pkg-config --exists "$pc"; then
            add_missing "$pc"
        fi
    done

    for header in usrsctp.h srtp2/srtp.h; do
        if ! printf '#include <%s>\nint main(void) { return 0; }\n' "$header" | cc -x c - -fsyntax-only >/dev/null 2>&1; then
            add_missing "$header"
        fi
    done
    if ! printf '#include <log4cplus/logger.h>\nint main() { return 0; }\n' | c++ -x c++ - -fsyntax-only >/dev/null 2>&1; then
        add_missing "log4cplus/logger.h"
    fi
    command -v protoc >/dev/null 2>&1 || add_missing "protoc"
    command -v grpc_cpp_plugin >/dev/null 2>&1 || add_missing "grpc_cpp_plugin"

    for library in srtp2 usrsctp log4cplus curl websockets z ssl crypto protobuf grpc++ grpc; do
        path="$(cc -print-file-name="lib${library}.so")"
        if [ "$path" = "lib${library}.so" ] || [ ! -f "$path" ]; then
            add_missing "lib${library}.so"
        fi
    done

    if [ -n "$missing" ]; then
        printf 'Missing system KVS dependency/dependencies: %s\n' "$missing" >&2
        printf 'Install distro packages, for example:\n' >&2
        printf '  apt install -y libssl-dev libcurl4-openssl-dev liblog4cplus-dev libsrtp2-dev libusrsctp-dev libwebsockets-dev zlib1g-dev libprotobuf-dev protobuf-compiler libgrpc++-dev protobuf-compiler-grpc\n' >&2
        exit 1
    fi

@kvs-build-native:
    #!/bin/sh
    set -eu
    if [ -f "{{native_kvs_master_build_dir}}/CMakeCache.txt" ] && grep -Fq "TXING_KVS_WEBRTC_SDK_" "{{native_kvs_master_build_dir}}/CMakeCache.txt"; then
        rm -rf "{{native_kvs_master_build_dir}}"
    fi
    if [ "$(uname -s)" = "Linux" ]; then
        just --justfile "{{daemon_justfile}}" _kvs-check-system-dependencies
        openssl_libdir="$(pkg-config --variable=libdir openssl)"
        openssl_includedir="$(pkg-config --variable=includedir openssl)"
        cmake \
            -S "{{native_kvs_master_dir}}" \
            -B "{{native_kvs_master_build_dir}}" \
            -DCMAKE_BUILD_TYPE=Release \
            -DBUILD_TESTING=OFF \
            -DTXING_KVS_SYSTEM_CA_CERT_PATH="{{default_kvs_system_ca_cert_path}}" \
            -DTXING_KVS_GRPC_BRIDGE=ON \
            -DTXING_AWS_KVS_WEBRTC_SDK_GIT_TAG="{{aws_kvs_sdk_commit}}" \
            -DOPENSSL_USE_STATIC_LIBS=FALSE \
            -DOPENSSL_INCLUDE_DIR="$openssl_includedir" \
            -DOPENSSL_SSL_LIBRARY="$openssl_libdir/libssl.so" \
            -DOPENSSL_CRYPTO_LIBRARY="$openssl_libdir/libcrypto.so"
    else
        cmake \
            -S "{{native_kvs_master_dir}}" \
            -B "{{native_kvs_master_build_dir}}" \
            -DCMAKE_BUILD_TYPE=Release \
            -DBUILD_TESTING=OFF \
            -DTXING_KVS_SYSTEM_CA_CERT_PATH="{{default_kvs_system_ca_cert_path}}" \
            -DTXING_KVS_GRPC_BRIDGE=OFF
    fi
    cmake --build "{{native_kvs_master_build_dir}}" --config Release
    test -x "{{built_native_kvs_master}}"

@kvs-test-native:
    cmake -S "{{native_kvs_master_dir}}" -B "{{native_kvs_master_test_build_dir}}" -DCMAKE_BUILD_TYPE=Debug -DTXING_KVS_REAL_SDK=OFF -DTXING_KVS_SYSTEM_CA_CERT_PATH="{{default_kvs_system_ca_cert_path}}"
    cmake --build "{{native_kvs_master_test_build_dir}}" --config Debug --target txing-unit-kvs-master-tests
    ctest --test-dir "{{native_kvs_master_test_build_dir}}" --output-on-failure

@hardware-build-native:
