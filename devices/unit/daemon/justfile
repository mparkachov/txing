set shell := ["bash", "-eu", "-o", "pipefail", "-c"]
set quiet := true

daemon_dir := source_directory()
project_root := canonicalize(daemon_dir + "/../../..")
root_justfile := project_root + "/justfile"
aws_lib := project_root + "/shared/aws/scripts/aws_lib.sh"

region := ""
profile := ""
config_dir := ""
prerelease_branch := "feature/unit-daemon-prerelease"
prerelease_asset := "txing-unit-daemon-linux-aarch64.tar.gz"
prerelease_dir := daemon_dir + "/target/prerelease"
prerelease_metadata := prerelease_dir + "/metadata.json"
prerelease_builder_image := "txing-unit-daemon-builder:ubuntu24-rust-stable"
prerelease_builder_dockerfile := daemon_dir + "/Dockerfile.prerelease-builder"
prerelease_cargo_registry_volume := "txing-cargo-registry"
prerelease_cargo_git_volume := "txing-cargo-git"
prerelease_target_volume := "txing-unit-daemon-target"

cert thing_id='' region=region profile=profile config_dir=config_dir:
    #!/usr/bin/env bash
    set -euo pipefail
    requested_thing_name="{{thing_id}}"
    if [[ "$requested_thing_name" == *=* ]]; then
      echo "Do not pass just recipe arguments as name=value. Use: just unit::daemon::cert <thing-id>" >&2
      exit 2
    fi
    requested_config_dir="{{config_dir}}"
    if [[ "$requested_config_dir" == *=* ]]; then
      echo "Do not pass just recipe arguments as name=value. Use positional arguments." >&2
      exit 2
    fi
    if [ -n "$requested_thing_name" ]; then
      export TXING_THING_ID="$requested_thing_name"
    fi
    source "{{aws_lib}}"
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env device "{{region}}" "{{profile}}")"
    txing_aws_init
    effective_thing_name="${requested_thing_name:-$THING_NAME}"
    if [[ "$effective_thing_name" == *=* ]]; then
      echo "Invalid Thing ID '$effective_thing_name'. Use positional just arguments, for example: just unit::daemon::cert unit-bl95f2" >&2
      exit 2
    fi
    if [[ ! "$effective_thing_name" =~ ^[a-zA-Z0-9:_-]+$ ]]; then
      echo "Invalid Thing ID '$effective_thing_name'. Allowed characters: letters, digits, colon, underscore, hyphen." >&2
      exit 2
    fi
    daemon_policy_name="$(stack_output "$AWS_STACK_NAME" DeviceDaemonIotPolicyName)"
    if [ -z "$daemon_policy_name" ] || [ "$daemon_policy_name" = "None" ]; then
      echo "Could not resolve DeviceDaemonIotPolicyName from stack $AWS_STACK_NAME." >&2
      exit 1
    fi
    account_id="$(aws sts get-caller-identity "${aws_flags[@]}" --query Account --output text)"
    caller_arn="$(aws sts get-caller-identity "${aws_flags[@]}" --query Arn --output text)"
    partition="$(cut -d: -f2 <<<"$caller_arn")"
    daemon_role_name="txing-daemon-$effective_thing_name"
    iot_role_alias="txing-daemon-$effective_thing_name"
    if [ "${#daemon_role_name}" -gt 64 ]; then
      echo "IAM role name $daemon_role_name is longer than 64 characters." >&2
      exit 1
    fi
    if [ "${#iot_role_alias}" -gt 128 ]; then
      echo "IoT role alias $iot_role_alias is longer than 128 characters." >&2
      exit 1
    fi
    cloudwatch_log_group="txing/${TXING_TOWN_ID}/${TXING_RIG_ID}/${effective_thing_name}"
    iot_data_endpoint="$(aws iot describe-endpoint --endpoint-type iot:Data-ATS "${aws_flags[@]}" --query endpointAddress --output text)"
    iot_credential_endpoint="$(aws iot describe-endpoint --endpoint-type iot:CredentialProvider "${aws_flags[@]}" --query endpointAddress --output text)"
    default_config_dir() {
      if [ -n "${TXING_DAEMON_CONFIG_DIR:-}" ]; then
        printf '%s\n' "$TXING_DAEMON_CONFIG_DIR"
      elif [ -n "${XDG_CONFIG_HOME:-}" ]; then
        printf '%s\n' "$XDG_CONFIG_HOME/txing/unit-daemon"
      elif [ -n "${HOME:-}" ]; then
        printf '%s\n' "$HOME/.config/txing/unit-daemon"
      else
        echo "HOME is not set; pass an explicit config directory as a positional argument." >&2
        exit 1
      fi
    }
    daemon_config_dir="${requested_config_dir:-$(default_config_dir)}"
    env_file="$daemon_config_dir/.env"
    cert_path="$daemon_config_dir/certificate.pem.crt"
    public_key_path="$daemon_config_dir/public.pem.key"
    private_key_path="$daemon_config_dir/private.pem.key"
    cert_arn_path="$daemon_config_dir/certificate.arn"
    root_ca_path="$daemon_config_dir/AmazonRootCA1.pem"
    install -d -m 700 "$daemon_config_dir"
    if [ -e "$env_file" ] || [ -e "$cert_path" ] || [ -e "$public_key_path" ] || [ -e "$private_key_path" ] || [ -e "$cert_arn_path" ]; then
      echo "Daemon certificate or env material already exists under $daemon_config_dir." >&2
      echo "Move or delete those files before issuing a replacement certificate." >&2
      exit 1
    fi
    temp_files=()
    cleanup_temp_files() {
      if [ "${#temp_files[@]}" -gt 0 ]; then
        rm -f "${temp_files[@]}"
      fi
    }
    trap cleanup_temp_files EXIT
    trust_policy_file="$(mktemp "${TMPDIR:-/tmp}/txing-daemon-trust.XXXXXX")"
    credential_policy_file="$(mktemp "${TMPDIR:-/tmp}/txing-daemon-credential-policy.XXXXXX")"
    temp_files+=("$trust_policy_file" "$credential_policy_file")
    jq -n '{Version: "2012-10-17", Statement: [{Effect: "Allow", Principal: {Service: "credentials.iot.amazonaws.com"}, Action: "sts:AssumeRole"}]}' >"$trust_policy_file"
    jq -n \
      --arg iotShadowArn "arn:${partition}:iot:${AWS_REGION}:${account_id}:thing/${effective_thing_name}/sparkplug" \
      --arg cloudwatchLogGroupArn "arn:${partition}:logs:${AWS_REGION}:${account_id}:log-group:${cloudwatch_log_group}" \
      --arg cloudwatchLogStreamArn "arn:${partition}:logs:${AWS_REGION}:${account_id}:log-group:${cloudwatch_log_group}:log-stream:*" \
      '{Version: "2012-10-17", Statement: [
        {Sid: "DaemonSparkplugShadowRead", Effect: "Allow", Action: "iot:GetThingShadow", Resource: $iotShadowArn},
        {Sid: "DaemonCloudWatchLogsWrite", Effect: "Allow", Action: ["logs:CreateLogGroup", "logs:CreateLogStream", "logs:DescribeLogStreams", "logs:PutRetentionPolicy", "logs:PutLogEvents"], Resource: [$cloudwatchLogGroupArn, $cloudwatchLogStreamArn]}
      ]}' \
      >"$credential_policy_file"
    if aws iam get-role --role-name "$daemon_role_name" "${aws_flags[@]}" >/dev/null 2>&1; then
      aws iam update-assume-role-policy --role-name "$daemon_role_name" --policy-document "file://$trust_policy_file" "${aws_flags[@]}"
    else
      aws iam create-role --role-name "$daemon_role_name" --assume-role-policy-document "file://$trust_policy_file" "${aws_flags[@]}" >/dev/null
    fi
    aws iam put-role-policy \
      --role-name "$daemon_role_name" \
      --policy-name txing-daemon-own-thing \
      --policy-document "file://$credential_policy_file" \
      "${aws_flags[@]}"
    daemon_role_arn="$(aws iam get-role --role-name "$daemon_role_name" "${aws_flags[@]}" --query 'Role.Arn' --output text)"
    if aws iot describe-role-alias --role-alias "$iot_role_alias" "${aws_flags[@]}" >/dev/null 2>&1; then
      aws iot update-role-alias --role-alias "$iot_role_alias" --role-arn "$daemon_role_arn" --credential-duration-seconds 3600 "${aws_flags[@]}" >/dev/null
    else
      aws iot create-role-alias --role-alias "$iot_role_alias" --role-arn "$daemon_role_arn" --credential-duration-seconds 3600 "${aws_flags[@]}" >/dev/null
    fi
    curl -fsSL https://www.amazontrust.com/repository/AmazonRootCA1.pem -o "$root_ca_path"
    cert_arn="$(
      aws iot create-keys-and-certificate \
        --set-as-active \
        --certificate-pem-outfile "$cert_path" \
        --public-key-outfile "$public_key_path" \
        --private-key-outfile "$private_key_path" \
        "${aws_flags[@]}" \
        --query certificateArn \
        --output text
    )"
    aws iot attach-policy --policy-name "$daemon_policy_name" --target "$cert_arn" "${aws_flags[@]}"
    aws iot attach-thing-principal \
      --thing-name "$effective_thing_name" \
      --principal "$cert_arn" \
      --thing-principal-type EXCLUSIVE_THING \
      "${aws_flags[@]}"
    printf '%s\n' "$cert_arn" >"$cert_arn_path"
    {
      printf 'export TXING_THING_ID=%s\n' "$effective_thing_name"
      printf 'export AWS_REGION=%s\n' "$AWS_REGION"
      printf 'export TXING_IOT_ENDPOINT=%s\n' "$iot_data_endpoint"
      printf 'export TXING_IOT_CREDENTIAL_ENDPOINT=%s\n' "$iot_credential_endpoint"
      printf 'export TXING_IOT_ROLE_ALIAS=%s\n' "$iot_role_alias"
      printf 'export TXING_CLOUDWATCH_LOG_GROUP=%s\n' "$cloudwatch_log_group"
      printf 'export TXING_CLOUDWATCH_LOG_LEVEL=info\n'
      printf 'export TXING_CLOUDWATCH_LOG_RETENTION_DAYS=14\n'
    } >"$env_file"
    chmod 600 "$env_file" "$cert_path" "$public_key_path" "$private_key_path" "$cert_arn_path"
    chmod 644 "$root_ca_path"
    jq -n \
      --arg thingName "$effective_thing_name" \
      --arg policyName "$daemon_policy_name" \
      --arg certificateArn "$cert_arn" \
      --arg certificatePem "$cert_path" \
      --arg publicKey "$public_key_path" \
      --arg privateKey "$private_key_path" \
      --arg certificateArnFile "$cert_arn_path" \
      --arg rootCaFile "$root_ca_path" \
      --arg envFile "$env_file" \
      --arg iotDataEndpoint "$iot_data_endpoint" \
      --arg iotCredentialEndpoint "$iot_credential_endpoint" \
      --arg iotRoleAlias "$iot_role_alias" \
      --arg cloudWatchLogGroup "$cloudwatch_log_group" \
      --arg daemonRoleName "$daemon_role_name" \
      --arg daemonRoleArn "$daemon_role_arn" \
      '{thingName: $thingName, policyName: $policyName, certificateArn: $certificateArn, certificatePem: $certificatePem, publicKey: $publicKey, privateKey: $privateKey, certificateArnFile: $certificateArnFile, rootCaFile: $rootCaFile, envFile: $envFile, iotDataEndpoint: $iotDataEndpoint, iotCredentialEndpoint: $iotCredentialEndpoint, iotRoleAlias: $iotRoleAlias, cloudWatchLogGroup: $cloudWatchLogGroup, daemonRoleName: $daemonRoleName, daemonRoleArn: $daemonRoleArn}'

test:
    cargo test --manifest-path "{{daemon_dir}}/Cargo.toml"

run:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{project_root}}"
    cargo run --manifest-path devices/unit/daemon/Cargo.toml

prerelease-builder-image rust_toolchain="stable":
    #!/usr/bin/env bash
    set -euo pipefail

    rust_toolchain="{{rust_toolchain}}"
    image="{{prerelease_builder_image}}"
    dockerfile="{{prerelease_builder_dockerfile}}"

    if [[ "$rust_toolchain" == *=* ]]; then
      echo "Do not pass just recipe arguments as name=value. Use positional arguments." >&2
      exit 2
    fi
    command -v docker >/dev/null || {
      echo "docker is required to build the unit daemon prerelease builder image." >&2
      exit 1
    }
    if [ ! -r "$dockerfile" ]; then
      echo "Missing prerelease builder Dockerfile: $dockerfile" >&2
      exit 1
    fi

    empty_context="$(mktemp -d "${TMPDIR:-/tmp}/txing-unit-daemon-builder-context.XXXXXX")"
    cleanup() {
      rm -rf "$empty_context"
    }
    trap cleanup EXIT

    docker build \
      --build-arg "RUST_TOOLCHAIN=$rust_toolchain" \
      -f "$dockerfile" \
      -t "$image" \
      "$empty_context"

prerelease-builder-shell:
    #!/usr/bin/env bash
    set -euo pipefail

    project_root="{{project_root}}"
    image="{{prerelease_builder_image}}"

    command -v docker >/dev/null || {
      echo "docker is required to run the unit daemon prerelease builder shell." >&2
      exit 1
    }
    if ! docker image inspect "$image" >/dev/null 2>&1; then
      echo "Missing prerelease builder image: $image" >&2
      echo "Run: just unit::daemon::prerelease-builder-image" >&2
      exit 1
    fi

    docker volume create "{{prerelease_cargo_registry_volume}}" >/dev/null
    docker volume create "{{prerelease_cargo_git_volume}}" >/dev/null
    docker volume create "{{prerelease_target_volume}}" >/dev/null

    exec docker run --rm -it \
      --mount "type=bind,source=$project_root,target=$project_root,readonly" \
      --mount "type=volume,source={{prerelease_cargo_registry_volume}},target=/opt/cargo/registry" \
      --mount "type=volume,source={{prerelease_cargo_git_volume}},target=/opt/cargo/git" \
      --mount "type=volume,source={{prerelease_target_volume}},target=/target" \
      -e CARGO_TARGET_DIR=/target \
      -w "$project_root" \
      "$image" \
      bash

prerelease-build branch=prerelease_branch:
    #!/usr/bin/env bash
    set -euo pipefail

    project_root="{{project_root}}"
    daemon_dir="{{daemon_dir}}"
    prerelease_dir="{{prerelease_dir}}"
    metadata_path="{{prerelease_metadata}}"
    branch="{{branch}}"
    asset_name="{{prerelease_asset}}"
    asset_path="$prerelease_dir/$asset_name"
    package_dir="$prerelease_dir/package"
    binary_name="txing-unit-daemon"
    binary_path="$package_dir/$binary_name"
    builder_image="{{prerelease_builder_image}}"
    docker_out_dir="$prerelease_dir/docker-out"

    if [[ "$branch" == *=* ]]; then
      echo "Do not pass just recipe arguments as name=value. Use positional arguments." >&2
      exit 2
    fi
    if [[ "$branch" != feature/* ]]; then
      echo "Feature prerelease branch must be under feature/, got: $branch" >&2
      exit 2
    fi
    for command in docker git python3 tar; do
      if ! command -v "$command" >/dev/null 2>&1; then
        echo "unit daemon prerelease-build requires '$command'." >&2
        exit 1
      fi
    done
    if ! docker image inspect "$builder_image" >/dev/null 2>&1; then
      echo "Missing prerelease builder image: $builder_image" >&2
      echo "Run: just unit::daemon::prerelease-builder-image" >&2
      exit 1
    fi
    server_platform="$(docker version | awk '/^  OS\/Arch:/ {print $2; exit}')"
    if [ "$server_platform" != "linux/arm64" ]; then
      echo "unit daemon prerelease-build requires a native linux/arm64 Docker daemon, got: $server_platform" >&2
      exit 1
    fi
    if [ -n "$(git -C "$project_root" status --porcelain --untracked-files=all)" ]; then
      echo "Working tree must be clean before prerelease build." >&2
      git -C "$project_root" status --short --untracked-files=all >&2
      exit 1
    fi

    version_base="$(tr -d '[:space:]' < "$project_root/VERSION")"
    if [[ ! "$version_base" =~ ^([0-9]+)\.([0-9]+)\.([0-9]+)$ ]]; then
      echo "VERSION must contain a base semantic version like x.y.z." >&2
      exit 1
    fi
    major="${BASH_REMATCH[1]}"
    minor="${BASH_REMATCH[2]}"
    patch="${BASH_REMATCH[3]}"
    timestamp="$(date -u +%s)"
    version="$major.$minor.$((patch + 1))-feature.$timestamp"
    tag="v$version"
    commit="$(git -C "$project_root" rev-parse HEAD)"

    docker volume create "{{prerelease_cargo_registry_volume}}" >/dev/null
    docker volume create "{{prerelease_cargo_git_volume}}" >/dev/null
    docker volume create "{{prerelease_target_volume}}" >/dev/null

    install -d "$prerelease_dir"
    rm -rf "$docker_out_dir"
    install -d "$docker_out_dir"

    docker run --rm -i \
      --mount "type=bind,source=$project_root,target=$project_root,readonly" \
      --mount "type=bind,source=$docker_out_dir,target=/out" \
      --mount "type=volume,source={{prerelease_cargo_registry_volume}},target=/opt/cargo/registry" \
      --mount "type=volume,source={{prerelease_cargo_git_volume}},target=/opt/cargo/git" \
      --mount "type=volume,source={{prerelease_target_volume}},target=/target" \
      -e CARGO_TARGET_DIR=/target \
      -e TXING_DAEMON_BUILD_VERSION="$version" \
      -e TXING_PRERELEASE_ASSET_NAME="$asset_name" \
      -e TXING_PRERELEASE_BINARY_NAME="$binary_name" \
      -w "$project_root" \
      "$builder_image" \
      bash -se <<'DOCKER_BUILD'
    set -euo pipefail

    build_host="$(hostname)"
    build_kernel="$(uname -a)"
    printf '%s\n' "$build_host" > /out/build-host
    printf '%s\n' "$build_kernel" > /out/build-kernel

    cargo test --manifest-path devices/unit/daemon/Cargo.toml
    cargo build --release --manifest-path devices/unit/daemon/Cargo.toml --bin daemon

    package_dir="$(mktemp -d /tmp/txing-unit-daemon-package.XXXXXX)"
    binary_path="$package_dir/$TXING_PRERELEASE_BINARY_NAME"
    install -m 755 "$CARGO_TARGET_DIR/release/daemon" "$binary_path"
    strip "$binary_path"
    file "$binary_path"
    install -m 755 "$binary_path" "/out/$TXING_PRERELEASE_BINARY_NAME"
    tar -C "$package_dir" -czf "/out/$TXING_PRERELEASE_ASSET_NAME" "$TXING_PRERELEASE_BINARY_NAME"
    tar -tzf "/out/$TXING_PRERELEASE_ASSET_NAME"
    DOCKER_BUILD

    build_host="$(cat "$docker_out_dir/build-host")"
    build_kernel="$(cat "$docker_out_dir/build-kernel")"

    rm -rf "$package_dir"
    install -d "$package_dir"
    install -m 755 "$docker_out_dir/$binary_name" "$binary_path"
    rm -f "$asset_path"
    install -m 644 "$docker_out_dir/$asset_name" "$asset_path"
    tar -tzf "$asset_path"

    python3 - "$metadata_path" <<PY
    import json
    import sys

    metadata = {
        "version": "$version",
        "tag": "$tag",
        "branch": "$branch",
        "commit": "$commit",
        "timestamp": int("$timestamp"),
        "assetName": "$asset_name",
        "assetPath": "$asset_path",
        "assetFormat": "tar.gz",
        "binaryName": "$binary_name",
        "binaryPath": "$binary_path",
        "projectRoot": "$project_root",
        "buildHost": "$build_host",
        "buildKernel": "$build_kernel",
    }
    with open(sys.argv[1], "w", encoding="utf-8") as handle:
        json.dump(metadata, handle, indent=2)
        handle.write("\n")
    PY

    rm -rf "$docker_out_dir"

    printf 'prepared unit daemon prerelease artifact\n'
    printf '  tag: %s\n' "$tag"
    printf '  branch: %s\n' "$branch"
    printf '  commit: %s\n' "$commit"
    printf '  asset: %s\n' "$asset_path"
    printf '  binary: %s\n' "$binary_path"
    printf '  metadata: %s\n' "$metadata_path"

prerelease-publish:
    #!/usr/bin/env bash
    set -euo pipefail

    project_root="{{project_root}}"
    metadata_path="{{prerelease_metadata}}"
    expected_asset_name="{{prerelease_asset}}"

    if [ "$(uname -s)" != "Darwin" ]; then
      echo "unit daemon prerelease-publish must run on macOS where gh is authenticated." >&2
      exit 1
    fi
    command -v gh >/dev/null || {
      echo "gh is required to publish the unit daemon prerelease." >&2
      exit 1
    }
    command -v python3 >/dev/null || {
      echo "python3 is required to read prerelease metadata." >&2
      exit 1
    }
    command -v tar >/dev/null || {
      echo "tar is required to verify the prerelease archive." >&2
      exit 1
    }
    if [ ! -r "$metadata_path" ]; then
      echo "Missing prerelease metadata: $metadata_path" >&2
      echo "Run just unit::daemon::prerelease-build first." >&2
      exit 1
    fi
    if [ -n "$(git -C "$project_root" status --porcelain --untracked-files=all)" ]; then
      echo "Working tree must be clean before prerelease publish." >&2
      git -C "$project_root" status --short --untracked-files=all >&2
      exit 1
    fi

    read_metadata() {
      local key="$1"
      python3 - "$metadata_path" "$key" <<'PY'
    import json
    import sys

    with open(sys.argv[1], encoding="utf-8") as handle:
        value = json.load(handle)[sys.argv[2]]
    print(value)
    PY
    }

    tag="$(read_metadata tag)"
    branch="$(read_metadata branch)"
    commit="$(read_metadata commit)"
    version="$(read_metadata version)"
    timestamp="$(read_metadata timestamp)"
    asset_name="$(read_metadata assetName)"
    asset_path="$(read_metadata assetPath)"
    asset_format="$(read_metadata assetFormat)"
    binary_name="$(read_metadata binaryName)"
    build_host="$(read_metadata buildHost)"
    build_kernel="$(read_metadata buildKernel)"

    if [[ "$branch" != feature/* ]]; then
      echo "Feature prerelease branch must be under feature/, got: $branch" >&2
      exit 2
    fi
    if [[ ! "$tag" =~ ^v[0-9]+\.[0-9]+\.[0-9]+-feature\.[0-9]+$ ]]; then
      echo "Unexpected unit daemon feature tag: $tag" >&2
      exit 1
    fi
    if [ "$asset_name" != "$expected_asset_name" ]; then
      echo "Unexpected prerelease asset name: $asset_name" >&2
      exit 1
    fi
    if [ "$asset_format" != "tar.gz" ]; then
      echo "Unexpected prerelease asset format: $asset_format" >&2
      exit 1
    fi
    if [ "$binary_name" != "txing-unit-daemon" ]; then
      echo "Unexpected prerelease binary name: $binary_name" >&2
      exit 1
    fi
    if [ ! -s "$asset_path" ]; then
      echo "Missing prerelease archive asset: $asset_path" >&2
      exit 1
    fi
    archive_listing="$(tar -tzf "$asset_path")"
    if ! grep -Fxq "$binary_name" <<<"$archive_listing"; then
      echo "Prerelease archive does not contain $binary_name at its root." >&2
      exit 1
    fi
    current_commit="$(git -C "$project_root" rev-parse HEAD)"
    if [ "$current_commit" != "$commit" ]; then
      echo "Current HEAD $current_commit does not match prerelease build commit $commit." >&2
      exit 1
    fi
    cd "$project_root"

    notes_file="$(mktemp "${TMPDIR:-/tmp}/txing-unit-daemon-prerelease-notes.XXXXXX")"
    old_tags_file="$(mktemp "${TMPDIR:-/tmp}/txing-unit-daemon-prerelease-old-tags.XXXXXX")"
    cleanup() {
      rm -f "$notes_file" "$old_tags_file"
    }
    trap cleanup EXIT
    cat >"$notes_file" <<NOTES
    Unit daemon feature prerelease.

    - Version: $version
    - Tag: $tag
    - Branch: $branch
    - Commit: $commit
    - Asset: $asset_name
    - Build host: $build_host
    - Build kernel: $build_kernel
    - Timestamp: $timestamp
    NOTES

    git -C "$project_root" push --force-with-lease origin "HEAD:refs/heads/$branch"
    git -C "$project_root" tag -a "$tag" -m "unit daemon feature prerelease $version" "$commit"
    git -C "$project_root" push origin "refs/tags/$tag:refs/tags/$tag"
    gh release create "$tag" "$asset_path" \
      --prerelease \
      --latest=false \
      --verify-tag \
      --title "$tag" \
      --notes-file "$notes_file"

    gh api --paginate repos/{owner}/{repo}/releases \
      --jq '.[] | select(.prerelease == true) | select(.tag_name | test("^v[0-9]+\\.[0-9]+\\.[0-9]+-feature\\.[0-9]+$")) | select(any(.assets[]?; .name == "'"$expected_asset_name"'")) | [.tag_name, .published_at] | @tsv' \
      | sort -r -k2,2 \
      | awk 'NR > 10 {print $1}' \
      >"$old_tags_file"
    while IFS= read -r old_tag; do
      [ -n "$old_tag" ] || continue
      printf 'pruning old unit daemon feature prerelease %s\n' "$old_tag"
      gh release delete "$old_tag" --cleanup-tag --yes
    done <"$old_tags_file"

    printf 'published unit daemon feature prerelease\n'
    printf '  tag: %s\n' "$tag"
    printf '  branch: %s\n' "$branch"
    printf '  asset: %s\n' "$asset_path"
