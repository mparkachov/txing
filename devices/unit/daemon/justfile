set shell := ["sh", "-eu", "-c"]
set quiet := true

daemon_dir := source_directory()
project_root := canonicalize(daemon_dir + "/../../..")
tmp_dir := project_root + "/tmp"
export TMPDIR := tmp_dir
root_justfile := project_root + "/justfile"
daemon_justfile := daemon_dir + "/justfile"
aws_lib := project_root + "/shared/aws/scripts/aws_lib.sh"
daemon_env_template := daemon_dir + "/daemon.env.template"
unit_board_dir := project_root + "/devices/unit/board"
common_board_dir := project_root + "/devices/common/board"
native_kvs_master_dir := unit_board_dir + "/kvs_master"
native_kvs_master_build_dir := native_kvs_master_dir + "/build"
native_kvs_master_test_build_dir := native_kvs_master_dir + "/build-tests"
built_native_kvs_master := native_kvs_master_build_dir + "/txing-board-kvs-master"
aws_kvs_sdk_dir := project_root + "/modules/awslabs/amazon-kinesis-video-streams-webrtc-sdk-c"
aws_kvs_sdk_commit := "bb106510cf74edd2c24881c1ae94ceaa0083d15c"
aws_kvs_sdk_build_dir := common_board_dir + "/aws-kvs-webrtc-sdk-build"
aws_kvs_sdk_install_dir := common_board_dir + "/aws-kvs-webrtc-sdk-install"
aws_kvs_sdk_system_deps_dir := common_board_dir + "/aws-kvs-webrtc-sdk-system-deps"
aws_kvs_sdk_install_header := aws_kvs_sdk_install_dir + "/include/com/amazonaws/kinesis/video/webrtcclient/Include.h"
