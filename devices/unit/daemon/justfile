docker-builder-image rust_toolchain="stable":
    #!/bin/sh
    set -eu

    rust_toolchain="{{rust_toolchain}}"
    image="{{docker_builder_image}}"
    dockerfile="{{docker_builder_dockerfile}}"

    case "$rust_toolchain" in *=*) echo "Do not pass just recipe arguments as name=value. Use positional arguments." >&2; exit 2 ;; esac
    command -v docker >/dev/null || {
      echo "docker is required to build the board binaries builder image." >&2
      exit 1
    }
    if [ ! -r "$dockerfile" ]; then
      echo "Missing Docker builder Dockerfile: $dockerfile" >&2
      exit 1
    fi

    mkdir -p "$TMPDIR"
    empty_context="$(mktemp -d "${TMPDIR:-/tmp}/txing-board-binaries-builder-context.XXXXXX")"
    cleanup() {
      rm -rf "$empty_context"
    }
    trap cleanup EXIT

    docker build \
      --build-arg "RUST_TOOLCHAIN=$rust_toolchain" \
      -f "$dockerfile" \
      -t "$image" \
      "$empty_context"

docker-builder-shell:
    #!/bin/sh
    set -eu

    project_root="{{project_root}}"
    image="{{docker_builder_image}}"

    command -v docker >/dev/null || {
      echo "docker is required to run the board binaries builder shell." >&2
      exit 1
    }
    if ! docker image inspect "$image" >/dev/null 2>&1; then
      echo "Missing Docker builder image: $image" >&2
      echo "Run: just unit::daemon::docker-builder-image" >&2
      exit 1
    fi

    docker volume create "{{docker_cargo_registry_volume}}" >/dev/null
    docker volume create "{{docker_cargo_git_volume}}" >/dev/null
    docker volume create "{{docker_target_volume}}" >/dev/null

    exec docker run --rm -it \
      --mount "type=bind,source=$project_root,target=$project_root,readonly" \
      --mount "type=volume,source={{docker_cargo_registry_volume}},target=/opt/cargo/registry" \
      --mount "type=volume,source={{docker_cargo_git_volume}},target=/opt/cargo/git" \
      --mount "type=volume,source={{docker_target_volume}},target=/target" \
      -e CARGO_TARGET_DIR=/target \
      -w "$project_root" \
      "$image" \
      sh

@_kvs-ensure-aws-sdk-submodule:
    test -f "{{aws_kvs_sdk_dir}}/CMakeLists.txt" || { echo "missing AWS KVS WebRTC SDK submodule. Run: just unit::daemon::kvs-submodules" >&2; exit 1; }
    test "$(git -C "{{aws_kvs_sdk_dir}}" rev-parse HEAD)" = "{{aws_kvs_sdk_commit}}" || { echo "AWS KVS WebRTC SDK submodule is not at {{aws_kvs_sdk_commit}}. Run: just unit::daemon::kvs-submodules" >&2; exit 1; }

@_kvs-check-system-dependencies:
    #!/bin/sh
    set -eu
    if [ "$(uname -s)" != "Linux" ]; then
        exit 0
    fi

    missing=""
    add_missing() {
        if [ -z "$missing" ]; then
            missing="$1"
        else
            missing="$missing $1"
        fi
    }
    for pc in openssl libcurl libwebsockets zlib; do
        if ! pkg-config --exists "$pc"; then
            add_missing "$pc"
        fi
    done

    for header in usrsctp.h srtp2/srtp.h; do
        if ! printf '#include <%s>\nint main(void) { return 0; }\n' "$header" | cc -x c - -fsyntax-only >/dev/null 2>&1; then
            add_missing "$header"
        fi
    done
    if ! printf '#include <log4cplus/logger.h>\nint main() { return 0; }\n' | c++ -x c++ - -fsyntax-only >/dev/null 2>&1; then
        add_missing "log4cplus/logger.h"
    fi

    for library in srtp2 usrsctp log4cplus curl websockets z ssl crypto; do
        path="$(cc -print-file-name="lib${library}.so")"
        if [ "$path" = "lib${library}.so" ] || [ ! -f "$path" ]; then
            add_missing "lib${library}.so"
        fi
    done

    if [ -n "$missing" ]; then
        printf 'Missing system KVS dependency/dependencies: %s\n' "$missing" >&2
        printf 'Install distro packages, for example:\n' >&2
        printf '  apt install -y libssl-dev libcurl4-openssl-dev liblog4cplus-dev libsrtp2-dev libusrsctp-dev libwebsockets-dev zlib1g-dev\n' >&2
        exit 1
    fi

@kvs-submodules:
    git -C "{{project_root}}" submodule update --init --recursive -- modules/awslabs/amazon-kinesis-video-streams-webrtc-sdk-c
    git -C "{{aws_kvs_sdk_dir}}" fetch --depth=1 origin "{{aws_kvs_sdk_commit}}"
    git -C "{{aws_kvs_sdk_dir}}" checkout --detach "{{aws_kvs_sdk_commit}}"

@kvs-build-aws-sdk: _kvs-ensure-aws-sdk-submodule
    #!/bin/sh
    set -eu
    just --justfile "{{daemon_justfile}}" _kvs-check-system-dependencies
    if [ "$(uname -s)" != "Linux" ]; then
        echo "kvs-build-aws-sdk uses apt/distro system dependencies and must run on the Linux board host." >&2
        exit 1
    fi
    rm -rf "{{aws_kvs_sdk_build_dir}}" "{{aws_kvs_sdk_install_dir}}" "{{aws_kvs_sdk_system_deps_dir}}"
    mkdir -p "{{aws_kvs_sdk_system_deps_dir}}/lib" "{{aws_kvs_sdk_system_deps_dir}}/include"
    openssl_libdir="$(pkg-config --variable=libdir openssl)"
    openssl_includedir="$(pkg-config --variable=includedir openssl)"
    openssl_ssl_library="$openssl_libdir/libssl.so"
    openssl_crypto_library="$openssl_libdir/libcrypto.so"
    if [ ! -f "$openssl_ssl_library" ] || [ ! -f "$openssl_crypto_library" ]; then
        echo "Expected shared OpenSSL libraries were not found under $openssl_libdir" >&2
        exit 1
    fi

    for library in srtp2 usrsctp log4cplus curl websockets z ssl crypto; do
        library_path="$(cc -print-file-name="lib${library}.so")"
        if [ "$library_path" = "lib${library}.so" ] || [ ! -f "$library_path" ]; then
            echo "System lib${library}.so not found; install the matching distro development package" >&2
            exit 1
        fi
        ln -s "$library_path" "{{aws_kvs_sdk_system_deps_dir}}/lib/lib${library}.so"
        ln -s "$library_path" "{{aws_kvs_sdk_system_deps_dir}}/lib${library}.so"
    done
    cmake \
        -S "{{aws_kvs_sdk_dir}}" \
        -B "{{aws_kvs_sdk_build_dir}}" \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX="{{aws_kvs_sdk_install_dir}}" \
        -DOPEN_SRC_INSTALL_PREFIX="{{aws_kvs_sdk_system_deps_dir}}" \
        -DBUILD_DEPENDENCIES=OFF \
        -DBUILD_SAMPLE=OFF \
        -DBUILD_TEST=OFF \
        -DBUILD_BENCHMARK=OFF \
        -DBUILD_STATIC_LIBS=ON \
        -DUSE_OPENSSL=ON \
        -DUSE_MBEDTLS=OFF \
        -DOPENSSL_USE_STATIC_LIBS=FALSE \
        -DOPENSSL_INCLUDE_DIR="$openssl_includedir" \
        -DOPENSSL_SSL_LIBRARY="$openssl_ssl_library" \
        -DOPENSSL_CRYPTO_LIBRARY="$openssl_crypto_library"
    cmake --build "{{aws_kvs_sdk_build_dir}}" --config Release
    cmake --install "{{aws_kvs_sdk_build_dir}}" --config Release
    if [ ! -f "{{aws_kvs_sdk_system_deps_dir}}/include/com/amazonaws/kinesis/video/common/Include.h" ]; then
        echo "Expected AWS SDK support headers were not built under {{aws_kvs_sdk_system_deps_dir}}/include" >&2
        exit 1
    fi
    cp -a "{{aws_kvs_sdk_system_deps_dir}}/include/com" "{{aws_kvs_sdk_install_dir}}/include/"
    for aws_library in kvsCommonLws kvspicUtils kvspicState; do
        source_library="{{aws_kvs_sdk_system_deps_dir}}/lib/lib${aws_library}.a"
        if [ ! -f "$source_library" ]; then
            echo "Expected AWS SDK support library was not built: $source_library" >&2
            exit 1
        fi
        cp -a "$source_library" "{{aws_kvs_sdk_install_dir}}/lib/"
    done
    sdk_head="$(git -C "{{aws_kvs_sdk_dir}}" rev-parse HEAD)"
    printf 'sdk_head=%s\nbuild_dependencies=OFF\ndependency_source=system\n' "$sdk_head" > "{{aws_kvs_sdk_state_file}}"

@kvs-ensure-aws-sdk: _kvs-ensure-aws-sdk-submodule
    #!/bin/sh
    set -eu
    sdk_head="$(git -C "{{aws_kvs_sdk_dir}}" rev-parse HEAD)"
    if [ ! -f "{{aws_kvs_sdk_install_header}}" ] || [ ! -f "{{aws_kvs_sdk_install_common_header}}" ] || [ ! -f "{{aws_kvs_sdk_install_library}}" ] || [ ! -f "{{aws_kvs_sdk_install_dir}}/lib/libkvsCommonLws.a" ] || [ ! -f "{{aws_kvs_sdk_install_dir}}/lib/libkvspicUtils.a" ] || [ ! -f "{{aws_kvs_sdk_install_dir}}/lib/libkvspicState.a" ] || [ ! -f "{{aws_kvs_sdk_state_file}}" ]; then
        just --justfile "{{daemon_justfile}}" kvs-build-aws-sdk
    elif ! grep -Fqx "sdk_head=$sdk_head" "{{aws_kvs_sdk_state_file}}"; then
        just --justfile "{{daemon_justfile}}" kvs-build-aws-sdk
    elif ! grep -Fqx "build_dependencies=OFF" "{{aws_kvs_sdk_state_file}}"; then
        just --justfile "{{daemon_justfile}}" kvs-build-aws-sdk
    elif ! grep -Fqx "dependency_source=system" "{{aws_kvs_sdk_state_file}}"; then
        just --justfile "{{daemon_justfile}}" kvs-build-aws-sdk
    elif [ "$(uname -s)" = "Linux" ] && { [ ! -f "{{aws_kvs_sdk_flags_file}}" ] || grep -E -q 'KVS_CA_CERT_PATH=|CMAKE_DETECTED_CACERT_PATH' "{{aws_kvs_sdk_flags_file}}"; }; then
        just --justfile "{{daemon_justfile}}" kvs-build-aws-sdk
    fi

@kvs-build-native:
    #!/bin/sh
    set -eu
    if [ "$(uname -s)" = "Linux" ]; then
        just --justfile "{{daemon_justfile}}" _kvs-check-system-dependencies
        just --justfile "{{daemon_justfile}}" kvs-ensure-aws-sdk
        openssl_libdir="$(pkg-config --variable=libdir openssl)"
        openssl_includedir="$(pkg-config --variable=includedir openssl)"
        cmake \
            -S "{{native_kvs_master_dir}}" \
            -B "{{native_kvs_master_build_dir}}" \
            -DCMAKE_BUILD_TYPE=Release \
            -DBUILD_TESTING=OFF \
            -DTXING_KVS_SYSTEM_CA_CERT_PATH="{{default_kvs_system_ca_cert_path}}" \
            -DTXING_KVS_WEBRTC_SDK_DIR="{{aws_kvs_sdk_dir}}" \
            -DTXING_KVS_WEBRTC_SDK_INSTALL_DIR="{{aws_kvs_sdk_install_dir}}" \
            -DOPENSSL_USE_STATIC_LIBS=FALSE \
            -DOPENSSL_INCLUDE_DIR="$openssl_includedir" \
            -DOPENSSL_SSL_LIBRARY="$openssl_libdir/libssl.so" \
            -DOPENSSL_CRYPTO_LIBRARY="$openssl_libdir/libcrypto.so"
    else
        cmake \
            -S "{{native_kvs_master_dir}}" \
            -B "{{native_kvs_master_build_dir}}" \
            -DCMAKE_BUILD_TYPE=Release \
            -DBUILD_TESTING=OFF \
            -DTXING_KVS_SYSTEM_CA_CERT_PATH="{{default_kvs_system_ca_cert_path}}" \
            -DTXING_KVS_WEBRTC_SDK_DIR="{{aws_kvs_sdk_dir}}" \
            -DTXING_KVS_WEBRTC_SDK_INSTALL_DIR="{{aws_kvs_sdk_install_dir}}"
    fi
    cmake --build "{{native_kvs_master_build_dir}}" --config Release
    test -x "{{built_native_kvs_master}}"

@kvs-test-native:
    cmake -S "{{native_kvs_master_dir}}" -B "{{native_kvs_master_test_build_dir}}" -DCMAKE_BUILD_TYPE=Debug -DTXING_KVS_REAL_SDK=OFF -DTXING_KVS_SYSTEM_CA_CERT_PATH="{{default_kvs_system_ca_cert_path}}"
    cmake --build "{{native_kvs_master_test_build_dir}}" --config Debug --target txing-board-kvs-master-tests
    ctest --test-dir "{{native_kvs_master_test_build_dir}}" --output-on-failure

@kvs-clean:
    rm -rf "{{native_kvs_master_build_dir}}" "{{native_kvs_master_test_build_dir}}" "{{aws_kvs_sdk_build_dir}}" "{{aws_kvs_sdk_install_dir}}" "{{aws_kvs_sdk_system_deps_dir}}"

docker-build:
    #!/bin/sh
    set -eu

    project_root="{{project_root}}"
    daemon_dir="{{daemon_dir}}"
    docker_build_dir="{{docker_build_dir}}"
    metadata_path="{{docker_build_metadata}}"
    builder_image="{{docker_builder_image}}"
    kvs_master_build_image="{{docker_kvs_master_build_image}}"
    docker_out_dir="$docker_build_dir/docker-out"
    bin_dir="$docker_build_dir/bin"
    daemon_binary_name="txing-unit-daemon"
    kvs_master_binary_name="txing-board-kvs-master"
    daemon_binary_path="$bin_dir/$daemon_binary_name"
    kvs_master_binary_path="$bin_dir/$kvs_master_binary_name"

    for command in docker git jq file; do
      if ! command -v "$command" >/dev/null 2>&1; then
        echo "unit daemon docker-build requires '$command'." >&2
        exit 1
      fi
    done
    if ! docker image inspect "$builder_image" >/dev/null 2>&1; then
      echo "Missing Docker builder image: $builder_image" >&2
      echo "Run: just unit::daemon::docker-builder-image" >&2
      exit 1
    fi
    server_platform="$(docker version | awk '/^  OS\/Arch:/ {print $2; exit}')"
    if [ "$server_platform" != "linux/arm64" ]; then
      echo "unit daemon docker-build requires a native linux/arm64 Docker daemon, got: $server_platform" >&2
      exit 1
    fi

    version="$(tr -d '[:space:]' < "$project_root/VERSION")"
    if ! printf '%s\n' "$version" | grep -E -q '^(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)$'; then
      echo "VERSION must contain a base semantic version like x.y.z." >&2
      exit 1
    fi
    commit="$(git -C "$project_root" rev-parse HEAD)"
    timestamp="$(date -u +%s)"

    docker volume create "{{docker_cargo_registry_volume}}" >/dev/null
    docker volume create "{{docker_cargo_git_volume}}" >/dev/null
    docker volume create "{{docker_target_volume}}" >/dev/null

    rm -rf "$docker_build_dir"
    install -d "$docker_build_dir" "$bin_dir"
    rm -rf "$docker_out_dir"
    install -d "$docker_out_dir"

    docker run --rm -i \
      --mount "type=bind,source=$project_root,target=$project_root,readonly" \
      --mount "type=bind,source=$docker_out_dir,target=/out" \
      --mount "type=volume,source={{docker_cargo_registry_volume}},target=/opt/cargo/registry" \
      --mount "type=volume,source={{docker_cargo_git_volume}},target=/opt/cargo/git" \
      --mount "type=volume,source={{docker_target_volume}},target=/target" \
      -e CARGO_TARGET_DIR=/target \
      -e TXING_DAEMON_BUILD_VERSION="$version" \
      -e TXING_DAEMON_BINARY_NAME="$daemon_binary_name" \
      -w "$project_root" \
      "$builder_image" \
      sh -se <<'DAEMON_BUILD'
    set -eu

    build_host="$(hostname)"
    build_kernel="$(uname -a)"
    printf '%s\n' "$build_host" > /out/daemon-build-host
    printf '%s\n' "$build_kernel" > /out/daemon-build-kernel

    cargo test --manifest-path devices/unit/daemon/Cargo.toml
    cargo build --release --manifest-path devices/unit/daemon/Cargo.toml --bin daemon

    install -m 755 "$CARGO_TARGET_DIR/release/daemon" "/out/$TXING_DAEMON_BINARY_NAME"
    strip "/out/$TXING_DAEMON_BINARY_NAME"
    file "/out/$TXING_DAEMON_BINARY_NAME"
    DAEMON_BUILD

    docker run --rm -i \
      -v "$project_root:$project_root" \
      -v "$docker_out_dir:/out" \
      -w "$project_root" \
      -e DEBIAN_FRONTEND=noninteractive \
      -e KVS_MASTER_BINARY="$kvs_master_binary_name" \
      "$kvs_master_build_image" \
      sh -se <<'KVS_MASTER_BUILD'
    set -eu
    build_host="$(hostname)"
    build_kernel="$(uname -a)"
    printf '%s\n' "$build_host" > /out/kvs-master-build-host
    printf '%s\n' "$build_kernel" > /out/kvs-master-build-kernel
    apt-get update
    apt-get install -y --no-install-recommends ca-certificates curl
    cat >/etc/apt/sources.list.d/raspi.sources <<'APT_SOURCE'
    Types: deb
    URIs: https://archive.raspberrypi.com/debian/
    Suites: trixie
    Components: main
    Architectures: arm64
    Trusted: yes
    APT_SOURCE
    cat >/etc/apt/preferences.d/raspi-libcamera <<'APT_PREFERENCES'
    Package: libcamera* python3-libcamera gstreamer1.0-libcamera
    Pin: origin archive.raspberrypi.com
    Pin-Priority: 1001
    APT_PREFERENCES
    apt-get update
    apt-get install -y --no-install-recommends \
      build-essential pkg-config cmake perl file curl git ca-certificates \
      libssl-dev libcurl4-openssl-dev liblog4cplus-dev libsrtp2-dev \
      libusrsctp-dev libwebsockets-dev zlib1g-dev libcamera-dev
    apt-cache policy libcamera-dev libcamera0.7
    curl https://mise.run | sh
    export PATH="$HOME/.local/bin:$HOME/.local/share/mise/shims:$PATH"
    mise use --global --yes just@latest
    git config --global --add safe.directory "$PWD"
    git config --global --add safe.directory "$PWD/modules/awslabs/amazon-kinesis-video-streams-webrtc-sdk-c"
    just unit::daemon::kvs-submodules
    just unit::daemon::kvs-build-native
    kvs_master_build_binary="devices/unit/board/kvs_master/build/$KVS_MASTER_BINARY"
    test -x "$kvs_master_build_binary"
    ldd "$kvs_master_build_binary"
    if ldd "$kvs_master_build_binary" | grep -Fq "not found"; then
      echo "txing-board-kvs-master has unresolved shared libraries" >&2
      exit 1
    fi
    ldd "$kvs_master_build_binary" | grep -F "libcamera.so.0.7"
    ldd "$kvs_master_build_binary" | grep -F "libcamera-base.so.0.7"
    install -m 755 "$kvs_master_build_binary" "/out/$KVS_MASTER_BINARY"
    strip "/out/$KVS_MASTER_BINARY"
    file "/out/$KVS_MASTER_BINARY"
    KVS_MASTER_BUILD

    install -m 755 "$docker_out_dir/$daemon_binary_name" "$daemon_binary_path"
    install -m 755 "$docker_out_dir/$kvs_master_binary_name" "$kvs_master_binary_path"
    daemon_build_host="$(cat "$docker_out_dir/daemon-build-host")"
    daemon_build_kernel="$(cat "$docker_out_dir/daemon-build-kernel")"
    kvs_master_build_host="$(cat "$docker_out_dir/kvs-master-build-host")"
    kvs_master_build_kernel="$(cat "$docker_out_dir/kvs-master-build-kernel")"

    jq -n \
      --arg version "$version" \
      --arg commit "$commit" \
      --argjson timestamp "$timestamp" \
      --arg daemonBinaryName "$daemon_binary_name" \
      --arg daemonBinaryPath "$daemon_binary_path" \
      --arg kvsMasterBinaryName "$kvs_master_binary_name" \
      --arg kvsMasterBinaryPath "$kvs_master_binary_path" \
      --arg projectRoot "$project_root" \
      --arg daemonBuildHost "$daemon_build_host" \
      --arg daemonBuildKernel "$daemon_build_kernel" \
      --arg kvsMasterBuildHost "$kvs_master_build_host" \
      --arg kvsMasterBuildKernel "$kvs_master_build_kernel" \
      '{
        version: $version,
        commit: $commit,
        timestamp: $timestamp,
        outputs: {
          ($daemonBinaryName): $daemonBinaryPath,
          ($kvsMasterBinaryName): $kvsMasterBinaryPath
        },
        projectRoot: $projectRoot,
        daemonBuildHost: $daemonBuildHost,
        daemonBuildKernel: $daemonBuildKernel,
        kvsMasterBuildHost: $kvsMasterBuildHost,
        kvsMasterBuildKernel: $kvsMasterBuildKernel
      }' >"$metadata_path"

    rm -rf "$docker_out_dir"

    printf 'prepared local board binaries with docker\n'
    printf '  version: %s\n' "$version"
    printf '  commit: %s\n' "$commit"
    printf '  daemon binary: %s\n' "$daemon_binary_path"
    printf '  KVS master binary: %s\n' "$kvs_master_binary_path"
    printf '  metadata: %s\n' "$metadata_path"
