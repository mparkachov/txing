aws_kvs_sdk_install_library := aws_kvs_sdk_install_dir + "/lib/libkvsWebrtcClient.a"
aws_kvs_sdk_flags_file := aws_kvs_sdk_build_dir + "/CMakeFiles/kvsWebrtcSignalingClient.dir/flags.make"
aws_kvs_sdk_state_file := aws_kvs_sdk_install_dir + "/.txing-sdk-build-state"
default_kvs_system_ca_cert_path := env_var_or_default("TXING_BOARD_KVS_SYSTEM_CA_CERT_PATH", "/etc/ssl/certs/Starfield_Services_Root_Certificate_Authority_-_G2.pem")

config_dir := ""
docker_build_dir := daemon_dir + "/target/docker-build"
docker_build_metadata := docker_build_dir + "/metadata.json"
docker_builder_image := "txing-board-binaries-builder:ubuntu24-rust-stable"
docker_builder_dockerfile := daemon_dir + "/Dockerfile.docker-builder"
docker_cargo_registry_volume := "txing-cargo-registry"
docker_cargo_git_volume := "txing-cargo-git"
docker_target_volume := "txing-unit-daemon-target"
docker_kvs_master_build_image := "debian:trixie"

cert thing_id='' config_dir=config_dir:
    #!/bin/sh
    set -eu
    requested_thing_name="{{thing_id}}"
    case "$requested_thing_name" in *=*) echo "Do not pass just recipe arguments as name=value. Use: just unit::cert <thing-id>" >&2; exit 2 ;; esac
    requested_config_dir="{{config_dir}}"
    case "$requested_config_dir" in *=*) echo "Do not pass just recipe arguments as name=value. Use positional arguments." >&2; exit 2 ;; esac
    if [ -n "$requested_thing_name" ]; then
      export TXING_THING_ID="$requested_thing_name"
    fi
    . "{{aws_lib}}"
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env device)"
    txing_aws_init
    effective_thing_name="${requested_thing_name:-$THING_NAME}"
    case "$effective_thing_name" in *=*) echo "Invalid Thing ID '$effective_thing_name'. Use positional just arguments, for example: just unit::cert unit-bl95f2" >&2; exit 2 ;; esac
    if ! printf '%s\n' "$effective_thing_name" | grep -E -q '^[a-zA-Z0-9:_-]+$'; then
      echo "Invalid Thing ID '$effective_thing_name'. Allowed characters: letters, digits, colon, underscore, hyphen." >&2
      exit 2
    fi
    daemon_policy_name="$(stack_parameter DeviceDaemonIotPolicyName)"
    if [ -z "$daemon_policy_name" ] || [ "$daemon_policy_name" = "None" ]; then
      echo "Could not resolve /txing/stack/DeviceDaemonIotPolicyName." >&2
      exit 1
    fi
    account_id="$(aws sts get-caller-identity --query Account --output text)"
    caller_arn="$(aws sts get-caller-identity --query Arn --output text)"
    partition="$(printf '%s\n' "$caller_arn" | cut -d: -f2)"
    daemon_role_name="txing-daemon-$effective_thing_name"
    iot_role_alias="txing-daemon-$effective_thing_name"
    if [ "${#daemon_role_name}" -gt 64 ]; then
      echo "IAM role name $daemon_role_name is longer than 64 characters." >&2
      exit 1
    fi
    if [ "${#iot_role_alias}" -gt 128 ]; then
      echo "IoT role alias $iot_role_alias is longer than 128 characters." >&2
      exit 1
    fi
    cloudwatch_log_group="txing/${TXING_TOWN_ID}/${TXING_RIG_ID}/${effective_thing_name}"
    video_channel_name="${TXING_BOARD_VIDEO_CHANNEL_NAME:-${effective_thing_name}-board-video}"
    iot_data_endpoint="$(aws iot describe-endpoint --endpoint-type iot:Data-ATS --query endpointAddress --output text)"
    iot_credential_endpoint="$(aws iot describe-endpoint --endpoint-type iot:CredentialProvider --query endpointAddress --output text)"
    default_output_root() {
      printf '%s\n' "{{project_root}}/config/certs/unit/$effective_thing_name"
    }
    default_config_dir() {
      if [ -n "${TXING_DAEMON_CONFIG_DIR:-}" ]; then
        printf '%s\n' "$TXING_DAEMON_CONFIG_DIR"
      else
        printf '%s\n' "$(default_output_root)/unit-daemon"
      fi
    }
    daemon_config_dir="${requested_config_dir:-$(default_config_dir)}"
    if [ -n "$requested_config_dir" ]; then
      output_root="$(dirname "$daemon_config_dir")"
      tarball_path="$output_root/${effective_thing_name}-daemon-config.tgz"
    elif [ -n "${TXING_DAEMON_CONFIG_DIR:-}" ]; then
      output_root="$(dirname "$daemon_config_dir")"
      tarball_path="$output_root/${effective_thing_name}-daemon-config.tgz"
    else
      output_root="$(default_output_root)"
      tarball_path="{{project_root}}/config/certs/unit/${effective_thing_name}-daemon-config.tgz"
    fi
    env_file="$daemon_config_dir/daemon.env"
    cert_path="$daemon_config_dir/certificate.pem.crt"
    public_key_path="$daemon_config_dir/public.pem.key"
    private_key_path="$daemon_config_dir/private.pem.key"
    cert_arn_path="$daemon_config_dir/certificate.arn"
    root_ca_path="$daemon_config_dir/AmazonRootCA1.pem"
    daemon_env_template="{{daemon_env_template}}"
    [ -r "$daemon_env_template" ] || { echo "Missing daemon env template: $daemon_env_template" >&2; exit 1; }
    install -d -m 700 "$daemon_config_dir"
    if [ -e "$env_file" ] || [ -e "$cert_path" ] || [ -e "$public_key_path" ] || [ -e "$private_key_path" ] || [ -e "$cert_arn_path" ] || [ -e "$tarball_path" ]; then
      echo "Daemon certificate or env material already exists under $daemon_config_dir." >&2
      echo "Daemon config tarball path: $tarball_path" >&2
      echo "Move or delete those files before issuing a replacement certificate." >&2
      exit 1
    fi
    trust_policy_file=""
    credential_policy_file=""
    cleanup_temp_files() {
      [ -z "$trust_policy_file" ] || rm -f "$trust_policy_file"
      [ -z "$credential_policy_file" ] || rm -f "$credential_policy_file"
    }
    trap cleanup_temp_files EXIT
    trust_policy_file="$(mktemp "${TMPDIR:-/tmp}/txing-daemon-trust.XXXXXX")"
    credential_policy_file="$(mktemp "${TMPDIR:-/tmp}/txing-daemon-credential-policy.XXXXXX")"
    jq -n '{Version: "2012-10-17", Statement: [{Effect: "Allow", Principal: {Service: "credentials.iot.amazonaws.com"}, Action: "sts:AssumeRole"}]}' >"$trust_policy_file"
    jq -n \
      --arg iotShadowArn "arn:${partition}:iot:${TXING_AWS_REGION}:${account_id}:thing/${effective_thing_name}/sparkplug" \
      --arg cloudwatchLogGroupArn "arn:${partition}:logs:${TXING_AWS_REGION}:${account_id}:log-group:${cloudwatch_log_group}" \
      --arg cloudwatchLogStreamArn "arn:${partition}:logs:${TXING_AWS_REGION}:${account_id}:log-group:${cloudwatch_log_group}:log-stream:*" \
      --arg kvsChannelArn "arn:${partition}:kinesisvideo:${TXING_AWS_REGION}:${account_id}:channel/${effective_thing_name}-board-video/*" \
      '{Version: "2012-10-17", Statement: [
        {Sid: "DaemonSparkplugShadowRead", Effect: "Allow", Action: "iot:GetThingShadow", Resource: $iotShadowArn},
        {Sid: "DaemonCloudWatchLogsWrite", Effect: "Allow", Action: ["logs:CreateLogGroup", "logs:CreateLogStream", "logs:DescribeLogStreams", "logs:PutRetentionPolicy", "logs:PutLogEvents"], Resource: [$cloudwatchLogGroupArn, $cloudwatchLogStreamArn]},
        {Sid: "DaemonBoardVideoMaster", Effect: "Allow", Action: ["kinesisvideo:DescribeSignalingChannel", "kinesisvideo:GetSignalingChannelEndpoint", "kinesisvideo:GetIceServerConfig", "kinesisvideo:ConnectAsMaster"], Resource: $kvsChannelArn}
      ]}' \
      >"$credential_policy_file"
    if aws iam get-role --role-name "$daemon_role_name" >/dev/null 2>&1; then
      aws iam update-assume-role-policy --role-name "$daemon_role_name" --policy-document "file://$trust_policy_file"
    else
      aws iam create-role --role-name "$daemon_role_name" --assume-role-policy-document "file://$trust_policy_file" >/dev/null
    fi
    aws iam put-role-policy \
      --role-name "$daemon_role_name" \
      --policy-name txing-daemon-own-thing \
      --policy-document "file://$credential_policy_file"
    daemon_role_arn="$(aws iam get-role --role-name "$daemon_role_name" --query 'Role.Arn' --output text)"
    if aws iot describe-role-alias --role-alias "$iot_role_alias" >/dev/null 2>&1; then
      aws iot update-role-alias --role-alias "$iot_role_alias" --role-arn "$daemon_role_arn" --credential-duration-seconds 3600 >/dev/null
    else
      aws iot create-role-alias --role-alias "$iot_role_alias" --role-arn "$daemon_role_arn" --credential-duration-seconds 3600 >/dev/null
    fi
    curl -fsSL https://www.amazontrust.com/repository/AmazonRootCA1.pem -o "$root_ca_path"
    cert_arn="$(
      aws iot create-keys-and-certificate \
        --set-as-active \
        --certificate-pem-outfile "$cert_path" \
        --public-key-outfile "$public_key_path" \
        --private-key-outfile "$private_key_path" \
        --query certificateArn \
        --output text
    )"
    aws iot attach-policy --policy-name "$daemon_policy_name" --target "$cert_arn"
    aws iot attach-thing-principal \
      --thing-name "$effective_thing_name" \
      --principal "$cert_arn" \
      --thing-principal-type EXCLUSIVE_THING
    printf '%s\n' "$cert_arn" >"$cert_arn_path"
    sed \
      -e "s|[{][{]TXING_THING_ID[}][}]|$effective_thing_name|g" \
      -e "s|[{][{]AWS_REGION[}][}]|$TXING_AWS_REGION|g" \
      -e "s|[{][{]TXING_IOT_ENDPOINT[}][}]|$iot_data_endpoint|g" \
      -e "s|[{][{]TXING_IOT_CREDENTIAL_ENDPOINT[}][}]|$iot_credential_endpoint|g" \
      -e "s|[{][{]TXING_IOT_ROLE_ALIAS[}][}]|$iot_role_alias|g" \
      -e "s|[{][{]TXING_BOARD_VIDEO_CHANNEL_NAME[}][}]|$video_channel_name|g" \
      -e "s|[{][{]TXING_CLOUDWATCH_LOG_GROUP[}][}]|$cloudwatch_log_group|g" \
      "$daemon_env_template" >"$env_file"
    chmod 600 "$env_file" "$cert_path" "$public_key_path" "$private_key_path" "$cert_arn_path"
    chmod 644 "$root_ca_path"
    COPYFILE_DISABLE=1 tar -C "$output_root" -czf "$tarball_path" "$(basename "$daemon_config_dir")"
    chmod 600 "$tarball_path"
    jq -n \
      --arg thingName "$effective_thing_name" \
      --arg policyName "$daemon_policy_name" \
      --arg certificateArn "$cert_arn" \
      --arg certificatePem "$cert_path" \
      --arg publicKey "$public_key_path" \
      --arg privateKey "$private_key_path" \
      --arg certificateArnFile "$cert_arn_path" \
      --arg rootCaFile "$root_ca_path" \
      --arg envFile "$env_file" \
      --arg iotDataEndpoint "$iot_data_endpoint" \
      --arg iotCredentialEndpoint "$iot_credential_endpoint" \
      --arg iotRoleAlias "$iot_role_alias" \
      --arg videoRegion "$TXING_AWS_REGION" \
      --arg videoChannelName "$video_channel_name" \
      --arg cloudWatchLogGroup "$cloudwatch_log_group" \
      --arg daemonRoleName "$daemon_role_name" \
      --arg daemonRoleArn "$daemon_role_arn" \
      --arg configTarball "$tarball_path" \
      '{thingName: $thingName, policyName: $policyName, certificateArn: $certificateArn, certificatePem: $certificatePem, publicKey: $publicKey, privateKey: $privateKey, certificateArnFile: $certificateArnFile, rootCaFile: $rootCaFile, envFile: $envFile, configTarball: $configTarball, iotDataEndpoint: $iotDataEndpoint, iotCredentialEndpoint: $iotCredentialEndpoint, iotRoleAlias: $iotRoleAlias, videoRegion: $videoRegion, videoChannelName: $videoChannelName, cloudWatchLogGroup: $cloudWatchLogGroup, daemonRoleName: $daemonRoleName, daemonRoleArn: $daemonRoleArn}'

role-policy thing_id='':
    #!/bin/sh
    set -eu
    requested_thing_name="{{thing_id}}"
    case "$requested_thing_name" in *=*) echo "Do not pass just recipe arguments as name=value. Use: just unit::daemon::role-policy <thing-id>" >&2; exit 2 ;; esac
    if [ -n "$requested_thing_name" ]; then
      export TXING_THING_ID="$requested_thing_name"
    fi
    . "{{aws_lib}}"
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env device)"
    txing_aws_init
    effective_thing_name="${requested_thing_name:-$THING_NAME}"
    case "$effective_thing_name" in *=*) echo "Invalid Thing ID '$effective_thing_name'. Use positional just arguments, for example: just unit::daemon::role-policy unit-bl95f2" >&2; exit 2 ;; esac
    if ! printf '%s\n' "$effective_thing_name" | grep -E -q '^[a-zA-Z0-9:_-]+$'; then
      echo "Invalid Thing ID '$effective_thing_name'. Allowed characters: letters, digits, colon, underscore, hyphen." >&2
      exit 2
    fi
    account_id="$(aws sts get-caller-identity --query Account --output text)"
    caller_arn="$(aws sts get-caller-identity --query Arn --output text)"
    partition="$(printf '%s\n' "$caller_arn" | cut -d: -f2)"
    daemon_role_name="txing-daemon-$effective_thing_name"
    if ! aws iam get-role --role-name "$daemon_role_name" >/dev/null 2>&1; then
      echo "Daemon IAM role $daemon_role_name does not exist. Run just unit::cert <thing-id> first." >&2
      exit 1
    fi
    cloudwatch_log_group="txing/${TXING_TOWN_ID}/${TXING_RIG_ID}/${effective_thing_name}"
    credential_policy_file="$(mktemp "${TMPDIR:-/tmp}/txing-daemon-credential-policy.XXXXXX")"
    cleanup() {
      rm -f "$credential_policy_file"
    }
    trap cleanup EXIT
    jq -n \
      --arg iotShadowArn "arn:${partition}:iot:${TXING_AWS_REGION}:${account_id}:thing/${effective_thing_name}/sparkplug" \
      --arg cloudwatchLogGroupArn "arn:${partition}:logs:${TXING_AWS_REGION}:${account_id}:log-group:${cloudwatch_log_group}" \
      --arg cloudwatchLogStreamArn "arn:${partition}:logs:${TXING_AWS_REGION}:${account_id}:log-group:${cloudwatch_log_group}:log-stream:*" \
      --arg kvsChannelArn "arn:${partition}:kinesisvideo:${TXING_AWS_REGION}:${account_id}:channel/${effective_thing_name}-board-video/*" \
      '{Version: "2012-10-17", Statement: [
        {Sid: "DaemonSparkplugShadowRead", Effect: "Allow", Action: "iot:GetThingShadow", Resource: $iotShadowArn},
        {Sid: "DaemonCloudWatchLogsWrite", Effect: "Allow", Action: ["logs:CreateLogGroup", "logs:CreateLogStream", "logs:DescribeLogStreams", "logs:PutRetentionPolicy", "logs:PutLogEvents"], Resource: [$cloudwatchLogGroupArn, $cloudwatchLogStreamArn]},
        {Sid: "DaemonBoardVideoMaster", Effect: "Allow", Action: ["kinesisvideo:DescribeSignalingChannel", "kinesisvideo:GetSignalingChannelEndpoint", "kinesisvideo:GetIceServerConfig", "kinesisvideo:ConnectAsMaster"], Resource: $kvsChannelArn}
      ]}' \
      >"$credential_policy_file"
    aws iam put-role-policy \
      --role-name "$daemon_role_name" \
      --policy-name txing-daemon-own-thing \
      --policy-document "file://$credential_policy_file"
    printf 'refreshed daemon IAM role policy\n'
    printf '  thing: %s\n' "$effective_thing_name"
    printf '  role: %s\n' "$daemon_role_name"
    printf '  video region: %s\n' "$TXING_AWS_REGION"

