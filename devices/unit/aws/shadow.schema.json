{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://txing.local/schemas/txing-shadow.schema.json",
  "title": "Txing Thing Shadow Contract v25",
  "description": "Canonical payload shape for txing Thing Shadow updates and snapshots.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "state"
  ],
  "properties": {
    "state": {
      "type": "object",
      "description": "Classic (unnamed) Thing Shadow state object.",
      "additionalProperties": true,
      "properties": {
        "reported": {
          "$ref": "#/$defs/reportedState"
        }
      },
      "required": [
        "reported"
      ]
    },
    "clientToken": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 0
    },
    "timestamp": {
      "type": "integer",
      "minimum": 0
    }
  },
  "$defs": {
    "reportedState": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "redcon": {
          "description": "Rig-derived readiness summary. 4=MCU sleep state or BLE unavailable, 3=MCU wakeup state with BLE reachability but MCP unavailable, 2=BLE and MCP ready but video not ready, 1=BLE and MCP ready with video ready.",
          "type": "integer",
          "minimum": 1,
          "maximum": 4
        },
        "device": {
          "$ref": "#/$defs/reportedDeviceState"
        }
      },
      "required": [
        "redcon"
      ]
    },
    "reportedDeviceState": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "batteryMv": {
          "description": "Rig-reported MCU battery estimate in millivolts.",
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "mcu": {
          "$ref": "#/$defs/reportedMcuState"
        },
        "board": {
          "$ref": "#/$defs/reportedBoardState"
        }
      }
    },
    "reportedMcuState": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "power",
        "online"
      ],
      "properties": {
        "power": {
          "type": "boolean"
        },
        "online": {
          "type": "boolean"
        }
      }
    },
    "reportedBoardState": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "power",
        "wifi"
      ],
      "properties": {
        "power": {
          "type": "boolean"
        },
        "wifi": {
          "$ref": "#/$defs/reportedBoardWifiState"
        }
      }
    },
    "reportedBoardWifiState": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "online"
      ],
      "properties": {
        "online": {
          "type": "boolean"
        },
        "ipv4": {
          "type": [
            "string",
            "null"
          ],
          "format": "ipv4"
        },
        "ipv6": {
          "type": [
            "string",
            "null"
          ],
          "format": "ipv6"
        }
      }
    }
  }
}
