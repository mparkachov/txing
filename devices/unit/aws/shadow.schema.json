{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://txing.local/schemas/txing-shadow.schema.json",
  "title": "Txing Thing Shadow Contract v23",
  "description": "Canonical payload shape for txing Thing Shadow updates and snapshots.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "state"
  ],
  "properties": {
    "state": {
      "type": "object",
      "description": "Classic (unnamed) Thing Shadow state object.",
      "additionalProperties": true,
      "properties": {
        "desired": {
          "$ref": "#/$defs/desiredState"
        },
        "reported": {
          "$ref": "#/$defs/reportedState"
        }
      },
      "anyOf": [
        {
          "required": [
            "desired"
          ]
        },
        {
          "required": [
            "reported"
          ]
        }
      ]
    },
    "clientToken": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 0
    },
    "timestamp": {
      "type": "integer",
      "minimum": 0
    }
  },
  "$defs": {
    "desiredState": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "redcon": {
          "description": "Latest unresolved Sparkplug lifecycle target reflected into shadow by rig.",
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1,
          "maximum": 4
        },
        "board": {
          "description": "Internal-only rig-to-board graceful-halt actuator used during REDCON 4 convergence.",
          "$ref": "#/$defs/desiredBoardState"
        }
      },
      "anyOf": [
        {
          "required": [
            "redcon"
          ]
        },
        {
          "required": [
            "board"
          ]
        }
      ]
    },
    "desiredBoardState": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "power": {
          "description": "Internal-only board graceful-halt request. false asks the board to halt locally before MCU sleep.",
          "type": [
            "boolean",
            "null"
          ]
        }
      }
    },
    "reportedState": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "redcon": {
          "description": "Rig-derived readiness summary. 4=MCU sleep state or BLE unavailable, 3=MCU wakeup state with BLE reachability but MCP unavailable, 2=BLE and MCP ready but video not ready, 1=BLE and MCP ready with video ready.",
          "type": "integer",
          "minimum": 1,
          "maximum": 4
        },
        "batteryMv": {
          "description": "Rig-reported MCU battery estimate in millivolts, surfaced at top-level alongside redcon.",
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "mcu": {
          "$ref": "#/$defs/reportedMcuState"
        },
        "video": {
          "$ref": "#/$defs/reportedVideoState"
        },
        "board": {
          "$ref": "#/$defs/reportedBoardState"
        }
      },
      "anyOf": [
        {
          "required": [
            "batteryMv"
          ]
        },
        {
          "required": [
            "mcu"
          ]
        },
        {
          "required": [
            "video"
          ]
        },
        {
          "required": [
            "board"
          ]
        }
      ]
    },
    "reportedMcuState": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "power",
        "online"
      ],
      "properties": {
        "power": {
          "type": "boolean"
        },
        "online": {
          "type": "boolean"
        }
      }
    },
    "reportedBoardState": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "power",
        "wifi",
        "drive"
      ],
      "properties": {
        "power": {
          "type": "boolean"
        },
        "wifi": {
          "$ref": "#/$defs/reportedBoardWifiState"
        },
        "drive": {
          "$ref": "#/$defs/reportedBoardDriveState"
        }
      }
    },
    "reportedBoardWifiState": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "online"
      ],
      "properties": {
        "online": {
          "type": "boolean"
        },
        "ipv4": {
          "type": [
            "string",
            "null"
          ],
          "format": "ipv4"
        },
        "ipv6": {
          "type": [
            "string",
            "null"
          ],
          "format": "ipv6"
        }
      }
    },
    "reportedBoardDriveState": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "leftSpeed",
        "rightSpeed"
      ],
      "properties": {
        "leftSpeed": {
          "type": "integer",
          "minimum": -100,
          "maximum": 100
        },
        "rightSpeed": {
          "type": "integer",
          "minimum": -100,
          "maximum": 100
        }
      }
    },
    "reportedVideoState": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "serviceId",
        "serverInfo",
        "available",
        "ready",
        "status",
        "transport",
        "codec",
        "viewerConnected",
        "lastError"
      ],
      "properties": {
        "serviceId": {
          "type": "string",
          "enum": [
            "video"
          ]
        },
        "serverInfo": {
          "$ref": "#/$defs/reportedVideoServerInfo"
        },
        "available": {
          "type": "boolean"
        },
        "ready": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": [
            "starting",
            "ready",
            "error",
            "unavailable"
          ]
        },
        "transport": {
          "type": "string",
          "enum": [
            "aws-webrtc"
          ]
        },
        "codec": {
          "$ref": "#/$defs/reportedBoardVideoCodecState"
        },
        "viewerConnected": {
          "type": "boolean"
        },
        "lastError": {
          "type": [
            "string",
            "null"
          ]
        },
        "updatedAtMs": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "topicRoot": {
          "type": "string"
        },
        "descriptorTopic": {
          "type": "string"
        },
        "statusTopic": {
          "type": "string"
        },
        "channelName": {
          "type": "string"
        },
        "region": {
          "type": [
            "string",
            "null"
          ]
        },
        "serverVersion": {
          "type": "string"
        }
      }
    },
    "reportedVideoServerInfo": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "reportedBoardVideoCodecState": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "video"
      ],
      "properties": {
        "video": {
          "enum": [
            "h264",
            null
          ]
        }
      }
    }
  }
}
