{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://txing.local/schemas/txing-sparkplug-shadow.schema.json",
  "title": "Txing Sparkplug Named Shadow Contract v1",
  "description": "Named shadow 'sparkplug' AWS-side materialized Sparkplug view for a txing entity.",
  "type": "object",
  "additionalProperties": true,
  "required": ["state"],
  "properties": {
    "state": {
      "type": "object",
      "additionalProperties": true,
      "required": ["reported"],
      "properties": {
        "reported": {
          "type": "object",
          "additionalProperties": false,
          "required": ["session", "metrics"],
          "properties": {
            "session": {
              "type": "object",
              "additionalProperties": false,
              "required": ["entityKind", "groupId", "online"],
              "properties": {
                "entityKind": {
                  "type": "string",
                  "enum": ["group", "node", "device"]
                },
                "groupId": {
                  "type": "string",
                  "minLength": 1
                },
                "edgeNodeId": {
                  "type": "string",
                  "minLength": 1
                },
                "deviceId": {
                  "type": "string",
                  "minLength": 1
                },
                "messageType": {
                  "type": "string",
                  "enum": ["NBIRTH", "NDATA", "NDEATH", "DBIRTH", "DDATA", "DDEATH"]
                },
                "online": {
                  "type": "boolean"
                },
                "seq": {
                  "type": "integer",
                  "minimum": 0
                },
                "sparkplugTimestamp": {
                  "type": "integer",
                  "minimum": 0
                },
                "observedAt": {
                  "type": "integer",
                  "minimum": 0
                }
              },
              "allOf": [
                {
                  "if": {
                    "properties": {
                      "entityKind": {
                        "const": "node"
                      }
                    }
                  },
                  "then": {
                    "required": ["edgeNodeId", "messageType"]
                  }
                },
                {
                  "if": {
                    "properties": {
                      "entityKind": {
                        "const": "device"
                      }
                    }
                  },
                  "then": {
                    "required": ["edgeNodeId", "deviceId", "messageType"]
                  }
                }
              ]
            },
            "metrics": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      }
    },
    "clientToken": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 0
    },
    "timestamp": {
      "type": "integer",
      "minimum": 0
    }
  }
}
