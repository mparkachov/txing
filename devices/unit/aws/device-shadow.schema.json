{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://txing.local/schemas/txing-device-shadow.schema.json",
  "title": "Txing Device Named Shadow Contract v1",
  "description": "Named shadow 'device' shared device metrics for a txing device.",
  "type": "object",
  "additionalProperties": true,
  "required": ["state"],
  "properties": {
    "state": {
      "type": "object",
      "additionalProperties": true,
      "required": ["reported"],
      "properties": {
        "reported": {
          "type": "object",
          "additionalProperties": false,
          "required": ["batteryMv"],
          "properties": {
            "batteryMv": {
              "description": "Rig-reported MCU battery estimate in millivolts.",
              "type": "integer",
              "minimum": 0,
              "maximum": 10000
            }
          }
        }
      }
    },
    "clientToken": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 0
    },
    "timestamp": {
      "type": "integer",
      "minimum": 0
    }
  }
}
