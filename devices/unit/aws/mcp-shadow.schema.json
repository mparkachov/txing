{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://txing.local/schemas/txing-mcp-shadow.schema.json",
  "title": "Txing MCP Named Shadow Contract v1",
  "description": "Named shadow 'mcp' mirrors board MCP descriptor and status topics.",
  "type": "object",
  "additionalProperties": true,
  "required": ["state"],
  "properties": {
    "state": {
      "type": "object",
      "additionalProperties": true,
      "required": ["reported"],
      "properties": {
        "reported": {
          "type": "object",
          "additionalProperties": true,
          "required": ["descriptor", "status"],
          "properties": {
            "descriptor": {
              "type": ["object", "null"],
              "additionalProperties": true,
              "properties": {
                "serviceId": {
                  "const": "mcp"
                },
                "transport": {
                  "type": "string"
                },
                "descriptorTopic": {
                  "type": "string"
                },
                "statusTopic": {
                  "type": "string"
                },
                "mcpProtocolVersion": {
                  "type": "string"
                },
                "protocolVersion": {
                  "type": "string"
                },
                "serverInfo": {
                  "type": "object",
                  "additionalProperties": true,
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "version": {
                      "type": "string"
                    }
                  }
                },
                "serverVersion": {
                  "type": "string"
                },
                "control": {
                  "type": "object",
                  "additionalProperties": true,
                  "properties": {
                    "mode": {
                      "const": "active"
                    },
                    "activeTtlMs": {
                      "type": "number",
                      "exclusiveMinimum": 0
                    }
                  }
                },
                "transports": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": true,
                    "required": ["type"],
                    "properties": {
                      "type": {
                        "enum": ["mqtt-jsonrpc", "webrtc-datachannel"]
                      },
                      "priority": {
                        "type": "number"
                      }
                    }
                  }
                }
              }
            },
            "status": {
              "type": "object",
              "additionalProperties": true,
              "required": ["serviceId", "available"],
              "properties": {
                "serviceId": {
                  "const": "mcp"
                },
                "available": {
                  "type": "boolean"
                },
                "status": {
                  "type": "string"
                },
                "protocolVersion": {
                  "type": "string"
                },
                "observedAtMs": {
                  "type": "integer",
                  "minimum": 0
                },
                "updatedAtMs": {
                  "type": "integer",
                  "minimum": 0
                },
                "activeControl": {
                  "type": ["object", "null"],
                  "additionalProperties": true,
                  "required": ["sessionId", "transport", "sinceMs", "expiresAtMs", "epoch"],
                  "properties": {
                    "sessionId": {
                      "type": "string"
                    },
                    "actor": {
                      "type": ["string", "null"]
                    },
                    "transport": {
                      "enum": ["mqtt-jsonrpc", "webrtc-datachannel"]
                    },
                    "sinceMs": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "expiresAtMs": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "epoch": {
                      "type": "integer",
                      "minimum": 1
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "clientToken": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 0
    },
    "timestamp": {
      "type": "integer",
      "minimum": 0
    }
  }
}
