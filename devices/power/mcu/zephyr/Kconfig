mainmenu "txing power MCU"

menu "Power MCU"

config POWER_ADV_INTERVAL
	hex "BLE advertising interval in 0.625 ms units"
	range 0x0020 0x4000
	help
	  BLE advertising interval for REDCON idle advertising.

config POWER_ADV_TX_POWER_DBM
	int "BLE advertising TX power in dBm"
	range -46 8
	help
	  Requested advertising transmit power.

config POWER_ADV_CONNECTABLE
	bool "Use connectable advertising"
	help
	  Use connectable advertising so the rig can open REDCON GATT sessions.

config POWER_ADV_SCANNABLE
	bool "Use scannable advertising"
	help
	  Use scannable advertising so the REDCON service UUID can be included in
	  the scan response.

config POWER_ADV_INCLUDE_UUID
	bool "Advertise REDCON service UUID"
	help
	  Include the REDCON service UUID in advertising scan response data.

config POWER_REDCON_CONN_INTERVAL_MS
	int "REDCON connection interval request in ms"
	range 8 4000
	help
	  Connection interval requested when entering REDCON 3 wakeup state.

config POWER_REDCON_CONN_LATENCY
	int "REDCON connection latency request"
	range 0 499
	help
	  Connection latency requested when entering REDCON 3 wakeup state.

config POWER_REDCON_CONN_SUPERVISION_MS
	int "REDCON supervision timeout request in ms"
	range 100 32000
	help
	  Connection supervision timeout requested when entering REDCON 3 wakeup
	  state.

config POWER_REDCON_STATE_NOTIFY_INTERVAL_SECONDS
	int "REDCON state notification interval in seconds"
	range 1 3600
	help
	  Periodic REDCON state notification interval while in REDCON 3 wakeup
	  state.

config POWER_REDCON_IDLE_DISCONNECT_DELAY_MS
	int "REDCON idle disconnect delay in ms"
	range 0 60000
	help
	  Delay before disconnecting after receiving REDCON 4 sleep command.

config POWER_REDCON_BATTERY_ADC_SETTLE_MS
	int "REDCON battery ADC settle delay in ms"
	range 0 60000
	help
	  Delay after enabling battery measurement power before sampling ADC.

endmenu

source "Kconfig.zephyr"
