mainmenu "txing power MCU"

menu "REDCON"

config REDCON_BATTERY_ADC_SETTLE_MS
	int "REDCON battery ADC settle delay in ms"
	range 0 60000
	help
	  Delay after enabling battery measurement power before sampling ADC.

config REDCON_FACTORY_DATA_ADDRESS
	hex "REDCON factory/NVE data address"
	help
	  Flash address containing the REDCON factory/NVE record. The first
	  record version stores the BLE device name used for advertising and
	  the Generic Access device name.

menu "REDCON BLE"

config REDCON_BLE_ADV_INTERVAL
	hex "BLE advertising interval in 0.625 ms units"
	range 0x0020 0x4000
	help
	  BLE advertising interval for REDCON idle advertising.

config REDCON_BLE_ADV_TX_POWER_DBM
	int "BLE advertising TX power in dBm"
	range -46 8
	help
	  Requested advertising transmit power.

config REDCON_BLE_CONN_INTERVAL_MS
	int "REDCON connection interval request in ms"
	range 8 4000
	help
	  Connection interval requested when entering REDCON 3 wakeup state.

config REDCON_BLE_CONN_LATENCY
	int "REDCON connection latency request"
	range 0 499
	help
	  Connection latency requested when entering REDCON 3 wakeup state.

config REDCON_BLE_CONN_SUPERVISION_MS
	int "REDCON supervision timeout request in ms"
	range 100 32000
	help
	  Connection supervision timeout requested when entering REDCON 3 wakeup
	  state.

config REDCON_BLE_STATE_NOTIFY_INTERVAL_SECONDS
	int "REDCON state notification interval in seconds"
	range 1 3600
	help
	  Periodic REDCON state notification interval while in REDCON 3 wakeup
	  state.

config REDCON_BLE_IDLE_STATE_NOTIFY_INTERVAL_SECONDS
	int "REDCON idle state notification interval in seconds"
	range 1 3600
	help
	  Periodic REDCON state notification interval while connected in REDCON 4
	  sleep state.

endmenu
endmenu

source "Kconfig.zephyr"
