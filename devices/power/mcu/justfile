set shell := ["bash", "-eu", "-o", "pipefail", "-c"]
set quiet

mcu_dir := source_directory()
project_root := canonicalize(mcu_dir + "/../../..")
common_mcu_dir := canonicalize(project_root + "/devices/common/mcu")
ncs_dir := common_mcu_dir + "/ncs"
ncs_repo := ncs_dir + "/nrf"
zephyr_base := ncs_dir + "/zephyr"
board := "xiao_nrf54l15/nrf54l15/cpuapp"
build_version := "ncs-v3.3.0"
build_dir := mcu_dir + "/build/ncs-xiao_nrf54l15_cpuapp"
firmware_hex := build_dir + "/zephyr/zephyr/zephyr.hex"
firmware_hex_fallback := build_dir + "/zephyr/zephyr.hex"
nve_script := mcu_dir + "/scripts/redcon_nve.py"
ncs_script := mcu_dir + "/scripts/ncs_power_mcu.py"
nve_hex := build_dir + "/redcon-factory-nve.hex"
nve_address := "0x000f0000"
ncs_python := env_var_or_default("POWER_MCU_NCS_PYTHON", "python3")
openocd_support_dir := zephyr_base + "/boards/seeed/xiao_nrf54l15/support"
openocd_cfg := openocd_support_dir + "/openocd.cfg"

[private]
_ensure-ncs-submodule:
    test -f "{{ ncs_repo }}/west.yml" || { echo "missing NCS sdk-nrf submodule. Run: just power::mcu::submodules" >&2; exit 1; }

[private]
_ensure-openocd:
    test -f "{{ openocd_cfg }}" || { echo "missing NCS Seeed OpenOCD config: {{ openocd_cfg }}. Run: just power::mcu::install" >&2; exit 1; }
    command -v openocd >/dev/null || { echo "missing OpenOCD. Install manually with: brew install open-ocd" >&2; exit 1; }

[private]
_firmware-hex:
    firmware="{{ firmware_hex }}"; \
    if [ ! -f "$firmware" ]; then firmware="{{ firmware_hex_fallback }}"; fi; \
    test -f "$firmware" || { echo "missing firmware hex. Run: just power::mcu::check" >&2; exit 1; }; \
    printf '%s\n' "$firmware"

@submodules:
    git -C "{{ project_root }}" submodule update --init --recursive -- devices/common/mcu/ncs/nrf

@install: submodules
    "{{ ncs_python }}" "{{ ncs_script }}" install

@check: _ensure-ncs-submodule
    "{{ ncs_python }}" "{{ ncs_script }}" check

@build: _ensure-ncs-submodule
    "{{ ncs_python }}" "{{ ncs_script }}" build

@flash: _ensure-openocd
    firmware="$(just --justfile "{{ mcu_dir }}/justfile" _firmware-hex)"; \
    openocd \
      -s "{{ openocd_support_dir }}" \
      -f "{{ openocd_cfg }}" \
      -c init \
      -c "targets nrf54l.cpu" \
      -c "reset init" \
      -c "nrf54l-load $firmware" \
      -c "verify_image $firmware" \
      -c "reset run" \
      -c shutdown

@flash-check: _ensure-openocd
    firmware="$(just --justfile "{{ mcu_dir }}/justfile" _firmware-hex)"; \
    printf '%q ' \
      openocd \
      -s "{{ openocd_support_dir }}" \
      -f "{{ openocd_cfg }}" \
      -c init \
      -c "targets nrf54l.cpu" \
      -c "reset init" \
      -c "nrf54l-load $firmware" \
      -c "verify_image $firmware" \
      -c "reset run" \
      -c shutdown
    printf '\n'

@nve-hex device_name="power-test":
    test -f "{{ nve_script }}" || { echo "missing REDCON NVE script: {{ nve_script }}" >&2; exit 1; }
    mkdir -p "{{ build_dir }}"
    python3 "{{ nve_script }}" write-hex "{{ device_name }}" --address "{{ nve_address }}" --output "{{ nve_hex }}"

@nve-check device_name="power-test": _ensure-openocd
    just --justfile "{{ mcu_dir }}/justfile" nve-hex "{{ device_name }}"
    printf '%q ' \
      openocd \
      -s "{{ openocd_support_dir }}" \
      -f "{{ openocd_cfg }}" \
      -c init \
      -c "targets nrf54l.cpu" \
      -c "reset init" \
      -c "nrf54l-load {{ nve_hex }}" \
      -c "verify_image {{ nve_hex }}" \
      -c "reset run" \
      -c shutdown
    printf '\n'

@nve-flash device_name="power-test": _ensure-openocd
    just --justfile "{{ mcu_dir }}/justfile" nve-hex "{{ device_name }}"
    openocd \
      -s "{{ openocd_support_dir }}" \
      -f "{{ openocd_cfg }}" \
      -c init \
      -c "targets nrf54l.cpu" \
      -c "reset init" \
      -c "nrf54l-load {{ nve_hex }}" \
      -c "verify_image {{ nve_hex }}" \
      -c "reset run" \
      -c shutdown

@paths:
    "{{ ncs_python }}" "{{ ncs_script }}" paths
    echo "board: {{ board }}"
    echo "buildVersion: {{ build_version }}"
    echo "nveScript: {{ nve_script }} exists=$([ -f "{{ nve_script }}" ] && echo 1 || echo 0)"
    echo "nveHex: {{ nve_hex }} exists=$([ -f "{{ nve_hex }}" ] && echo 1 || echo 0)"
    echo "nveAddress: {{ nve_address }}"

@clean:
    "{{ ncs_python }}" "{{ ncs_script }}" clean

@default:
    @just --list
