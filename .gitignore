# Editor settings
.vscode/
.idea/
*.swp
*.swo
*~

# macOS
.DS_Store

# Shared certs directory: keep only public/non-sensitive files in git
/certs/*
!/certs/AmazonRootCA1.pem
!/certs/iot-data-ats.endpoint

# Project-local AWS config: keep examples only
/config/*
!/config/*.example

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
