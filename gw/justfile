set shell := ["bash", "-eu", "-o", "pipefail", "-c"]

gw_dir := source_directory()
python_executable := "python3"
built_gw := gw_dir + "/.venv/bin/gw"
built_gw_sparkplug_cmd := gw_dir + "/.venv/bin/gw-sparkplug-cmd"
built_gw_sparkplug_log := gw_dir + "/.venv/bin/gw-sparkplug-log"
project_root := gw_dir + "/.."
aws_justfile := project_root + "/aws/justfile"
thing_name := "txing"
region := "eu-central-1"
endpoint_file := gw_dir + "/../certs/iot-data-ats.endpoint"
systemd_unit := "/etc/systemd/system/txing-gw.service"

@sync:
    cd "{{gw_dir}}" && uv sync --python "{{python_executable}}" --no-managed-python --no-python-downloads

@build:
    cd "{{gw_dir}}" && uv sync --frozen --no-editable --compile-bytecode --python "{{python_executable}}" --no-managed-python --no-python-downloads --refresh-package gw --reinstall-package gw
    test -x "{{built_gw}}"
    test -x "{{built_gw_sparkplug_cmd}}"
    test -x "{{built_gw_sparkplug_log}}"

@check:
    just --justfile "{{aws_justfile}}" check

@run:
    cd "{{gw_dir}}" && "{{built_gw}}"

@debug:
    cd "{{gw_dir}}" && "{{built_gw}}" --debug

@dev:
    cd "{{gw_dir}}" && uv run gw

@debug-dev:
    cd "{{gw_dir}}" && uv run gw --debug

@wake:
    cd "{{gw_dir}}" && "{{built_gw_sparkplug_cmd}}" --redcon 3 --thing-name "{{thing_name}}"

@sleep:
    cd "{{gw_dir}}" && "{{built_gw_sparkplug_cmd}}" --redcon 4 --thing-name "{{thing_name}}"

@dcmd:
    cd "{{gw_dir}}" && "{{built_gw_sparkplug_log}}" --thing-name "{{thing_name}}" --message-type dcmd

@ddata:
    cd "{{gw_dir}}" && "{{built_gw_sparkplug_log}}" --thing-name "{{thing_name}}" --message-type ddata

@print:
    aws iot-data get-thing-shadow \
      --region "{{region}}" \
      --endpoint-url "https://$(tr -d '\n' < "{{endpoint_file}}")" \
      --thing-name "{{thing_name}}" \
      /dev/stdout | jq '.'

@install-service:
    test -x "{{built_gw}}" || { \
        echo "Missing built gateway executable at {{built_gw}}. Run 'just build' first." >&2; \
        exit 1; \
    }
    sudo systemctl enable --now bluetooth
    run_user="$(id -un)"; printf '%s\n' \
        '[Unit]' \
        'Description=txing gateway' \
        'After=network-online.target bluetooth.target' \
        'Wants=network-online.target bluetooth.target' \
        '' \
        '[Service]' \
        'Type=simple' \
        "User=$run_user" \
        'WorkingDirectory={{gw_dir}}' \
        'Environment=AWS_REGION={{region}}' \
        'ExecStart={{built_gw}}' \
        'Restart=always' \
        'RestartSec=3' \
        '' \
        '[Install]' \
        'WantedBy=multi-user.target' \
        | sudo tee "{{systemd_unit}}" >/dev/null
    sudo systemctl daemon-reload
    sudo systemctl enable --now txing-gw
