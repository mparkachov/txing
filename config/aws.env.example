# Copy this file to `config/aws.env` and edit it for AWS access.
# Keep `config/aws.env` local-only. Secrets remain only in `config/aws.credentials`.

AWS_REGION=eu-central-1
AWS_STACK_NAME=town

# Direct source profile in `config/aws.credentials`.
AWS_SOURCE_PROFILE=town
AWS_TOWN_PROFILE=town
AWS_SHARED_CREDENTIALS_FILE=config/aws.credentials

# Optional selected AWS IoT thing IDs for commands that operate on one instance.
# Enrollment commands print these generated IDs.
# TXING_TOWN_ID=town-xxxxxx
# TXING_RIG_ID=rig-xxxxxx
# TXING_THING_ID=unit-xxxxxx

# Base web/admin environment.
AWS_COGNITO_DOMAIN_PREFIX=town
AWS_ADMIN_EMAIL=admin@example.com
AWS_WEB_APP_URL=https://office.txing.dev

# Rig runtime identity is derived from TXING_RIG_ID by `just _project-aws-env`.
# CLOUDWATCH_LOG_GROUP=
