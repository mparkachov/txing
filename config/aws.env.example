# Copy this file to `config/aws.env` and edit the values for your town/account.
# Keep `config/aws.env`, `config/aws.credentials`, and `config/aws.config` local-only.
# The intended flow is:
# 1. Copy `config/aws.env.example` -> `config/aws.env`
# 2. Copy `config/aws.credentials.example` -> `config/aws.credentials`
# 3. Copy `config/aws.config.example` -> `config/aws.config`
# 4. Put your town account credentials and rig role ARN into those copied files
# 5. Copy `config/rig.env.example` -> `config/rig.env` if you are configuring the rig runtime
# 6. Copy `config/board.env.example` -> `config/board.env` if you are configuring the board runtime
# 7. Run `just aws::check`; production rig startup is supervised by Greengrass
#
# This keeps all rig and AWS CLI configuration inside the project checkout.
# Do not put these credentials in `~/.aws` for the project-local flow.

AWS_REGION=eu-central-1
AWS_STACK_NAME=town

# Used by `just aws::create`, `just aws::update`, `just aws::deploy`, and
# `just aws::create-admin-user` when you omit explicit arguments. This is the
# direct profile for the town AWS account that owns the resources.
AWS_COGNITO_DOMAIN_PREFIX=town
AWS_ADMIN_EMAIL=admin@example.com
AWS_TOWN_PROFILE=town

# Used by legacy/local `rig` runtime, `just rig::check`, `just rig::run`,
# `just rig::wake`, and `just rig::sleep`. Production Greengrass components use
# the AWS IoT token exchange role alias instead of this profile.
AWS_RIG_PROFILE=rig

# Used by device-side runtimes such as the current `unit` board implementation.
# This should assume the stack output role exported for registered device hosts.
AWS_DEVICE_PROFILE=device

# Keep these files inside the repo so a fresh clone only needs local config edits.
AWS_SHARED_CREDENTIALS_FILE=config/aws.credentials
AWS_CONFIG_FILE=config/aws.config

# Rig-local runtime defaults now live in `config/rig.env`.
# Board-local runtime defaults now live in `config/board.env`.
# Keep `config/aws.env` focused on shared AWS/profile configuration.
