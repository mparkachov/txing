# Copy this file to `config/aws.env` and edit it for AWS access.
# Keep `config/aws.env` local-only. Secrets remain only in `config/aws.credentials`.

AWS_REGION=eu-central-1
AWS_STACK_NAME=town

# Direct source profile in `config/aws.credentials`.
AWS_SOURCE_PROFILE=town
AWS_TOWN_PROFILE=town
AWS_SHARED_CREDENTIALS_FILE=config/aws.credentials

# Optional selected AWS IoT thing IDs for commands that operate on one instance.
# Enrollment commands print these generated IDs.
# TXING_TOWN_ID=town-xxxxxx
# TXING_RIG_ID=rig-xxxxxx
# TXING_THING_ID=unit-xxxxxx

# Base web/admin environment.
AWS_COGNITO_DOMAIN_PREFIX=town
AWS_ADMIN_EMAIL=admin@example.com

# Rig runtime identity is derived from TXING_RIG_ID by `just _project-aws-env`.
# CLOUDWATCH_LOG_GROUP=

# Device board runtime config. THING_NAME is derived from TXING_THING_ID.
BOARD_VIDEO_REGION=$AWS_REGION
BOARD_VIDEO_SENDER_COMMAND=/home/user/txing/devices/unit/board/kvs_master/build/txing-board-kvs-master
KVS_DUALSTACK_ENDPOINTS=ON

# DRV8835 hardware ceiling and stock shield wiring.
BOARD_DRIVE_RAW_MAX_SPEED=480
BOARD_DRIVE_PWM_HZ=20000
BOARD_DRIVE_PWM_CHIP=0
BOARD_DRIVE_LEFT_PWM_CHANNEL=0
BOARD_DRIVE_RIGHT_PWM_CHANNEL=1
BOARD_DRIVE_GPIO_CHIP=0
BOARD_DRIVE_LEFT_DIR_GPIO=5
BOARD_DRIVE_RIGHT_DIR_GPIO=6
BOARD_DRIVE_LEFT_INVERTED=false
BOARD_DRIVE_RIGHT_INVERTED=false

# `cmd_vel` percent mapping range only. `board-motor-raw` still accepts the full
# [-BOARD_DRIVE_RAW_MAX_SPEED, BOARD_DRIVE_RAW_MAX_SPEED] range directly.
BOARD_DRIVE_CMD_RAW_MIN_SPEED=50
BOARD_DRIVE_CMD_RAW_MAX_SPEED=250
