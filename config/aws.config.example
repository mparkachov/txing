# Copy this file to `config/aws.config`.
# `town` is the direct profile for the AWS account that owns the resources.
# `rig` is for legacy/local foreground commands. Production Greengrass
# components use the stack output `GreengrassTokenExchangeRoleAlias`.
# The local profile assumes `RigRuntimeRoleArn` using `town` as its source credentials.
# `device` assumes the runtime role created by the stack output for registered device hosts
# using `town` as its source credentials.

[profile town]
region = eu-central-1

[profile rig]
region = eu-central-1
role_arn = arn:aws:iam::123456789012:role/town-rig-runtime
source_profile = town

[profile device]
region = eu-central-1
role_arn = arn:aws:iam::123456789012:role/town-device-runtime
source_profile = town
