# Copy this file to `config/aws.credentials`.
# Fill in the `town` profile with access keys from the town AWS account.
# The same town access keys are used directly by `just aws-town ...` and as the
# source credentials for the `rig` assume-role profile in `config/aws.config`.

[town]
aws_access_key_id = REPLACE_ME
aws_secret_access_key = REPLACE_ME
