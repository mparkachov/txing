# Copy this file to `config/rig.env` for rig-local runtime defaults.
# Keep `config/rig.env` local-only alongside the other files in `config/`.
#
# This file is loaded after `config/aws.env`, so rig-local values here
# override any legacy rig settings that may still exist in `config/aws.env`.

RIG_NAME=rig
SPARKPLUG_GROUP_ID=town
SPARKPLUG_EDGE_NODE_ID=rig
CLOUDWATCH_LOG_GROUP=/town/rig/txing
