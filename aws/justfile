@create-admin-user AdminEmail AdminPassword stack_name=stack_name region=region profile=profile:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"

    if [ -z "{{region}}" ]; then
      echo "region is empty and no default AWS region is configured. Set region=<aws-region>" >&2
      exit 1
    fi

    aws_flags=(--region "{{region}}")
    if [ -n "{{profile}}" ]; then
      aws_flags+=(--profile "{{profile}}")
    fi

    user_pool_id="$(aws cloudformation describe-stacks \
      --stack-name "{{stack_name}}" \
      "${aws_flags[@]}" \
      --query "Stacks[0].Outputs[?OutputKey=='WebCognitoUserPoolId'].OutputValue | [0]" \
      --output text)"

    if [ "$user_pool_id" = "None" ]; then
      echo "WebCognitoUserPoolId output not found in stack {{stack_name}}." >&2
      exit 1
    fi

    if aws cognito-idp admin-get-user \
      --user-pool-id "$user_pool_id" \
      --username "{{AdminEmail}}" \
      "${aws_flags[@]}" >/dev/null 2>&1; then
      echo "Admin user already exists, updating password."
    else
      aws cognito-idp admin-create-user \
        --user-pool-id "$user_pool_id" \
        --username "{{AdminEmail}}" \
        --user-attributes Name=email,Value="{{AdminEmail}}" Name=email_verified,Value=true \
        --message-action SUPPRESS \
        "${aws_flags[@]}" >/dev/null
      echo "Admin user created."
    fi

    aws cognito-idp admin-set-user-password \
      --user-pool-id "$user_pool_id" \
      --username "{{AdminEmail}}" \
      --password "{{AdminPassword}}" \
      --permanent \
      "${aws_flags[@]}" >/dev/null

    echo "Admin user password set."

@check thing_name=thing_name rig_thing_name=rig_thing_name policy_name=policy_name log_group_name=log_group_name region=region profile=profile cert_dir=cert_dir endpoint_file=endpoint_file ca_file=ca_file cert_basename='' cert_arn_file='':
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"

    if [ -z "{{region}}" ]; then
      echo "region is empty and no default AWS region is configured. Set region=<aws-region>" >&2
      exit 1
    fi

    aws_flags=(--region "{{region}}")
    if [ -n "{{profile}}" ]; then
      aws_flags+=(--profile "{{profile}}")
    fi

    cert_basename="{{cert_basename}}"
    if [ -z "$cert_basename" ]; then
      cert_basename="{{thing_name}}"
    fi

    cert_arn_file="{{cert_arn_file}}"
    if [ -z "$cert_arn_file" ]; then
      cert_arn_file="{{cert_dir}}/${cert_basename}.cert.arn"
    fi

    cert_file="{{cert_dir}}/${cert_basename}.cert.pem"
    private_key_file="{{cert_dir}}/${cert_basename}.private.key"

    failures=0

    check_tool() {
      local tool="$1"
      if command -v "$tool" >/dev/null 2>&1; then
        echo "ok: tool '$tool' is installed"
      else
        echo "fail: tool '$tool' is not installed"
        failures=$((failures + 1))
      fi
    }

    check_cmd() {
      local label="$1"
      shift
      if "$@" >/dev/null 2>&1; then
        echo "ok: $label"
      else
        echo "fail: $label"
        failures=$((failures + 1))
      fi
    }

    check_file() {
      local path="$1"
      local label="$2"
      if [ -s "$path" ]; then
        echo "ok: $label ($path)"
      else
        echo "fail: $label missing or empty ($path)"
        failures=$((failures + 1))
      fi
    }

    echo "Checking local tools..."
    check_tool aws
    check_tool jq
    check_tool uv
    check_tool just
    check_tool openssl

    echo "Checking AWS identity..."
    check_cmd "STS caller identity" aws sts get-caller-identity "${aws_flags[@]}"
    check_cmd "IoT DescribeThing on {{thing_name}}" aws iot describe-thing --thing-name "{{thing_name}}" "${aws_flags[@]}"
    check_cmd "IoT DescribeThing on {{rig_thing_name}}" aws iot describe-thing --thing-name "{{rig_thing_name}}" "${aws_flags[@]}"

    thing_indexing_mode="$(
      aws iot get-indexing-configuration \
        "${aws_flags[@]}" \
        --query "thingIndexingConfiguration.thingIndexingMode" \
        --output text 2>/dev/null || true
    )"
    thing_connectivity_indexing_mode="$(
      aws iot get-indexing-configuration \
        "${aws_flags[@]}" \
        --query "thingIndexingConfiguration.thingConnectivityIndexingMode" \
        --output text 2>/dev/null || true
    )"
    if [ "$thing_indexing_mode" = "REGISTRY" ] && [ "$thing_connectivity_indexing_mode" = "OFF" ]; then
      echo "ok: AWS IoT fleet indexing is enabled in REGISTRY mode"
    else
      echo "fail: AWS IoT fleet indexing is not configured as REGISTRY/OFF"
      failures=$((failures + 1))
    fi

    indexed_rig="$(
      aws iot search-index \
        --index-name "{{thing_index_name}}" \
        --query-string "thingName:{{rig_thing_name}}" \
        "${aws_flags[@]}" \
        --query "things[0].thingName" \
        --output text 2>/dev/null || true
    )"
    if [ "$indexed_rig" = "{{rig_thing_name}}" ]; then
      echo "ok: AWS IoT SearchIndex can query indexed things"
    else
      echo "fail: AWS IoT SearchIndex did not return thing {{rig_thing_name}}"
      failures=$((failures + 1))
    fi

    if assigned_query="$(
      aws iot search-index \
        --index-name "{{thing_index_name}}" \
        --query-string "attributes.rig:{{rig_thing_name}}" \
        "${aws_flags[@]}" 2>/dev/null
    )"; then
      assigned_count="$(printf '%s' "$assigned_query" | jq '.things | length')"
      echo "ok: Fleet index query by attributes.rig succeeded ($assigned_count assigned thing(s) for {{rig_thing_name}})"
    else
      echo "fail: Fleet index query by attributes.rig failed"
      failures=$((failures + 1))
    fi

    log_group_found="$(
      aws logs describe-log-groups \
        --log-group-name-prefix "{{log_group_name}}" \
        "${aws_flags[@]}" \
        --query "logGroups[?logGroupName=='{{log_group_name}}'].logGroupName | [0]" \
        --output text 2>/dev/null || true
    )"
    if [ "$log_group_found" = "{{log_group_name}}" ]; then
      echo "ok: CloudWatch log group {{log_group_name}} exists"
    else
      echo "fail: CloudWatch log group {{log_group_name}} not found"
      failures=$((failures + 1))
    fi

    check_stream="aws-check-$(date -u +%Y%m%dT%H%M%SZ)-$$"
    check_cmd \
      "CloudWatch CreateLogStream on {{log_group_name}}" \
      aws logs create-log-stream \
      --log-group-name "{{log_group_name}}" \
      --log-stream-name "$check_stream" \
      "${aws_flags[@]}"

    log_event_ts_ms="$(( $(date +%s) * 1000 ))"
    check_cmd \
      "CloudWatch PutLogEvents on {{log_group_name}}" \
      aws logs put-log-events \
      --log-group-name "{{log_group_name}}" \
      --log-stream-name "$check_stream" \
      --log-events "timestamp=${log_event_ts_ms},message=txing-aws-check" \
      "${aws_flags[@]}"

    echo "Checking local AWS IoT client certificate artifacts..."
    check_file "$cert_file" "AWS IoT client certificate file"
    check_file "$private_key_file" "AWS IoT client private key file"
    check_file "{{ca_file}}" "Root CA file"
    check_file "{{endpoint_file}}" "IoT endpoint file"
    check_file "$cert_arn_file" "Certificate ARN file"

    cert_arn=""
    cert_id=""
    if [ -s "$cert_arn_file" ]; then
      cert_arn="$(tr -d '\r\n' < "$cert_arn_file")"
      cert_id="${cert_arn##*/}"
    fi

    if [ -s "$cert_file" ]; then
      check_cmd "AWS IoT client certificate file parses" openssl x509 -in "$cert_file" -noout
    fi
    if [ -s "$private_key_file" ]; then
      check_cmd "AWS IoT client private key parses" openssl pkey -in "$private_key_file" -noout
    fi
    endpoint_value=""
    if [ -s "{{endpoint_file}}" ]; then
      endpoint_value="$(tr -d '\r\n' < "{{endpoint_file}}")"
      if [ -n "$endpoint_value" ]; then
        echo "ok: IoT endpoint file contains endpoint"
      else
        echo "fail: IoT endpoint file is empty"
        failures=$((failures + 1))
      fi
    fi

    if [ -n "$cert_id" ]; then
      cert_status="$(
        aws iot describe-certificate \
          --certificate-id "$cert_id" \
          "${aws_flags[@]}" \
          --query "certificateDescription.status" \
          --output text 2>/dev/null || true
      )"
      if [ -z "$cert_status" ] || [ "$cert_status" = "None" ]; then
        echo "warn: Could not verify certificate status via AWS API (insufficient permission or missing cert)"
      elif [ "$cert_status" = "ACTIVE" ]; then
        echo "ok: Certificate is ACTIVE"
      else
        echo "fail: Certificate status is '$cert_status' (expected ACTIVE)"
        failures=$((failures + 1))
      fi

      principals="$(
        aws iot list-thing-principals \
          --thing-name "{{thing_name}}" \
          "${aws_flags[@]}" \
          --query principals \
          --output text 2>/dev/null || true
      )"
      if [ -z "$principals" ] || [ "$principals" = "None" ]; then
        echo "warn: Could not verify thing principal attachment via AWS API"
      elif printf '%s\n' "$principals" | tr '\t' '\n' | grep -Fx "$cert_arn" >/dev/null; then
        echo "ok: Certificate attached to thing {{thing_name}}"
      else
        echo "fail: Certificate is not attached to thing {{thing_name}}"
        failures=$((failures + 1))
      fi

      attached_policies="$(
        aws iot list-attached-policies \
          --target "$cert_arn" \
          "${aws_flags[@]}" \
          --query "policies[].policyName" \
          --output text 2>/dev/null || true
      )"
      if [ -z "$attached_policies" ] || [ "$attached_policies" = "None" ]; then
        echo "warn: Could not verify certificate policy attachment via AWS API"
      elif printf '%s\n' "$attached_policies" | tr '\t' '\n' | grep -Fx "{{policy_name}}" >/dev/null; then
        echo "ok: Policy {{policy_name}} attached to certificate"
      else
        echo "fail: Policy {{policy_name}} is not attached to certificate"
        failures=$((failures + 1))
      fi
    else
      echo "fail: Could not parse certificate ARN from $cert_arn_file"
      failures=$((failures + 1))
    fi

    if [ "$failures" -ne 0 ]; then
      echo "AWS/device check failed with $failures issue(s)."
      exit 1
    fi
    echo "AWS/device check passed. Shared AWS IoT client prerequisites look good."

@assign-rig thing_name rig_name=rig_thing_name region=region profile=profile ble_device_id='':
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"

    if [ -z "{{region}}" ]; then
      echo "region is empty and no default AWS region is configured. Set region=<aws-region>" >&2
      exit 1
    fi

    aws_flags=(--region "{{region}}")
    if [ -n "{{profile}}" ]; then
      aws_flags+=(--profile "{{profile}}")
    fi

    attribute_payload="$(
      jq -nc \
        --arg rig "{{rig_name}}" \
        --arg ble_device_id "{{ble_device_id}}" \
        'if $ble_device_id == "" then
           {attributes: {rig: $rig}, merge: true}
         else
           {attributes: {rig: $rig, bleDeviceId: $ble_device_id}, merge: true}
         end'
    )"

    aws iot update-thing \
      --thing-name "{{thing_name}}" \
      --attribute-payload "$attribute_payload" \
      "${aws_flags[@]}"

    aws iot describe-thing \
      --thing-name "{{thing_name}}" \
      "${aws_flags[@]}" \
      --query "{thingName: thingName, rig: attributes.rig, bleDeviceId: attributes.bleDeviceId, version: version}" \
      --output table

@things-for-rig rig_name=rig_thing_name region=region profile=profile:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"

    if [ -z "{{region}}" ]; then
      echo "region is empty and no default AWS region is configured. Set region=<aws-region>" >&2
      exit 1
    fi

    aws_flags=(--region "{{region}}")
    if [ -n "{{profile}}" ]; then
      aws_flags+=(--profile "{{profile}}")
    fi

    aws iot search-index \
      --index-name "{{thing_index_name}}" \
      --query-string "attributes.rig:{{rig_name}}" \
      "${aws_flags[@]}" \
      --query "things[].{thingName: thingName, rig: attributes.rig, bleDeviceId: attributes.bleDeviceId}" \
      --output table

@shadow thing_name=thing_name region=region profile=profile endpoint_file=endpoint_file iot_data_endpoint=iot_data_endpoint:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"

    if [ -z "{{region}}" ]; then
      echo "region is empty and no default AWS region is configured. Set region=<aws-region>" >&2
      exit 1
    fi

    aws_flags=(--region "{{region}}")
    if [ -n "{{profile}}" ]; then
      aws_flags+=(--profile "{{profile}}")
    fi

    endpoint="{{iot_data_endpoint}}"
    if [ -z "$endpoint" ] && [ -s "{{endpoint_file}}" ]; then
      endpoint="$(tr -d '\r\n' < "{{endpoint_file}}")"
    fi
    if [ -z "$endpoint" ]; then
      endpoint="$(aws iot describe-endpoint --endpoint-type iot:Data-ATS "${aws_flags[@]}" --query endpointAddress --output text)"
    fi

    aws iot-data get-thing-shadow \
      --endpoint-url "https://$endpoint" \
      --thing-name "{{thing_name}}" \
      "${aws_flags[@]}" \
      /dev/stdout | jq '.'

@shadow-reset thing_name=thing_name region=region profile=profile endpoint_file=endpoint_file default_shadow_file=default_shadow_file iot_data_endpoint=iot_data_endpoint:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"

    if [ -z "{{region}}" ]; then
      echo "region is empty and no default AWS region is configured. Set region=<aws-region>" >&2
      exit 1
    fi
    if [ ! -f "{{default_shadow_file}}" ]; then
      echo "shadow reset payload {{default_shadow_file}} not found" >&2
      exit 1
    fi

    aws_flags=(--region "{{region}}")
    if [ -n "{{profile}}" ]; then
      aws_flags+=(--profile "{{profile}}")
    fi

    endpoint="{{iot_data_endpoint}}"
    if [ -z "$endpoint" ] && [ -s "{{endpoint_file}}" ]; then
      endpoint="$(tr -d '\r\n' < "{{endpoint_file}}")"
    fi
    if [ -z "$endpoint" ]; then
      endpoint="$(aws iot describe-endpoint --endpoint-type iot:Data-ATS "${aws_flags[@]}" --query endpointAddress --output text)"
    fi

    delete_output=""
    if ! delete_output="$(
      aws iot-data delete-thing-shadow \
        --endpoint-url "https://$endpoint" \
        --thing-name "{{thing_name}}" \
        "${aws_flags[@]}" \
        /dev/null 2>&1
    )"; then
      if ! printf '%s\n' "$delete_output" | grep -F "ResourceNotFoundException" >/dev/null; then
        printf '%s\n' "$delete_output" >&2
        exit 1
      fi
    fi

    aws iot-data update-thing-shadow \
      --endpoint-url "https://$endpoint" \
      --thing-name "{{thing_name}}" \
      --payload "fileb://{{default_shadow_file}}" \
      "${aws_flags[@]}" \
      /dev/stdout | jq '.'

@cert thing_name=thing_name policy_name=policy_name region=region profile=profile cert_dir=cert_dir cert_basename='' cert_arn_file='':
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"

    if [ -z "{{region}}" ]; then
      echo "region is empty and no default AWS region is configured. Set region=<aws-region>" >&2
      exit 1
    fi

    aws_flags=(--region "{{region}}")
    if [ -n "{{profile}}" ]; then
      aws_flags+=(--profile "{{profile}}")
    fi

    cert_basename="{{cert_basename}}"
    if [ -z "$cert_basename" ]; then
      cert_basename="{{thing_name}}"
    fi

    cert_arn_file="{{cert_arn_file}}"
    if [ -z "$cert_arn_file" ]; then
      cert_arn_file="{{cert_dir}}/${cert_basename}.cert.arn"
    fi

    mkdir -p "{{cert_dir}}"
    if [ -f "$cert_arn_file" ]; then
      echo "$cert_arn_file already exists. Reuse this certificate or delete the file to issue a new one."
      exit 0
    fi

    cert_arn="$(
      aws iot create-keys-and-certificate \
        --set-as-active \
        --certificate-pem-outfile "{{cert_dir}}/${cert_basename}.cert.pem" \
        --public-key-outfile "{{cert_dir}}/${cert_basename}.public.key" \
        --private-key-outfile "{{cert_dir}}/${cert_basename}.private.key" \
        "${aws_flags[@]}" \
        --query certificateArn \
        --output text
    )"
    echo "$cert_arn" | tee "$cert_arn_file"
    aws iot attach-policy --policy-name "{{policy_name}}" --target "$cert_arn" "${aws_flags[@]}"
    aws iot attach-thing-principal --thing-name "{{thing_name}}" --principal "$cert_arn" "${aws_flags[@]}"
    echo "Certificate ARN saved to $cert_arn_file"

@endpoint region=region profile=profile cert_dir=cert_dir endpoint_file=endpoint_file:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"

    if [ -z "{{region}}" ]; then
      echo "region is empty and no default AWS region is configured. Set region=<aws-region>" >&2
      exit 1
    fi

    aws_flags=(--region "{{region}}")
    if [ -n "{{profile}}" ]; then
      aws_flags+=(--profile "{{profile}}")
    fi

    mkdir -p "{{cert_dir}}"
    aws iot describe-endpoint \
      --endpoint-type iot:Data-ATS \
      "${aws_flags[@]}" \
      --query endpointAddress \
      --output text | tee "{{endpoint_file}}"

@ca cert_dir=cert_dir ca_file=ca_file ca_url=ca_url:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"

    mkdir -p "{{cert_dir}}"
    curl -fsSL "{{ca_url}}" -o "{{ca_file}}"
    echo "Root CA saved to {{ca_file}}"

@init-shadow thing_name=thing_name region=region profile=profile cert_dir=cert_dir default_shadow_file=default_shadow_file shadow_response_file='' iot_data_endpoint=iot_data_endpoint:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"

    if [ -z "{{region}}" ]; then
      echo "region is empty and no default AWS region is configured. Set region=<aws-region>" >&2
      exit 1
    fi

    aws_flags=(--region "{{region}}")
    if [ -n "{{profile}}" ]; then
      aws_flags+=(--profile "{{profile}}")
    fi

    shadow_response_file="{{shadow_response_file}}"
    if [ -z "$shadow_response_file" ]; then
      shadow_response_file="{{cert_dir}}/{{thing_name}}.shadow-response.json"
    fi

    mkdir -p "{{cert_dir}}"
    endpoint="{{iot_data_endpoint}}"
    if [ -z "$endpoint" ]; then
      endpoint="$(aws iot describe-endpoint --endpoint-type iot:Data-ATS "${aws_flags[@]}" --query endpointAddress --output text)"
    fi

    aws iot-data update-thing-shadow \
      --endpoint-url "https://$endpoint" \
      --thing-name "{{thing_name}}" \
      --payload "fileb://{{default_shadow_file}}" \
      "${aws_flags[@]}" \
      "$shadow_response_file"
    echo "Shadow initialized from {{default_shadow_file}}"

@bootstrap CognitoDomainPrefix AdminEmail stack_name=stack_name template_file=template_file thing_name=thing_name rig_thing_name=rig_thing_name town_thing_name=town_thing_name policy_name=policy_name region=region profile=profile cert_dir=cert_dir cert_basename='' cert_arn_file='' endpoint_file=endpoint_file ca_file=ca_file ca_url=ca_url default_shadow_file=default_shadow_file default_rig_shadow_file=default_rig_shadow_file default_town_shadow_file=default_town_shadow_file shadow_response_file='' iot_data_endpoint=iot_data_endpoint:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"

    just --justfile "{{aws_dir}}/justfile" deploy \
      "{{CognitoDomainPrefix}}" \
      "{{AdminEmail}}" \
      "{{stack_name}}" \
      "{{template_file}}" \
      "{{region}}" \
      "{{profile}}"
    just --justfile "{{aws_dir}}/justfile" cert \
      "{{thing_name}}" \
      "{{policy_name}}" \
      "{{region}}" \
      "{{profile}}" \
      "{{cert_dir}}" \
      "{{cert_basename}}" \
      "{{cert_arn_file}}"
    just --justfile "{{aws_dir}}/justfile" endpoint \
      "{{region}}" \
      "{{profile}}" \
      "{{cert_dir}}" \
      "{{endpoint_file}}"
    just --justfile "{{aws_dir}}/justfile" ca \
      "{{cert_dir}}" \
      "{{ca_file}}" \
      "{{ca_url}}"
    just --justfile "{{aws_dir}}/justfile" init-shadow \
      "{{thing_name}}" \
      "{{region}}" \
      "{{profile}}" \
      "{{cert_dir}}" \
      "{{default_shadow_file}}" \
      "{{shadow_response_file}}" \
      "{{iot_data_endpoint}}"
    just --justfile "{{aws_dir}}/justfile" init-shadow \
      "{{rig_thing_name}}" \
      "{{region}}" \
      "{{profile}}" \
      "{{cert_dir}}" \
      "{{default_rig_shadow_file}}" \
      "" \
      "{{iot_data_endpoint}}"
    just --justfile "{{aws_dir}}/justfile" init-shadow \
      "{{town_thing_name}}" \
      "{{region}}" \
      "{{profile}}" \
      "{{cert_dir}}" \
      "{{default_town_shadow_file}}" \
      "" \
      "{{iot_data_endpoint}}"
