set shell := ["bash", "-eu", "-o", "pipefail", "-c"]
set quiet := true

rig_dir := source_directory()
project_root := rig_dir + "/.."
root_justfile := project_root + "/justfile"
greengrass_lite_dir := rig_dir + "/greengrass-lite"
greengrass_lite_build_dir := greengrass_lite_dir + "/build"
greengrass_lite_target := "greengrass-lite.target"
greengrass_core_units := "ggl.core.ggconfigd.service ggl.core.ggipcd.service ggl.core.iotcored.service ggl.core.tesd.service ggl.aws.greengrass.TokenExchangeService.service ggl.core.ggdeploymentd.service ggl.core.gg-fleet-statusd.service ggl.core.ggpubsubd.service ggl.core.gghealthd.service"
greengrass_core_sockets := "ggl.gg_config.socket ggl.gg_deployment.socket ggl.gg_fleet_status.socket ggl.aws_iot_mqtt.socket ggl.aws_iot_tes.socket ggl.gg_pubsub.socket ggl.ipc_component.socket ggl.gg-ipc.socket.socket ggl.gg_health.socket"
greengrass_warning_log_units := "ggl.core.ggipcd.service ggl.core.iotcored.service"
shared_raspi_rig_component_units := "ggl.dev.txing.rig.SparkplugManager.service ggl.dev.txing.rig.BleConnectivity.service"
raspi_rig_component_units := shared_raspi_rig_component_units
aws_rig_component_units := "ggl.dev.txing.rig.SparkplugManager.service ggl.dev.txing.rig.AwsConnectivity.service"
local_run_dir := rig_dir + "/run/local"
local_pubsub_socket := local_run_dir + "/pubsub.sock"
default_greengrass_lite_repository := env_var_or_default("TXING_RIG_GREENGRASS_LITE_REPOSITORY", "https://github.com/aws-greengrass/aws-greengrass-lite.git")
default_greengrass_lite_ref := env_var_or_default("TXING_RIG_GREENGRASS_LITE_REF", "main")
thing_name := "unit-local"
region := ""
aws_profile := ""
aws_shared_credentials_file := ""

[positional-arguments]
aws *args:
    #!/usr/bin/env bash
    set -euo pipefail
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig)"
    command aws "$@"

check rig_id='' cloudwatch_log_group='' region=region aws_profile=aws_profile aws_shared_credentials_file=aws_shared_credentials_file:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ -n "{{rig_id}}" ]; then
      export TXING_RIG_ID="{{rig_id}}"
    fi
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig "{{region}}" "{{aws_profile}}" "" "" "" "{{aws_shared_credentials_file}}")"
    region="$AWS_REGION"
    profile="$AWS_SELECTED_PROFILE"
    aws_flags=(--region "$region")
    if [ -n "$profile" ]; then
      aws_flags+=(--profile "$profile")
    fi
    rig_name="$RIG_NAME"
    selected_rig_type="$RIG_TYPE"
    sparkplug_group_id="$SPARKPLUG_GROUP_ID"
    sparkplug_edge_node_id="$SPARKPLUG_EDGE_NODE_ID"
    cloudwatch_log_group="$CLOUDWATCH_LOG_GROUP"
    if [ -n "{{cloudwatch_log_group}}" ]; then
      cloudwatch_log_group="{{cloudwatch_log_group}}"
    fi
    failures=0
    fail_check() {
      echo "fail: $*" >&2
      failures=$((failures + 1))
    }
    if [ "$rig_name" != "$TXING_RIG_ID" ]; then
      fail_check "RIG_NAME=$rig_name must match TXING_RIG_ID=$TXING_RIG_ID"
    else
      echo "ok: RIG_NAME matches TXING_RIG_ID ($rig_name)"
    fi
    if [ "$sparkplug_group_id" != "$TXING_TOWN_ID" ]; then
      fail_check "SPARKPLUG_GROUP_ID=$sparkplug_group_id must match TXING_TOWN_ID=$TXING_TOWN_ID"
    else
      echo "ok: SPARKPLUG_GROUP_ID matches TXING_TOWN_ID ($sparkplug_group_id)"
    fi
    if [ "$sparkplug_edge_node_id" != "$TXING_RIG_ID" ]; then
      fail_check "SPARKPLUG_EDGE_NODE_ID=$sparkplug_edge_node_id must match TXING_RIG_ID=$TXING_RIG_ID"
    else
      echo "ok: SPARKPLUG_EDGE_NODE_ID matches TXING_RIG_ID ($sparkplug_edge_node_id)"
    fi
    case "$selected_rig_type" in
      raspi|cloud)
        echo "ok: configured RIG_TYPE=$selected_rig_type"
        ;;
      *)
        fail_check "unsupported RIG_TYPE=$selected_rig_type; supported rig types: raspi, cloud"
        ;;
    esac
    check_enabled_active_service() {
      local service="$1"
      if ! command -v systemctl >/dev/null 2>&1; then
        fail_check "systemctl is required to verify host service $service"
        return
      fi
      if ! systemctl cat "$service" >/dev/null 2>&1; then
        fail_check "required host service $service is not installed"
        return
      fi
      if ! systemctl is-enabled --quiet "$service"; then
        fail_check "required host service $service is not enabled"
      else
        echo "ok: host service $service is enabled"
      fi
      if ! systemctl is-active --quiet "$service"; then
        fail_check "required host service $service is not active"
      else
        echo "ok: host service $service is active"
      fi
    }
    case "$selected_rig_type" in
      raspi)
        check_enabled_active_service bluetooth.service
        ;;
      cloud)
        echo "ok: rig type cloud has no extra host service prerequisites"
        ;;
    esac
    if [ "$failures" -ne 0 ]; then
      echo "rig configuration check failed with $failures issue(s)." >&2
      exit 1
    fi
    cert_dir="{{project_root}}/config/certs/rig"
    cert_path="$cert_dir/rig.cert.pem"
    private_key_path="$cert_dir/rig.private.key"
    cert_arn_path="$cert_dir/rig.cert.arn"
    root_ca_path="$cert_dir/AmazonRootCA1.pem"
    for required_file in "$cert_path" "$private_key_path" "$cert_arn_path"; do
      if [ ! -f "$required_file" ]; then
        echo "fail: missing rig certificate material $required_file. Run 'just aws::cert'." >&2
        exit 1
      fi
    done
    if [ ! -f "$root_ca_path" ]; then
      install -d -m 700 "$cert_dir"
      curl -fsSL https://www.amazontrust.com/repository/AmazonRootCA1.pem -o "$root_ca_path"
      chmod 644 "$root_ca_path"
    fi

    uv run --project "{{project_root}}/shared/aws/python" \
      python -m aws.check \
      --scope rig \
      --rig-id "$TXING_RIG_ID" \
      --log-group-name "$cloudwatch_log_group"

    rig_thing_name="$TXING_RIG_ID"
    registered_rig_type="$(
      aws iot describe-thing \
        --thing-name "$rig_thing_name" \
        "${aws_flags[@]}" \
        --query 'thingTypeName' \
        --output text
    )"
    if [ -z "$registered_rig_type" ] || [ "$registered_rig_type" = "None" ]; then
      echo "fail: rig thing $rig_thing_name is missing required ThingTypeName" >&2
      exit 1
    fi
    if [ "$registered_rig_type" != "$selected_rig_type" ]; then
      echo "fail: rig thing $rig_thing_name has ThingTypeName=$registered_rig_type but resolved RIG_TYPE=$selected_rig_type" >&2
      exit 1
    fi
    echo "ok: rig thing $rig_thing_name has ThingTypeName=$registered_rig_type"
    cert_arn="$(tr -d '[:space:]' <"$cert_arn_path")"
    if [ -z "$cert_arn" ]; then
      echo "fail: rig certificate ARN file is empty: $cert_arn_path" >&2
      exit 1
    fi
    principal_things="$(
      aws iot list-principal-things \
        --principal "$cert_arn" \
        "${aws_flags[@]}" \
        --query 'things[]' \
        --output text
    )"
    if ! tr '[:space:]' '\n' <<<"$principal_things" | grep -Fx "$rig_thing_name" >/dev/null; then
      echo "fail: certificate $cert_arn is not attached to rig thing $rig_thing_name" >&2
      exit 1
    fi
    echo "ok: certificate is attached to rig thing $rig_thing_name"

    iot_data_endpoint="$(aws iot describe-endpoint --endpoint-type iot:Data-ATS "${aws_flags[@]}" --query endpointAddress --output text)"
    mqtt_client_id="rig-check-${rig_name}-$$"
    uv run --project "{{project_root}}/shared/aws/python" python - "$iot_data_endpoint" "$cert_path" "$private_key_path" "$root_ca_path" "$mqtt_client_id" <<'PY'
    import sys

    from awsiot import mqtt_connection_builder

    endpoint, cert_path, private_key_path, root_ca_path, client_id = sys.argv[1:]
    connection = mqtt_connection_builder.mtls_from_path(
        endpoint=endpoint,
        cert_filepath=cert_path,
        pri_key_filepath=private_key_path,
        ca_filepath=root_ca_path,
        client_id=client_id,
        clean_session=True,
        keep_alive_secs=30,
    )
    try:
        connection.connect().result(timeout=15)
        connection.disconnect().result(timeout=15)
    except Exception as err:
        print(f"fail: AWS IoT MQTT mTLS connect ({err})", file=sys.stderr)
        raise SystemExit(1) from err
    print(f"ok: AWS IoT MQTT mTLS connect ({client_id})")
    PY

    iot_cred_endpoint="$(aws iot describe-endpoint --endpoint-type iot:CredentialProvider "${aws_flags[@]}" --query endpointAddress --output text)"
    iot_role_alias="$(
      aws cloudformation describe-stacks \
        --stack-name "$AWS_STACK_NAME" \
        "${aws_flags[@]}" \
        --query "Stacks[0].Outputs[?OutputKey=='GreengrassTokenExchangeRoleAlias'].OutputValue | [0]" \
        --output text
    )"
    if [ -z "$iot_role_alias" ] || [ "$iot_role_alias" = "None" ]; then
      echo "fail: could not resolve GreengrassTokenExchangeRoleAlias from stack $AWS_STACK_NAME" >&2
      exit 1
    fi
    tes_response="$(mktemp "${TMPDIR:-/tmp}/txing-tes-check.XXXXXX")"
    trap 'rm -f "$tes_response"' EXIT
    curl -fsS \
      --cert "$cert_path" \
      --key "$private_key_path" \
      --cacert "$root_ca_path" \
      -H "x-amzn-iot-thingname: $rig_thing_name" \
      "https://$iot_cred_endpoint/role-aliases/$iot_role_alias/credentials" \
      -o "$tes_response"
    jq -e '.credentials.accessKeyId and .credentials.secretAccessKey and .credentials.sessionToken' "$tes_response" >/dev/null
    echo "ok: AWS IoT Credentials Provider mTLS role alias ($iot_role_alias)"
    managed_device_thing="$(
      aws iot search-index \
        --index-name AWS_Things \
        --query-string "attributes.rigId:${TXING_RIG_ID}" \
        --max-results 1 \
        "${aws_flags[@]}" \
        --query 'things[0].thingName' \
        --output text
    )"
    if [ -z "$managed_device_thing" ] || [ "$managed_device_thing" = "None" ]; then
      managed_device_thing="$(
        aws iot search-index \
          --index-name AWS_Things \
          --query-string "attributes.rigId:${TXING_RIG_ID}" \
          --max-results 1 \
          "${aws_flags[@]}" \
          --query 'things[0].thingName' \
          --output text
      )"
    fi
    if [ -n "$managed_device_thing" ] && [ "$managed_device_thing" != "None" ]; then
      device_client_id="$managed_device_thing"
      device_will_topic="spBv1.0/${sparkplug_group_id}/DDEATH/${sparkplug_edge_node_id}/${managed_device_thing}"
      uv run --project "{{project_root}}/shared/aws/python" python - "$iot_data_endpoint" "$region" "$tes_response" "$device_client_id" "$device_will_topic" <<'PY'
    import json
    import sys

    from awscrt import auth, mqtt
    from awsiot import mqtt_connection_builder

    endpoint, region, tes_response_path, client_id, will_topic = sys.argv[1:]
    with open(tes_response_path, "r", encoding="utf-8") as handle:
        credentials = json.load(handle)["credentials"]
    credentials_provider = auth.AwsCredentialsProvider.new_static(
        credentials["accessKeyId"],
        credentials["secretAccessKey"],
        credentials.get("sessionToken"),
    )
    connection = mqtt_connection_builder.websockets_with_default_aws_signing(
        region=region,
        credentials_provider=credentials_provider,
        endpoint=endpoint,
        client_id=client_id,
        port=443,
        clean_session=True,
        keep_alive_secs=30,
        will=mqtt.Will(will_topic, mqtt.QoS.AT_LEAST_ONCE, b"", False),
    )
    try:
        connection.connect().result(timeout=15)
        connection.disconnect().result(timeout=15)
    except Exception as err:
        print(
            f"fail: AWS IoT SigV4 MQTT connect with device Last Will "
            f"client_id={client_id} will_topic={will_topic} ({err})",
            file=sys.stderr,
        )
        raise SystemExit(1) from err
    print(
        f"ok: AWS IoT SigV4 MQTT connect with device Last Will "
        f"client_id={client_id} will_topic={will_topic}"
    )
    PY
    else
      echo "skip: no managed ${TXING_DEVICE_TYPE} device found for rig=${rig_name} town=${sparkplug_group_id}; skipped per-device SigV4 MQTT check"
    fi

@clone-greengrass-lite:
    if [ ! -d "{{greengrass_lite_dir}}/.git" ]; then \
        git clone --branch "{{default_greengrass_lite_ref}}" --depth 1 "{{default_greengrass_lite_repository}}" "{{greengrass_lite_dir}}"; \
    else \
        git -C "{{greengrass_lite_dir}}" remote set-url origin "{{default_greengrass_lite_repository}}"; \
        git -C "{{greengrass_lite_dir}}" fetch --force --tags origin; \
        if git -C "{{greengrass_lite_dir}}" show-ref --verify --quiet "refs/remotes/origin/{{default_greengrass_lite_ref}}"; then \
            git -C "{{greengrass_lite_dir}}" checkout -B "{{default_greengrass_lite_ref}}" "origin/{{default_greengrass_lite_ref}}"; \
            git -C "{{greengrass_lite_dir}}" reset --hard "origin/{{default_greengrass_lite_ref}}"; \
        else \
            git -C "{{greengrass_lite_dir}}" checkout "{{default_greengrass_lite_ref}}"; \
        fi; \
    fi

@clean-native:
    rm -rf "{{greengrass_lite_build_dir}}"

@distclean-native:
    just clean-native
    rm -rf "{{greengrass_lite_dir}}"

build:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ "$(uname -s)" != "Linux" ]; then \
        echo "Greengrass Lite native build is supported only on Linux targets such as Raspberry Pi OS Lite." >&2; \
        exit 1; \
    fi
    missing_native_packages=()
    if ! command -v pkg-config >/dev/null 2>&1; then
      missing_native_packages+=("pkg-config")
    else
      require_pkg_config() {
        local module="$1"
        local package="$2"
        if ! pkg-config --exists "$module"; then
          missing_native_packages+=("$package")
        fi
      }
      require_pkg_config openssl libssl-dev
      require_pkg_config libcurl libcurl4-openssl-dev
      require_pkg_config dbus-1 libdbus-1-dev
    fi
    if [ "${#missing_native_packages[@]}" -ne 0 ]; then
      echo "Missing native build prerequisite(s): ${missing_native_packages[*]}" >&2
      echo "Install on Raspberry Pi OS/Debian with:" >&2
      echo "  sudo apt update && sudo apt install -y ${missing_native_packages[*]}" >&2
      exit 1
    fi
    just clone-greengrass-lite
    cmake \
      -S "{{greengrass_lite_dir}}" \
      -B "{{greengrass_lite_build_dir}}" \
      -DCMAKE_BUILD_TYPE=MinSizeRel \
      -DGG_LOG_LEVEL=INFO \
      -DGGL_SYSTEMD_SYSTEM_USER=ggcore \
      -DGGL_SYSTEMD_SYSTEM_GROUP=ggcore \
      -DGGL_SYSTEMD_SYSTEM_DIR=/lib/systemd/system
    cmake --build "{{greengrass_lite_build_dir}}" --config MinSizeRel --parallel
    test -x "{{greengrass_lite_build_dir}}/bin/ggl-cli"
    TXING_REAL_CC="${CC:-cc}" CC="{{rig_dir}}/tools/cc-greengrass-info-log" cargo build --release --features greengrass-sdk --manifest-path "{{rig_dir}}/sparkplug-manager/Cargo.toml"
    test -x "{{rig_dir}}/sparkplug-manager/target/release/txing-sparkplug-manager"
    TXING_REAL_CC="${CC:-cc}" CC="{{rig_dir}}/tools/cc-greengrass-info-log" cargo build --release --features greengrass-sdk --manifest-path "{{rig_dir}}/ble-connectivity/Cargo.toml"
    test -x "{{rig_dir}}/ble-connectivity/target/release/txing-ble-connectivity"
    TXING_REAL_CC="${CC:-cc}" CC="{{rig_dir}}/tools/cc-greengrass-info-log" cargo build --release --features greengrass-sdk --manifest-path "{{rig_dir}}/aws-connectivity/Cargo.toml"
    test -x "{{rig_dir}}/aws-connectivity/target/release/txing-aws-connectivity"

print shadow_name='sparkplug':
    #!/usr/bin/env bash
    set -euo pipefail
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig "{{region}}" "{{aws_profile}}")"
    region="$AWS_REGION"
    aws_profile="$AWS_SELECTED_PROFILE"
    aws_flags=(--region "$region")
    if [ -n "$aws_profile" ]; then
      aws_flags+=(--profile "$aws_profile")
    fi
    endpoint="$(aws iot describe-endpoint --endpoint-type iot:Data-ATS "${aws_flags[@]}" --query endpointAddress --output text)"
    aws iot-data get-thing-shadow \
      --region "$region" \
      --endpoint-url "https://$endpoint" \
      --thing-name "{{thing_name}}" \
      --shadow-name "{{shadow_name}}" \
      /dev/stdout | jq '.'

install-service rig_id='' rig_name='' sparkplug_group_id='' sparkplug_edge_node_id='' region=region aws_profile=aws_profile aws_shared_credentials_file=aws_shared_credentials_file cloudwatch_log_group='':
    #!/usr/bin/env bash
    set -euo pipefail
    if [ -n "{{rig_id}}" ]; then
      export TXING_RIG_ID="{{rig_id}}"
    fi
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig "{{region}}" "{{aws_profile}}" "" "" "" "{{aws_shared_credentials_file}}")"
    region="$AWS_REGION"
    profile="$AWS_SELECTED_PROFILE"
    aws_flags=(--region "$region")
    if [ -n "$profile" ]; then \
        aws_flags+=(--profile "$profile"); \
    fi
    rig_name="$RIG_NAME"
    selected_rig_type="$RIG_TYPE"
    sparkplug_group_id="$SPARKPLUG_GROUP_ID"
    sparkplug_edge_node_id="$SPARKPLUG_EDGE_NODE_ID"
    if [ -n "{{rig_name}}" ]; then \
        rig_name="{{rig_name}}"; \
    fi; \
    if [ -n "{{sparkplug_group_id}}" ]; then \
        sparkplug_group_id="{{sparkplug_group_id}}"; \
    fi; \
    if [ -n "{{sparkplug_edge_node_id}}" ]; then \
        sparkplug_edge_node_id="{{sparkplug_edge_node_id}}"; \
    fi; \
    if [ ! -d "{{greengrass_lite_build_dir}}" ]; then \
        echo "Greengrass Lite native build is missing at {{greengrass_lite_build_dir}}." >&2; \
        echo "Run 'just rig::build' before 'just rig::install-service'." >&2; \
        exit 1; \
    fi
    install_core_log_overrides() {
      local log_unit
      for log_unit in {{greengrass_warning_log_units}}; do
        sudo install -d -m 755 "/etc/systemd/system/$log_unit.d"
        printf '[Service]\nLogLevelMax=warning\n' | sudo tee "/etc/systemd/system/$log_unit.d/10-log-level.conf" >/dev/null
      done
      sudo systemctl daemon-reload || true
    }
    if ! getent group ggcore >/dev/null; then \
        sudo groupadd --system ggcore; \
    fi
    if ! id -u ggcore >/dev/null 2>&1; then \
        sudo useradd --system --gid ggcore --home-dir /var/lib/greengrass --shell /usr/sbin/nologin ggcore; \
    fi
    if ! getent group gg_component >/dev/null; then \
        sudo groupadd --system gg_component; \
    fi
    if ! id -u gg_component >/dev/null 2>&1; then \
        sudo useradd --system --gid gg_component --home-dir /var/lib/greengrass/component --shell /usr/sbin/nologin gg_component; \
    fi
    rig_cert_path="{{project_root}}/config/certs/rig/rig.cert.pem"
    rig_private_key_path="{{project_root}}/config/certs/rig/rig.private.key"
    if [ ! -f "$rig_cert_path" ] || [ ! -f "$rig_private_key_path" ]; then \
        echo "Rig certificate material is missing under {{project_root}}/config/certs/rig." >&2; \
        echo "Run 'just aws::cert' before 'just rig::install-service'." >&2; \
        exit 1; \
    fi
    rig_thing_name="$TXING_RIG_ID"
    iot_data_endpoint="$(aws iot describe-endpoint --endpoint-type iot:Data-ATS "${aws_flags[@]}" --query endpointAddress --output text)"
    iot_cred_endpoint="$(aws iot describe-endpoint --endpoint-type iot:CredentialProvider "${aws_flags[@]}" --query endpointAddress --output text)"
    iot_role_alias="$(
        aws cloudformation describe-stacks \
          --stack-name "$AWS_STACK_NAME" \
          "${aws_flags[@]}" \
          --query "Stacks[0].Outputs[?OutputKey=='GreengrassTokenExchangeRoleAlias'].OutputValue | [0]" \
          --output text
    )"
    if [ -z "$iot_role_alias" ] || [ "$iot_role_alias" = "None" ]; then \
        echo "Could not resolve GreengrassTokenExchangeRoleAlias from stack $AWS_STACK_NAME." >&2; \
        exit 1; \
    fi
    temp_files=()
    cleanup_temp_files() {
        if [ "${#temp_files[@]}" -gt 0 ]; then
            rm -f "${temp_files[@]}"
        fi
    }
    trap cleanup_temp_files EXIT
    sudo mkdir -p /var/lib/greengrass /etc/greengrass /etc/tmpfiles.d
    sudo install -d -o ggcore -g ggcore -m 775 /run/greengrass
    sudo install -d -o ggcore -g ggcore -m 770 /etc/greengrass/config.d
    greengrass_tmpfiles_temp="$(mktemp "${TMPDIR:-/tmp}/txing-greengrass-tmpfiles.XXXXXX")"
    temp_files+=("$greengrass_tmpfiles_temp")
    cat >"$greengrass_tmpfiles_temp" <<'EOF'
    d /run/greengrass 0775 ggcore ggcore -
    d /etc/greengrass/config.d 0770 ggcore ggcore -
    EOF
    sudo install -m 644 "$greengrass_tmpfiles_temp" /etc/tmpfiles.d/txing-greengrass-lite.conf
    sudo systemd-tmpfiles --create /etc/tmpfiles.d/txing-greengrass-lite.conf
    sudo install -d -o ggcore -g ggcore -m 700 /var/lib/greengrass/credentials
    sudo install -o ggcore -g ggcore -m 600 "$rig_cert_path" /var/lib/greengrass/credentials/rig.cert.pem
    sudo install -o ggcore -g ggcore -m 600 "$rig_private_key_path" /var/lib/greengrass/credentials/rig.private.key
    root_ca_temp="$(mktemp "${TMPDIR:-/tmp}/txing-amazon-root-ca.XXXXXX")"
    temp_files+=("$root_ca_temp")
    curl -fsSL https://www.amazontrust.com/repository/AmazonRootCA1.pem -o "$root_ca_temp"
    sudo install -o ggcore -g ggcore -m 644 "$root_ca_temp" /var/lib/greengrass/credentials/AmazonRootCA1.pem
    greengrass_config_temp="$(mktemp "${TMPDIR:-/tmp}/txing-greengrass-config.XXXXXX")"
    temp_files+=("$greengrass_config_temp")
    cat >"$greengrass_config_temp" <<EOF
    system:
      privateKeyPath: "/var/lib/greengrass/credentials/rig.private.key"
      certificateFilePath: "/var/lib/greengrass/credentials/rig.cert.pem"
      rootCaPath: "/var/lib/greengrass/credentials/AmazonRootCA1.pem"
      rootPath: "/var/lib/greengrass"
      thingName: "$rig_thing_name"
    services:
      aws.greengrass.NucleusLite:
        componentType: "NUCLEUS"
        configuration:
          awsRegion: "$region"
          iotCredEndpoint: "$iot_cred_endpoint"
          iotDataEndpoint: "$iot_data_endpoint"
          iotRoleAlias: "$iot_role_alias"
          runWithDefault:
            posixUser: "gg_component:gg_component"
          greengrassDataPlanePort: "8443"
          platformOverride: {}
    EOF
    sudo install -m 644 "$greengrass_config_temp" /etc/greengrass/config.yaml
    sudo chown -R ggcore:ggcore /var/lib/greengrass
    sudo cmake --install "{{greengrass_lite_build_dir}}" --config MinSizeRel
    install_core_log_overrides
    sudo "{{greengrass_lite_dir}}/misc/run_nucleus"
    printf 'txing rig is supervised by the standard Greengrass Lite systemd target %s\n' "{{greengrass_lite_target}}"
    printf 'Deploy rig type %s components with RigName=%s SparkplugGroupId=%s SparkplugEdgeNodeId=%s\n' "$selected_rig_type" "$rig_name" "$sparkplug_group_id" "$sparkplug_edge_node_id"

[private]
_local-component-list components selected_rig_type:
    #!/usr/bin/env bash
    set -euo pipefail
    requested="{{components}}"
    case "$requested" in
      ''|auto)
        case "{{selected_rig_type}}" in
          raspi) requested="sparkplug,ble" ;;
          cloud) requested="sparkplug,aws" ;;
          *)
            echo "Unsupported RIG_TYPE={{selected_rig_type}}. Supported rig types: raspi, cloud." >&2
            exit 1
            ;;
        esac
        ;;
      all)
        requested="sparkplug,ble,aws"
        ;;
    esac
    printf '%s\n' "$requested" | tr ',' '\n' | sed 's/^[[:space:]]*//; s/[[:space:]]*$//' | awk 'NF'

[private]
_local-start rig_id='' components='auto':
    #!/usr/bin/env bash
    set -euo pipefail
    if [ "$(uname -s)" != "Darwin" ]; then
      echo "rig local runtime is supported by this recipe only on macOS." >&2
      exit 1
    fi
    if [ -n "{{rig_id}}" ]; then
      export TXING_RIG_ID="{{rig_id}}"
    fi
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig)"
    region="$AWS_REGION"
    profile="$AWS_SELECTED_PROFILE"
    aws_flags=(--region "$region")
    if [ -n "$profile" ]; then
      aws_flags+=(--profile "$profile")
    fi
    iot_data_endpoint="$(aws iot describe-endpoint --endpoint-type iot:Data-ATS "${aws_flags[@]}" --query endpointAddress --output text)"
    run_dir="{{local_run_dir}}"
    socket="{{local_pubsub_socket}}"
    mkdir -p "$run_dir"

    cargo build --manifest-path "{{rig_dir}}/local-pubsub/Cargo.toml" >/dev/null
    cargo build --manifest-path "{{rig_dir}}/sparkplug-manager/Cargo.toml" >/dev/null
    cargo build --manifest-path "{{rig_dir}}/aws-connectivity/Cargo.toml" >/dev/null
    ble_mode="${TXING_RIG_MAC_BLE_MODE:-simulated}"
    case "$ble_mode" in
      real)
        cargo build --features ble-real --manifest-path "{{rig_dir}}/ble-connectivity/Cargo.toml" >/dev/null
        ble_args=()
        ;;
      simulated|disabled)
        cargo build --manifest-path "{{rig_dir}}/ble-connectivity/Cargo.toml" >/dev/null
        ble_args=(--no-ble)
        ;;
      *)
        echo "Unsupported TXING_RIG_MAC_BLE_MODE=$ble_mode. Supported modes: simulated, disabled, real." >&2
        exit 1
        ;;
    esac

    broker_bin="{{rig_dir}}/local-pubsub/target/debug/txing-rig-local-pubsub"
    sparkplug_bin="{{rig_dir}}/sparkplug-manager/target/debug/txing-sparkplug-manager"
    ble_bin="{{rig_dir}}/ble-connectivity/target/debug/txing-ble-connectivity"
    aws_bin="{{rig_dir}}/aws-connectivity/target/debug/txing-aws-connectivity"

    is_running() {
      local pid_file="$1"
      [ -f "$pid_file" ] && kill -0 "$(cat "$pid_file")" >/dev/null 2>&1
    }
    start_process() {
      local name="$1"
      shift
      local pid_file="$run_dir/$name.pid"
      local log_file="$run_dir/$name.log"
      if is_running "$pid_file"; then
        printf '%s already running pid=%s log=%s\n' "$name" "$(cat "$pid_file")" "$log_file"
        return 0
      fi
      rm -f "$pid_file"
      nohup "$@" >>"$log_file" 2>&1 &
      printf '%s\n' "$!" >"$pid_file"
      printf 'started %s pid=%s log=%s\n' "$name" "$!" "$log_file"
    }

    start_process broker "$broker_bin" --socket "$socket"
    for _attempt in $(seq 1 50); do
      [ -S "$socket" ] && break
      sleep 0.1
    done
    if [ ! -S "$socket" ]; then
      echo "local pub/sub broker did not create $socket" >&2
      exit 1
    fi

    mapfile -t selected_components < <(just --justfile "{{rig_dir}}/justfile" _local-component-list "{{components}}" "$RIG_TYPE")
    contains_component() {
      local wanted="$1"
      local component
      for component in "${selected_components[@]}"; do
        [ "$component" = "$wanted" ] && return 0
      done
      return 1
    }
    for component in ble aws sparkplug; do
      contains_component "$component" || continue
      case "$component" in
        sparkplug)
          start_process sparkplug "$sparkplug_bin" \
            --rig-id "$TXING_RIG_ID" \
            --town-id "$TXING_TOWN_ID" \
            --iot-endpoint "$iot_data_endpoint" \
            --aws-region "$region" \
            --local-ipc-socket "$socket"
          ;;
        ble)
          start_process ble "$ble_bin" \
            --local-ipc-socket "$socket" \
            "${ble_args[@]}"
          ;;
        aws)
          start_process aws "$aws_bin" \
            --iot-endpoint "$iot_data_endpoint" \
            --aws-region "$region" \
            --client-id "$TXING_RIG_ID-aws-connectivity" \
            --local-ipc-socket "$socket" \
            --include-capability time
          ;;
        *)
          echo "Unsupported local rig component '$component'. Supported: sparkplug, ble, aws, all, auto." >&2
          exit 1
          ;;
      esac
    done
    just --justfile "{{rig_dir}}/justfile" _local-status

[private]
_local-stop:
    #!/usr/bin/env bash
    set -euo pipefail
    run_dir="{{local_run_dir}}"
    stop_process() {
      local name="$1"
      local pid_file="$run_dir/$name.pid"
      if [ ! -f "$pid_file" ]; then
        return 0
      fi
      local pid
      pid="$(cat "$pid_file")"
      if kill -0 "$pid" >/dev/null 2>&1; then
        kill "$pid" || true
        for _attempt in $(seq 1 50); do
          if ! kill -0 "$pid" >/dev/null 2>&1; then
            break
          fi
          sleep 0.1
        done
        if kill -0 "$pid" >/dev/null 2>&1; then
          kill -9 "$pid" || true
        fi
        printf 'stopped %s pid=%s\n' "$name" "$pid"
      fi
      rm -f "$pid_file"
    }
    for name in aws ble sparkplug broker; do
      stop_process "$name"
    done
    rm -f "{{local_pubsub_socket}}"

[private]
_local-status:
    #!/usr/bin/env bash
    set -euo pipefail
    run_dir="{{local_run_dir}}"
    printf 'local rig runtime: %s\n' "$run_dir"
    for name in broker sparkplug ble aws; do
      pid_file="$run_dir/$name.pid"
      log_file="$run_dir/$name.log"
      if [ -f "$pid_file" ] && kill -0 "$(cat "$pid_file")" >/dev/null 2>&1; then
        printf '  %-9s running pid=%s log=%s\n' "$name" "$(cat "$pid_file")" "$log_file"
      else
        printf '  %-9s stopped log=%s\n' "$name" "$log_file"
      fi
    done

[private]
_local-log lines='200' follow='true':
    #!/usr/bin/env bash
    set -euo pipefail
    shopt -s nullglob
    logs=({{local_run_dir}}/*.log)
    if [ "${#logs[@]}" -eq 0 ]; then
      echo "No local rig logs under {{local_run_dir}}." >&2
      exit 1
    fi
    case "{{follow}}" in
      true|1|yes|on) tail -n "{{lines}}" -F "${logs[@]}" ;;
      false|0|no|off) tail -n "{{lines}}" "${logs[@]}" ;;
      *)
        echo "follow must be true or false." >&2
        exit 1
        ;;
    esac

start rig_id='' components='auto':
    #!/usr/bin/env bash
    set -euo pipefail
    if [ "$(uname -s)" = "Darwin" ]; then
      exec just --justfile "{{rig_dir}}/justfile" _local-start "{{rig_id}}" "{{components}}"
    fi
    if [ -n "{{rig_id}}" ]; then
      export TXING_RIG_ID="{{rig_id}}"
    fi
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig)"
    selected_rig_type="$RIG_TYPE"
    if ! systemctl cat "{{greengrass_lite_target}}" >/dev/null 2>&1; then \
        echo "Greengrass Lite target {{greengrass_lite_target}} is not installed. Run 'just rig::install-service' first." >&2; \
        exit 1; \
    fi
    unit_exists() {
      systemctl cat "$1" >/dev/null 2>&1
    }
    start_unit_if_present() {
      local unit="$1"
      if unit_exists "$unit"; then
        sudo systemctl start "$unit" || true
      fi
    }
    wait_active_if_present() {
      local unit="$1"
      if ! unit_exists "$unit"; then
        return 0
      fi
      for _attempt in $(seq 1 30); do
        if systemctl is-active --quiet "$unit"; then
          return 0
        fi
        sleep 1
      done
      return 1
    }
    case "$selected_rig_type" in
      raspi)
        component_units=({{raspi_rig_component_units}})
        ;;
      cloud)
        component_units=({{aws_rig_component_units}})
        ;;
      *)
        echo "Unsupported RIG_TYPE=$selected_rig_type. Supported rig types: raspi, cloud." >&2
        exit 1
        ;;
    esac
    sudo install -d -o ggcore -g ggcore -m 775 /run/greengrass || true
    sudo install -d -o ggcore -g ggcore -m 770 /etc/greengrass/config.d || true
    core_units=({{greengrass_core_units}})
    core_sockets=({{greengrass_core_sockets}})
    reset_units=("{{greengrass_lite_target}}")
    for unit in "${core_sockets[@]}" "${core_units[@]}" "${component_units[@]}"; do
      if unit_exists "$unit"; then
        reset_units+=("$unit")
      fi
    done
    sudo systemctl reset-failed "${reset_units[@]}" || true
    sudo systemctl start "{{greengrass_lite_target}}"
    for unit in "${core_sockets[@]}"; do
      start_unit_if_present "$unit"
      wait_active_if_present "$unit" || true
    done
    for unit in "${component_units[@]}"; do
      if unit_exists "$unit"; then
        start_unit_if_present "$unit"
        wait_active_if_present "$unit" || true
      fi
    done
    status_units=("{{greengrass_lite_target}}")
    for unit in "${core_sockets[@]}" "${core_units[@]}" "${component_units[@]}"; do
      if unit_exists "$unit"; then
        status_units+=("$unit")
      fi
    done
    sudo systemctl --no-pager --full status "${status_units[@]}"

stop rig_id='':
    #!/usr/bin/env bash
    set -euo pipefail
