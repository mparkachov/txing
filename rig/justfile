set shell := ["bash", "-eu", "-o", "pipefail", "-c"]
set quiet := true

rig_dir := source_directory()
python_executable := "python3"
built_rig := rig_dir + "/.venv/bin/rig"
built_rig_device_process := rig_dir + "/.venv/bin/rig-device-process"
built_rig_sparkplug_cmd := rig_dir + "/.venv/bin/rig-sparkplug-cmd"
built_rig_sparkplug_log := rig_dir + "/.venv/bin/rig-sparkplug-log"
project_root := rig_dir + "/.."
root_justfile := project_root + "/justfile"
greengrass_lite_dir := rig_dir + "/greengrass-lite"
greengrass_lite_build_dir := greengrass_lite_dir + "/build"
greengrass_lite_target := "greengrass-lite.target"
native_python_dir := rig_dir + "/build/python"
native_uv_cache_dir := rig_dir + "/build/uv-cache"
greengrass_core_units := "ggl.core.ggconfigd.service ggl.core.ggipcd.service ggl.core.iotcored.service ggl.core.tesd.service ggl.aws.greengrass.TokenExchangeService.service ggl.core.ggdeploymentd.service ggl.core.gg-fleet-statusd.service ggl.core.ggpubsubd.service ggl.core.gghealthd.service"
greengrass_core_sockets := "ggl.gg_config.socket ggl.gg_deployment.socket ggl.gg_fleet_status.socket ggl.aws_iot_mqtt.socket ggl.aws_iot_tes.socket ggl.gg_pubsub.socket ggl.ipc_component.socket ggl.gg-ipc.socket.socket ggl.gg_health.socket"
shared_raspi_rig_component_units := "ggl.dev.txing.rig.SparkplugManager.service ggl.dev.txing.rig.BleConnectivity.service"
raspi_rig_component_units := shared_raspi_rig_component_units
aws_rig_component_units := "ggl.dev.txing.rig.SparkplugManager.service ggl.dev.txing.rig.AwsConnectivity.service"
default_greengrass_lite_repository := env_var_or_default("TXING_RIG_GREENGRASS_LITE_REPOSITORY", "https://github.com/aws-greengrass/aws-greengrass-lite.git")
default_greengrass_lite_ref := env_var_or_default("TXING_RIG_GREENGRASS_LITE_REF", "main")
thing_name := "unit-local"
region := ""
aws_profile := ""
aws_shared_credentials_file := ""

@sync:
    cd "{{rig_dir}}" && uv sync --python "{{python_executable}}" --no-managed-python --no-python-downloads

build:
    #!/usr/bin/env bash
    set -euo pipefail
    eval "$(just --justfile "{{root_justfile}}" _project-version-env)"
    cd "{{rig_dir}}" && uv sync --frozen --no-editable --compile-bytecode --python "{{python_executable}}" --no-managed-python --no-python-downloads --refresh-package rig --reinstall-package rig --refresh-package aws --reinstall-package aws
    test -x "{{built_rig}}"
    test -x "{{built_rig_device_process}}"
    test -x "{{built_rig_sparkplug_cmd}}"
    test -x "{{built_rig_sparkplug_log}}"

[positional-arguments]
aws *args:
    #!/usr/bin/env bash
    set -euo pipefail
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig)"
    command aws "$@"

check rig_id='' cloudwatch_log_group='' region=region aws_profile=aws_profile aws_shared_credentials_file=aws_shared_credentials_file:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ -n "{{rig_id}}" ]; then
      export TXING_RIG_ID="{{rig_id}}"
    fi
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig "{{region}}" "{{aws_profile}}" "" "" "" "{{aws_shared_credentials_file}}")"
    region="$AWS_REGION"
    profile="$AWS_SELECTED_PROFILE"
    aws_flags=(--region "$region")
    if [ -n "$profile" ]; then
      aws_flags+=(--profile "$profile")
    fi
    rig_name="$RIG_NAME"
    selected_rig_type="$RIG_TYPE"
    sparkplug_group_id="$SPARKPLUG_GROUP_ID"
    sparkplug_edge_node_id="$SPARKPLUG_EDGE_NODE_ID"
    cloudwatch_log_group="$CLOUDWATCH_LOG_GROUP"
    if [ -n "{{cloudwatch_log_group}}" ]; then
      cloudwatch_log_group="{{cloudwatch_log_group}}"
    fi
    failures=0
    fail_check() {
      echo "fail: $*" >&2
      failures=$((failures + 1))
    }
    if [ "$rig_name" != "$TXING_RIG_ID" ]; then
      fail_check "RIG_NAME=$rig_name must match TXING_RIG_ID=$TXING_RIG_ID"
    else
      echo "ok: RIG_NAME matches TXING_RIG_ID ($rig_name)"
    fi
    if [ "$sparkplug_group_id" != "$TXING_TOWN_ID" ]; then
      fail_check "SPARKPLUG_GROUP_ID=$sparkplug_group_id must match TXING_TOWN_ID=$TXING_TOWN_ID"
    else
      echo "ok: SPARKPLUG_GROUP_ID matches TXING_TOWN_ID ($sparkplug_group_id)"
    fi
    if [ "$sparkplug_edge_node_id" != "$TXING_RIG_ID" ]; then
      fail_check "SPARKPLUG_EDGE_NODE_ID=$sparkplug_edge_node_id must match TXING_RIG_ID=$TXING_RIG_ID"
    else
      echo "ok: SPARKPLUG_EDGE_NODE_ID matches TXING_RIG_ID ($sparkplug_edge_node_id)"
    fi
    case "$selected_rig_type" in
      raspi|cloud)
        echo "ok: configured RIG_TYPE=$selected_rig_type"
        ;;
      *)
        fail_check "unsupported RIG_TYPE=$selected_rig_type; supported rig types: raspi, cloud"
        ;;
    esac
    check_enabled_active_service() {
      local service="$1"
      if ! command -v systemctl >/dev/null 2>&1; then
        fail_check "systemctl is required to verify host service $service"
        return
      fi
      if ! systemctl cat "$service" >/dev/null 2>&1; then
        fail_check "required host service $service is not installed"
        return
      fi
      if ! systemctl is-enabled --quiet "$service"; then
        fail_check "required host service $service is not enabled"
      else
        echo "ok: host service $service is enabled"
      fi
      if ! systemctl is-active --quiet "$service"; then
        fail_check "required host service $service is not active"
      else
        echo "ok: host service $service is active"
      fi
    }
    case "$selected_rig_type" in
      raspi)
        check_enabled_active_service bluetooth.service
        ;;
      cloud)
        echo "ok: rig type cloud has no extra host service prerequisites"
        ;;
    esac
    if [ "$failures" -ne 0 ]; then
      echo "rig configuration check failed with $failures issue(s)." >&2
      exit 1
    fi
    cert_dir="{{project_root}}/config/certs/rig"
    cert_path="$cert_dir/rig.cert.pem"
    private_key_path="$cert_dir/rig.private.key"
    cert_arn_path="$cert_dir/rig.cert.arn"
    root_ca_path="$cert_dir/AmazonRootCA1.pem"
    for required_file in "$cert_path" "$private_key_path" "$cert_arn_path"; do
      if [ ! -f "$required_file" ]; then
        echo "fail: missing rig certificate material $required_file. Run 'just aws::cert'." >&2
        exit 1
      fi
    done
    if [ ! -f "$root_ca_path" ]; then
      install -d -m 700 "$cert_dir"
      curl -fsSL https://www.amazontrust.com/repository/AmazonRootCA1.pem -o "$root_ca_path"
      chmod 644 "$root_ca_path"
    fi

    uv run --project "{{project_root}}/shared/aws/python" \
      python -m aws.check \
      --scope rig \
      --rig-id "$TXING_RIG_ID" \
      --log-group-name "$cloudwatch_log_group"

    rig_thing_name="$TXING_RIG_ID"
    registered_rig_type="$(
      aws iot describe-thing \
        --thing-name "$rig_thing_name" \
        "${aws_flags[@]}" \
        --query 'thingTypeName' \
        --output text
    )"
    if [ -z "$registered_rig_type" ] || [ "$registered_rig_type" = "None" ]; then
      echo "fail: rig thing $rig_thing_name is missing required ThingTypeName" >&2
      exit 1
    fi
    if [ "$registered_rig_type" != "$selected_rig_type" ]; then
      echo "fail: rig thing $rig_thing_name has ThingTypeName=$registered_rig_type but resolved RIG_TYPE=$selected_rig_type" >&2
      exit 1
    fi
    echo "ok: rig thing $rig_thing_name has ThingTypeName=$registered_rig_type"
    cert_arn="$(tr -d '[:space:]' <"$cert_arn_path")"
    if [ -z "$cert_arn" ]; then
      echo "fail: rig certificate ARN file is empty: $cert_arn_path" >&2
      exit 1
    fi
    principal_things="$(
      aws iot list-principal-things \
        --principal "$cert_arn" \
        "${aws_flags[@]}" \
        --query 'things[]' \
        --output text
    )"
    if ! tr '[:space:]' '\n' <<<"$principal_things" | grep -Fx "$rig_thing_name" >/dev/null; then
      echo "fail: certificate $cert_arn is not attached to rig thing $rig_thing_name" >&2
      exit 1
    fi
    echo "ok: certificate is attached to rig thing $rig_thing_name"

    iot_data_endpoint="$(aws iot describe-endpoint --endpoint-type iot:Data-ATS "${aws_flags[@]}" --query endpointAddress --output text)"
    mqtt_client_id="rig-check-${rig_name}-$$"
    uv run --project "{{project_root}}/shared/aws/python" python - "$iot_data_endpoint" "$cert_path" "$private_key_path" "$root_ca_path" "$mqtt_client_id" <<'PY'
    import sys

    from awsiot import mqtt_connection_builder

    endpoint, cert_path, private_key_path, root_ca_path, client_id = sys.argv[1:]
    connection = mqtt_connection_builder.mtls_from_path(
        endpoint=endpoint,
        cert_filepath=cert_path,
        pri_key_filepath=private_key_path,
        ca_filepath=root_ca_path,
        client_id=client_id,
        clean_session=True,
        keep_alive_secs=30,
    )
    try:
        connection.connect().result(timeout=15)
        connection.disconnect().result(timeout=15)
    except Exception as err:
        print(f"fail: AWS IoT MQTT mTLS connect ({err})", file=sys.stderr)
        raise SystemExit(1) from err
    print(f"ok: AWS IoT MQTT mTLS connect ({client_id})")
    PY

    iot_cred_endpoint="$(aws iot describe-endpoint --endpoint-type iot:CredentialProvider "${aws_flags[@]}" --query endpointAddress --output text)"
    iot_role_alias="$(
      aws cloudformation describe-stacks \
        --stack-name "$AWS_STACK_NAME" \
        "${aws_flags[@]}" \
        --query "Stacks[0].Outputs[?OutputKey=='GreengrassTokenExchangeRoleAlias'].OutputValue | [0]" \
        --output text
    )"
    if [ -z "$iot_role_alias" ] || [ "$iot_role_alias" = "None" ]; then
      echo "fail: could not resolve GreengrassTokenExchangeRoleAlias from stack $AWS_STACK_NAME" >&2
      exit 1
    fi
    tes_response="$(mktemp "${TMPDIR:-/tmp}/txing-tes-check.XXXXXX")"
    trap 'rm -f "$tes_response"' EXIT
    curl -fsS \
      --cert "$cert_path" \
      --key "$private_key_path" \
      --cacert "$root_ca_path" \
      -H "x-amzn-iot-thingname: $rig_thing_name" \
      "https://$iot_cred_endpoint/role-aliases/$iot_role_alias/credentials" \
      -o "$tes_response"
    jq -e '.credentials.accessKeyId and .credentials.secretAccessKey and .credentials.sessionToken' "$tes_response" >/dev/null
    echo "ok: AWS IoT Credentials Provider mTLS role alias ($iot_role_alias)"
    managed_device_thing="$(
      aws iot search-index \
        --index-name AWS_Things \
        --query-string "attributes.rigId:${TXING_RIG_ID}" \
        --max-results 1 \
        "${aws_flags[@]}" \
        --query 'things[0].thingName' \
        --output text
    )"
    if [ -z "$managed_device_thing" ] || [ "$managed_device_thing" = "None" ]; then
      managed_device_thing="$(
        aws iot search-index \
          --index-name AWS_Things \
          --query-string "attributes.rigId:${TXING_RIG_ID}" \
          --max-results 1 \
          "${aws_flags[@]}" \
          --query 'things[0].thingName' \
          --output text
      )"
    fi
    if [ -n "$managed_device_thing" ] && [ "$managed_device_thing" != "None" ]; then
      device_client_id="$managed_device_thing"
      device_will_topic="spBv1.0/${sparkplug_group_id}/DDEATH/${sparkplug_edge_node_id}/${managed_device_thing}"
      uv run --project "{{project_root}}/shared/aws/python" python - "$iot_data_endpoint" "$region" "$tes_response" "$device_client_id" "$device_will_topic" <<'PY'
    import json
    import sys

    from awscrt import auth, mqtt
    from awsiot import mqtt_connection_builder

    endpoint, region, tes_response_path, client_id, will_topic = sys.argv[1:]
    with open(tes_response_path, "r", encoding="utf-8") as handle:
        credentials = json.load(handle)["credentials"]
    credentials_provider = auth.AwsCredentialsProvider.new_static(
        credentials["accessKeyId"],
        credentials["secretAccessKey"],
        credentials.get("sessionToken"),
    )
    connection = mqtt_connection_builder.websockets_with_default_aws_signing(
        region=region,
        credentials_provider=credentials_provider,
        endpoint=endpoint,
        client_id=client_id,
        port=443,
        clean_session=True,
        keep_alive_secs=30,
        will=mqtt.Will(will_topic, mqtt.QoS.AT_LEAST_ONCE, b"", False),
    )
    try:
        connection.connect().result(timeout=15)
        connection.disconnect().result(timeout=15)
    except Exception as err:
        print(
            f"fail: AWS IoT SigV4 MQTT connect with device Last Will "
            f"client_id={client_id} will_topic={will_topic} ({err})",
            file=sys.stderr,
        )
        raise SystemExit(1) from err
    print(
        f"ok: AWS IoT SigV4 MQTT connect with device Last Will "
        f"client_id={client_id} will_topic={will_topic}"
    )
    PY
    else
      echo "skip: no managed ${TXING_DEVICE_TYPE} device found for rig=${rig_name} town=${sparkplug_group_id}; skipped per-device SigV4 MQTT check"
    fi

@clone-greengrass-lite:
    if [ ! -d "{{greengrass_lite_dir}}/.git" ]; then \
        git clone --branch "{{default_greengrass_lite_ref}}" --depth 1 "{{default_greengrass_lite_repository}}" "{{greengrass_lite_dir}}"; \
    else \
        git -C "{{greengrass_lite_dir}}" remote set-url origin "{{default_greengrass_lite_repository}}"; \
        git -C "{{greengrass_lite_dir}}" fetch --force --tags origin; \
        if git -C "{{greengrass_lite_dir}}" show-ref --verify --quiet "refs/remotes/origin/{{default_greengrass_lite_ref}}"; then \
            git -C "{{greengrass_lite_dir}}" checkout -B "{{default_greengrass_lite_ref}}" "origin/{{default_greengrass_lite_ref}}"; \
            git -C "{{greengrass_lite_dir}}" reset --hard "origin/{{default_greengrass_lite_ref}}"; \
        else \
            git -C "{{greengrass_lite_dir}}" checkout "{{default_greengrass_lite_ref}}"; \
        fi; \
    fi

@clean-native:
    rm -rf "{{greengrass_lite_build_dir}}" "{{native_python_dir}}" "{{native_uv_cache_dir}}"

@distclean-native:
    just clean-native
    rm -rf "{{greengrass_lite_dir}}"

build-native:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ "$(uname -s)" != "Linux" ]; then \
        echo "Greengrass Lite native build is supported only on Linux targets such as Raspberry Pi OS Lite." >&2; \
        exit 1; \
    fi
    missing_native_packages=()
    if ! command -v pkg-config >/dev/null 2>&1; then
      missing_native_packages+=("pkg-config")
    else
      require_pkg_config() {
        local module="$1"
        local package="$2"
        if ! pkg-config --exists "$module"; then
          missing_native_packages+=("$package")
        fi
      }
      require_pkg_config openssl libssl-dev
      require_pkg_config libcurl libcurl4-openssl-dev
      require_pkg_config dbus-1 libdbus-1-dev
    fi
    if [ "${#missing_native_packages[@]}" -ne 0 ]; then
      echo "Missing native build prerequisite(s): ${missing_native_packages[*]}" >&2
      echo "Install on Raspberry Pi OS/Debian with:" >&2
      echo "  sudo apt update && sudo apt install -y ${missing_native_packages[*]}" >&2
      exit 1
    fi
    just clone-greengrass-lite
    cmake \
      -S "{{greengrass_lite_dir}}" \
      -B "{{greengrass_lite_build_dir}}" \
      -DCMAKE_BUILD_TYPE=MinSizeRel \
      -DGG_LOG_LEVEL=INFO \
      -DGGL_SYSTEMD_SYSTEM_USER=ggcore \
      -DGGL_SYSTEMD_SYSTEM_GROUP=ggcore \
      -DGGL_SYSTEMD_SYSTEM_DIR=/lib/systemd/system
    cmake --build "{{greengrass_lite_build_dir}}" --config MinSizeRel --parallel
    test -x "{{greengrass_lite_build_dir}}/bin/ggl-cli"
    TXING_REAL_CC="${CC:-cc}" CC="{{rig_dir}}/tools/cc-greengrass-info-log" cargo build --release --features greengrass-sdk --manifest-path "{{rig_dir}}/sparkplug-manager/Cargo.toml"
    test -x "{{rig_dir}}/sparkplug-manager/target/release/txing-sparkplug-manager"
    TXING_REAL_CC="${CC:-cc}" CC="{{rig_dir}}/tools/cc-greengrass-info-log" cargo build --release --features greengrass-sdk --manifest-path "{{rig_dir}}/ble-connectivity/Cargo.toml"
    test -x "{{rig_dir}}/ble-connectivity/target/release/txing-ble-connectivity"
    TXING_REAL_CC="${CC:-cc}" CC="{{rig_dir}}/tools/cc-greengrass-info-log" cargo build --release --features greengrass-sdk --manifest-path "{{rig_dir}}/aws-connectivity/Cargo.toml"
    test -x "{{rig_dir}}/aws-connectivity/target/release/txing-aws-connectivity"

run:
    #!/usr/bin/env bash
    set -euo pipefail
    test -x "{{built_rig}}" || { \
        echo "Missing built rig executable at {{built_rig}}. Run 'just rig::build' first." >&2; \
        exit 1; \
    }
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig "{{region}}" "{{aws_profile}}")"
    cd "{{rig_dir}}" && "{{built_rig}}"

