set shell := ["bash", "-eu", "-o", "pipefail", "-c"]

rig_dir := source_directory()
python_executable := "python3"
built_rig := rig_dir + "/.venv/bin/rig"
built_rig_sparkplug_cmd := rig_dir + "/.venv/bin/rig-sparkplug-cmd"
built_rig_sparkplug_log := rig_dir + "/.venv/bin/rig-sparkplug-log"
project_root := rig_dir + "/.."
root_justfile := project_root + "/justfile"
thing_name := "txing"
region := ""
aws_profile := ""
aws_shared_credentials_file := ""
aws_config_file := ""
systemd_unit := "/etc/systemd/system/rig.service"

@sync:
    cd "{{rig_dir}}" && uv sync --python "{{python_executable}}" --no-managed-python --no-python-downloads

@build:
    cd "{{rig_dir}}" && uv sync --frozen --no-editable --compile-bytecode --python "{{python_executable}}" --no-managed-python --no-python-downloads --refresh-package rig --reinstall-package rig --refresh-package aws --reinstall-package aws
    test -x "{{built_rig}}"
    test -x "{{built_rig_sparkplug_cmd}}"
    test -x "{{built_rig_sparkplug_log}}"

[positional-arguments]
@aws *args:
    #!/usr/bin/env bash
    set -euo pipefail
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig)"
    command aws "$@"

@check rig_name='' cloudwatch_log_group='' region=region aws_profile=aws_profile:
    #!/usr/bin/env bash
    set -euo pipefail
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig "{{region}}" "{{aws_profile}}")"
    thing_name="$THING_NAME"
    rig_name="$RIG_NAME"
    cloudwatch_log_group="$CLOUDWATCH_LOG_GROUP"
    if [ -n "{{rig_name}}" ]; then
      rig_name="{{rig_name}}"
    fi
    if [ -n "{{cloudwatch_log_group}}" ]; then
      cloudwatch_log_group="{{cloudwatch_log_group}}"
    fi

    uv run --project "{{project_root}}/shared/aws/python" \
      python -m aws.check \
      --scope rig \
      --thing-name "$thing_name" \
      --rig-name "$rig_name" \
      --log-group-name "$cloudwatch_log_group"

@run:
    #!/usr/bin/env bash
    set -euo pipefail
    test -x "{{built_rig}}" || { \
        echo "Missing built rig executable at {{built_rig}}. Run 'just rig::build' first." >&2; \
        exit 1; \
    }
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig "{{region}}" "{{aws_profile}}")"
    cd "{{rig_dir}}" && "{{built_rig}}"

@debug:
    #!/usr/bin/env bash
    set -euo pipefail
    test -x "{{built_rig}}" || { \
        echo "Missing built rig executable at {{built_rig}}. Run 'just rig::build' first." >&2; \
        exit 1; \
    }
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig "{{region}}" "{{aws_profile}}")"
    cd "{{rig_dir}}" && "{{built_rig}}" --debug

@dev:
    #!/usr/bin/env bash
    set -euo pipefail
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig "{{region}}" "{{aws_profile}}")"
    cd "{{rig_dir}}" && uv run rig

@debug-dev:
    #!/usr/bin/env bash
    set -euo pipefail
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig "{{region}}" "{{aws_profile}}")"
    cd "{{rig_dir}}" && uv run rig --debug

@wake sparkplug_group_id='' sparkplug_edge_node_id='' region=region aws_profile=aws_profile:
    #!/usr/bin/env bash
    set -euo pipefail
    test -x "{{built_rig_sparkplug_cmd}}" || { \
        echo "Missing built rig Sparkplug command executable at {{built_rig_sparkplug_cmd}}. Run 'just rig::build' first." >&2; \
        exit 1; \
    }
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig "{{region}}" "{{aws_profile}}")"
    sparkplug_group_id="$SPARKPLUG_GROUP_ID"
    sparkplug_edge_node_id="$SPARKPLUG_EDGE_NODE_ID"
    if [ -n "{{sparkplug_group_id}}" ]; then
      sparkplug_group_id="{{sparkplug_group_id}}"
    fi
    if [ -n "{{sparkplug_edge_node_id}}" ]; then
      sparkplug_edge_node_id="{{sparkplug_edge_node_id}}"
    fi
    cd "{{rig_dir}}" && "{{built_rig_sparkplug_cmd}}" --redcon 3 --thing-name "{{thing_name}}" --sparkplug-group-id "$sparkplug_group_id" --sparkplug-edge-node-id "$sparkplug_edge_node_id"

@sleep sparkplug_group_id='' sparkplug_edge_node_id='' region=region aws_profile=aws_profile:
    #!/usr/bin/env bash
    set -euo pipefail
    test -x "{{built_rig_sparkplug_cmd}}" || { \
        echo "Missing built rig Sparkplug command executable at {{built_rig_sparkplug_cmd}}. Run 'just rig::build' first." >&2; \
        exit 1; \
    }
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig "{{region}}" "{{aws_profile}}")"
    sparkplug_group_id="$SPARKPLUG_GROUP_ID"
    sparkplug_edge_node_id="$SPARKPLUG_EDGE_NODE_ID"
    if [ -n "{{sparkplug_group_id}}" ]; then
      sparkplug_group_id="{{sparkplug_group_id}}"
    fi
    if [ -n "{{sparkplug_edge_node_id}}" ]; then
      sparkplug_edge_node_id="{{sparkplug_edge_node_id}}"
    fi
    cd "{{rig_dir}}" && "{{built_rig_sparkplug_cmd}}" --redcon 4 --thing-name "{{thing_name}}" --sparkplug-group-id "$sparkplug_group_id" --sparkplug-edge-node-id "$sparkplug_edge_node_id"

@dcmd sparkplug_group_id='' sparkplug_edge_node_id='' region=region aws_profile=aws_profile:
    #!/usr/bin/env bash
    set -euo pipefail
    test -x "{{built_rig_sparkplug_log}}" || { \
        echo "Missing built rig Sparkplug log executable at {{built_rig_sparkplug_log}}. Run 'just rig::build' first." >&2; \
        exit 1; \
    }
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig "{{region}}" "{{aws_profile}}")"
    sparkplug_group_id="$SPARKPLUG_GROUP_ID"
    sparkplug_edge_node_id="$SPARKPLUG_EDGE_NODE_ID"
    if [ -n "{{sparkplug_group_id}}" ]; then
      sparkplug_group_id="{{sparkplug_group_id}}"
    fi
    if [ -n "{{sparkplug_edge_node_id}}" ]; then
      sparkplug_edge_node_id="{{sparkplug_edge_node_id}}"
    fi
    cd "{{rig_dir}}" && "{{built_rig_sparkplug_log}}" --thing-name "{{thing_name}}" --sparkplug-group-id "$sparkplug_group_id" --sparkplug-edge-node-id "$sparkplug_edge_node_id" --message-type dcmd

@ddata sparkplug_group_id='' sparkplug_edge_node_id='' region=region aws_profile=aws_profile:
    #!/usr/bin/env bash
    set -euo pipefail
    test -x "{{built_rig_sparkplug_log}}" || { \
        echo "Missing built rig Sparkplug log executable at {{built_rig_sparkplug_log}}. Run 'just rig::build' first." >&2; \
        exit 1; \
    }
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig "{{region}}" "{{aws_profile}}")"
    sparkplug_group_id="$SPARKPLUG_GROUP_ID"
    sparkplug_edge_node_id="$SPARKPLUG_EDGE_NODE_ID"
    if [ -n "{{sparkplug_group_id}}" ]; then
      sparkplug_group_id="{{sparkplug_group_id}}"
    fi
    if [ -n "{{sparkplug_edge_node_id}}" ]; then
      sparkplug_edge_node_id="{{sparkplug_edge_node_id}}"
    fi
    cd "{{rig_dir}}" && "{{built_rig_sparkplug_log}}" --thing-name "{{thing_name}}" --sparkplug-group-id "$sparkplug_group_id" --sparkplug-edge-node-id "$sparkplug_edge_node_id" --message-type ddata

@print:
    #!/usr/bin/env bash
    set -euo pipefail
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig "{{region}}" "{{aws_profile}}")"
    region="$AWS_REGION"
    aws_profile="$AWS_SELECTED_PROFILE"
    aws_flags=(--region "$region")
    if [ -n "$aws_profile" ]; then
      aws_flags+=(--profile "$aws_profile")
    fi
    endpoint="$(aws iot describe-endpoint --endpoint-type iot:Data-ATS "${aws_flags[@]}" --query endpointAddress --output text)"
    aws iot-data get-thing-shadow \
      --region "$region" \
      --endpoint-url "https://$endpoint" \
      --thing-name "{{thing_name}}" \
      /dev/stdout | jq '.'

@install-service rig_name='' sparkplug_group_id='' sparkplug_edge_node_id='' region=region aws_profile=aws_profile aws_shared_credentials_file=aws_shared_credentials_file aws_config_file=aws_config_file cloudwatch_log_group='':
    #!/usr/bin/env bash
    set -euo pipefail
    test -x "{{built_rig}}" || { \
        echo "Missing built rig executable at {{built_rig}}. Run 'just build' first." >&2; \
        exit 1; \
    }
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig "{{region}}" "{{aws_profile}}" "" "" "" "{{aws_shared_credentials_file}}" "{{aws_config_file}}")"
    project_root="$TXING_PROJECT_ROOT"
    env_file="$AWS_ENV_FILE"
    region="$AWS_REGION"
    aws_profile="$AWS_SELECTED_PROFILE"
    aws_shared_credentials_file="$AWS_SHARED_CREDENTIALS_FILE"
    aws_config_file="$AWS_CONFIG_FILE"
    rig_name="$RIG_NAME"
    sparkplug_group_id="$SPARKPLUG_GROUP_ID"
    sparkplug_edge_node_id="$SPARKPLUG_EDGE_NODE_ID"
    cloudwatch_log_group="$CLOUDWATCH_LOG_GROUP"
    if [ -n "{{rig_name}}" ]; then \
        rig_name="{{rig_name}}"; \
    fi; \
    if [ -n "{{sparkplug_group_id}}" ]; then \
        sparkplug_group_id="{{sparkplug_group_id}}"; \
    fi; \
    if [ -n "{{sparkplug_edge_node_id}}" ]; then \
        sparkplug_edge_node_id="{{sparkplug_edge_node_id}}"; \
    fi; \
    if [ -n "{{cloudwatch_log_group}}" ]; then \
        cloudwatch_log_group="{{cloudwatch_log_group}}"; \
    fi; \
    sudo systemctl enable --now bluetooth
    run_user="$(id -un)"; \
    service_env=(); \
    if [ -n "{{rig_name}}" ]; then \
        service_env+=("Environment=\"RIG_NAME=$rig_name\""); \
    fi; \
    if [ -n "{{sparkplug_group_id}}" ]; then \
        service_env+=("Environment=\"SPARKPLUG_GROUP_ID=$sparkplug_group_id\""); \
    fi; \
    if [ -n "{{sparkplug_edge_node_id}}" ]; then \
        service_env+=("Environment=\"SPARKPLUG_EDGE_NODE_ID=$sparkplug_edge_node_id\""); \
    fi; \
    if [ -n "{{cloudwatch_log_group}}" ]; then \
        service_env+=("Environment=\"CLOUDWATCH_LOG_GROUP=$cloudwatch_log_group\""); \
    fi; \
    if [ -n "{{region}}" ] && [ -n "$region" ]; then \
        service_env+=("Environment=\"AWS_REGION=$region\""); \
    fi; \
    if [ -n "{{aws_profile}}" ] && [ -n "$aws_profile" ]; then \
        service_env+=("Environment=\"AWS_PROFILE=$aws_profile\""); \
    fi; \
    if [ -n "{{aws_shared_credentials_file}}" ] && [ -n "$aws_shared_credentials_file" ]; then \
        service_env+=("Environment=\"AWS_SHARED_CREDENTIALS_FILE=$aws_shared_credentials_file\""); \
    fi; \
    if [ -n "{{aws_config_file}}" ] && [ -n "$aws_config_file" ]; then \
        service_env+=("Environment=\"AWS_CONFIG_FILE=$aws_config_file\""); \
    fi; \
    { \
        printf '%s\n' \
            '[Unit]' \
            'Description=txing rig lifecycle runtime' \
            'After=network-online.target bluetooth.target' \
            'Wants=network-online.target bluetooth.target' \
            '' \
            '[Service]' \
            'Type=simple' \
            "User=$run_user" \
            "WorkingDirectory=$project_root" \
            "EnvironmentFile=$env_file"; \
        printf '%s\n' "${service_env[@]}"; \
        printf '%s\n' \
            'ExecStart={{built_rig}}' \
            'Restart=always' \
            'RestartSec=3' \
            '' \
            '[Install]' \
            'WantedBy=multi-user.target'; \
    } | sudo tee "{{systemd_unit}}" >/dev/null
    sudo systemctl daemon-reload
    sudo systemctl enable --now rig
