        exit 1; \
    }
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig "{{region}}" "{{aws_profile}}")"
    sparkplug_group_id="$SPARKPLUG_GROUP_ID"
    sparkplug_edge_node_id="$SPARKPLUG_EDGE_NODE_ID"
    if [ -n "{{sparkplug_group_id}}" ]; then
      sparkplug_group_id="{{sparkplug_group_id}}"
    fi
    if [ -n "{{sparkplug_edge_node_id}}" ]; then
      sparkplug_edge_node_id="{{sparkplug_edge_node_id}}"
    fi
    cd "{{rig_dir}}" && "{{built_rig_sparkplug_log}}" --thing-name "{{thing_name}}" --sparkplug-group-id "$sparkplug_group_id" --sparkplug-edge-node-id "$sparkplug_edge_node_id" --message-type ddata

@print shadow_name='sparkplug':
    #!/usr/bin/env bash
    set -euo pipefail
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig "{{region}}" "{{aws_profile}}")"
    region="$AWS_REGION"
    aws_profile="$AWS_SELECTED_PROFILE"
    aws_flags=(--region "$region")
    if [ -n "$aws_profile" ]; then
      aws_flags+=(--profile "$aws_profile")
    fi
    endpoint="$(aws iot describe-endpoint --endpoint-type iot:Data-ATS "${aws_flags[@]}" --query endpointAddress --output text)"
    aws iot-data get-thing-shadow \
      --region "$region" \
      --endpoint-url "https://$endpoint" \
      --thing-name "{{thing_name}}" \
      --shadow-name "{{shadow_name}}" \
      /dev/stdout | jq '.'

@install-service rig_id='' rig_name='' sparkplug_group_id='' sparkplug_edge_node_id='' region=region aws_profile=aws_profile aws_shared_credentials_file=aws_shared_credentials_file cloudwatch_log_group='':
    #!/usr/bin/env bash
    set -euo pipefail
    for built_entrypoint in "{{built_rig}}" "{{built_rig_device_process}}"; do \
        if [ ! -x "$built_entrypoint" ]; then \
            echo "Missing built rig entrypoint at $built_entrypoint. Run 'just rig::build' before 'just rig::install-service'." >&2; \
            exit 1; \
        fi; \
    done
    if [ -n "{{rig_id}}" ]; then
      export TXING_RIG_ID="{{rig_id}}"
    fi
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig "{{region}}" "{{aws_profile}}" "" "" "" "{{aws_shared_credentials_file}}")"
    region="$AWS_REGION"
    profile="$AWS_SELECTED_PROFILE"
    aws_flags=(--region "$region")
    if [ -n "$profile" ]; then \
        aws_flags+=(--profile "$profile"); \
    fi
    rig_name="$RIG_NAME"
    selected_rig_type="$RIG_TYPE"
    sparkplug_group_id="$SPARKPLUG_GROUP_ID"
    sparkplug_edge_node_id="$SPARKPLUG_EDGE_NODE_ID"
    if [ -n "{{rig_name}}" ]; then \
        rig_name="{{rig_name}}"; \
    fi; \
    if [ -n "{{sparkplug_group_id}}" ]; then \
        sparkplug_group_id="{{sparkplug_group_id}}"; \
    fi; \
    if [ -n "{{sparkplug_edge_node_id}}" ]; then \
        sparkplug_edge_node_id="{{sparkplug_edge_node_id}}"; \
    fi; \
    if [ ! -d "{{greengrass_lite_build_dir}}" ]; then \
        echo "Greengrass Lite native build is missing at {{greengrass_lite_build_dir}}." >&2; \
        echo "Run 'just rig::build-native' before 'just rig::install-service'." >&2; \
        exit 1; \
    fi
    if ! getent group ggcore >/dev/null; then \
        sudo groupadd --system ggcore; \
    fi
    if ! id -u ggcore >/dev/null 2>&1; then \
        sudo useradd --system --gid ggcore --home-dir /var/lib/greengrass --shell /usr/sbin/nologin ggcore; \
    fi
    if ! getent group gg_component >/dev/null; then \
        sudo groupadd --system gg_component; \
    fi
    if ! id -u gg_component >/dev/null 2>&1; then \
        sudo useradd --system --gid gg_component --home-dir /var/lib/greengrass/component --shell /usr/sbin/nologin gg_component; \
    fi
    rig_cert_path="{{project_root}}/config/certs/rig/rig.cert.pem"
    rig_private_key_path="{{project_root}}/config/certs/rig/rig.private.key"
    if [ ! -f "$rig_cert_path" ] || [ ! -f "$rig_private_key_path" ]; then \
        echo "Rig certificate material is missing under {{project_root}}/config/certs/rig." >&2; \
        echo "Run 'just aws::cert' before 'just rig::install-service'." >&2; \
        exit 1; \
    fi
    rig_thing_name="$TXING_RIG_ID"
    iot_data_endpoint="$(aws iot describe-endpoint --endpoint-type iot:Data-ATS "${aws_flags[@]}" --query endpointAddress --output text)"
    iot_cred_endpoint="$(aws iot describe-endpoint --endpoint-type iot:CredentialProvider "${aws_flags[@]}" --query endpointAddress --output text)"
    iot_role_alias="$(
        aws cloudformation describe-stacks \
          --stack-name "$AWS_STACK_NAME" \
          "${aws_flags[@]}" \
          --query "Stacks[0].Outputs[?OutputKey=='GreengrassTokenExchangeRoleAlias'].OutputValue | [0]" \
          --output text
    )"
    if [ -z "$iot_role_alias" ] || [ "$iot_role_alias" = "None" ]; then \
        echo "Could not resolve GreengrassTokenExchangeRoleAlias from stack $AWS_STACK_NAME." >&2; \
        exit 1; \
    fi
    temp_files=()
    cleanup_temp_files() {
        if [ "${#temp_files[@]}" -gt 0 ]; then
            rm -f "${temp_files[@]}"
        fi
    }
    trap cleanup_temp_files EXIT
    sudo mkdir -p /var/lib/greengrass /etc/greengrass
    sudo install -d -o ggcore -g ggcore -m 700 /var/lib/greengrass/credentials
    sudo install -o ggcore -g ggcore -m 600 "$rig_cert_path" /var/lib/greengrass/credentials/rig.cert.pem
    sudo install -o ggcore -g ggcore -m 600 "$rig_private_key_path" /var/lib/greengrass/credentials/rig.private.key
    root_ca_temp="$(mktemp "${TMPDIR:-/tmp}/txing-amazon-root-ca.XXXXXX")"
    temp_files+=("$root_ca_temp")
    curl -fsSL https://www.amazontrust.com/repository/AmazonRootCA1.pem -o "$root_ca_temp"
    sudo install -o ggcore -g ggcore -m 644 "$root_ca_temp" /var/lib/greengrass/credentials/AmazonRootCA1.pem
    greengrass_config_temp="$(mktemp "${TMPDIR:-/tmp}/txing-greengrass-config.XXXXXX")"
    temp_files+=("$greengrass_config_temp")
    cat >"$greengrass_config_temp" <<EOF
    system:
      privateKeyPath: "/var/lib/greengrass/credentials/rig.private.key"
      certificateFilePath: "/var/lib/greengrass/credentials/rig.cert.pem"
      rootCaPath: "/var/lib/greengrass/credentials/AmazonRootCA1.pem"
      rootPath: "/var/lib/greengrass"
      thingName: "$rig_thing_name"
    services:
      aws.greengrass.NucleusLite:
        componentType: "NUCLEUS"
        configuration:
          awsRegion: "$region"
          iotCredEndpoint: "$iot_cred_endpoint"
          iotDataEndpoint: "$iot_data_endpoint"
          iotRoleAlias: "$iot_role_alias"
          runWithDefault:
            posixUser: "gg_component:gg_component"
          greengrassDataPlanePort: "8443"
          platformOverride: {}
    EOF
    sudo install -m 644 "$greengrass_config_temp" /etc/greengrass/config.yaml
    sudo chown -R ggcore:ggcore /var/lib/greengrass
    sudo cmake --install "{{greengrass_lite_build_dir}}" --config MinSizeRel
    sudo "{{greengrass_lite_dir}}/misc/run_nucleus"
    printf 'txing rig is supervised by the standard Greengrass Lite systemd target %s\n' "{{greengrass_lite_target}}"
    printf 'Deploy rig type %s components with RigName=%s SparkplugGroupId=%s SparkplugEdgeNodeId=%s\n' "$selected_rig_type" "$rig_name" "$sparkplug_group_id" "$sparkplug_edge_node_id"

@start rig_id='':
    #!/usr/bin/env bash
    set -euo pipefail
    if [ -n "{{rig_id}}" ]; then
      export TXING_RIG_ID="{{rig_id}}"
    fi
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig)"
    selected_rig_type="$RIG_TYPE"
    if ! systemctl cat "{{greengrass_lite_target}}" >/dev/null 2>&1; then \
        echo "Greengrass Lite target {{greengrass_lite_target}} is not installed. Run 'just rig::install-service' first." >&2; \
        exit 1; \
    fi
    unit_exists() {
      systemctl cat "$1" >/dev/null 2>&1
    }
    start_unit_if_present() {
      local unit="$1"
      if unit_exists "$unit"; then
        sudo systemctl start "$unit" || true
      fi
    }
    wait_active_if_present() {
      local unit="$1"
      if ! unit_exists "$unit"; then
        return 0
      fi
      for _attempt in $(seq 1 30); do
        if systemctl is-active --quiet "$unit"; then
          return 0
        fi
        sleep 1
      done
      return 1
    }
    case "$selected_rig_type" in
      raspi)
        component_units=({{unit_rig_component_units}})
        ;;
      cloud)
        component_units=({{aws_rig_component_units}})
        ;;
      *)
        echo "Unsupported RIG_TYPE=$selected_rig_type. Supported rig types: raspi, cloud." >&2
        exit 1
        ;;
    esac
    reset_units=("{{greengrass_lite_target}}")
    for unit in "${component_units[@]}"; do
      if unit_exists "$unit"; then
        reset_units+=("$unit")
      fi
    done
    sudo systemctl reset-failed "${reset_units[@]}" || true
    sudo systemctl start "{{greengrass_lite_target}}"
    core_units=({{greengrass_core_units}})
    for unit in "${core_units[@]}"; do
      wait_active_if_present "$unit" || true
    done
    for unit in "${component_units[@]}"; do
      if unit_exists "$unit"; then
        start_unit_if_present "$unit"
        wait_active_if_present "$unit" || true
      fi
    done
    status_units=("{{greengrass_lite_target}}")
    for unit in "${core_units[@]}" "${component_units[@]}"; do
      if unit_exists "$unit"; then
        status_units+=("$unit")
      fi
    done
    sudo systemctl --no-pager --full status "${status_units[@]}"

@stop rig_id='':
    #!/usr/bin/env bash
    set -euo pipefail
    if [ -n "{{rig_id}}" ]; then
      export TXING_RIG_ID="{{rig_id}}"
    fi
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig)"
    selected_rig_type="$RIG_TYPE"
    if ! systemctl cat "{{greengrass_lite_target}}" >/dev/null 2>&1; then \
        echo "Greengrass Lite target {{greengrass_lite_target}} is not installed. Run 'just rig::install-service' first." >&2; \
        exit 1; \
    fi
    unit_exists() {
      systemctl cat "$1" >/dev/null 2>&1
    }
    case "$selected_rig_type" in
      raspi)
        component_units=({{unit_rig_component_units}})
        ;;
      cloud)
        component_units=({{aws_rig_component_units}})
        ;;
      *)
        echo "Unsupported RIG_TYPE=$selected_rig_type. Supported rig types: raspi, cloud." >&2
        exit 1
        ;;
    esac
    stop_units=()
    for unit in "${component_units[@]}"; do
      if unit_exists "$unit"; then
        stop_units+=("$unit")
      fi
    done
    if [ "${#stop_units[@]}" -gt 0 ]; then
      sudo systemctl stop "${stop_units[@]}" || true
    fi
    sudo systemctl stop "{{greengrass_lite_target}}"
    core_units=({{greengrass_core_units}})
    status_units=("{{greengrass_lite_target}}")
    for unit in "${core_units[@]}" "${component_units[@]}"; do
      if unit_exists "$unit"; then
        status_units+=("$unit")
      fi
    done
    sudo systemctl --no-pager --full status "${status_units[@]}" || true

@restart: stop start

@log rig_id='' lines='200' follow='true':
    #!/usr/bin/env bash
    set -euo pipefail
    if [ -n "{{rig_id}}" ]; then
      export TXING_RIG_ID="{{rig_id}}"
    fi
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig)"
    selected_rig_type="$RIG_TYPE"
    case "{{lines}}" in
      ''|*[!0-9]*)
        echo "lines must be a positive integer." >&2
        exit 1
        ;;
    esac
    if [ "{{lines}}" -le 0 ]; then
      echo "lines must be a positive integer." >&2
      exit 1
    fi
    if ! systemctl cat "{{greengrass_lite_target}}" >/dev/null 2>&1; then \
        echo "Greengrass Lite target {{greengrass_lite_target}} is not installed. Run 'just rig::install-service' first." >&2; \
        exit 1; \
    fi
    unit_exists() {
      systemctl cat "$1" >/dev/null 2>&1
    }
    case "$selected_rig_type" in
      raspi)
        component_units=({{unit_rig_component_units}})
        ;;
      cloud)
        component_units=({{aws_rig_component_units}})
        ;;
      *)
        echo "Unsupported RIG_TYPE=$selected_rig_type. Supported rig types: raspi, cloud." >&2
        exit 1
        ;;
    esac
    core_units=({{greengrass_core_units}})
    log_units=("{{greengrass_lite_target}}")
    for unit in "${core_units[@]}" "${component_units[@]}"; do
      if unit_exists "$unit"; then
        log_units+=("$unit")
      fi
    done
    journal_unit_args=()
    for unit in "${log_units[@]}"; do
      journal_unit_args+=(-u "$unit")
    done
    journal_flags=(-a -n "{{lines}}")
    case "{{follow}}" in
      true|1|yes|on)
        journal_flags+=(-f)
        ;;
      false|0|no|off)
        journal_flags+=(--no-pager)
        ;;
      *)
        echo "follow must be true or false." >&2
        exit 1
        ;;
    esac
    printf 'showing rig logs for RIG_TYPE=%s units:\n' "$selected_rig_type"
    printf '  %s\n' "${log_units[@]}"
    sudo journalctl "${journal_flags[@]}" "${journal_unit_args[@]}"

@deploy rig_id='' rig_name='' sparkplug_group_id='' sparkplug_edge_node_id='' component_version='' adapter_id='ble-main' name_fragment='txing' region=region aws_profile=aws_profile aws_shared_credentials_file=aws_shared_credentials_file: build
    #!/usr/bin/env bash
    set -euo pipefail
    for built_entrypoint in "{{built_rig}}" "{{built_rig_device_process}}"; do \
        if [ ! -x "$built_entrypoint" ]; then \
            echo "Missing built rig entrypoint at $built_entrypoint. Run 'just rig::build' before 'just rig::deploy'." >&2; \
            exit 1; \
        fi; \
    done
    for positional_arg in "{{rig_id}}" "{{rig_name}}" "{{sparkplug_group_id}}" "{{sparkplug_edge_node_id}}" "{{component_version}}" "{{adapter_id}}" "{{name_fragment}}"; do
      case "$positional_arg" in
        *=*)
          echo "rig::deploy arguments are positional; '$positional_arg' was treated as an argument value, not a named option." >&2
          echo "Use TXING_RIG_COMPONENT_VERSION=0.5.1 just rig::deploy, or pass positional args as: just rig::deploy '' '' '' 0.5.1" >&2
          exit 1
          ;;
      esac
    done
    if [ -n "{{rig_id}}" ]; then
      export TXING_RIG_ID="{{rig_id}}"
    fi
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig "{{region}}" "{{aws_profile}}" "" "" "" "{{aws_shared_credentials_file}}")"
    region="$AWS_REGION"
    profile="$AWS_SELECTED_PROFILE"
    aws_flags=(--region "$region")
    if [ -n "$profile" ]; then \
        aws_flags+=(--profile "$profile"); \
    fi
    if ! systemctl is-active --quiet "{{greengrass_lite_target}}"; then \
        echo "Greengrass Lite target {{greengrass_lite_target}} is not active. Run 'just rig::install-service' first." >&2; \
        exit 1; \
    fi
    ggl_cli="$(command -v ggl-cli || true)"
    if [ -z "$ggl_cli" ] && [ -x /usr/local/bin/ggl-cli ]; then \
        ggl_cli=/usr/local/bin/ggl-cli; \
    fi
    if [ -z "$ggl_cli" ]; then \
        echo "Missing ggl-cli. Run 'just rig::install-service' to install Greengrass Lite." >&2; \
        exit 1; \
    fi
    rig_name="$RIG_NAME"
    selected_rig_type="$RIG_TYPE"
    sparkplug_group_id="$SPARKPLUG_GROUP_ID"
    sparkplug_edge_node_id="$SPARKPLUG_EDGE_NODE_ID"
    if [ -n "{{rig_name}}" ]; then \
        rig_name="{{rig_name}}"; \
    fi; \
    if [ -n "{{sparkplug_group_id}}" ]; then \
        sparkplug_group_id="{{sparkplug_group_id}}"; \
    fi; \
    if [ -n "{{sparkplug_edge_node_id}}" ]; then \
        sparkplug_edge_node_id="{{sparkplug_edge_node_id}}"; \
    fi; \
    resolved_component_version="${TXING_RIG_COMPONENT_VERSION:-{{component_version}}}"
    if [ -z "$resolved_component_version" ]; then \
        resolved_component_version="0.5.0"; \
    fi
    case "$selected_rig_type" in
      raspi)
        device_type="unit"
        device_python_project="{{project_root}}/devices/unit/rig/python"
        device_wheel_prefix="unit_rig"
        sparkplug_component="dev.txing.device.unit.SparkplugManager"
        connectivity_component="dev.txing.device.unit.ConnectivityBle"
        legacy_components=(dev.txing.rig.SparkplugManager dev.txing.rig.ConnectivityBle)
        sparkplug_module="unit_rig.sparkplug_manager"
        connectivity_module="unit_rig.connectivity_ble"
        connectivity_description="txing rig BLE connectivity adapter for MCU rendezvous and GATT power control."
        connectivity_requires_privilege="true"
        connectivity_extra_args=(--adapter-id "{{adapter_id}}" --name "{{name_fragment}}")
        ;;
      cloud)
        device_type="time"
        device_python_project="{{project_root}}/devices/time/rig/python"
        device_wheel_prefix="time_rig"
        sparkplug_component="dev.txing.device.time.SparkplugManager"
        connectivity_component="dev.txing.device.time.AwsConnectivity"
        legacy_components=()
        sparkplug_module="time_rig.sparkplug_manager"
        connectivity_module="time_rig.aws_connectivity"
        connectivity_description="txing virtual time AWS IoT MQTT connectivity bridge."
        connectivity_requires_privilege="false"
        connectivity_extra_args=()
        ;;
      *)
        echo "Unsupported rig type '$selected_rig_type'. Supported rig types: raspi, cloud." >&2
        exit 1
        ;;
    esac
    iot_data_endpoint="$(aws iot describe-endpoint --endpoint-type iot:Data-ATS "${aws_flags[@]}" --query endpointAddress --output text)"
    deploy_root="{{rig_dir}}/build/greengrass-local"
    staging_root="$(mktemp -d "${TMPDIR:-/tmp}/txing-greengrass-stage.XXXXXX")"
    cleanup_staging_root() {
        rm -rf "$staging_root"
    }
    trap cleanup_staging_root EXIT
    recipe_dir="$deploy_root/recipes"
    artifacts_dir="$deploy_root/artifacts"
    wheelhouse_dir="$staging_root/wheelhouse"
    python_tree_dir="$staging_root/python"
    requirements_file="$staging_root/requirements.txt"
    rm -rf "$deploy_root"
    mkdir -p "$recipe_dir" "$artifacts_dir" "$wheelhouse_dir" "$python_tree_dir"
    uv build --wheel --out-dir "$wheelhouse_dir" "{{project_root}}/shared/aws/python" >/dev/null
    uv build --wheel --out-dir "$wheelhouse_dir" "$device_python_project" >/dev/null
    uv build --wheel --out-dir "$wheelhouse_dir" "{{rig_dir}}" >/dev/null
    uv export \
      --project "$device_python_project" \
      --format requirements.txt \
      --no-dev \
      --no-editable \
      --no-hashes \
      | awk 'NF && $0 !~ /^[[:space:]]*#/ && $0 !~ /^\./ && $0 !~ /^\.\.\//' >"$requirements_file"
    uv pip install \
      --python "{{python_executable}}" \
      --target "$python_tree_dir" \
      --compile-bytecode \
      --reinstall \
      --find-links "$wheelhouse_dir" \
      --requirements "$requirements_file" \
      "$wheelhouse_dir"/aws-*.whl \
      "$wheelhouse_dir"/"$device_wheel_prefix"-*.whl \
      "$wheelhouse_dir"/rig-*.whl >/dev/null
    for component_name in "$sparkplug_component" "$connectivity_component"; do \
        component_artifact_dir="$artifacts_dir/$component_name/$resolved_component_version"; \
        mkdir -p "$component_artifact_dir/python"; \
        cp -a "$python_tree_dir/." "$component_artifact_dir/python/"; \
        mkdir -p "$component_artifact_dir/devices/$device_type"; \
        cp "{{project_root}}/devices/$device_type/manifest.toml" "$component_artifact_dir/devices/$device_type/"; \
        cp -a "{{project_root}}/devices/$device_type/aws" "$component_artifact_dir/devices/$device_type/aws"; \
        printf 'txing local Greengrass artifact for %s %s\n' "$component_name" "$resolved_component_version" >"$component_artifact_dir/txing-local-artifact.txt"; \
    done
    cat >"$recipe_dir/$sparkplug_component-$resolved_component_version.yaml" <<EOF
    RecipeFormatVersion: '2020-01-25'
    ComponentName: $sparkplug_component
    ComponentVersion: '$resolved_component_version'
    ComponentType: aws.greengrass.generic
    ComponentDescription: txing rig Sparkplug lifecycle manager for rig type $selected_rig_type.
    ComponentPublisher: txing
    ComponentDependencies:
      aws.greengrass.TokenExchangeService:
        VersionRequirement: '>=0.0.0'
        DependencyType: HARD
    ComponentConfiguration:
      DefaultConfiguration:
        accessControl:
          aws.greengrass.ipc.pubsub:
            $sparkplug_component:pubsub:1:
              policyDescription: Allows the Sparkplug manager to exchange local connectivity messages with rig adapters.
              operations:
                - aws.greengrass#PublishToTopic
                - aws.greengrass#SubscribeToTopic
              resources:
                - dev/txing/rig/v1/connectivity/*
    Manifests:
      - Platform:
          os: linux
          runtime: aws_nucleus_lite
        Lifecycle:
          run:
            Script: |-
              export AWS_REGION="$AWS_REGION"
              export AWS_DEFAULT_REGION="$AWS_REGION"
              unset AWS_PROFILE AWS_DEFAULT_PROFILE AWS_SHARED_CREDENTIALS_FILE
              export RIG_NAME="$rig_name"
              export TXING_RIG_ID="$TXING_RIG_ID"
              export RIG_ID="$TXING_RIG_ID"
              export SPARKPLUG_GROUP_ID="$sparkplug_group_id"
              export SPARKPLUG_EDGE_NODE_ID="$sparkplug_edge_node_id"
              export AWS_IOT_ENDPOINT="$iot_data_endpoint"
              export TXING_RIG_TYPE="$selected_rig_type"
              export RIG_TYPE="$selected_rig_type"
              export TXING_DEVICE_TYPE="$device_type"
              export TXING_DEVICE_DIR="{artifacts:path}/devices/$device_type"
              export TXING_DEVICE_MANIFEST="{artifacts:path}/devices/$device_type/manifest.toml"
              export PYTHONPATH="{artifacts:path}/python"
              exec python3 -m $sparkplug_module
        Artifacts:
          - Uri: "s3://txing-local-greengrass/txing-local-artifact.txt"
            Unarchive: "NONE"
    EOF
    if [ "$connectivity_requires_privilege" = "true" ]; then
      connectivity_privilege_line="        RequiresPrivilege: true"
    else
      connectivity_privilege_line=""
    fi
    connectivity_command="exec python3 -m $connectivity_module"
    for arg in "${connectivity_extra_args[@]}"; do
      printf -v quoted_arg '%q' "$arg"
      connectivity_command="$connectivity_command $quoted_arg"
    done
    cat >"$recipe_dir/$connectivity_component-$resolved_component_version.yaml" <<EOF
    RecipeFormatVersion: '2020-01-25'
    ComponentName: $connectivity_component
    ComponentVersion: '$resolved_component_version'
    ComponentType: aws.greengrass.generic
    ComponentDescription: $connectivity_description
    ComponentPublisher: txing
    ComponentDependencies:
      aws.greengrass.TokenExchangeService:
        VersionRequirement: '>=0.0.0'
        DependencyType: HARD
    ComponentConfiguration:
      DefaultConfiguration:
        accessControl:
          aws.greengrass.ipc.pubsub:
            $connectivity_component:pubsub:1:
              policyDescription: Allows the connectivity adapter to exchange local connectivity messages with the Sparkplug manager.
              operations:
                - aws.greengrass#PublishToTopic
                - aws.greengrass#SubscribeToTopic
              resources:
                - dev/txing/rig/v1/connectivity/*
    Manifests:
      - Platform:
          os: linux
          runtime: aws_nucleus_lite
        Lifecycle:
          run:
    $connectivity_privilege_line
            Script: |-
              export AWS_REGION="$AWS_REGION"
              export AWS_DEFAULT_REGION="$AWS_REGION"
              unset AWS_PROFILE AWS_DEFAULT_PROFILE AWS_SHARED_CREDENTIALS_FILE
              export RIG_NAME="$rig_name"
              export TXING_RIG_ID="$TXING_RIG_ID"
              export RIG_ID="$TXING_RIG_ID"
              export SPARKPLUG_GROUP_ID="$sparkplug_group_id"
              export SPARKPLUG_EDGE_NODE_ID="$sparkplug_edge_node_id"
              export AWS_IOT_ENDPOINT="$iot_data_endpoint"
              export TXING_RIG_TYPE="$selected_rig_type"
              export RIG_TYPE="$selected_rig_type"
              export TXING_DEVICE_TYPE="$device_type"
              export TXING_DEVICE_DIR="{artifacts:path}/devices/$device_type"
              export TXING_DEVICE_MANIFEST="{artifacts:path}/devices/$device_type/manifest.toml"
              export PYTHONPATH="{artifacts:path}/python"
              $connectivity_command
        Artifacts:
          - Uri: "s3://txing-local-greengrass/txing-local-artifact.txt"
            Unarchive: "NONE"
    EOF
    deploy_args=(
      --recipe-dir "$recipe_dir" \
      --artifacts-dir "$artifacts_dir" \
      --add-component "$sparkplug_component=$resolved_component_version" \
      --add-component "$connectivity_component=$resolved_component_version"
    )
    for legacy_component in "${legacy_components[@]}"; do
      legacy_unit="ggl.$legacy_component.service"
      if systemctl cat "$legacy_unit" >/dev/null 2>&1; then
        deploy_args+=(--remove-component "$legacy_component")
      fi
    done
    sudo "$ggl_cli" deploy "${deploy_args[@]}"
    printf 'deployed Greengrass components version %s for RigName=%s RigType=%s SparkplugGroupId=%s SparkplugEdgeNodeId=%s\n' "$resolved_component_version" "$rig_name" "$selected_rig_type" "$sparkplug_group_id" "$sparkplug_edge_node_id"
    printf 'inspect rig logs with: just rig::log\n'
