log rig_id='' lines='200' follow='true':
    #!/usr/bin/env bash
    set -euo pipefail
    if [ "$(uname -s)" = "Darwin" ]; then
      exec just --justfile "{{rig_dir}}/justfile" _local-log "{{lines}}" "{{follow}}"
    fi
    if [ -n "{{rig_id}}" ]; then
      export TXING_RIG_ID="{{rig_id}}"
    fi
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig)"
    selected_rig_type="$RIG_TYPE"
    case "{{lines}}" in
      ''|*[!0-9]*)
        echo "lines must be a positive integer." >&2
        exit 1
        ;;
    esac
    if [ "{{lines}}" -le 0 ]; then
      echo "lines must be a positive integer." >&2
      exit 1
    fi
    if ! systemctl cat "{{greengrass_lite_target}}" >/dev/null 2>&1; then \
        echo "Greengrass Lite target {{greengrass_lite_target}} is not installed. Run 'just rig::install-service' first." >&2; \
        exit 1; \
    fi
    unit_exists() {
      systemctl cat "$1" >/dev/null 2>&1
    }
    case "$selected_rig_type" in
      raspi)
        component_units=({{raspi_rig_component_units}})
        ;;
      cloud)
        component_units=({{aws_rig_component_units}})
        ;;
      *)
        echo "Unsupported RIG_TYPE=$selected_rig_type. Supported rig types: raspi, cloud." >&2
        exit 1
        ;;
    esac
    core_units=({{greengrass_core_units}})
    core_sockets=({{greengrass_core_sockets}})
    log_units=("{{greengrass_lite_target}}")
    for unit in "${core_sockets[@]}" "${core_units[@]}" "${component_units[@]}"; do
      if unit_exists "$unit"; then
        log_units+=("$unit")
      fi
    done
    journal_unit_args=()
    for unit in "${log_units[@]}"; do
      journal_unit_args+=(-u "$unit")
    done
    journal_flags=(-a -n "{{lines}}")
    case "{{follow}}" in
      true|1|yes|on)
        journal_flags+=(-f)
        ;;
      false|0|no|off)
        journal_flags+=(--no-pager)
        ;;
      *)
        echo "follow must be true or false." >&2
        exit 1
        ;;
    esac
    printf 'showing rig logs for RIG_TYPE=%s units:\n' "$selected_rig_type"
    printf '  %s\n' "${log_units[@]}"
    sudo journalctl "${journal_flags[@]}" "${journal_unit_args[@]}"

deploy target='all' component_version='' region=region aws_profile=aws_profile aws_shared_credentials_file=aws_shared_credentials_file:
    #!/usr/bin/env bash
    set -euo pipefail
    case "{{target}}" in
      raspi|cloud|all) ;;
      *)
        echo "target must be raspi, cloud, or all." >&2
        exit 1
        ;;
    esac
    if [ "$(uname -s)" != "Linux" ]; then
      echo "rig::deploy builds Linux Greengrass component binaries; run it on a Linux builder or rig host." >&2
      echo "This deploy path publishes to AWS Greengrass and does not use host-local ggl-cli deploy state." >&2
      exit 1
    fi
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env aws "{{region}}" "{{aws_profile}}" "" "" "" "{{aws_shared_credentials_file}}")"
    region="$AWS_REGION"
    profile="$AWS_SELECTED_PROFILE"
    aws_flags=(--region "$region")
    if [ -n "$profile" ]; then
      aws_flags+=(--profile "$profile")
    fi
    resolved_component_version="{{component_version}}"
    if [ -z "$resolved_component_version" ]; then
      resolved_component_version="$TXING_VERSION"
    fi
    case "$resolved_component_version" in
      *-*)
        echo "Greengrass component versions must not contain '-'. Use a version like 0.8.0+g<sha> or 0.8.0." >&2
        exit 1
        ;;
    esac
    artifacts_bucket="$(
      aws cloudformation describe-stacks \
        --stack-name "$AWS_STACK_NAME" \
        "${aws_flags[@]}" \
        --query "Stacks[0].Outputs[?OutputKey=='GreengrassArtifactsBucketName'].OutputValue | [0]" \
        --output text
    )"
    if [ -z "$artifacts_bucket" ] || [ "$artifacts_bucket" = "None" ]; then
      echo "Could not resolve GreengrassArtifactsBucketName from stack $AWS_STACK_NAME." >&2
      exit 1
    fi
    iot_data_endpoint="$(aws iot describe-endpoint --endpoint-type iot:Data-ATS "${aws_flags[@]}" --query endpointAddress --output text)"
    build_root="$(mktemp -d "${TMPDIR:-/tmp}/txing-greengrass-cloud.XXXXXX")"
    cleanup_build_root() {
      rm -rf "$build_root"
    }
    trap cleanup_build_root EXIT
    recipe_dir="$build_root/recipes"
    artifact_dir="$build_root/artifacts"
    mkdir -p "$recipe_dir" "$artifact_dir"

    TXING_REAL_CC="${CC:-cc}" CC="{{rig_dir}}/tools/cc-greengrass-info-log" cargo build --release --features greengrass-sdk --manifest-path "{{rig_dir}}/sparkplug-manager/Cargo.toml" >/dev/null
    TXING_REAL_CC="${CC:-cc}" CC="{{rig_dir}}/tools/cc-greengrass-info-log" cargo build --release --features greengrass-sdk --manifest-path "{{rig_dir}}/ble-connectivity/Cargo.toml" >/dev/null
    TXING_REAL_CC="${CC:-cc}" CC="{{rig_dir}}/tools/cc-greengrass-info-log" cargo build --release --features greengrass-sdk --manifest-path "{{rig_dir}}/aws-connectivity/Cargo.toml" >/dev/null
    sparkplug_manager_binary="{{rig_dir}}/sparkplug-manager/target/release/txing-sparkplug-manager"
    ble_connectivity_binary="{{rig_dir}}/ble-connectivity/target/release/txing-ble-connectivity"
    aws_connectivity_binary="{{rig_dir}}/aws-connectivity/target/release/txing-aws-connectivity"
    for binary in "$sparkplug_manager_binary" "$ble_connectivity_binary" "$aws_connectivity_binary"; do
      if [ ! -x "$binary" ]; then
        echo "Missing built component binary $binary" >&2
        exit 1
      fi
    done

    upload_artifact() {
      local component="$1"
      local source="$2"
      local filename="$3"
      local key="greengrass/$resolved_component_version/$component/$filename"
      aws s3 cp "$source" "s3://$artifacts_bucket/$key" "${aws_flags[@]}" >/dev/null
      printf 's3://%s/%s\n' "$artifacts_bucket" "$key"
    }
    sparkplug_uri="$(upload_artifact dev.txing.rig.SparkplugManager "$sparkplug_manager_binary" txing-sparkplug-manager)"
    ble_uri="$(upload_artifact dev.txing.rig.BleConnectivity "$ble_connectivity_binary" txing-ble-connectivity)"
    aws_uri="$(upload_artifact dev.txing.rig.AwsConnectivity "$aws_connectivity_binary" txing-aws-connectivity)"

    cat >"$recipe_dir/dev.txing.rig.SparkplugManager.yaml" <<EOF
    RecipeFormatVersion: '2020-01-25'
    ComponentName: dev.txing.rig.SparkplugManager
    ComponentVersion: '$resolved_component_version'
    ComponentType: aws.greengrass.generic
    ComponentDescription: txing rig Sparkplug lifecycle manager.
    ComponentPublisher: txing
    ComponentDependencies:
      aws.greengrass.TokenExchangeService:
        VersionRequirement: '>=0.0.0'
        DependencyType: HARD
    ComponentConfiguration:
      DefaultConfiguration:
        InventoryIntervalSeconds: 30
        CommandDeadlineMs: 60000
        accessControl:
          aws.greengrass.ipc.pubsub:
            dev.txing.rig.SparkplugManager:pubsub:1:
              policyDescription: Allows Sparkplug manager to exchange v2 capability messages with rig adapters.
              operations:
                - aws.greengrass#PublishToTopic
                - aws.greengrass#SubscribeToTopic
              resources:
                - dev/txing/rig/v2/*
    Manifests:
      - Platform:
          os: linux
          runtime: aws_nucleus_lite
        Lifecycle:
          run:
            Script: |-
              export AWS_REGION="$AWS_REGION"
              export AWS_DEFAULT_REGION="$AWS_REGION"
              export AWS_IOT_ENDPOINT="$iot_data_endpoint"
              export TXING_VERSION_BASE="$TXING_VERSION_BASE"
              export TXING_VERSION="$resolved_component_version"
              unset AWS_PROFILE AWS_DEFAULT_PROFILE AWS_SHARED_CREDENTIALS_FILE
              exec "{artifacts:path}/txing-sparkplug-manager" \
                --iot-endpoint "$iot_data_endpoint" \
                --aws-region "$AWS_REGION" \
                --inventory-interval-seconds "{configuration:/InventoryIntervalSeconds}" \
                --command-deadline-ms "{configuration:/CommandDeadlineMs}"
        Artifacts:
          - Uri: "$sparkplug_uri"
            Unarchive: "NONE"
    EOF
    cat >"$recipe_dir/dev.txing.rig.BleConnectivity.yaml" <<EOF
    RecipeFormatVersion: '2020-01-25'
    ComponentName: dev.txing.rig.BleConnectivity
    ComponentVersion: '$resolved_component_version'
    ComponentType: aws.greengrass.generic
    ComponentDescription: txing rig-wide BLE connectivity adapter for power and weather devices.
    ComponentPublisher: txing
    ComponentConfiguration:
      DefaultConfiguration:
        AdapterId: dev.txing.rig.BleConnectivity
        ScanIntervalMs: 500
        PresenceTimeoutMs: 20000
        ReconnectDelayMs: 2000
        ConnectTimeoutMs: 8000
        CommandTimeoutMs: 8000
        HeartbeatIntervalMs: 10000
        MaxConnections: 0
        accessControl:
          aws.greengrass.ipc.pubsub:
            dev.txing.rig.BleConnectivity:pubsub:1:
              policyDescription: Allows BLE connectivity to exchange v2 capability messages with the Sparkplug manager.
              operations:
                - aws.greengrass#PublishToTopic
                - aws.greengrass#SubscribeToTopic
              resources:
                - dev/txing/rig/v2/*
          aws.greengrass.ipc.mqttproxy:
            dev.txing.rig.BleConnectivity:mqttproxy:1:
              policyDescription: Allows BLE connectivity to publish BLE-owned named shadow updates.
              operations:
                - aws.greengrass#PublishToIoTCore
              resources:
                - \$aws/things/+/shadow/name/ble/update
                - \$aws/things/+/shadow/name/power/update
                - \$aws/things/+/shadow/name/weather/update
    Manifests:
      - Platform:
          os: linux
          runtime: aws_nucleus_lite
        Lifecycle:
          run:
            RequiresPrivilege: true
            Script: |-
              exec "{artifacts:path}/txing-ble-connectivity" \
                --adapter-id "{configuration:/AdapterId}" \
                --scan-interval-ms "{configuration:/ScanIntervalMs}" \
                --presence-timeout-ms "{configuration:/PresenceTimeoutMs}" \
                --reconnect-delay-ms "{configuration:/ReconnectDelayMs}" \
                --connect-timeout-ms "{configuration:/ConnectTimeoutMs}" \
                --command-timeout-ms "{configuration:/CommandTimeoutMs}" \
                --heartbeat-interval-ms "{configuration:/HeartbeatIntervalMs}" \
                --max-connections "{configuration:/MaxConnections}"
        Artifacts:
          - Uri: "$ble_uri"
            Unarchive: "NONE"
    EOF
    cat >"$recipe_dir/dev.txing.rig.AwsConnectivity.yaml" <<EOF
    RecipeFormatVersion: '2020-01-25'
    ComponentName: dev.txing.rig.AwsConnectivity
    ComponentVersion: '$resolved_component_version'
    ComponentType: aws.greengrass.generic
    ComponentDescription: txing rig-wide AWS retained MQTT connectivity adapter for cloud devices.
    ComponentPublisher: txing
    ComponentDependencies:
      aws.greengrass.TokenExchangeService:
        VersionRequirement: '>=0.0.0'
        DependencyType: HARD
    ComponentConfiguration:
      DefaultConfiguration:
        AdapterId: dev.txing.rig.AwsConnectivity
        HeartbeatIntervalMs: 10000
        StateReportIntervalMs: 10000
        KeepAliveSeconds: 60
        accessControl:
          aws.greengrass.ipc.pubsub:
            dev.txing.rig.AwsConnectivity:pubsub:1:
              policyDescription: Allows AWS connectivity to exchange v2 capability messages with the Sparkplug manager.
              operations:
                - aws.greengrass#PublishToTopic
                - aws.greengrass#SubscribeToTopic
              resources:
                - dev/txing/rig/v2/*
    Manifests:
      - Platform:
          os: linux
          runtime: aws_nucleus_lite
        Lifecycle:
          run:
            Script: |-
              export AWS_REGION="$AWS_REGION"
              export AWS_DEFAULT_REGION="$AWS_REGION"
              export AWS_IOT_ENDPOINT="$iot_data_endpoint"
              export TXING_VERSION_BASE="$TXING_VERSION_BASE"
              export TXING_VERSION="$resolved_component_version"
              unset AWS_PROFILE AWS_DEFAULT_PROFILE AWS_SHARED_CREDENTIALS_FILE
              exec "{artifacts:path}/txing-aws-connectivity" \
                --adapter-id "{configuration:/AdapterId}" \
                --iot-endpoint "$iot_data_endpoint" \
                --aws-region "$AWS_REGION" \
                --heartbeat-interval-ms "{configuration:/HeartbeatIntervalMs}" \
                --state-report-interval-ms "{configuration:/StateReportIntervalMs}" \
                --keep-alive-seconds "{configuration:/KeepAliveSeconds}" \
                --include-capability time
        Artifacts:
          - Uri: "$aws_uri"
            Unarchive: "NONE"
    EOF

    create_component_version() {
      local recipe="$1"
      local err_file="$build_root/create-component.err"
      if aws greengrassv2 create-component-version --inline-recipe "fileb://$recipe" "${aws_flags[@]}" >/dev/null 2>"$err_file"; then
        printf 'published component recipe %s\n' "$(basename "$recipe")"
      elif grep -Eiq 'already exists|conflict|ConflictException' "$err_file"; then
        printf 'component recipe already exists: %s\n' "$(basename "$recipe")"
      else
        cat "$err_file" >&2
        exit 1
      fi
    }
    create_component_version "$recipe_dir/dev.txing.rig.SparkplugManager.yaml"
    create_component_version "$recipe_dir/dev.txing.rig.BleConnectivity.yaml"
    create_component_version "$recipe_dir/dev.txing.rig.AwsConnectivity.yaml"

    ensure_thing_group() {
      local rig_type="$1"
      local group="txing-rig-type-$rig_type"
      local err_file="$build_root/create-thing-group.err"
      if aws iot create-thing-group --thing-group-name "$group" "${aws_flags[@]}" >/dev/null 2>"$err_file"; then
        printf 'created thing group %s\n' "$group"
      elif grep -Eiq 'already exists|ResourceAlreadyExistsException' "$err_file"; then
        printf 'thing group already exists: %s\n' "$group"
      else
        cat "$err_file" >&2
        exit 1
      fi
      aws iot describe-thing-group --thing-group-name "$group" "${aws_flags[@]}" --query thingGroupArn --output text
    }
    deploy_rig_type() {
      local rig_type="$1"
      local target_arn
      target_arn="$(ensure_thing_group "$rig_type" | tail -n 1)"
      local components_json="$build_root/$rig_type-components.json"
      case "$rig_type" in
        raspi)
          jq -n --arg version "$resolved_component_version" '{
            "dev.txing.rig.SparkplugManager": { "componentVersion": $version },
            "dev.txing.rig.BleConnectivity": { "componentVersion": $version }
          }' >"$components_json"
          ;;
        cloud)
          jq -n --arg version "$resolved_component_version" '{
            "dev.txing.rig.SparkplugManager": { "componentVersion": $version },
            "dev.txing.rig.AwsConnectivity": { "componentVersion": $version }
          }' >"$components_json"
          ;;
      esac
      aws greengrassv2 create-deployment \
        --target-arn "$target_arn" \
        --deployment-name "txing-$rig_type-$resolved_component_version" \
        --components "file://$components_json" \
        "${aws_flags[@]}" >/dev/null
      printf 'created Greengrass deployment target=%s version=%s group=%s\n' "$rig_type" "$resolved_component_version" "$target_arn"
    }
    case "{{target}}" in
      raspi|cloud) deploy_rig_type "{{target}}" ;;
      all)
        deploy_rig_type raspi
        deploy_rig_type cloud
        ;;
    esac

deploy-local rig_id='' rig_name='' sparkplug_group_id='' sparkplug_edge_node_id='' component_version='' adapter_id='ble-main' name_fragment='txing' region=region aws_profile=aws_profile aws_shared_credentials_file=aws_shared_credentials_file:
    #!/usr/bin/env bash
    set -euo pipefail
    for positional_arg in "{{rig_id}}" "{{rig_name}}" "{{sparkplug_group_id}}" "{{sparkplug_edge_node_id}}" "{{component_version}}" "{{adapter_id}}" "{{name_fragment}}"; do
      case "$positional_arg" in
        *=*)
          echo "rig::deploy arguments are positional; '$positional_arg' was treated as an argument value, not a named option." >&2
          echo "Component version is generated automatically; leave the internal component_version argument empty for normal deploys." >&2
          exit 1
          ;;
      esac
    done
    if [ -n "{{rig_id}}" ]; then
      export TXING_RIG_ID="{{rig_id}}"
    fi
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig "{{region}}" "{{aws_profile}}" "" "" "" "{{aws_shared_credentials_file}}")"
    region="$AWS_REGION"
    profile="$AWS_SELECTED_PROFILE"
    aws_flags=(--region "$region")
    if [ -n "$profile" ]; then \
        aws_flags+=(--profile "$profile"); \
    fi
    if ! systemctl cat "{{greengrass_lite_target}}" >/dev/null 2>&1; then \
        echo "Greengrass Lite target {{greengrass_lite_target}} is not installed. Run 'just rig::install-service' first." >&2; \
        exit 1; \
    fi
    wait_active_unit() {
      local unit="$1"
      local attempts=20
      local attempt=0
      while [ "$attempt" -lt "$attempts" ]; do
        if systemctl is-active --quiet "$unit"; then
          return 0
        fi
        attempt=$((attempt + 1))
        sleep 0.5
      done
      return 1
    }
    wait_inactive_unit() {
      local unit="$1"
      local attempts=20
      local attempt=0
      while [ "$attempt" -lt "$attempts" ]; do
        if ! systemctl is-active --quiet "$unit"; then
          return 0
        fi
        attempt=$((attempt + 1))
        sleep 0.5
      done
      return 1
    }
    wait_unit_present() {
      local unit="$1"
      local attempts=60
      local attempt=0
      while [ "$attempt" -lt "$attempts" ]; do
        sudo systemctl daemon-reload || true
        if systemctl cat "$unit" >/dev/null 2>&1; then
          return 0
        fi
        attempt=$((attempt + 1))
        sleep 1
      done
      return 1
    }
    loaded_unit_matches_version() {
      local unit="$1"
      local version="$2"
      systemctl cat "$unit" | grep -F -- "-v $version" >/dev/null 2>&1
    }
    wait_unit_version() {
      local unit="$1"
      local version="$2"
      local attempts=90
      local attempt=0
      while [ "$attempt" -lt "$attempts" ]; do
        sudo systemctl daemon-reload || true
        if loaded_unit_matches_version "$unit" "$version"; then
          return 0
        fi
        attempt=$((attempt + 1))
        sleep 1
      done
      return 1
    }
    reset_failed_if_present() {
      local unit="$1"
      if systemctl cat "$unit" >/dev/null 2>&1; then
        sudo systemctl reset-failed "$unit" || true
      fi
    }
    prune_component_config_arn() {
      local component="$1"
      local config_db="/var/lib/greengrass/config.db"
      if [ ! -f "$config_db" ]; then
        return 0
      fi
      if ! command -v sqlite3 >/dev/null 2>&1; then
        echo "warning: sqlite3 is not installed; cannot prune stale Greengrass Lite local configArn entries before deploy." >&2
        echo "warning: install sqlite3 if deployments fail with: Json encode failed for key services/<component>/configArn" >&2
        return 0
      fi
      local component_sql="${component//\'/\'\'}"
      local safe_component="${component//[^A-Za-z0-9_.-]/_}"
      local backup_path="$config_db.txing-configArn-backup.$safe_component.$(date -u +%Y%m%dT%H%M%SZ).$$"
      sudo cp -a "$config_db" "$backup_path"
      sudo sqlite3 "$config_db" <<SQL
    BEGIN IMMEDIATE;
    CREATE TEMP TABLE txing_delete_keys(keyid INTEGER PRIMARY KEY);
    INSERT OR IGNORE INTO txing_delete_keys(keyid)
    WITH
      root AS (
        SELECT keyid
        FROM keyTable
        WHERE keyvalue = 'services'
          AND keyid NOT IN (SELECT keyid FROM relationTable)
      ),
      component AS (
        SELECT kt.keyid
        FROM keyTable kt
        JOIN relationTable rt ON rt.keyid = kt.keyid
        JOIN root ON rt.parentid = root.keyid
        WHERE kt.keyvalue = '$component_sql'
      ),
      target AS (
        SELECT kt.keyid
        FROM keyTable kt
        JOIN relationTable rt ON rt.keyid = kt.keyid
        JOIN component ON rt.parentid = component.keyid
        WHERE kt.keyvalue = 'configArn'
      ),
      descendants(keyid) AS (
        SELECT keyid FROM target
        UNION ALL
        SELECT rt.keyid
        FROM relationTable rt
        JOIN descendants d ON rt.parentid = d.keyid
      )
    SELECT keyid FROM descendants;
    DELETE FROM valueTable
    WHERE keyid IN (SELECT keyid FROM txing_delete_keys);
    DELETE FROM relationTable
    WHERE keyid IN (SELECT keyid FROM txing_delete_keys)
       OR parentid IN (SELECT keyid FROM txing_delete_keys);
    DELETE FROM keyTable
    WHERE keyid IN (SELECT keyid FROM txing_delete_keys);
    DROP TABLE txing_delete_keys;
    COMMIT;
    SQL
      echo "pruned stale Greengrass Lite local configArn entries for $component (backup: $backup_path)"
    }
    prune_local_deployment_config_arns() {
      local components=("$@")
      if [ "${#components[@]}" -eq 0 ]; then
        return 0
      fi
      if [ ! -f /var/lib/greengrass/config.db ]; then
        return 0
      fi
      echo "Pruning stale Greengrass Lite local deployment configArn entries before deploy."
      sudo systemctl stop ggl.gg_config.socket ggl.core.ggconfigd.service || true
      for component in "${components[@]}"; do
        prune_component_config_arn "$component"
      done
      sudo systemctl start ggl.gg_config.socket || true
      if ! wait_active_unit ggl.gg_config.socket; then
        echo "warning: Greengrass Lite config socket did not become active after configArn prune." >&2
      fi
    }
    install_core_log_overrides() {
      local log_unit
      for log_unit in {{greengrass_warning_log_units}}; do
        sudo install -d -m 755 "/etc/systemd/system/$log_unit.d"
        printf '[Service]\nLogLevelMax=warning\n' | sudo tee "/etc/systemd/system/$log_unit.d/10-log-level.conf" >/dev/null
      done
      sudo systemctl daemon-reload || true
    }
    restart_core_log_override_units() {
      local log_unit
      for log_unit in {{greengrass_warning_log_units}}; do
        if systemctl cat "$log_unit" >/dev/null 2>&1 && systemctl is-active --quiet "$log_unit"; then
          sudo systemctl try-restart "$log_unit" || true
          if ! wait_active_unit "$log_unit"; then
            echo "warning: Greengrass Lite core unit $log_unit did not become active after applying log override." >&2
          fi
        fi
      done
    }
    if ! systemctl is-active --quiet "{{greengrass_lite_target}}"; then
      echo "Starting Greengrass deployment sockets before deploy; component target {{greengrass_lite_target}} will be activated after deployment."
    fi
    sudo install -d -o ggcore -g ggcore -m 775 /run/greengrass || true
    sudo install -d -o ggcore -g ggcore -m 770 /etc/greengrass/config.d || true
    core_units=({{greengrass_core_units}})
    core_sockets=({{greengrass_core_sockets}})
    install_core_log_overrides
    core_runtime_units=("${core_sockets[@]}")
    is_deployment_required_core_unit() {
      case "$1" in
        ggl.gg_config.socket|ggl.gg_deployment.socket)
          return 0
          ;;
        *)
          return 1
          ;;
      esac
    }
    for core_runtime_unit in "${core_sockets[@]}" "${core_units[@]}"; do
      reset_failed_if_present "$core_runtime_unit"
    done
    for core_runtime_unit in "${core_runtime_units[@]}"; do
      if ! systemctl cat "$core_runtime_unit" >/dev/null 2>&1; then
        if is_deployment_required_core_unit "$core_runtime_unit"; then
          echo "Greengrass Lite deployment runtime $core_runtime_unit is not installed. Run 'just rig::build' and 'just rig::install-service' to install the current Greengrass Lite service set." >&2
          exit 1
        fi
        echo "warning: optional Greengrass Lite socket $core_runtime_unit is not installed; continuing." >&2
        continue
      fi
      if ! sudo systemctl start "$core_runtime_unit"; then
        if is_deployment_required_core_unit "$core_runtime_unit"; then
          echo "Greengrass Lite deployment runtime $core_runtime_unit failed to start." >&2
          echo "Inspect it with: sudo journalctl -a --no-pager -u $core_runtime_unit -u ggl.gg_config.socket -u ggl.gg_deployment.socket -u ggl.core.ggdeploymentd.service -n 200" >&2
          exit 1
        fi
        echo "warning: Greengrass Lite socket $core_runtime_unit failed to start; continuing." >&2
        continue
      fi
      if ! wait_active_unit "$core_runtime_unit"; then
        if is_deployment_required_core_unit "$core_runtime_unit"; then
          echo "Greengrass Lite deployment runtime $core_runtime_unit did not become active." >&2
          echo "Inspect it with: sudo journalctl -a --no-pager -u $core_runtime_unit -u ggl.gg_config.socket -u ggl.gg_deployment.socket -u ggl.core.ggdeploymentd.service -n 200" >&2
          exit 1
        fi
        echo "warning: Greengrass Lite socket $core_runtime_unit did not report active before deploy; continuing." >&2
      fi
    done
    ggl_cli="$(command -v ggl-cli || true)"
    if [ -z "$ggl_cli" ] && [ -x /usr/local/bin/ggl-cli ]; then \
        ggl_cli=/usr/local/bin/ggl-cli; \
    fi
    if [ -z "$ggl_cli" ]; then \
        echo "Missing ggl-cli. Run 'just rig::install-service' to install Greengrass Lite." >&2; \
        exit 1; \
    fi
    rig_name="$RIG_NAME"
    selected_rig_type="$RIG_TYPE"
    sparkplug_group_id="$SPARKPLUG_GROUP_ID"
    sparkplug_edge_node_id="$SPARKPLUG_EDGE_NODE_ID"
    if [ -n "{{rig_name}}" ]; then \
        rig_name="{{rig_name}}"; \
    fi; \
    if [ -n "{{sparkplug_group_id}}" ]; then \
        sparkplug_group_id="{{sparkplug_group_id}}"; \
    fi; \
    if [ -n "{{sparkplug_edge_node_id}}" ]; then \
        sparkplug_edge_node_id="{{sparkplug_edge_node_id}}"; \
    fi; \
    explicit_component_version="{{component_version}}"
    if [ -n "$explicit_component_version" ]; then \
        resolved_component_version="$explicit_component_version"; \
    else
        resolved_component_version="$TXING_VERSION"
    fi
    case "$resolved_component_version" in
      *-*)
        echo "Greengrass Lite local component versions must not contain '-' because its recipe filename scanner splits on the last hyphen. Use a version like 0.8.0+g<sha> or 0.6.1." >&2
        exit 1
        ;;
    esac
    case "$selected_rig_type" in
      raspi)
        sparkplug_component="dev.txing.rig.SparkplugManager"
        connectivity_component="dev.txing.rig.BleConnectivity"
        ;;
      cloud)
        sparkplug_component="dev.txing.rig.SparkplugManager"
        connectivity_component="dev.txing.rig.AwsConnectivity"
        ;;
      *)
        echo "Unsupported rig type '$selected_rig_type'. Supported rig types: raspi, cloud." >&2
        exit 1
        ;;
    esac
    if [ "$(uname -s)" != "Linux" ]; then
      echo "Rust Greengrass SDK builds are Linux-only; run rig::deploy on the Greengrass rig host." >&2
      exit 1
    fi
    iot_data_endpoint="$(aws iot describe-endpoint --endpoint-type iot:Data-ATS "${aws_flags[@]}" --query endpointAddress --output text)"
    deploy_root="{{rig_dir}}/build/greengrass-local"
    staging_root="$(mktemp -d "${TMPDIR:-/tmp}/txing-greengrass-stage.XXXXXX")"
    cleanup_staging_root() {
        rm -rf "$staging_root"
    }
    trap cleanup_staging_root EXIT
    recipe_dir="$deploy_root/recipes"
    artifacts_dir="$deploy_root/artifacts"
    rm -rf "$deploy_root"
    mkdir -p "$recipe_dir" "$artifacts_dir"
    TXING_REAL_CC="${CC:-cc}" CC="{{rig_dir}}/tools/cc-greengrass-info-log" cargo build --release --features greengrass-sdk --manifest-path "{{rig_dir}}/sparkplug-manager/Cargo.toml" >/dev/null
    sparkplug_manager_binary="{{rig_dir}}/sparkplug-manager/target/release/txing-sparkplug-manager"
    if [ ! -x "$sparkplug_manager_binary" ]; then
      echo "Missing built Rust Sparkplug manager binary at $sparkplug_manager_binary" >&2
      exit 1
    fi
    if [ "$selected_rig_type" = "raspi" ]; then
      TXING_REAL_CC="${CC:-cc}" CC="{{rig_dir}}/tools/cc-greengrass-info-log" cargo build --release --features greengrass-sdk --manifest-path "{{rig_dir}}/ble-connectivity/Cargo.toml" >/dev/null
      ble_connectivity_binary="{{rig_dir}}/ble-connectivity/target/release/txing-ble-connectivity"
      if [ ! -x "$ble_connectivity_binary" ]; then
        echo "Missing built Rust BLE connectivity binary at $ble_connectivity_binary" >&2
        exit 1
      fi
    fi
    if [ "$selected_rig_type" = "cloud" ]; then
      TXING_REAL_CC="${CC:-cc}" CC="{{rig_dir}}/tools/cc-greengrass-info-log" cargo build --release --features greengrass-sdk --manifest-path "{{rig_dir}}/aws-connectivity/Cargo.toml" >/dev/null
      aws_connectivity_binary="{{rig_dir}}/aws-connectivity/target/release/txing-aws-connectivity"
      if [ ! -x "$aws_connectivity_binary" ]; then
        echo "Missing built Rust AWS connectivity binary at $aws_connectivity_binary" >&2
        exit 1
      fi
    fi
    component_artifact_dir="$artifacts_dir/$sparkplug_component/$resolved_component_version"
    mkdir -p "$component_artifact_dir"
    cp "$sparkplug_manager_binary" "$component_artifact_dir/txing-sparkplug-manager"
    chmod 755 "$component_artifact_dir/txing-sparkplug-manager"
    printf 'txing local Greengrass artifact for %s %s\n' "$sparkplug_component" "$resolved_component_version" >"$component_artifact_dir/txing-local-artifact.txt"
    if [ "$selected_rig_type" = "raspi" ]; then
      component_artifact_dir="$artifacts_dir/$connectivity_component/$resolved_component_version"
      mkdir -p "$component_artifact_dir"
      cp "$ble_connectivity_binary" "$component_artifact_dir/txing-ble-connectivity"
      chmod 755 "$component_artifact_dir/txing-ble-connectivity"
      printf 'txing local Greengrass artifact for %s %s\n' "$connectivity_component" "$resolved_component_version" >"$component_artifact_dir/txing-local-artifact.txt"
    else
      component_artifact_dir="$artifacts_dir/$connectivity_component/$resolved_component_version"
      mkdir -p "$component_artifact_dir"
      cp "$aws_connectivity_binary" "$component_artifact_dir/txing-aws-connectivity"
      chmod 755 "$component_artifact_dir/txing-aws-connectivity"
      printf 'txing local Greengrass artifact for %s %s\n' "$connectivity_component" "$resolved_component_version" >"$component_artifact_dir/txing-local-artifact.txt"
    fi
    if [ "$selected_rig_type" = "raspi" ]; then
      cat >"$recipe_dir/$connectivity_component-$resolved_component_version.yaml" <<EOF
    RecipeFormatVersion: '2020-01-25'
    ComponentName: $connectivity_component
    ComponentVersion: '$resolved_component_version'
    ComponentType: aws.greengrass.generic
    ComponentDescription: txing rig-wide BLE connectivity adapter for power and weather devices.
    ComponentPublisher: txing
    ComponentConfiguration:
      DefaultConfiguration:
        AdapterId: dev.txing.rig.BleConnectivity
        ScanIntervalMs: 500
        PresenceTimeoutMs: 20000
        ReconnectDelayMs: 2000
        ConnectTimeoutMs: 8000
        CommandTimeoutMs: 8000
        HeartbeatIntervalMs: 10000
        MaxConnections: 0
        accessControl:
          aws.greengrass.ipc.pubsub:
            $connectivity_component:pubsub:1:
              policyDescription: Allows BLE connectivity to exchange v2 capability messages with the Sparkplug manager.
              operations:
                - aws.greengrass#PublishToTopic
                - aws.greengrass#SubscribeToTopic
              resources:
                - dev/txing/rig/v2/*
          aws.greengrass.ipc.mqttproxy:
            $connectivity_component:mqttproxy:1:
              policyDescription: Allows BLE connectivity to publish BLE-owned named shadow updates through the rig IoT Core connection.
              operations:
                - aws.greengrass#PublishToIoTCore
              resources:
                - \$aws/things/+/shadow/name/ble/update
                - \$aws/things/+/shadow/name/power/update
                - \$aws/things/+/shadow/name/weather/update
    Manifests:
      - Platform:
          os: linux
          runtime: aws_nucleus_lite
        Lifecycle:
          run:
            RequiresPrivilege: true
            Script: |-
              exec "{artifacts:path}/txing-ble-connectivity" \
                --adapter-id "{configuration:/AdapterId}" \
                --scan-interval-ms "{configuration:/ScanIntervalMs}" \
                --presence-timeout-ms "{configuration:/PresenceTimeoutMs}" \
                --reconnect-delay-ms "{configuration:/ReconnectDelayMs}" \
                --connect-timeout-ms "{configuration:/ConnectTimeoutMs}" \
                --command-timeout-ms "{configuration:/CommandTimeoutMs}" \
                --heartbeat-interval-ms "{configuration:/HeartbeatIntervalMs}" \
                --max-connections "{configuration:/MaxConnections}"
        Artifacts:
          - Uri: "s3://txing-local-greengrass/txing-local-artifact.txt"
            Unarchive: "NONE"
    EOF
    fi
    cat >"$recipe_dir/$sparkplug_component-$resolved_component_version.yaml" <<EOF
    RecipeFormatVersion: '2020-01-25'
    ComponentName: $sparkplug_component
    ComponentVersion: '$resolved_component_version'
    ComponentType: aws.greengrass.generic
    ComponentDescription: txing rig Sparkplug lifecycle manager for rig type $selected_rig_type.
    ComponentPublisher: txing
    ComponentDependencies:
      aws.greengrass.TokenExchangeService:
        VersionRequirement: '>=0.0.0'
        DependencyType: HARD
    ComponentConfiguration:
      DefaultConfiguration:
        accessControl:
          aws.greengrass.ipc.pubsub:
            $sparkplug_component:pubsub:1:
              policyDescription: Allows the Sparkplug manager to exchange local connectivity messages with rig adapters.
              operations:
                - aws.greengrass#PublishToTopic
                - aws.greengrass#SubscribeToTopic
              resources:
                - dev/txing/rig/v2/*
    Manifests:
      - Platform:
          os: linux
          runtime: aws_nucleus_lite
        Lifecycle:
          run:
            Script: |-
              export AWS_REGION="$AWS_REGION"
              export AWS_DEFAULT_REGION="$AWS_REGION"
              export TXING_VERSION_BASE="$TXING_VERSION_BASE"
              export TXING_VERSION="$resolved_component_version"
              unset AWS_PROFILE AWS_DEFAULT_PROFILE AWS_SHARED_CREDENTIALS_FILE
              export RIG_NAME="$rig_name"
              export TXING_RIG_ID="$TXING_RIG_ID"
              export TXING_TOWN_ID="$sparkplug_group_id"
              export RIG_ID="$TXING_RIG_ID"
              export SPARKPLUG_GROUP_ID="$sparkplug_group_id"
              export SPARKPLUG_EDGE_NODE_ID="$sparkplug_edge_node_id"
              export AWS_IOT_ENDPOINT="$iot_data_endpoint"
              export TXING_RIG_TYPE="$selected_rig_type"
              export RIG_TYPE="$selected_rig_type"
              exec "{artifacts:path}/txing-sparkplug-manager" --rig-id "$TXING_RIG_ID" --town-id "$sparkplug_group_id" --iot-endpoint "$iot_data_endpoint" --aws-region "$AWS_REGION" --inventory-interval-seconds 30 --command-deadline-ms 60000
        Artifacts:
          - Uri: "s3://txing-local-greengrass/txing-local-artifact.txt"
            Unarchive: "NONE"
    EOF
    if [ "$selected_rig_type" = "cloud" ]; then
    cat >"$recipe_dir/$connectivity_component-$resolved_component_version.yaml" <<EOF
    RecipeFormatVersion: '2020-01-25'
    ComponentName: $connectivity_component
    ComponentVersion: '$resolved_component_version'
    ComponentType: aws.greengrass.generic
    ComponentDescription: txing rig-wide AWS retained MQTT connectivity adapter.
    ComponentPublisher: txing
    ComponentDependencies:
      aws.greengrass.TokenExchangeService:
        VersionRequirement: '>=0.0.0'
        DependencyType: HARD
    ComponentConfiguration:
      DefaultConfiguration:
        accessControl:
          aws.greengrass.ipc.pubsub:
            $connectivity_component:pubsub:1:
              policyDescription: Allows the connectivity adapter to exchange local connectivity messages with the Sparkplug manager.
              operations:
                - aws.greengrass#PublishToTopic
                - aws.greengrass#SubscribeToTopic
              resources:
                - dev/txing/rig/v2/*
    Manifests:
      - Platform:
          os: linux
          runtime: aws_nucleus_lite
        Lifecycle:
          run:
            Script: |-
              export AWS_REGION="$AWS_REGION"
              export AWS_DEFAULT_REGION="$AWS_REGION"
              export TXING_VERSION_BASE="$TXING_VERSION_BASE"
              export TXING_VERSION="$resolved_component_version"
              unset AWS_PROFILE AWS_DEFAULT_PROFILE AWS_SHARED_CREDENTIALS_FILE
              export RIG_NAME="$rig_name"
              export TXING_RIG_ID="$TXING_RIG_ID"
              export RIG_ID="$TXING_RIG_ID"
              export SPARKPLUG_GROUP_ID="$sparkplug_group_id"
              export SPARKPLUG_EDGE_NODE_ID="$sparkplug_edge_node_id"
              export AWS_IOT_ENDPOINT="$iot_data_endpoint"
              export TXING_RIG_TYPE="$selected_rig_type"
              export RIG_TYPE="$selected_rig_type"
              exec "{artifacts:path}/txing-aws-connectivity" --adapter-id "$connectivity_component" --iot-endpoint "$iot_data_endpoint" --aws-region "$AWS_REGION" --client-id "$TXING_RIG_ID-aws-connectivity" --heartbeat-interval-ms 10000 --state-report-interval-ms 10000 --keep-alive-seconds 60
        Artifacts:
          - Uri: "s3://txing-local-greengrass/txing-local-artifact.txt"
            Unarchive: "NONE"
    EOF
    fi
    deploy_args=(
      --recipe-dir "$recipe_dir" \
      --artifacts-dir "$artifacts_dir" \
      --add-component "$sparkplug_component=$resolved_component_version" \
      --add-component "$connectivity_component=$resolved_component_version"
    )
    deployed_units=("ggl.$sparkplug_component.service" "ggl.$connectivity_component.service")
    prune_local_deployment_config_arns "$sparkplug_component" "$connectivity_component"
    quiesce_units=()
    for unit in "${deployed_units[@]}"; do
      if systemctl cat "$unit" >/dev/null 2>&1; then
        quiesce_units+=("$unit")
      fi
    done
    if [ "${#quiesce_units[@]}" -gt 0 ]; then
      printf 'Stopping running Greengrass component units before deploy: %s\n' "${quiesce_units[*]}"
      sudo systemctl stop "${quiesce_units[@]}" || true
      for unit in "${quiesce_units[@]}"; do
        if ! wait_inactive_unit "$unit"; then
          echo "warning: component unit $unit did not become inactive before deploy." >&2
        fi
      done
    fi
    if sudo timeout 180 "$ggl_cli" deploy "${deploy_args[@]}"; then
      deploy_command_status=0
    else
      deploy_command_status=$?
      echo "warning: ggl-cli deploy failed or timed out with status $deploy_command_status; checking deployed systemd component units anyway." >&2
    fi
    sudo systemctl daemon-reload || true
    restart_core_log_override_units
    sudo systemctl start "{{greengrass_lite_target}}" || true
    wait_active_unit "{{greengrass_lite_target}}" || true
    for core_socket in "${core_sockets[@]}"; do
      if systemctl cat "$core_socket" >/dev/null 2>&1; then
        sudo systemctl start "$core_socket" || true
        wait_active_unit "$core_socket" || true
      fi
    done
    activation_failures=0
    for deployed_unit in "${deployed_units[@]}"; do
      if ! wait_unit_present "$deployed_unit"; then
        echo "warning: expected deployed unit $deployed_unit was not loaded after waiting for Greengrass deployment." >&2
        activation_failures=$((activation_failures + 1))
        continue
      fi
      if ! wait_unit_version "$deployed_unit" "$resolved_component_version"; then
        echo "warning: expected deployed unit $deployed_unit to load version $resolved_component_version, but systemd still points at a different component version after waiting." >&2
        echo "Inspect it with: sudo systemctl cat $deployed_unit" >&2
        activation_failures=$((activation_failures + 1))
        continue
      fi
      reset_failed_if_present "$deployed_unit"
      sudo systemctl start "$deployed_unit" || true
      if ! wait_active_unit "$deployed_unit"; then
        echo "warning: deployed unit $deployed_unit did not become active." >&2
        activation_failures=$((activation_failures + 1))
      fi
    done
    if [ "$activation_failures" -ne 0 ]; then
      echo "inspect Greengrass deployment processing with: sudo journalctl -a --no-pager -u ggl.core.ggdeploymentd.service -u ggl.gg_deployment.socket -n 200" >&2
      echo "Greengrass deploy completed, but $activation_failures deployed unit(s) did not stay active." >&2
      exit 1
    fi
    if [ "$deploy_command_status" -ne 0 ]; then
      echo "warning: Greengrass deploy command reported failure, but component units are active at the expected version." >&2
    fi
    printf 'deployed Greengrass components version %s for RigName=%s RigType=%s SparkplugGroupId=%s SparkplugEdgeNodeId=%s\n' "$resolved_component_version" "$rig_name" "$selected_rig_type" "$sparkplug_group_id" "$sparkplug_edge_node_id"
    printf 'inspect rig logs with: just rig::log\n'
