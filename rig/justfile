print shadow_name='sparkplug':
    #!/usr/bin/env bash
    set -euo pipefail
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig "{{region}}" "{{aws_profile}}")"
    region="$AWS_REGION"
    aws_profile="$AWS_SELECTED_PROFILE"
    aws_flags=(--region "$region")
    if [ -n "$aws_profile" ]; then
      aws_flags+=(--profile "$aws_profile")
    fi
    endpoint="$(aws iot describe-endpoint --endpoint-type iot:Data-ATS "${aws_flags[@]}" --query endpointAddress --output text)"
    aws iot-data get-thing-shadow \
      --region "$region" \
      --endpoint-url "https://$endpoint" \
      --thing-name "{{thing_name}}" \
      --shadow-name "{{shadow_name}}" \
      /dev/stdout | jq '.'

install-service rig_id='' rig_name='' sparkplug_group_id='' sparkplug_edge_node_id='' region=region aws_profile=aws_profile aws_shared_credentials_file=aws_shared_credentials_file cloudwatch_log_group='':
    #!/usr/bin/env bash
    set -euo pipefail
    for built_entrypoint in "{{built_rig}}" "{{built_rig_device_process}}"; do \
        if [ ! -x "$built_entrypoint" ]; then \
            echo "Missing built rig entrypoint at $built_entrypoint. Run 'just rig::build' before 'just rig::install-service'." >&2; \
            exit 1; \
        fi; \
    done
    if [ -n "{{rig_id}}" ]; then
      export TXING_RIG_ID="{{rig_id}}"
    fi
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig "{{region}}" "{{aws_profile}}" "" "" "" "{{aws_shared_credentials_file}}")"
    region="$AWS_REGION"
    profile="$AWS_SELECTED_PROFILE"
    aws_flags=(--region "$region")
    if [ -n "$profile" ]; then \
        aws_flags+=(--profile "$profile"); \
    fi
    rig_name="$RIG_NAME"
    selected_rig_type="$RIG_TYPE"
    sparkplug_group_id="$SPARKPLUG_GROUP_ID"
    sparkplug_edge_node_id="$SPARKPLUG_EDGE_NODE_ID"
    if [ -n "{{rig_name}}" ]; then \
        rig_name="{{rig_name}}"; \
    fi; \
    if [ -n "{{sparkplug_group_id}}" ]; then \
        sparkplug_group_id="{{sparkplug_group_id}}"; \
    fi; \
    if [ -n "{{sparkplug_edge_node_id}}" ]; then \
        sparkplug_edge_node_id="{{sparkplug_edge_node_id}}"; \
    fi; \
    if [ ! -d "{{greengrass_lite_build_dir}}" ]; then \
        echo "Greengrass Lite native build is missing at {{greengrass_lite_build_dir}}." >&2; \
        echo "Run 'just rig::build-native' before 'just rig::install-service'." >&2; \
        exit 1; \
    fi
    if ! getent group ggcore >/dev/null; then \
        sudo groupadd --system ggcore; \
    fi
    if ! id -u ggcore >/dev/null 2>&1; then \
        sudo useradd --system --gid ggcore --home-dir /var/lib/greengrass --shell /usr/sbin/nologin ggcore; \
    fi
    if ! getent group gg_component >/dev/null; then \
        sudo groupadd --system gg_component; \
    fi
    if ! id -u gg_component >/dev/null 2>&1; then \
        sudo useradd --system --gid gg_component --home-dir /var/lib/greengrass/component --shell /usr/sbin/nologin gg_component; \
    fi
    rig_cert_path="{{project_root}}/config/certs/rig/rig.cert.pem"
    rig_private_key_path="{{project_root}}/config/certs/rig/rig.private.key"
    if [ ! -f "$rig_cert_path" ] || [ ! -f "$rig_private_key_path" ]; then \
        echo "Rig certificate material is missing under {{project_root}}/config/certs/rig." >&2; \
        echo "Run 'just aws::cert' before 'just rig::install-service'." >&2; \
        exit 1; \
    fi
    rig_thing_name="$TXING_RIG_ID"
    iot_data_endpoint="$(aws iot describe-endpoint --endpoint-type iot:Data-ATS "${aws_flags[@]}" --query endpointAddress --output text)"
    iot_cred_endpoint="$(aws iot describe-endpoint --endpoint-type iot:CredentialProvider "${aws_flags[@]}" --query endpointAddress --output text)"
    iot_role_alias="$(
        aws cloudformation describe-stacks \
          --stack-name "$AWS_STACK_NAME" \
          "${aws_flags[@]}" \
          --query "Stacks[0].Outputs[?OutputKey=='GreengrassTokenExchangeRoleAlias'].OutputValue | [0]" \
          --output text
    )"
    if [ -z "$iot_role_alias" ] || [ "$iot_role_alias" = "None" ]; then \
        echo "Could not resolve GreengrassTokenExchangeRoleAlias from stack $AWS_STACK_NAME." >&2; \
        exit 1; \
    fi
    temp_files=()
    cleanup_temp_files() {
        if [ "${#temp_files[@]}" -gt 0 ]; then
            rm -f "${temp_files[@]}"
        fi
    }
    trap cleanup_temp_files EXIT
    sudo mkdir -p /var/lib/greengrass /etc/greengrass /etc/tmpfiles.d
    sudo install -d -o ggcore -g ggcore -m 775 /run/greengrass
    sudo install -d -o ggcore -g ggcore -m 770 /etc/greengrass/config.d
    greengrass_tmpfiles_temp="$(mktemp "${TMPDIR:-/tmp}/txing-greengrass-tmpfiles.XXXXXX")"
    temp_files+=("$greengrass_tmpfiles_temp")
    cat >"$greengrass_tmpfiles_temp" <<'EOF'
    d /run/greengrass 0775 ggcore ggcore -
    d /etc/greengrass/config.d 0770 ggcore ggcore -
    EOF
    sudo install -m 644 "$greengrass_tmpfiles_temp" /etc/tmpfiles.d/txing-greengrass-lite.conf
    sudo systemd-tmpfiles --create /etc/tmpfiles.d/txing-greengrass-lite.conf
    sudo install -d -o ggcore -g ggcore -m 700 /var/lib/greengrass/credentials
    sudo install -o ggcore -g ggcore -m 600 "$rig_cert_path" /var/lib/greengrass/credentials/rig.cert.pem
    sudo install -o ggcore -g ggcore -m 600 "$rig_private_key_path" /var/lib/greengrass/credentials/rig.private.key
    root_ca_temp="$(mktemp "${TMPDIR:-/tmp}/txing-amazon-root-ca.XXXXXX")"
    temp_files+=("$root_ca_temp")
    curl -fsSL https://www.amazontrust.com/repository/AmazonRootCA1.pem -o "$root_ca_temp"
    sudo install -o ggcore -g ggcore -m 644 "$root_ca_temp" /var/lib/greengrass/credentials/AmazonRootCA1.pem
    greengrass_config_temp="$(mktemp "${TMPDIR:-/tmp}/txing-greengrass-config.XXXXXX")"
    temp_files+=("$greengrass_config_temp")
    cat >"$greengrass_config_temp" <<EOF
    system:
      privateKeyPath: "/var/lib/greengrass/credentials/rig.private.key"
      certificateFilePath: "/var/lib/greengrass/credentials/rig.cert.pem"
      rootCaPath: "/var/lib/greengrass/credentials/AmazonRootCA1.pem"
      rootPath: "/var/lib/greengrass"
      thingName: "$rig_thing_name"
    services:
      aws.greengrass.NucleusLite:
        componentType: "NUCLEUS"
        configuration:
          awsRegion: "$region"
          iotCredEndpoint: "$iot_cred_endpoint"
          iotDataEndpoint: "$iot_data_endpoint"
          iotRoleAlias: "$iot_role_alias"
          runWithDefault:
            posixUser: "gg_component:gg_component"
          greengrassDataPlanePort: "8443"
          platformOverride: {}
    EOF
    sudo install -m 644 "$greengrass_config_temp" /etc/greengrass/config.yaml
    sudo chown -R ggcore:ggcore /var/lib/greengrass
    sudo cmake --install "{{greengrass_lite_build_dir}}" --config MinSizeRel
    sudo "{{greengrass_lite_dir}}/misc/run_nucleus"
    printf 'txing rig is supervised by the standard Greengrass Lite systemd target %s\n' "{{greengrass_lite_target}}"
    printf 'Deploy rig type %s components with RigName=%s SparkplugGroupId=%s SparkplugEdgeNodeId=%s\n' "$selected_rig_type" "$rig_name" "$sparkplug_group_id" "$sparkplug_edge_node_id"

start rig_id='':
    #!/usr/bin/env bash
    set -euo pipefail
    if [ -n "{{rig_id}}" ]; then
      export TXING_RIG_ID="{{rig_id}}"
    fi
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig)"
    selected_rig_type="$RIG_TYPE"
    if ! systemctl cat "{{greengrass_lite_target}}" >/dev/null 2>&1; then \
        echo "Greengrass Lite target {{greengrass_lite_target}} is not installed. Run 'just rig::install-service' first." >&2; \
        exit 1; \
    fi
    unit_exists() {
      systemctl cat "$1" >/dev/null 2>&1
    }
    start_unit_if_present() {
      local unit="$1"
      if unit_exists "$unit"; then
        sudo systemctl start "$unit" || true
      fi
    }
    wait_active_if_present() {
      local unit="$1"
      if ! unit_exists "$unit"; then
        return 0
      fi
      for _attempt in $(seq 1 30); do
        if systemctl is-active --quiet "$unit"; then
          return 0
        fi
        sleep 1
      done
      return 1
    }
    case "$selected_rig_type" in
      raspi)
        component_units=({{raspi_rig_component_units}})
        ;;
      cloud)
        component_units=({{aws_rig_component_units}})
        ;;
      *)
        echo "Unsupported RIG_TYPE=$selected_rig_type. Supported rig types: raspi, cloud." >&2
        exit 1
        ;;
    esac
    sudo install -d -o ggcore -g ggcore -m 775 /run/greengrass || true
    sudo install -d -o ggcore -g ggcore -m 770 /etc/greengrass/config.d || true
    core_units=({{greengrass_core_units}})
    core_sockets=({{greengrass_core_sockets}})
    reset_units=("{{greengrass_lite_target}}")
    for unit in "${core_sockets[@]}" "${core_units[@]}" "${component_units[@]}"; do
      if unit_exists "$unit"; then
        reset_units+=("$unit")
      fi
    done
    sudo systemctl reset-failed "${reset_units[@]}" || true
    sudo systemctl start "{{greengrass_lite_target}}"
    for unit in "${core_sockets[@]}"; do
      start_unit_if_present "$unit"
      wait_active_if_present "$unit" || true
    done
    for unit in "${component_units[@]}"; do
      if unit_exists "$unit"; then
        start_unit_if_present "$unit"
        wait_active_if_present "$unit" || true
      fi
    done
    status_units=("{{greengrass_lite_target}}")
    for unit in "${core_sockets[@]}" "${core_units[@]}" "${component_units[@]}"; do
      if unit_exists "$unit"; then
        status_units+=("$unit")
      fi
    done
    sudo systemctl --no-pager --full status "${status_units[@]}"

stop rig_id='':
    #!/usr/bin/env bash
    set -euo pipefail
    if [ -n "{{rig_id}}" ]; then
      export TXING_RIG_ID="{{rig_id}}"
    fi
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig)"
    selected_rig_type="$RIG_TYPE"
    if ! systemctl cat "{{greengrass_lite_target}}" >/dev/null 2>&1; then \
        echo "Greengrass Lite target {{greengrass_lite_target}} is not installed. Run 'just rig::install-service' first." >&2; \
        exit 1; \
    fi
    unit_exists() {
      systemctl cat "$1" >/dev/null 2>&1
    }
    case "$selected_rig_type" in
      raspi)
        component_units=({{raspi_rig_component_units}})
        ;;
      cloud)
        component_units=({{aws_rig_component_units}})
        ;;
      *)
        echo "Unsupported RIG_TYPE=$selected_rig_type. Supported rig types: raspi, cloud." >&2
        exit 1
        ;;
    esac
    stop_units=()
    for unit in "${component_units[@]}"; do
      if unit_exists "$unit"; then
        stop_units+=("$unit")
      fi
    done
    if [ "${#stop_units[@]}" -gt 0 ]; then
      sudo systemctl stop "${stop_units[@]}" || true
    fi
    sudo systemctl stop "{{greengrass_lite_target}}"
    core_units=({{greengrass_core_units}})
    core_sockets=({{greengrass_core_sockets}})
    status_units=("{{greengrass_lite_target}}")
    for unit in "${core_sockets[@]}" "${core_units[@]}" "${component_units[@]}"; do
      if unit_exists "$unit"; then
        status_units+=("$unit")
      fi
    done
    sudo systemctl --no-pager --full status "${status_units[@]}" || true

@restart: stop start

