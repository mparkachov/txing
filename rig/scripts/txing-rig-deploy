#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
Usage: txing-rig-deploy [auto|raspi|cloud|all]

Deploys txing rig component binaries to AWS IoT Greengrass. Binaries can come
from mise installs or explicit TXING_*_BINARY paths. This command is
self-contained and does not require a txing source checkout.
EOF
}

fail() {
  echo "error: $*" >&2
  exit 1
}

target="${1:-auto}"
if [ "$#" -gt 1 ]; then
  usage
  exit 2
fi
case "$target" in
  auto|raspi|cloud|all) ;;
  *=*) fail "pass arguments positionally, for example: txing-rig-deploy raspi" ;;
  *) fail "target must be auto, raspi, cloud, or all" ;;
esac

dry_run="${TXING_RIG_DEPLOY_DRY_RUN:-false}"
case "$dry_run" in
  true|1|yes|on) dry_run=true ;;
  false|0|no|off|'') dry_run=false ;;
  *) fail "TXING_RIG_DEPLOY_DRY_RUN must be true or false" ;;
esac

config_dir="${TXING_RIG_CONFIG_DIR:-${HOME:-}/.config/txing/rig}"
env_file="${TXING_RIG_ENV_FILE:-$config_dir/aws.env}"
if [ -r "$env_file" ]; then
  # shellcheck disable=SC1090
  source "$env_file"
elif [ "$dry_run" != true ]; then
  fail "missing rig AWS config: $env_file"
fi

AWS_REGION="${AWS_REGION:-}"
AWS_STACK_NAME="${AWS_STACK_NAME:-}"
AWS_SELECTED_PROFILE="${AWS_SELECTED_PROFILE:-${AWS_SOURCE_PROFILE:-${AWS_TOWN_PROFILE:-${AWS_PROFILE:-}}}}"
AWS_SHARED_CREDENTIALS_FILE="${AWS_SHARED_CREDENTIALS_FILE:-$config_dir/aws.credentials}"
case "$AWS_SHARED_CREDENTIALS_FILE" in
  /*) ;;
  *) AWS_SHARED_CREDENTIALS_FILE="$config_dir/$AWS_SHARED_CREDENTIALS_FILE" ;;
esac
export AWS_SHARED_CREDENTIALS_FILE

if [ "$dry_run" != true ]; then
  [ -n "$AWS_REGION" ] || fail "AWS_REGION is required in $env_file"
  [ -n "$AWS_STACK_NAME" ] || fail "AWS_STACK_NAME is required in $env_file"
  command -v aws >/dev/null 2>&1 || fail "aws CLI is required"
  command -v jq >/dev/null 2>&1 || fail "jq is required"
fi
AWS_REGION="${AWS_REGION:-test-region-1}"
AWS_STACK_NAME="${AWS_STACK_NAME:-test-stack}"
export AWS_REGION AWS_DEFAULT_REGION="$AWS_REGION"

aws_flags=(--region "$AWS_REGION")
if [ -n "$AWS_SELECTED_PROFILE" ]; then
  aws_flags+=(--profile "$AWS_SELECTED_PROFILE")
  export AWS_PROFILE="$AWS_SELECTED_PROFILE" AWS_DEFAULT_PROFILE="$AWS_SELECTED_PROFILE"
else
  unset AWS_PROFILE AWS_DEFAULT_PROFILE
fi

strict_semver_re='^[0-9]+\.[0-9]+\.[0-9]+$'

resolve_binary() {
  local env_name="$1"
  local binary_name="$2"
  local explicit="${!env_name:-}"
  if [ -n "$explicit" ]; then
    [ -x "$explicit" ] || fail "$env_name points to a non-executable path: $explicit"
    printf '%s\n' "$explicit"
    return 0
  fi
  command -v "$binary_name" 2>/dev/null || fail "could not find $binary_name on PATH"
}

version_from_binary_path() {
  local tool="$1"
  local path="$2"
  local version=""
  case "$path" in
    */installs/"$tool"/*/"$tool"|*/installs/"$tool"/*/bin/"$tool")
      version="${path#*/installs/$tool/}"
      version="${version%%/*}"
      ;;
  esac
  if [ -z "$version" ]; then
    version="${TXING_RIG_COMPONENT_VERSION:-}"
  fi
  [ -n "$version" ] || fail "could not infer version for $tool from $path; set TXING_RIG_COMPONENT_VERSION"
  [[ "$version" =~ $strict_semver_re ]] || fail "$tool version must be stable SemVer x.y.z, got: $version"
  printf '%s\n' "$version"
}

sparkplug_manager_binary="$(resolve_binary TXING_SPARKPLUG_MANAGER_BINARY txing-sparkplug-manager)"
ble_connectivity_binary="$(resolve_binary TXING_BLE_CONNECTIVITY_BINARY txing-ble-connectivity)"
aws_connectivity_binary="$(resolve_binary TXING_AWS_CONNECTIVITY_BINARY txing-aws-connectivity)"

sparkplug_version="$(version_from_binary_path txing-sparkplug-manager "$sparkplug_manager_binary")"
ble_version="$(version_from_binary_path txing-ble-connectivity "$ble_connectivity_binary")"
aws_version="$(version_from_binary_path txing-aws-connectivity "$aws_connectivity_binary")"
if [ "$sparkplug_version" != "$ble_version" ] || [ "$sparkplug_version" != "$aws_version" ]; then
  fail "rig component version skew: sparkplug=$sparkplug_version ble=$ble_version aws=$aws_version"
fi
resolved_component_version="$sparkplug_version"
export TXING_VERSION_BASE="${TXING_VERSION_BASE:-$resolved_component_version}"
export TXING_VERSION="$resolved_component_version"

describe_thing_json() {
  local thing_id="$1"
  aws iot describe-thing --thing-name "$thing_id" "${aws_flags[@]}" --output json
}

jq_string() {
  local json="$1"
  local query="$2"
  jq -r "$query // empty" <<<"$json"
}

deploy_target="$target"
if [ "$deploy_target" = "auto" ]; then
  if [ -n "${RIG_TYPE:-}" ]; then
    deploy_target="$RIG_TYPE"
  elif [ -n "${TXING_RIG_TYPE:-}" ]; then
    deploy_target="$TXING_RIG_TYPE"
  elif [ "$dry_run" = true ]; then
    deploy_target="${TXING_RIG_DEPLOY_DRY_RUN_RIG_TYPE:-raspi}"
  else
    [ -n "${TXING_RIG_ID:-}" ] || fail "TXING_RIG_ID is required to resolve auto deploy target"
    rig_json="$(describe_thing_json "$TXING_RIG_ID")"
    deploy_target="$(jq_string "$rig_json" '.thingTypeName')"
    TXING_TOWN_ID="${TXING_TOWN_ID:-$(jq_string "$rig_json" '.attributes.townId')}"
  fi
fi
case "$deploy_target" in
  raspi|cloud|all) ;;
  *) fail "target must resolve to raspi, cloud, or all, got: $deploy_target" ;;
esac

if [ "$dry_run" = true ]; then
  artifacts_bucket="${TXING_RIG_ARTIFACTS_BUCKET:-txing-greengrass-artifacts-dry-run}"
  iot_data_endpoint="${TXING_RIG_IOT_DATA_ENDPOINT:-iot.example.invalid}"
else
  artifacts_bucket="$(
    aws cloudformation describe-stacks \
      --stack-name "$AWS_STACK_NAME" \
      "${aws_flags[@]}" \
      --query "Stacks[0].Outputs[?OutputKey=='GreengrassArtifactsBucketName'].OutputValue | [0]" \
      --output text
  )"
  if [ -z "$artifacts_bucket" ] || [ "$artifacts_bucket" = "None" ]; then
    fail "could not resolve GreengrassArtifactsBucketName from stack $AWS_STACK_NAME"
  fi
  iot_data_endpoint="$(aws iot describe-endpoint --endpoint-type iot:Data-ATS "${aws_flags[@]}" --query endpointAddress --output text)"
fi

build_root="${TXING_RIG_DEPLOY_DRY_RUN_DIR:-}"
cleanup_build_root=true
if [ -z "$build_root" ]; then
  build_root="$(mktemp -d "${TMPDIR:-/tmp}/txing-rig-deploy.XXXXXX")"
else
  cleanup_build_root=false
  rm -rf "$build_root"
  mkdir -p "$build_root"
fi
cleanup() {
  if [ "$cleanup_build_root" = true ]; then
    rm -rf "$build_root"
  fi
}
trap cleanup EXIT
recipe_dir="$build_root/recipes"
mkdir -p "$recipe_dir"

upload_artifact() {
  local component="$1"
  local source="$2"
  local filename="$3"
  local key="artifacts/$component/$resolved_component_version/$filename"
  if [ "$dry_run" = true ]; then
    printf 's3://%s/%s\n' "$artifacts_bucket" "$key"
    return 0
  fi
  if aws s3api head-object --bucket "$artifacts_bucket" --key "$key" "${aws_flags[@]}" >/dev/null 2>&1; then
    printf 'artifact already exists: s3://%s/%s\n' "$artifacts_bucket" "$key" >&2
  else
    aws s3 cp "$source" "s3://$artifacts_bucket/$key" "${aws_flags[@]}" >/dev/null
  fi
  printf 's3://%s/%s\n' "$artifacts_bucket" "$key"
}

sparkplug_uri="$(upload_artifact dev.txing.rig.SparkplugManager "$sparkplug_manager_binary" txing-sparkplug-manager)"
ble_uri="$(upload_artifact dev.txing.rig.BleConnectivity "$ble_connectivity_binary" txing-ble-connectivity)"
aws_uri="$(upload_artifact dev.txing.rig.AwsConnectivity "$aws_connectivity_binary" txing-aws-connectivity)"

cat >"$recipe_dir/dev.txing.rig.SparkplugManager.yaml" <<EOF
RecipeFormatVersion: '2020-01-25'
ComponentName: dev.txing.rig.SparkplugManager
ComponentVersion: '$resolved_component_version'
ComponentType: aws.greengrass.generic
ComponentDescription: txing rig Sparkplug lifecycle manager.
ComponentPublisher: txing
ComponentDependencies:
  aws.greengrass.TokenExchangeService:
    VersionRequirement: '>=0.0.0'
    DependencyType: HARD
ComponentConfiguration:
  DefaultConfiguration:
    InventoryIntervalSeconds: 30
    CommandDeadlineMs: 60000
    accessControl:
      aws.greengrass.ipc.pubsub:
        dev.txing.rig.SparkplugManager:pubsub:1:
          policyDescription: Allows Sparkplug manager to exchange v2 capability messages with rig adapters.
          operations:
            - aws.greengrass#PublishToTopic
            - aws.greengrass#SubscribeToTopic
          resources:
            - dev/txing/rig/v2/*
Manifests:
  - Platform:
      os: linux
      runtime: aws_nucleus_lite
    Lifecycle:
      run:
        Script: |-
          export AWS_REGION="$AWS_REGION"
          export AWS_DEFAULT_REGION="$AWS_REGION"
          export AWS_IOT_ENDPOINT="$iot_data_endpoint"
          export TXING_VERSION_BASE="$TXING_VERSION_BASE"
          export TXING_VERSION="$resolved_component_version"
          unset AWS_PROFILE AWS_DEFAULT_PROFILE AWS_SHARED_CREDENTIALS_FILE
          exec "{artifacts:path}/txing-sparkplug-manager" \
            --iot-endpoint "$iot_data_endpoint" \
            --aws-region "$AWS_REGION" \
            --inventory-interval-seconds "{configuration:/InventoryIntervalSeconds}" \
            --command-deadline-ms "{configuration:/CommandDeadlineMs}"
    Artifacts:
      - Uri: "$sparkplug_uri"
        Unarchive: "NONE"
        Permission:
          Read: ALL
          Execute: ALL
EOF

cat >"$recipe_dir/dev.txing.rig.BleConnectivity.yaml" <<EOF
RecipeFormatVersion: '2020-01-25'
ComponentName: dev.txing.rig.BleConnectivity
ComponentVersion: '$resolved_component_version'
ComponentType: aws.greengrass.generic
ComponentDescription: txing rig-wide BLE connectivity adapter for power and weather devices.
ComponentPublisher: txing
ComponentConfiguration:
  DefaultConfiguration:
    AdapterId: dev.txing.rig.BleConnectivity
    ScanIntervalMs: 500
    PresenceTimeoutMs: 20000
    ReconnectDelayMs: 2000
    ConnectTimeoutMs: 8000
    CommandTimeoutMs: 8000
    HeartbeatIntervalMs: 10000
    MaxConnections: 0
    accessControl:
      aws.greengrass.ipc.pubsub:
        dev.txing.rig.BleConnectivity:pubsub:1:
          policyDescription: Allows BLE connectivity to exchange v2 capability messages with the Sparkplug manager.
          operations:
            - aws.greengrass#PublishToTopic
            - aws.greengrass#SubscribeToTopic
          resources:
            - dev/txing/rig/v2/*
      aws.greengrass.ipc.mqttproxy:
        dev.txing.rig.BleConnectivity:mqttproxy:1:
          policyDescription: Allows BLE connectivity to publish BLE-owned named shadow updates.
          operations:
            - aws.greengrass#PublishToIoTCore
          resources:
            - \$aws/things/+/shadow/name/ble/update
            - \$aws/things/+/shadow/name/power/update
            - \$aws/things/+/shadow/name/weather/update
Manifests:
  - Platform:
      os: linux
      runtime: aws_nucleus_lite
    Lifecycle:
      run:
        Script: |-
          exec "{artifacts:path}/txing-ble-connectivity" \
            --adapter-id "{configuration:/AdapterId}" \
            --scan-interval-ms "{configuration:/ScanIntervalMs}" \
            --presence-timeout-ms "{configuration:/PresenceTimeoutMs}" \
            --reconnect-delay-ms "{configuration:/ReconnectDelayMs}" \
            --connect-timeout-ms "{configuration:/ConnectTimeoutMs}" \
            --command-timeout-ms "{configuration:/CommandTimeoutMs}" \
            --heartbeat-interval-ms "{configuration:/HeartbeatIntervalMs}" \
            --max-connections "{configuration:/MaxConnections}"
    Artifacts:
      - Uri: "$ble_uri"
        Unarchive: "NONE"
        Permission:
          Read: ALL
          Execute: ALL
EOF

cat >"$recipe_dir/dev.txing.rig.AwsConnectivity.yaml" <<EOF
RecipeFormatVersion: '2020-01-25'
ComponentName: dev.txing.rig.AwsConnectivity
ComponentVersion: '$resolved_component_version'
ComponentType: aws.greengrass.generic
ComponentDescription: txing rig-wide AWS retained MQTT connectivity adapter for cloud devices.
ComponentPublisher: txing
ComponentDependencies:
  aws.greengrass.TokenExchangeService:
    VersionRequirement: '>=0.0.0'
    DependencyType: HARD
ComponentConfiguration:
  DefaultConfiguration:
    AdapterId: dev.txing.rig.AwsConnectivity
    HeartbeatIntervalMs: 10000
    StateReportIntervalMs: 10000
    KeepAliveSeconds: 60
    accessControl:
      aws.greengrass.ipc.pubsub:
        dev.txing.rig.AwsConnectivity:pubsub:1:
          policyDescription: Allows AWS connectivity to exchange v2 capability messages with the Sparkplug manager.
          operations:
            - aws.greengrass#PublishToTopic
            - aws.greengrass#SubscribeToTopic
          resources:
            - dev/txing/rig/v2/*
Manifests:
  - Platform:
      os: linux
      runtime: aws_nucleus_lite
    Lifecycle:
      run:
        Script: |-
          export AWS_REGION="$AWS_REGION"
          export AWS_DEFAULT_REGION="$AWS_REGION"
          export AWS_IOT_ENDPOINT="$iot_data_endpoint"
          export TXING_VERSION_BASE="$TXING_VERSION_BASE"
          export TXING_VERSION="$resolved_component_version"
          unset AWS_PROFILE AWS_DEFAULT_PROFILE AWS_SHARED_CREDENTIALS_FILE
          exec "{artifacts:path}/txing-aws-connectivity" \
            --adapter-id "{configuration:/AdapterId}" \
            --iot-endpoint "$iot_data_endpoint" \
            --aws-region "$AWS_REGION" \
            --heartbeat-interval-ms "{configuration:/HeartbeatIntervalMs}" \
            --state-report-interval-ms "{configuration:/StateReportIntervalMs}" \
            --keep-alive-seconds "{configuration:/KeepAliveSeconds}" \
            --include-capability time
    Artifacts:
      - Uri: "$aws_uri"
        Unarchive: "NONE"
        Permission:
          Read: ALL
          Execute: ALL
EOF

if [ "$dry_run" = true ]; then
  printf 'dry-run generated recipes in %s\n' "$recipe_dir"
  exit 0
fi

create_component_version() {
  local recipe="$1"
  local err_file="$build_root/create-component.err"
  if aws greengrassv2 create-component-version --inline-recipe "fileb://$recipe" "${aws_flags[@]}" >/dev/null 2>"$err_file"; then
    printf 'published component recipe %s\n' "$(basename "$recipe")"
  elif grep -Eiq 'already exists|conflict|ConflictException' "$err_file"; then
    printf 'component recipe already exists: %s\n' "$(basename "$recipe")"
  else
    cat "$err_file" >&2
    exit 1
  fi
}

create_component_version "$recipe_dir/dev.txing.rig.SparkplugManager.yaml"
create_component_version "$recipe_dir/dev.txing.rig.BleConnectivity.yaml"
create_component_version "$recipe_dir/dev.txing.rig.AwsConnectivity.yaml"

ensure_thing_group() {
  local rig_type="$1"
  local group="txing-rig-type-$rig_type"
  local err_file="$build_root/create-thing-group.err"
  if aws iot create-thing-group --thing-group-name "$group" "${aws_flags[@]}" >/dev/null 2>"$err_file"; then
    printf 'created thing group %s\n' "$group"
  elif grep -Eiq 'already exists|ResourceAlreadyExistsException' "$err_file"; then
    printf 'thing group already exists: %s\n' "$group"
  else
    cat "$err_file" >&2
    exit 1
  fi
  aws iot describe-thing-group --thing-group-name "$group" "${aws_flags[@]}" --query thingGroupArn --output text
}

deploy_rig_type() {
  local rig_type="$1"
  local target_arn
  target_arn="$(ensure_thing_group "$rig_type" | tail -n 1)"
  local components_json="$build_root/$rig_type-components.json"
  case "$rig_type" in
    raspi)
      jq -n --arg version "$resolved_component_version" '{
        "dev.txing.rig.SparkplugManager": { "componentVersion": $version },
        "dev.txing.rig.BleConnectivity": { "componentVersion": $version }
      }' >"$components_json"
      ;;
    cloud)
      jq -n --arg version "$resolved_component_version" '{
        "dev.txing.rig.SparkplugManager": { "componentVersion": $version },
        "dev.txing.rig.AwsConnectivity": { "componentVersion": $version }
      }' >"$components_json"
      ;;
  esac
  aws greengrassv2 create-deployment \
    --target-arn "$target_arn" \
    --deployment-name "txing-$rig_type-$resolved_component_version" \
    --components "file://$components_json" \
    "${aws_flags[@]}" >/dev/null
  printf 'created Greengrass deployment target=%s version=%s group=%s\n' "$rig_type" "$resolved_component_version" "$target_arn"
}

case "$deploy_target" in
  raspi|cloud) deploy_rig_type "$deploy_target" ;;
  all)
    deploy_rig_type raspi
    deploy_rig_type cloud
    ;;
esac

if command -v systemctl >/dev/null 2>&1 && systemctl cat greengrass-lite.target >/dev/null 2>&1; then
  printf 'local Greengrass Lite is installed; deployment will be processed by Greengrass cloud deployment polling.\n'
fi
