#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
Usage: txing-rig-deploy-release [latest|vX.Y.Z|X.Y.Z] [raspi|cloud|all]

Downloads txing rig binaries from a GitHub release with gh, then
publishes those binaries as AWS IoT Greengrass component artifacts using this
checkout's txing-rig-deploy shell script. Run this from an operator machine with
AWS credentials. The downloaded Linux component binaries are uploaded to S3 and
are not executed locally.
EOF
}

fail() {
  echo "error: $*" >&2
  exit 1
}

release_ref="${1:-latest}"
target="${2:-all}"
script_dir="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
if [ "$#" -gt 2 ]; then
  usage
  exit 2
fi
case "$release_ref" in
  *=*) fail "pass arguments positionally, for example: txing-rig-deploy-release latest all" ;;
esac
case "$target" in
  raspi|cloud|all) ;;
  *=*) fail "pass arguments positionally, for example: txing-rig-deploy-release latest all" ;;
  *) fail "target must be raspi, cloud, or all" ;;
esac

repo_full="${TXING_GITHUB_REPOSITORY:-${TXING_GITHUB_OWNER:-mparkachov}/${TXING_GITHUB_REPO:-txing}}"
dry_run="${TXING_RIG_DEPLOY_DRY_RUN:-false}"
case "$dry_run" in
  true|1|yes|on) dry_run=true ;;
  false|0|no|off|'') dry_run=false ;;
  *) fail "TXING_RIG_DEPLOY_DRY_RUN must be true or false" ;;
esac

command -v gh >/dev/null 2>&1 || fail "gh CLI is required"
command -v tar >/dev/null 2>&1 || fail "tar is required"
if [ "$dry_run" != true ]; then
  command -v aws >/dev/null 2>&1 || fail "aws CLI is required"
  command -v jq >/dev/null 2>&1 || fail "jq is required"
fi

case "$release_ref" in
  latest)
    release_tag="$(gh release view --repo "$repo_full" --json tagName --jq '.tagName')"
    ;;
  v[0-9]*)
    release_tag="$release_ref"
    ;;
  [0-9]*)
    release_tag="v$release_ref"
    ;;
  *)
    fail "release must be latest, vX.Y.Z, or X.Y.Z"
    ;;
esac

version="${release_tag#v}"
strict_semver_re='^[0-9]+\.[0-9]+\.[0-9]+$'
[[ "$version" =~ $strict_semver_re ]] || fail "release tag must be SemVer vX.Y.Z, got: $release_tag"

work_dir="$(mktemp -d "${TMPDIR:-/tmp}/txing-rig-release.XXXXXX")"
keep_work_dir="${TXING_RIG_RELEASE_KEEP_WORK_DIR:-false}"
case "$keep_work_dir" in
  true|1|yes|on) keep_work_dir=true ;;
  false|0|no|off|'') keep_work_dir=false ;;
  *) fail "TXING_RIG_RELEASE_KEEP_WORK_DIR must be true or false" ;;
esac
cleanup() {
  if [ "$keep_work_dir" = true ]; then
    printf 'kept release work directory: %s\n' "$work_dir" >&2
  else
    rm -rf "$work_dir"
  fi
}
trap cleanup EXIT

download_dir="$work_dir/downloads"
install_root="$work_dir/installs"
install -d -m 700 "$download_dir" "$install_root"

download_asset() {
  local asset_name="$1"
  gh release download "$release_tag" \
    --repo "$repo_full" \
    --pattern "$asset_name" \
    --dir "$download_dir" \
    --clobber
  [ -s "$download_dir/$asset_name" ] || fail "release asset is missing or empty: $asset_name"
}

extract_binary_asset() {
  local asset_name="$1"
  local binary_name="$2"
  local binary_dir="$install_root/$binary_name/$version"
  install -d -m 700 "$binary_dir"
  tar -xzf "$download_dir/$asset_name" -C "$binary_dir"
  [ -x "$binary_dir/$binary_name" ] || fail "$asset_name did not contain executable $binary_name"
  printf '%s\n' "$binary_dir/$binary_name"
}

sparkplug_asset="txing-sparkplug-manager-linux-aarch64.tar.gz"
ble_asset="txing-ble-connectivity-linux-aarch64.tar.gz"
aws_asset="txing-aws-connectivity-linux-aarch64.tar.gz"

download_asset "$sparkplug_asset"
download_asset "$ble_asset"
download_asset "$aws_asset"

sparkplug_binary="$(extract_binary_asset "$sparkplug_asset" txing-sparkplug-manager)"
ble_binary="$(extract_binary_asset "$ble_asset" txing-ble-connectivity)"
aws_binary="$(extract_binary_asset "$aws_asset" txing-aws-connectivity)"
deploy_binary="${TXING_RIG_DEPLOY_SCRIPT:-$script_dir/txing-rig-deploy}"
[ -x "$deploy_binary" ] || fail "txing-rig-deploy helper is missing or not executable: $deploy_binary"

printf 'deploying txing release %s to Greengrass target=%s from %s\n' "$release_tag" "$target" "$repo_full"

export TXING_RIG_COMPONENT_VERSION="$version"
export TXING_SPARKPLUG_MANAGER_BINARY="$sparkplug_binary"
export TXING_BLE_CONNECTIVITY_BINARY="$ble_binary"
export TXING_AWS_CONNECTIVITY_BINARY="$aws_binary"

exec "$deploy_binary" "$target"
