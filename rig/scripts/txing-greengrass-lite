#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
Usage: txing-greengrass-lite check
       txing-greengrass-lite payload-dir
       txing-greengrass-lite payload-files
       txing-greengrass-lite version

Inspects the mise-provided Greengrass Lite payload. This helper is intentionally
read-only: it does not install host files, call systemd, or require elevated
privileges.
EOF
}

fail() {
  echo "error: $*" >&2
  exit 1
}

script_path="${BASH_SOURCE[0]}"
script_dir="$(cd "$(dirname "$script_path")" && pwd -P)"
payload_dir="${TXING_GREENGRASS_LITE_PAYLOAD_DIR:-$script_dir/txing-greengrass-lite-payload}"
metadata_file="$payload_dir/metadata.env"
bin_dir="$payload_dir/bin"
systemd_dir="$payload_dir/systemd"
tmpfiles_dir="$payload_dir/tmpfiles"

load_metadata() {
  [ -r "$metadata_file" ] || fail "missing payload metadata: $metadata_file"
  # shellcheck disable=SC1090
  source "$metadata_file"
}

check_payload() {
  load_metadata
  [ ! -e "$payload_dir/root" ] || fail "unsafe Greengrass Lite payload contains a root filesystem tree"
  [ ! -e "$payload_dir/lib" ] || fail "unsafe Greengrass Lite payload contains top-level lib content"
  [ -d "$bin_dir" ] || fail "missing Greengrass Lite binary payload: $bin_dir"
  [ -d "$systemd_dir" ] || fail "missing Greengrass Lite systemd payload: $systemd_dir"
  [ -d "$tmpfiles_dir" ] || fail "missing Greengrass Lite tmpfiles payload: $tmpfiles_dir"
  [ -x "$bin_dir/ggl-cli" ] || fail "missing Greengrass Lite CLI: $bin_dir/ggl-cli"
  [ -r "$systemd_dir/greengrass-lite.target" ] || fail "missing greengrass-lite.target in $systemd_dir"
}

if [ "$#" -ne 1 ]; then
  usage
  exit 2
fi

case "$1" in
  check)
    check_payload
    printf 'txing Greengrass Lite payload %s is available at %s\n' \
      "${TXING_GREENGRASS_LITE_VERSION:?}" "$payload_dir"
    ;;
  payload-dir)
    check_payload
    printf '%s\n' "$payload_dir"
    ;;
  payload-files)
    check_payload
    printf 'TXING_GREENGRASS_LITE_PAYLOAD_DIR=%s\n' "$payload_dir"
    printf 'TXING_GREENGRASS_LITE_BIN_DIR=%s\n' "$bin_dir"
    printf 'TXING_GREENGRASS_LITE_SYSTEMD_DIR=%s\n' "$systemd_dir"
    printf 'TXING_GREENGRASS_LITE_TMPFILES_DIR=%s\n' "$tmpfiles_dir"
    ;;
  version)
    load_metadata
    printf '%s\n' "${TXING_GREENGRASS_LITE_VERSION:?}"
    ;;
  install)
    fail "automatic host installation was removed; use the payload paths with manual host configuration steps"
    ;;
  *)
    usage
    exit 2
    ;;
esac
