{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://txing.local/schemas/txing-shadow.schema.json",
  "title": "Txing Thing Shadow Contract v15",
  "description": "Canonical payload shape for txing Thing Shadow updates and snapshots.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "state"
  ],
  "properties": {
    "state": {
      "type": "object",
      "description": "Classic (unnamed) Thing Shadow state object.",
      "additionalProperties": true,
      "properties": {
        "desired": {
          "$ref": "#/$defs/desiredState"
        },
        "reported": {
          "$ref": "#/$defs/reportedState"
        }
      },
      "anyOf": [
        {
          "required": [
            "desired"
          ]
        },
        {
          "required": [
            "reported"
          ]
        }
      ]
    },
    "clientToken": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 0
    },
    "timestamp": {
      "type": "integer",
      "minimum": 0
    }
  },
  "$defs": {
    "desiredState": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "mcu": {
          "$ref": "#/$defs/desiredMcuState"
        },
        "board": {
          "$ref": "#/$defs/desiredBoardState"
        }
      },
      "anyOf": [
        {
          "required": [
            "mcu"
          ]
        },
        {
          "required": [
            "board"
          ]
        }
      ]
    },
    "desiredBoardState": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "power": {
          "type": [
            "boolean",
            "null"
          ]
        }
      }
    },
    "reportedState": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "mcu": {
          "$ref": "#/$defs/reportedMcuState"
        },
        "board": {
          "$ref": "#/$defs/reportedBoardState"
        }
      },
      "anyOf": [
        {
          "required": [
            "mcu"
          ]
        },
        {
          "required": [
            "board"
          ]
        }
      ]
    },
    "desiredMcuState": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "power": {
          "type": [
            "boolean",
            "null"
          ]
        }
      }
    },
    "reportedMcuState": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "power",
        "batteryMv",
        "ble"
      ],
      "properties": {
        "power": {
          "type": "boolean"
        },
        "batteryMv": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "ble": {
          "$ref": "#/$defs/bleGattUuids"
        }
      }
    },
    "reportedBoardState": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "power",
        "wifi"
      ],
      "properties": {
        "power": {
          "type": "boolean"
        },
        "wifi": {
          "$ref": "#/$defs/reportedBoardWifiState"
        }
      }
    },
    "reportedBoardWifiState": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "online"
      ],
      "properties": {
        "online": {
          "type": "boolean"
        },
        "ipv4": {
          "type": [
            "string",
            "null"
          ],
          "format": "ipv4"
        },
        "ipv6": {
          "type": [
            "string",
            "null"
          ],
          "format": "ipv6"
        }
      }
    },
    "bleGattUuids": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "serviceUuid",
        "sleepCommandUuid",
        "stateReportUuid",
        "online"
      ],
      "properties": {
        "serviceUuid": {
          "type": "string",
          "format": "uuid"
        },
        "sleepCommandUuid": {
          "type": "string",
          "format": "uuid"
        },
        "stateReportUuid": {
          "type": "string",
          "format": "uuid"
        },
        "online": {
          "type": "boolean"
        },
        "deviceId": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      }
    }
  }
}
