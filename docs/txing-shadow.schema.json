{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://txing.local/schemas/txing-shadow.schema.json",
  "title": "Txing Thing Shadow Contract v20",
  "description": "Canonical payload shape for txing Thing Shadow updates and snapshots.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "state"
  ],
  "properties": {
    "state": {
      "type": "object",
      "description": "Classic (unnamed) Thing Shadow state object.",
      "additionalProperties": true,
      "properties": {
        "desired": {
          "$ref": "#/$defs/desiredState"
        },
        "reported": {
          "$ref": "#/$defs/reportedState"
        }
      },
      "anyOf": [
        {
          "required": [
            "desired"
          ]
        },
        {
          "required": [
            "reported"
          ]
        }
      ]
    },
    "clientToken": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 0
    },
    "timestamp": {
      "type": "integer",
      "minimum": 0
    }
  },
  "$defs": {
    "desiredState": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "redcon": {
          "description": "Latest unresolved Sparkplug lifecycle target reflected into shadow by rig.",
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1,
          "maximum": 4
        },
        "mcu": {
          "description": "Deprecated compatibility desired subtree. Phase-1 runtime ignores desired.mcu.power as a lifecycle authority.",
          "$ref": "#/$defs/desiredMcuState"
        },
        "board": {
          "description": "Internal-only rig-to-board graceful-halt actuator used during REDCON 4 convergence.",
          "$ref": "#/$defs/desiredBoardState"
        }
      },
      "anyOf": [
        {
          "required": [
            "redcon"
          ]
        },
        {
          "required": [
            "mcu"
          ]
        },
        {
          "required": [
            "board"
          ]
        }
      ]
    },
    "desiredBoardState": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "power": {
          "description": "Internal-only board graceful-halt request. false asks the board to halt locally before MCU sleep.",
          "type": [
            "boolean",
            "null"
          ]
        }
      }
    },
    "reportedState": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "redcon": {
          "description": "Rig-derived readiness summary. 4=MCU sleep state, 3=MCU awake but operator video path not ready, 2=board online and video ready without an active viewer, 1=board online with an active viewer.",
          "type": "integer",
          "minimum": 1,
          "maximum": 4
        },
        "batteryMv": {
          "description": "Rig-reported MCU battery estimate in millivolts, surfaced at top-level alongside redcon.",
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "mcu": {
          "$ref": "#/$defs/reportedMcuState"
        },
        "board": {
          "$ref": "#/$defs/reportedBoardState"
        }
      },
      "anyOf": [
        {
          "required": [
            "batteryMv"
          ]
        },
        {
          "required": [
            "mcu"
          ]
        },
        {
          "required": [
            "board"
          ]
        }
      ]
    },
    "desiredMcuState": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "power": {
          "description": "Deprecated compatibility field. Phase-1 runtime ignores desired.mcu.power.",
          "type": [
            "boolean",
            "null"
          ]
        }
      }
    },
    "reportedMcuState": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "power",
        "ble"
      ],
      "properties": {
        "power": {
          "type": "boolean"
        },
        "ble": {
          "$ref": "#/$defs/bleGattUuids"
        }
      }
    },
    "reportedBoardState": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "power",
        "wifi",
        "drive"
      ],
      "properties": {
        "power": {
          "type": "boolean"
        },
        "wifi": {
          "$ref": "#/$defs/reportedBoardWifiState"
        },
        "drive": {
          "$ref": "#/$defs/reportedBoardDriveState"
        },
        "video": {
          "$ref": "#/$defs/reportedBoardVideoState"
        }
      }
    },
    "reportedBoardWifiState": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "online"
      ],
      "properties": {
        "online": {
          "type": "boolean"
        },
        "ipv4": {
          "type": [
            "string",
            "null"
          ],
          "format": "ipv4"
        },
        "ipv6": {
          "type": [
            "string",
            "null"
          ],
          "format": "ipv6"
        }
      }
    },
    "reportedBoardDriveState": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "leftSpeed",
        "rightSpeed"
      ],
      "properties": {
        "leftSpeed": {
          "type": "integer",
          "minimum": -100,
          "maximum": 100
        },
        "rightSpeed": {
          "type": "integer",
          "minimum": -100,
          "maximum": 100
        }
      }
    },
    "reportedBoardVideoState": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "ready",
        "status",
        "transport",
        "session",
        "codec",
        "viewerConnected",
        "lastError"
      ],
      "properties": {
        "ready": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": [
            "starting",
            "ready",
            "error"
          ]
        },
        "transport": {
          "type": "string",
          "enum": [
            "aws-webrtc"
          ]
        },
        "session": {
          "$ref": "#/$defs/reportedBoardVideoSessionState"
        },
        "codec": {
          "$ref": "#/$defs/reportedBoardVideoCodecState"
        },
        "viewerConnected": {
          "type": "boolean"
        },
        "lastError": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "reportedBoardVideoSessionState": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "viewerUrl",
        "channelName"
      ],
      "properties": {
        "viewerUrl": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "channelName": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      }
    },
    "reportedBoardVideoCodecState": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "video"
      ],
      "properties": {
        "video": {
          "enum": [
            "h264",
            null
          ]
        }
      }
    },
    "bleGattUuids": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "serviceUuid",
        "sleepCommandUuid",
        "stateReportUuid",
        "online"
      ],
      "properties": {
        "serviceUuid": {
          "type": "string",
          "format": "uuid"
        },
        "sleepCommandUuid": {
          "type": "string",
          "format": "uuid"
        },
        "stateReportUuid": {
          "type": "string",
          "format": "uuid"
        },
        "online": {
          "type": "boolean"
        },
        "deviceId": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      }
    }
  }
}
