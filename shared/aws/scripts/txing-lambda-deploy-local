#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
Usage: txing-lambda-deploy-local [all|txing-witness-lambda|txing-enlist-lambda|txing-cloud-rig-lambda|txing-cloud-mcu-lambda]

Builds txing Lambda bootstrap zips locally as linux/arm64 Go binaries, uploads
them to the stable current/bootstrap.zip keys in the txing CloudFormation
artifact bucket, and updates existing Lambda functions from those S3 objects.
If a function does not exist yet, the command only seeds the stable S3 bootstrap
key used by the first aws::deploy stack creation.
EOF
}

fail() {
  echo "error: $*" >&2
  exit 1
}

selector="${1:-all}"
if [ "$#" -gt 1 ]; then
  usage
  exit 2
fi
case "$selector" in
  *=*) fail "pass arguments positionally, for example: txing-lambda-deploy-local txing-witness-lambda" ;;
esac

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
project_root="$(cd "$script_dir/../../.." && pwd)"
artifact_bucket="${TXING_LAMBDA_ARTIFACT_BUCKET:-}"
[ -n "$artifact_bucket" ] || fail "TXING_LAMBDA_ARTIFACT_BUCKET is required"

command -v aws >/dev/null 2>&1 || fail "aws CLI is required"
command -v file >/dev/null 2>&1 || fail "file is required"
command -v go >/dev/null 2>&1 || fail "go is required"
command -v unzip >/dev/null 2>&1 || fail "unzip is required"
command -v zip >/dev/null 2>&1 || fail "zip is required"

case "${TXING_LAMBDA_LOCAL_SKIP_TESTS:-false}" in
  true|1|yes|on) skip_tests=true ;;
  false|0|no|off|"") skip_tests=false ;;
  *) fail "TXING_LAMBDA_LOCAL_SKIP_TESTS must be true or false" ;;
esac

work_dir="$(mktemp -d "${TMPDIR:-/tmp}/txing-lambda-local.XXXXXX")"
keep_work_dir="${TXING_LAMBDA_LOCAL_KEEP_WORK_DIR:-false}"
case "$keep_work_dir" in
  true|1|yes|on) keep_work_dir=true ;;
  false|0|no|off|"") keep_work_dir=false ;;
  *) fail "TXING_LAMBDA_LOCAL_KEEP_WORK_DIR must be true or false" ;;
esac
cleanup() {
  if [ "$keep_work_dir" = true ]; then
    printf 'kept local lambda work directory: %s\n' "$work_dir" >&2
  else
    rm -rf "$work_dir"
  fi
}
trap cleanup EXIT

functions=()
case "$selector" in
  all)
    functions=(
      txing-witness-lambda
      txing-enlist-lambda
      txing-cloud-rig-lambda
      txing-cloud-mcu-lambda
    )
    ;;
  witness|txing-witness-lambda) functions=(txing-witness-lambda) ;;
  enlist|txing-enlist-lambda) functions=(txing-enlist-lambda) ;;
  cloud-rig|txing-cloud-rig-lambda) functions=(txing-cloud-rig-lambda) ;;
  cloud-mcu|txing-cloud-mcu-lambda) functions=(txing-cloud-mcu-lambda) ;;
  *)
    usage
    fail "unknown Lambda selector: $selector"
    ;;
esac

lambda_workdir() {
  case "$1" in
    txing-witness-lambda) printf '%s\n' "$project_root/witness" ;;
    txing-enlist-lambda) printf '%s\n' "$project_root/shared/aws/enlist" ;;
    txing-cloud-rig-lambda|txing-cloud-mcu-lambda) printf '%s\n' "$project_root/devices/cloud-mcu/lambda" ;;
    *) fail "unknown Lambda function: $1" ;;
  esac
}

lambda_package() {
  case "$1" in
    txing-witness-lambda) printf '%s\n' "./cmd/txing-witness-lambda" ;;
    txing-enlist-lambda) printf '%s\n' "./cmd/txing-enlist-lambda" ;;
    txing-cloud-rig-lambda) printf '%s\n' "./cmd/txing-cloud-rig-lambda" ;;
    txing-cloud-mcu-lambda) printf '%s\n' "./cmd/txing-cloud-mcu-lambda" ;;
    *) fail "unknown Lambda function: $1" ;;
  esac
}

tested_dirs=":"

package_lambda() {
  local function_name="$1"
  local module_dir package_path binary_path package_dir asset_path bootstrap_file archive_listing
  module_dir="$(lambda_workdir "$function_name")"
  package_path="$(lambda_package "$function_name")"
  binary_path="$work_dir/$function_name"
  package_dir="$work_dir/package-$function_name"
  asset_path="$work_dir/$function_name.zip"

  if [ "$skip_tests" = false ]; then
    case "$tested_dirs" in
      *:"$module_dir":*) ;;
      *)
        printf 'testing %s\n' "$module_dir" >&2
        (cd "$module_dir" && go test -tags lambda.norpc ./... >&2)
        tested_dirs="${tested_dirs}${module_dir}:"
        ;;
    esac
  fi

  printf 'building %s\n' "$function_name" >&2
  (cd "$module_dir" && GOOS=linux GOARCH=arm64 CGO_ENABLED=0 \
    go build -trimpath -tags lambda.norpc -ldflags="-s -w" \
      -o "$binary_path" "$package_path" >&2)

  rm -rf "$package_dir"
  install -d "$package_dir"
  install -m 755 "$binary_path" "$package_dir/bootstrap"
  bootstrap_file="$(file "$package_dir/bootstrap")"
  printf '%s\n' "$bootstrap_file" >&2
  if ! grep -q 'ELF 64-bit LSB executable, ARM aarch64' <<<"$bootstrap_file"; then
    fail "$function_name bootstrap is not a Linux ARM64 executable"
  fi
  if ! grep -q 'statically linked' <<<"$bootstrap_file"; then
    fail "$function_name bootstrap is not statically linked"
  fi
  (cd "$package_dir" && zip -q "$asset_path" bootstrap)
  archive_listing="$(unzip -Z1 "$asset_path")"
  if [ "$archive_listing" != "bootstrap" ]; then
    printf 'bad archive listing for %s:\n%s\n' "$function_name" "$archive_listing" >&2
    exit 1
  fi
  printf '%s\n' "$asset_path"
}

deploy_lambda() {
  local function_name="$1"
  local asset_path current_key
  asset_path="$(package_lambda "$function_name")"
  current_key="lambda/$function_name/current/bootstrap.zip"

  aws s3 cp "$asset_path" "s3://$artifact_bucket/$current_key" >/dev/null
  printf 'uploaded local lambda bootstrap: s3://%s/%s\n' "$artifact_bucket" "$current_key"

  if aws lambda get-function --function-name "$function_name" >/dev/null 2>&1; then
    aws lambda update-function-code \
      --function-name "$function_name" \
      --s3-bucket "$artifact_bucket" \
      --s3-key "$current_key" \
      >/dev/null
    aws lambda wait function-updated --function-name "$function_name"
    printf 'updated lambda function %s from local current/bootstrap.zip\n' "$function_name"
  else
    printf 'lambda function %s does not exist yet; seeded S3 bootstrap for first aws::deploy\n' "$function_name"
  fi
}

printf 'deploying local txing Lambda build to bucket %s\n' "$artifact_bucket"
for function_name in "${functions[@]}"; do
  deploy_lambda "$function_name"
done
