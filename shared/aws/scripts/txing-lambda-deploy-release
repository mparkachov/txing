#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
Usage: txing-lambda-deploy-release [latest|vX.Y.Z|X.Y.Z]

Downloads txing Lambda bootstrap zips from a GitHub release with gh, uploads
them to the txing CloudFormation artifact bucket, and updates existing Lambda
functions. If a function does not exist yet, the command only seeds the stable
S3 bootstrap key used by the first aws::deploy stack creation.
EOF
}

fail() {
  echo "error: $*" >&2
  exit 1
}

release_ref="${1:-latest}"
if [ "$#" -gt 1 ]; then
  usage
  exit 2
fi
case "$release_ref" in
  *=*) fail "pass arguments positionally, for example: txing-lambda-deploy-release latest" ;;
esac

repo_full="${TXING_GITHUB_REPOSITORY:-${TXING_GITHUB_OWNER:-mparkachov}/${TXING_GITHUB_REPO:-txing}}"
artifact_bucket="${TXING_LAMBDA_ARTIFACT_BUCKET:-}"
[ -n "$artifact_bucket" ] || fail "TXING_LAMBDA_ARTIFACT_BUCKET is required"

command -v gh >/dev/null 2>&1 || fail "gh CLI is required"
command -v aws >/dev/null 2>&1 || fail "aws CLI is required"

case "$release_ref" in
  latest)
    release_tag="$(gh release view --repo "$repo_full" --json tagName --jq '.tagName')"
    ;;
  v[0-9]*)
    release_tag="$release_ref"
    ;;
  [0-9]*)
    release_tag="v$release_ref"
    ;;
  *)
    fail "release must be latest, vX.Y.Z, or X.Y.Z"
    ;;
esac

version="${release_tag#v}"
strict_semver_re='^[0-9]+\.[0-9]+\.[0-9]+$'
[[ "$version" =~ $strict_semver_re ]] || fail "release tag must be SemVer vX.Y.Z, got: $release_tag"

work_dir="$(mktemp -d "${TMPDIR:-/tmp}/txing-lambda-release.XXXXXX")"
keep_work_dir="${TXING_LAMBDA_RELEASE_KEEP_WORK_DIR:-false}"
case "$keep_work_dir" in
  true|1|yes|on) keep_work_dir=true ;;
  false|0|no|off|'') keep_work_dir=false ;;
  *) fail "TXING_LAMBDA_RELEASE_KEEP_WORK_DIR must be true or false" ;;
esac
cleanup() {
  if [ "$keep_work_dir" = true ]; then
    printf 'kept release work directory: %s\n' "$work_dir" >&2
  else
    rm -rf "$work_dir"
  fi
}
trap cleanup EXIT

download_dir="$work_dir/downloads"
install -d -m 700 "$download_dir"

download_asset() {
  local asset_name="$1"
  gh release download "$release_tag" \
    --repo "$repo_full" \
    --pattern "$asset_name" \
    --dir "$download_dir" \
    --clobber
  [ -s "$download_dir/$asset_name" ] || fail "release asset is missing or empty: $asset_name"
}

upload_lambda_asset() {
  local function_name="$1"
  local asset_name="$2"
  local source="$download_dir/$asset_name"
  local version_key="lambda/$function_name/$version/bootstrap.zip"
  local current_key="lambda/$function_name/current/bootstrap.zip"

  download_asset "$asset_name"
  if aws s3api head-object --bucket "$artifact_bucket" --key "$version_key" >/dev/null 2>&1; then
    printf 'lambda artifact already exists: s3://%s/%s\n' "$artifact_bucket" "$version_key" >&2
  else
    aws s3 cp "$source" "s3://$artifact_bucket/$version_key" >/dev/null
    printf 'uploaded lambda artifact: s3://%s/%s\n' "$artifact_bucket" "$version_key"
  fi
  aws s3 cp "$source" "s3://$artifact_bucket/$current_key" >/dev/null
  printf 'seeded lambda bootstrap: s3://%s/%s\n' "$artifact_bucket" "$current_key"

  if aws lambda get-function --function-name "$function_name" >/dev/null 2>&1; then
    aws lambda update-function-code \
      --function-name "$function_name" \
      --s3-bucket "$artifact_bucket" \
      --s3-key "$version_key" \
      >/dev/null
    aws lambda wait function-updated --function-name "$function_name"
    printf 'updated lambda function %s to release %s\n' "$function_name" "$release_tag"
  else
    printf 'lambda function %s does not exist yet; seeded S3 bootstrap for first aws::deploy\n' "$function_name"
  fi
}

printf 'deploying txing Lambda release %s from %s using bucket %s\n' "$release_tag" "$repo_full" "$artifact_bucket"

upload_lambda_asset txing-witness-lambda txing-witness-lambda-linux-aarch64.zip
upload_lambda_asset txing-enlist-lambda txing-enlist-lambda-linux-aarch64.zip
upload_lambda_asset txing-time-lambda txing-time-lambda-linux-aarch64.zip
