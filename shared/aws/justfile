@configure-indexing region=region profile=profile:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"

    eval "$(just --justfile "{{root_justfile}}" _project-aws-env town "{{region}}" "{{profile}}")"
    region="$AWS_REGION"
    profile="$AWS_SELECTED_PROFILE"

    if [ -z "$region" ]; then
      echo "region is empty and no default AWS region is configured. Set region=<aws-region>" >&2
      exit 1
    fi

    aws_flags=(--region "$region")
    if [ -n "$profile" ]; then
      aws_flags+=(--profile "$profile")
    fi

    thing_indexing_configuration='{"thingIndexingMode":"REGISTRY","thingConnectivityIndexingMode":"OFF","customFields":[{"name":"attributes.name","type":"String"},{"name":"attributes.town","type":"String"},{"name":"attributes.rig","type":"String"}]}'

    aws iot update-indexing-configuration \
      "${aws_flags[@]}" \
      --thing-indexing-configuration "$thing_indexing_configuration"

    deadline=$(( $(date +%s) + 90 ))
    while :; do
      thing_indexing_mode="$(
        aws iot get-indexing-configuration \
          "${aws_flags[@]}" \
          --query "thingIndexingConfiguration.thingIndexingMode" \
          --output text 2>/dev/null || true
      )"
      thing_connectivity_indexing_mode="$(
        aws iot get-indexing-configuration \
          "${aws_flags[@]}" \
          --query "thingIndexingConfiguration.thingConnectivityIndexingMode" \
          --output text 2>/dev/null || true
      )"
      indexing_custom_fields="$(
        aws iot get-indexing-configuration \
          "${aws_flags[@]}" \
          --query "thingIndexingConfiguration.customFields[].name" \
          --output text 2>/dev/null || true
      )"
      if [ "$thing_indexing_mode" = "REGISTRY" ] \
        && [ "$thing_connectivity_indexing_mode" = "OFF" ] \
        && printf '%s\n' "$indexing_custom_fields" | tr '\t' '\n' | grep -Fx "attributes.name" >/dev/null \
        && printf '%s\n' "$indexing_custom_fields" | tr '\t' '\n' | grep -Fx "attributes.town" >/dev/null \
        && printf '%s\n' "$indexing_custom_fields" | tr '\t' '\n' | grep -Fx "attributes.rig" >/dev/null; then
        break
      fi
      if [ "$(date +%s)" -ge "$deadline" ]; then
        echo "timed out waiting for AWS IoT fleet indexing configuration" >&2
        exit 1
      fi
      sleep 3
    done

    aws iot get-indexing-configuration \
      "${aws_flags[@]}" \
      --query "thingIndexingConfiguration" \
      --output json

# Register a new device. Usage: just aws::register-device <town> <rig> <device-type> [region] [profile]
@register-device town rig device_type region=region profile=profile:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"

    eval "$(just --justfile "{{root_justfile}}" _project-aws-env town "{{region}}" "{{profile}}")"
    region="$AWS_REGION"
    profile="$AWS_SELECTED_PROFILE"

    if [ -z "$region" ]; then
      echo "region is empty and no default AWS region is configured. Set region=<aws-region>" >&2
      exit 1
    fi
    if [ -z "{{town}}" ]; then
      echo "town is required. Usage: just aws::register-device <town> <rig> <device-type> [region] [profile]" >&2
      exit 1
    fi
    if [ -z "{{rig}}" ]; then
      echo "rig is required. Usage: just aws::register-device <town> <rig> <device-type> [region] [profile]" >&2
      exit 1
    fi
    if [ -z "{{device_type}}" ]; then
      echo "device_type is required. Usage: just aws::register-device <town> <rig> <device-type> [region] [profile]" >&2
      exit 1
    fi

    aws_flags=(--region "$region")
    if [ -n "$profile" ]; then
      aws_flags+=(--profile "$profile")
    fi

    uv run --project "{{aws_dir}}/python" \
      python -m aws.device_registry \
      --region "$region" \
      register-device \
      --town "{{town}}" \
      --rig "{{rig}}" \
      --device-type "{{device_type}}"

