deploy-town town_name stack_name=stack_name:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"
    source "{{aws_lib}}"
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env aws "{{stack_name}}")"
    txing_aws_init
    payload_file="$(mktemp "${TMPDIR:-/tmp}/txing-enlist-town.XXXXXX")"
    trap 'rm -f "$payload_file"' EXIT
    jq -n --arg townName "{{town_name}}" \
      '{action:"enlistTown", townName:$townName}' >"$payload_file"
    registration="$(invoke_enlist_payload_file "$payload_file")"
    jq -r '"town id: \(.thingName)"' <<<"$registration"
    jq '.' <<<"$registration"

