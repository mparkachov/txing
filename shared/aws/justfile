    mkdir -p "$(dirname "{{packaged_template_file}}")"
    artifact_bucket="$(ensure_artifact_bucket)"
    aws cloudformation package \
      --template-file "{{template_file}}" \
      --s3-bucket "$artifact_bucket" \
      --output-template-file "{{packaged_template_file}}" \
      "${aws_flags[@]}"

    aws cloudformation validate-template --template-body "file://{{packaged_template_file}}" "${aws_flags[@]}"

