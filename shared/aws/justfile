@things-for-rig rig_name=rig_name region=region profile=profile:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"

    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig "{{region}}" "{{profile}}")"
    region="$AWS_REGION"
    profile="$AWS_SELECTED_PROFILE"

    if [ -z "$region" ]; then
      echo "region is empty and no default AWS region is configured. Set region=<aws-region>" >&2
      exit 1
    fi

    aws_flags=(--region "$region")
    if [ -n "$profile" ]; then
      aws_flags+=(--profile "$profile")
    fi

    thing_names="$(
      aws iot list-things-in-thing-group \
        --thing-group-name "{{rig_name}}" \
        "${aws_flags[@]}" \
        --query "things" \
        --output text
    )"

    if [ -z "$thing_names" ] || [ "$thing_names" = "None" ]; then
      echo "[]"
      exit 0
    fi

    result="[]"
    for thing in $thing_names; do
      thing_json="$(
        aws iot describe-thing \
          --thing-name "$thing" \
          "${aws_flags[@]}" \
          --output json
      )"
      result="$(
        jq -cn \
          --argjson rows "$result" \
          --argjson thing "$thing_json" \
          '$rows + [{
            thingName: $thing.thingName,
            thingType: ($thing.thingTypeName // null),
            name: ($thing.attributes.name // null),
            shortId: ($thing.attributes.shortId // null),
            capabilitiesSet: ($thing.attributes.capabilitiesSet // null),
            town: ($thing.attributes.town // null),
            rig: ($thing.attributes.rig // null)
          }]'
      )"
    done

    printf '%s\n' "$result" | jq '.'

@shadow thing_name=thing_name shadow_name='' region=region profile=profile:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"

    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig "{{region}}" "{{profile}}")"
    region="$AWS_REGION"
    profile="$AWS_SELECTED_PROFILE"

    if [ -z "$region" ]; then
      echo "region is empty and no default AWS region is configured. Set region=<aws-region>" >&2
      exit 1
    fi

    aws_flags=(--region "$region")
    if [ -n "$profile" ]; then
      aws_flags+=(--profile "$profile")
    fi

    endpoint="$(aws iot describe-endpoint --endpoint-type iot:Data-ATS "${aws_flags[@]}" --query endpointAddress --output text)"
    thing_json="$(
      aws iot describe-thing \
        --thing-name "{{thing_name}}" \
        "${aws_flags[@]}" \
        --output json
    )"
    thing_type="$(jq -r '.thingTypeName // empty' <<<"$thing_json")"
    if [ -z "$thing_type" ]; then
      echo "thing {{thing_name}} has no thingTypeName; cannot select required named shadows" >&2
      exit 1
    fi
    capabilities_set="$(jq -r '.attributes.capabilitiesSet // empty' <<<"$thing_json")"
    if [ -z "$capabilities_set" ]; then
      echo "thing {{thing_name}} is missing required attribute capabilitiesSet" >&2
      exit 1
    fi
    allowed_shadow_names=()
    while IFS= read -r allowed_shadow_name; do
      allowed_shadow_names+=("$allowed_shadow_name")
    done < <(jq -r '.attributes.capabilitiesSet | split(",")[]' <<<"$thing_json")
    if [ "${#allowed_shadow_names[@]}" -eq 0 ]; then
      echo "thing {{thing_name}} has empty capabilitiesSet" >&2
      exit 1
    fi
    for allowed_shadow_name in "${allowed_shadow_names[@]}"; do
      case "$allowed_shadow_name" in
        sparkplug|mcu|board|mcp|video)
          ;;
        ""|*" "*)
          echo "thing {{thing_name}} has malformed capabilitiesSet: $capabilities_set" >&2
          exit 1
          ;;
        *)
          echo "thing {{thing_name}} has unsupported capability $allowed_shadow_name" >&2
          exit 1
          ;;
      esac
    done

    shadow_name="{{shadow_name}}"
    if [ -n "$shadow_name" ]; then
      allowed_shadow=0
      for allowed_shadow_name in "${allowed_shadow_names[@]}"; do
        if [ "$shadow_name" = "$allowed_shadow_name" ]; then
          allowed_shadow=1
          break
        fi
      done
      if [ "$allowed_shadow" -ne 1 ]; then
        echo "shadow $shadow_name is not required for $thing_type thing {{thing_name}}; required: ${allowed_shadow_names[*]}" >&2
        exit 1
      fi
      aws iot-data get-thing-shadow \
        --endpoint-url "https://$endpoint" \
        --thing-name "{{thing_name}}" \
        --shadow-name "$shadow_name" \
        "${aws_flags[@]}" \
        /dev/stdout | jq --arg shadowName "$shadow_name" '{($shadowName): .}'
      exit 0
    fi

    result="{}"
    for current_shadow_name in "${allowed_shadow_names[@]}"; do
      payload=""
      get_output=""
      if ! get_output="$(
        aws iot-data get-thing-shadow \
          --endpoint-url "https://$endpoint" \
          --thing-name "{{thing_name}}" \
          --shadow-name "$current_shadow_name" \
          "${aws_flags[@]}" \
          /dev/stdout 2>&1
      )"; then
        if ! printf '%s\n' "$get_output" | grep -F "ResourceNotFoundException" >/dev/null; then
          printf '%s\n' "$get_output" >&2
          exit 1
        fi
        payload='{"missing":true}'
      else
        payload="$get_output"
      fi
      result="$(
        jq \
          --arg shadowName "$current_shadow_name" \
          --argjson shadowPayload "$payload" \
          '. + {($shadowName): $shadowPayload}' \
          <<<"$result"
      )"
    done

    jq '.' <<<"$result"

@shadow-reset thing_name=thing_name shadow_name='' region=region profile=profile payload_file='':
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"

    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig "{{region}}" "{{profile}}")"
    region="$AWS_REGION"
    profile="$AWS_SELECTED_PROFILE"

    if [ -z "$region" ]; then
      echo "region is empty and no default AWS region is configured. Set region=<aws-region>" >&2
      exit 1
    fi
    aws_flags=(--region "$region")
    if [ -n "$profile" ]; then
      aws_flags+=(--profile "$profile")
    fi

    endpoint="$(aws iot describe-endpoint --endpoint-type iot:Data-ATS "${aws_flags[@]}" --query endpointAddress --output text)"
    thing_json="$(
      aws iot describe-thing \
        --thing-name "{{thing_name}}" \
        "${aws_flags[@]}" \
        --output json
    )"
    thing_type="$(jq -r '.thingTypeName // empty' <<<"$thing_json")"
    if [ -z "$thing_type" ]; then
      echo "thing {{thing_name}} has no thingTypeName; cannot select required named shadows" >&2
      exit 1
    fi
    capabilities_set="$(jq -r '.attributes.capabilitiesSet // empty' <<<"$thing_json")"
    if [ -z "$capabilities_set" ]; then
      echo "thing {{thing_name}} is missing required attribute capabilitiesSet" >&2
      exit 1
    fi
    allowed_shadow_names=()
    while IFS= read -r allowed_shadow_name; do
      allowed_shadow_names+=("$allowed_shadow_name")
    done < <(jq -r '.attributes.capabilitiesSet | split(",")[]' <<<"$thing_json")
    if [ "${#allowed_shadow_names[@]}" -eq 0 ]; then
      echo "thing {{thing_name}} has empty capabilitiesSet" >&2
      exit 1
    fi
    for allowed_shadow_name in "${allowed_shadow_names[@]}"; do
      case "$allowed_shadow_name" in
        sparkplug|mcu|board|mcp|video)
          ;;
        ""|*" "*)
          echo "thing {{thing_name}} has malformed capabilitiesSet: $capabilities_set" >&2
          exit 1
          ;;
        *)
          echo "thing {{thing_name}} has unsupported capability $allowed_shadow_name" >&2
          exit 1
          ;;
      esac
    done

    payload_file="{{payload_file}}"
    shadow_names=()
    if [ -n "{{shadow_name}}" ]; then
      requested_shadow_name="{{shadow_name}}"
      allowed_shadow=0
      for allowed_shadow_name in "${allowed_shadow_names[@]}"; do
        if [ "$requested_shadow_name" = "$allowed_shadow_name" ]; then
          allowed_shadow=1
          break
        fi
      done
      if [ "$allowed_shadow" -ne 1 ]; then
        echo "shadow $requested_shadow_name is not required for $thing_type thing {{thing_name}}; required: ${allowed_shadow_names[*]}" >&2
        exit 1
      fi
      shadow_names=("$requested_shadow_name")
    else
      shadow_names=("${allowed_shadow_names[@]}")
      delete_output=""
      if ! delete_output="$(
        aws iot-data delete-thing-shadow \
          --endpoint-url "https://$endpoint" \
          --thing-name "{{thing_name}}" \
          "${aws_flags[@]}" \
          /dev/null 2>&1
      )"; then
        if ! printf '%s\n' "$delete_output" | grep -F "ResourceNotFoundException" >/dev/null; then
          printf '%s\n' "$delete_output" >&2
          exit 1
        fi
      fi
      for obsolete_shadow_name in sparkplug device mcu board mcp video; do
        obsolete_shadow=1
        for allowed_shadow_name in "${allowed_shadow_names[@]}"; do
          if [ "$obsolete_shadow_name" = "$allowed_shadow_name" ]; then
            obsolete_shadow=0
            break
          fi
        done
        if [ "$obsolete_shadow" -eq 0 ]; then
          continue
        fi
        delete_output=""
        if ! delete_output="$(
          aws iot-data delete-thing-shadow \
            --endpoint-url "https://$endpoint" \
            --thing-name "{{thing_name}}" \
            --shadow-name "$obsolete_shadow_name" \
            "${aws_flags[@]}" \
            /dev/null 2>&1
        )"; then
          if ! printf '%s\n' "$delete_output" | grep -F "ResourceNotFoundException" >/dev/null; then
            printf '%s\n' "$delete_output" >&2
            exit 1
          fi
        fi
      done
    fi
    if [ -n "$payload_file" ] && [ "${#shadow_names[@]}" -ne 1 ]; then
      echo "payload file override is only valid when resetting one named shadow" >&2
      exit 1
    fi

    payload_temp_files=()
    cleanup_payload_temp_files() {
      if [ "${#payload_temp_files[@]}" -gt 0 ]; then
        rm -f "${payload_temp_files[@]}"
      fi
    }
    trap cleanup_payload_temp_files EXIT

    result="{}"
    for current_shadow_name in "${shadow_names[@]}"; do
      default_payload="$payload_file"
      if [ -z "$default_payload" ]; then
        case "$thing_type:$current_shadow_name" in
          town:sparkplug)
            default_payload="$(mktemp)"
            payload_temp_files+=("$default_payload")
            jq \
              -n \
              '{state: {reported: {payload: {metrics: {redcon: 1}}}}}' \
              >"$default_payload"
            ;;
          rig:sparkplug)
            default_payload="$(mktemp)"
            payload_temp_files+=("$default_payload")
            jq \
              -n \
              --arg groupId "$(jq -r '.attributes.town' <<<"$thing_json")" \
              --arg edgeNodeId "$(jq -r '.attributes.name' <<<"$thing_json")" \
              '{state: {reported: {topic: {namespace: "spBv1.0", groupId: $groupId, messageType: "NDEATH", edgeNodeId: $edgeNodeId}, payload: {metrics: {redcon: 4}}}}}' \
              >"$default_payload"
            ;;
          unit:sparkplug)
            default_payload="$(mktemp)"
            payload_temp_files+=("$default_payload")
            jq \
              -n \
              --arg groupId "$(jq -r '.attributes.town' <<<"$thing_json")" \
              --arg edgeNodeId "$(jq -r '.attributes.rig' <<<"$thing_json")" \
              --arg deviceId "$(jq -r '.thingName' <<<"$thing_json")" \
              '{state: {reported: {topic: {namespace: "spBv1.0", groupId: $groupId, messageType: "DDEATH", edgeNodeId: $edgeNodeId, deviceId: $deviceId}, payload: {metrics: {redcon: 4}}}}}' \
              >"$default_payload"
            ;;
          *)
            default_payload="{{project_root}}/devices/${thing_type}/aws/default-${current_shadow_name}-shadow.json"
            ;;
        esac
      fi
      if [ ! -f "$default_payload" ]; then
        echo "shadow reset payload $default_payload not found" >&2
        exit 1
      fi

      delete_output=""
      if ! delete_output="$(
        aws iot-data delete-thing-shadow \
          --endpoint-url "https://$endpoint" \
          --thing-name "{{thing_name}}" \
          --shadow-name "$current_shadow_name" \
          "${aws_flags[@]}" \
          /dev/null 2>&1
      )"; then
        if ! printf '%s\n' "$delete_output" | grep -F "ResourceNotFoundException" >/dev/null; then
          printf '%s\n' "$delete_output" >&2
          exit 1
        fi
      fi

      payload="$(
        aws iot-data update-thing-shadow \
          --endpoint-url "https://$endpoint" \
          --thing-name "{{thing_name}}" \
          --shadow-name "$current_shadow_name" \
          --payload "fileb://$default_payload" \
          "${aws_flags[@]}" \
          /dev/stdout
      )"
      result="$(
        jq \
          --arg shadowName "$current_shadow_name" \
          --argjson shadowPayload "$payload" \
          '. + {($shadowName): $shadowPayload}' \
          <<<"$result"
      )"
    done

    jq '.' <<<"$result"

@cert thing_name=thing_name policy_name=policy_name region=region profile=profile output_dir=local_state_dir cert_basename='' cert_arn_file='':
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"

    eval "$(just --justfile "{{root_justfile}}" _project-aws-env town "{{region}}" "{{profile}}")"
    region="$AWS_REGION"
    profile="$AWS_SELECTED_PROFILE"

    if [ -z "$region" ]; then
      echo "region is empty and no default AWS region is configured. Set region=<aws-region>" >&2
      exit 1
    fi

    aws_flags=(--region "$region")
    if [ -n "$profile" ]; then
      aws_flags+=(--profile "$profile")
    fi

    cert_basename="{{cert_basename}}"
    if [ -z "$cert_basename" ]; then
      cert_basename="{{thing_name}}"
    fi

    cert_arn_file="{{cert_arn_file}}"
    if [ -z "$cert_arn_file" ]; then
      cert_arn_file="{{output_dir}}/${cert_basename}.cert.arn"
    fi

    mkdir -p "{{output_dir}}"
    if [ -f "$cert_arn_file" ]; then
      echo "$cert_arn_file already exists. Reuse this certificate or delete the file to issue a new one."
      exit 0
    fi

    cert_arn="$(
      aws iot create-keys-and-certificate \
        --set-as-active \
        --certificate-pem-outfile "{{output_dir}}/${cert_basename}.cert.pem" \
        --public-key-outfile "{{output_dir}}/${cert_basename}.public.key" \
        --private-key-outfile "{{output_dir}}/${cert_basename}.private.key" \
        "${aws_flags[@]}" \
        --query certificateArn \
        --output text
    )"
    echo "$cert_arn" | tee "$cert_arn_file"
    aws iot attach-policy --policy-name "{{policy_name}}" --target "$cert_arn" "${aws_flags[@]}"
    aws iot attach-thing-principal --thing-name "{{thing_name}}" --principal "$cert_arn" "${aws_flags[@]}"
    echo "Certificate ARN saved to $cert_arn_file"

@init-shadow thing_name=thing_name shadow_name='sparkplug' region=region profile=profile output_dir=local_state_dir payload_file='' shadow_response_file='':
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"

    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig "{{region}}" "{{profile}}")"
    region="$AWS_REGION"
    profile="$AWS_SELECTED_PROFILE"

    if [ -z "$region" ]; then
      echo "region is empty and no default AWS region is configured. Set region=<aws-region>" >&2
      exit 1
    fi

    aws_flags=(--region "$region")
    if [ -n "$profile" ]; then
      aws_flags+=(--profile "$profile")
    fi

    shadow_response_file="{{shadow_response_file}}"
    if [ -z "$shadow_response_file" ]; then
      shadow_response_file="{{output_dir}}/{{thing_name}}.{{shadow_name}}.shadow-response.json"
    fi
    default_payload="{{payload_file}}"

    mkdir -p "{{output_dir}}"
    endpoint="$(aws iot describe-endpoint --endpoint-type iot:Data-ATS "${aws_flags[@]}" --query endpointAddress --output text)"
    thing_json="$(
      aws iot describe-thing \
        --thing-name "{{thing_name}}" \
        "${aws_flags[@]}" \
        --output json
    )"
    thing_type="$(jq -r '.thingTypeName // empty' <<<"$thing_json")"
    if [ -z "$thing_type" ]; then
      echo "thing {{thing_name}} has no thingTypeName; cannot select required named shadows" >&2
      exit 1
    fi
    capabilities_set="$(jq -r '.attributes.capabilitiesSet // empty' <<<"$thing_json")"
    if [ -z "$capabilities_set" ]; then
      echo "thing {{thing_name}} is missing required attribute capabilitiesSet" >&2
      exit 1
    fi
    allowed_shadow_names=()
    while IFS= read -r allowed_shadow_name; do
      allowed_shadow_names+=("$allowed_shadow_name")
    done < <(jq -r '.attributes.capabilitiesSet | split(",")[]' <<<"$thing_json")
    if [ "${#allowed_shadow_names[@]}" -eq 0 ]; then
      echo "thing {{thing_name}} has empty capabilitiesSet" >&2
      exit 1
    fi
    for allowed_shadow_name in "${allowed_shadow_names[@]}"; do
      case "$allowed_shadow_name" in
        sparkplug|mcu|board|mcp|video)
          ;;
        ""|*" "*)
          echo "thing {{thing_name}} has malformed capabilitiesSet: $capabilities_set" >&2
          exit 1
          ;;
        *)
          echo "thing {{thing_name}} has unsupported capability $allowed_shadow_name" >&2
          exit 1
          ;;
      esac
    done
    allowed_shadow=0
    for allowed_shadow_name in "${allowed_shadow_names[@]}"; do
      if [ "{{shadow_name}}" = "$allowed_shadow_name" ]; then
        allowed_shadow=1
        break
      fi
    done
    if [ "$allowed_shadow" -ne 1 ]; then
      echo "shadow {{shadow_name}} is not required for $thing_type thing {{thing_name}}; required: ${allowed_shadow_names[*]}" >&2
      exit 1
    fi
    payload_temp_file=""
    cleanup_payload_temp_file() {
      if [ -n "$payload_temp_file" ]; then
        rm -f "$payload_temp_file"
      fi
    }
    trap cleanup_payload_temp_file EXIT
    if [ -z "$default_payload" ]; then
      case "$thing_type:{{shadow_name}}" in
        town:sparkplug)
          payload_temp_file="$(mktemp)"
          default_payload="$payload_temp_file"
          jq \
            -n \
            '{state: {reported: {payload: {metrics: {redcon: 1}}}}}' \
            >"$default_payload"
          ;;
        rig:sparkplug)
          payload_temp_file="$(mktemp)"
          default_payload="$payload_temp_file"
          jq \
            -n \
            --arg groupId "$(jq -r '.attributes.town' <<<"$thing_json")" \
            --arg edgeNodeId "$(jq -r '.attributes.name' <<<"$thing_json")" \
            '{state: {reported: {topic: {namespace: "spBv1.0", groupId: $groupId, messageType: "NDEATH", edgeNodeId: $edgeNodeId}, payload: {metrics: {redcon: 4}}}}}' \
            >"$default_payload"
          ;;
        unit:sparkplug)
          payload_temp_file="$(mktemp)"
          default_payload="$payload_temp_file"
          jq \
            -n \
            --arg groupId "$(jq -r '.attributes.town' <<<"$thing_json")" \
            --arg edgeNodeId "$(jq -r '.attributes.rig' <<<"$thing_json")" \
            --arg deviceId "$(jq -r '.thingName' <<<"$thing_json")" \
            '{state: {reported: {topic: {namespace: "spBv1.0", groupId: $groupId, messageType: "DDEATH", edgeNodeId: $edgeNodeId, deviceId: $deviceId}, payload: {metrics: {redcon: 4}}}}}' \
            >"$default_payload"
          ;;
        *)
          default_payload="{{project_root}}/devices/${thing_type}/aws/default-{{shadow_name}}-shadow.json"
          ;;
      esac
    fi
    if [ ! -f "$default_payload" ]; then
      echo "shadow init payload $default_payload not found" >&2
      exit 1
    fi

    aws iot-data update-thing-shadow \
      --endpoint-url "https://$endpoint" \
      --thing-name "{{thing_name}}" \
      --shadow-name "{{shadow_name}}" \
      --payload "fileb://$default_payload" \
      "${aws_flags[@]}" \
      "$shadow_response_file"
    echo "Named shadow {{shadow_name}} initialized from $default_payload"

@bootstrap CognitoDomainPrefix='' AdminEmail='' stack_name=stack_name template_file=template_file thing_name=thing_name rig_name=rig_name policy_name=policy_name region=region profile=profile output_dir=local_state_dir cert_basename='' cert_arn_file='' default_shadow_file='' shadow_response_file='':
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"

    echo "warning: aws::bootstrap is not part of the recommended rig setup anymore."
    echo "warning: rig now uses IAM role credentials + SigV4 MQTT/WSS; this recipe remains only for legacy certificate flows elsewhere in the repo."

    just --justfile "{{aws_dir}}/justfile" deploy \
      "{{CognitoDomainPrefix}}" \
      "{{AdminEmail}}" \
      "{{stack_name}}" \
      "{{template_file}}" \
      "{{region}}" \
      "{{profile}}"
    just --justfile "{{aws_dir}}/justfile" cert \
      "{{thing_name}}" \
      "{{policy_name}}" \
      "{{region}}" \
      "{{profile}}" \
      "{{output_dir}}" \
      "{{cert_basename}}" \
      "{{cert_arn_file}}"
    just --justfile "{{aws_dir}}/justfile" init-shadow \
      "{{thing_name}}" \
      "sparkplug" \
      "{{region}}" \
      "{{profile}}" \
      "{{output_dir}}" \
      "{{default_shadow_file}}" \
      "{{shadow_response_file}}"
    just --justfile "{{aws_dir}}/justfile" upsert-rig-group \
      "{{rig_name}}" \
      "{{region}}" \
      "{{profile}}"
