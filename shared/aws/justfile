set shell := ["bash", "-eu", "-o", "pipefail", "-c"]

aws_dir := source_directory()
project_root := aws_dir + "/../.."
root_justfile := project_root + "/justfile"
aws_lib := aws_dir + "/scripts/aws_lib.sh"

stack_name := ""
template_file := "template.yaml"
town_template_file := "templates/town.yaml"
rig_template_file := "templates/rig.yaml"
device_template_file := "templates/device.yaml"
region := ""
profile := ""
localhost_app_url := "http://localhost:5173"
localhost_alt_app_url := "http://127.0.0.1:5173"

@deploy CognitoDomainPrefix='' AdminEmail='' stack_name=stack_name template_file=template_file region=region profile=profile LocalhostAppUrl=localhost_app_url LocalhostAltAppUrl=localhost_alt_app_url:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"
    source "{{aws_lib}}"
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env town "{{region}}" "{{profile}}" "{{stack_name}}" "{{CognitoDomainPrefix}}" "{{AdminEmail}}")"
    txing_aws_init
    deploy_template \
      "$AWS_STACK_NAME" \
      "{{template_file}}" \
      --parameter-overrides \
      "CognitoDomainPrefix=$AWS_COGNITO_DOMAIN_PREFIX" \
      "AdminEmail=$AWS_ADMIN_EMAIL" \
      "LocalhostAppUrl={{LocalhostAppUrl}}" \
      "LocalhostAltAppUrl={{LocalhostAltAppUrl}}"
    configure_indexing_and_wait
    describe_stack_outputs "$AWS_STACK_NAME"

