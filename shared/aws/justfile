@validate template_file=template_file region=region profile=profile stack_name=stack_name:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"
    source "{{aws_lib}}"
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env aws "{{region}}" "{{profile}}" "{{stack_name}}")"
    txing_aws_init
    artifact_bucket="$(ensure_artifact_bucket)"
    packaged_template_dir="$(mktemp -d "${TMPDIR:-/tmp}/txing-cfn.XXXXXX")"
    packaged_template="$packaged_template_dir/template.yaml"
    trap 'rm -rf "$packaged_template_dir"' EXIT
    aws cloudformation package \
      --template-file "{{template_file}}" \
      --s3-bucket "$artifact_bucket" \
      --output-template-file "$packaged_template" \
      "${aws_flags[@]}"
    aws cloudformation validate-template --template-body "file://$packaged_template" "${aws_flags[@]}"

@packaging-buckets region=region profile=profile stack_name=stack_name:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"
    source "{{aws_lib}}"
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env aws "{{region}}" "{{profile}}" "{{stack_name}}")"
    txing_aws_init
    for bucket in "$(artifact_bucket_name)" "$(legacy_time_lambda_artifact_bucket_name)"; do
      if aws s3api head-bucket --bucket "$bucket" "${aws_flags[@]}" >/dev/null 2>&1; then
        echo "exists: $bucket"
      else
        echo "missing: $bucket"
      fi
    done

