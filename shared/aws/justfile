set shell := ["bash", "-eu", "-o", "pipefail", "-c"]
set quiet := true

aws_dir := source_directory()
project_root := aws_dir + "/../.."
root_justfile := project_root + "/justfile"
aws_lib := aws_dir + "/scripts/aws_lib.sh"

stack_name := ""
template_file := "template.yaml"
town_template_file := "templates/town.yaml"
rig_template_file := "templates/rig.yaml"
device_template_file := "templates/device.yaml"
deploy_init_file := "deploy-init.json"

deploy-init parameter_file=deploy_init_file:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"
    source "{{aws_lib}}"
    parameter_file="{{parameter_file}}"
    if [ ! -f "$parameter_file" ]; then
      echo "Deploy init file $parameter_file not found. Copy shared/aws/deploy-init.example.json to shared/aws/deploy-init.json and edit it first." >&2
      exit 1
    fi
    deploy_config_json="$(
      jq -ce '
        def nonempty_string($key): has($key) and (.[$key] | type == "string" and length > 0);
        if type == "object"
          and nonempty_string("CognitoDomainPrefix")
          and nonempty_string("AdminEmail")
          and nonempty_string("WebAppUrl")
        then {
          CognitoDomainPrefix: .CognitoDomainPrefix,
          AdminEmail: .AdminEmail,
          WebAppUrl: .WebAppUrl
        }
        else error("deploy init JSON must define non-empty CognitoDomainPrefix, AdminEmail, and WebAppUrl strings")
        end
      ' "$parameter_file"
    )"
    for parameter_key in CognitoDomainPrefix AdminEmail WebAppUrl; do
      parameter_name="$(deploy_init_parameter_name "$parameter_key")"
      parameter_value="$(jq -r --arg key "$parameter_key" '.[$key]' <<<"$deploy_config_json")"
      aws ssm put-parameter \
        --name "$parameter_name" \
        --type String \
        --value "$parameter_value" \
        --overwrite \
        >/dev/null
      printf 'stored deploy init parameter %s\n' "$parameter_name"
    done

deploy stack_name=stack_name template_file=template_file:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"
    source "{{aws_lib}}"
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env aws "{{stack_name}}")"
    txing_aws_init
    deploy_template "$TXING_AWS_STACK" "{{template_file}}"
    describe_stack_outputs "$TXING_AWS_STACK"

deploy-lambdas release='latest':
    #!/usr/bin/env bash
    set -euo pipefail
    case "{{release}}" in
      latest|v[0-9]*|[0-9]*) ;;
      *=*)
        echo "release must be latest, vX.Y.Z, or X.Y.Z." >&2
        exit 1
        ;;
      *)
        echo "release must be latest, vX.Y.Z, or X.Y.Z." >&2
        exit 1
        ;;
    esac
    cd "{{aws_dir}}"
    source "{{aws_lib}}"
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env aws)"
    txing_aws_init
    artifact_bucket="$(ensure_artifact_bucket)"
    export TXING_LAMBDA_ARTIFACT_BUCKET="$artifact_bucket"
    exec "{{aws_dir}}/scripts/txing-lambda-deploy-release" "{{release}}"

delete stack_name=stack_name wait='true' delete_packaging_buckets='true':
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"
    source "{{aws_lib}}"
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env aws "{{stack_name}}")"
    txing_aws_init
    echo "Deleting CloudFormation stack $TXING_AWS_STACK"
    aws cloudformation delete-stack --stack-name "$TXING_AWS_STACK"
    if [ "{{wait}}" = "true" ]; then
      aws cloudformation wait stack-delete-complete --stack-name "$TXING_AWS_STACK"
      echo "Deleted CloudFormation stack $TXING_AWS_STACK"
    fi
    if [ "{{delete_packaging_buckets}}" = "true" ]; then
      delete_s3_bucket_if_exists "$(artifact_bucket_name)"
    fi

