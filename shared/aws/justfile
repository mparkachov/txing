@create-admin-user AdminPassword AdminEmail='' stack_name=stack_name region=region profile=profile:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"

    eval "$(just --justfile "{{root_justfile}}" _project-aws-env town "{{region}}" "{{profile}}" "{{stack_name}}" "" "{{AdminEmail}}")"
    stack_name="$AWS_STACK_NAME"
    region="$AWS_REGION"
    profile="$AWS_SELECTED_PROFILE"
    admin_email="$AWS_ADMIN_EMAIL"

    if [ -z "$region" ]; then
      echo "region is empty and no default AWS region is configured. Set region=<aws-region>" >&2
      exit 1
    fi

    aws_flags=(--region "$region")
    if [ -n "$profile" ]; then
      aws_flags+=(--profile "$profile")
    fi

    user_pool_id="$(aws cloudformation describe-stacks \
      --stack-name "$stack_name" \
      "${aws_flags[@]}" \
      --query "Stacks[0].Outputs[?OutputKey=='WebCognitoUserPoolId'].OutputValue | [0]" \
      --output text)"

    if [ "$user_pool_id" = "None" ]; then
      echo "WebCognitoUserPoolId output not found in stack $stack_name." >&2
      exit 1
    fi

    if aws cognito-idp admin-get-user \
      --user-pool-id "$user_pool_id" \
      --username "$admin_email" \
      "${aws_flags[@]}" >/dev/null 2>&1; then
      echo "Admin user already exists, updating password."
    else
      aws cognito-idp admin-create-user \
        --user-pool-id "$user_pool_id" \
        --username "$admin_email" \
        --user-attributes Name=email,Value="$admin_email" Name=email_verified,Value=true \
        --message-action SUPPRESS \
        "${aws_flags[@]}" >/dev/null
      echo "Admin user created."
    fi

    aws cognito-idp admin-set-user-password \
      --user-pool-id "$user_pool_id" \
      --username "$admin_email" \
      --password "{{AdminPassword}}" \
      --permanent \
      "${aws_flags[@]}" >/dev/null

    echo "Admin user password set."

@check thing_name='' rig_name=rig_name log_group_name=log_group_name region=region profile=profile device_profile='':
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"

    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig "{{region}}" "{{profile}}")"
    region="$AWS_REGION"
    profile="$AWS_SELECTED_PROFILE"

    if [ -z "$region" ]; then
      echo "region is empty and no default AWS region is configured. Set region=<aws-region>" >&2
      exit 1
    fi

    aws_flags=(--region "$region")
    if [ -n "$profile" ]; then
      aws_flags+=(--profile "$profile")
    fi

    failures=0

    check_tool() {
      local tool="$1"
      if command -v "$tool" >/dev/null 2>&1; then
        echo "ok: tool '$tool' is installed"
      else
        echo "fail: tool '$tool' is not installed"
        failures=$((failures + 1))
      fi
    }

    check_cmd() {
      local label="$1"
      shift
      if "$@" >/dev/null 2>&1; then
        echo "ok: $label"
      else
        echo "fail: $label"
        failures=$((failures + 1))
      fi
    }

    echo "Checking local tools..."
    check_tool aws
    check_tool jq
    check_tool uv
    check_tool just

    eval "$(just --justfile "{{root_justfile}}" _project-aws-env device "{{region}}" "{{device_profile}}")"
    device_thing_name="$THING_NAME"
    if [ -n "{{thing_name}}" ]; then
      device_thing_name="{{thing_name}}"
    fi

    run_python_service_check() {
      local scope="$1"
      local scope_profile="$2"
      shift 2

      eval "$(just --justfile "{{root_justfile}}" _project-aws-env "$scope" "{{region}}" "$scope_profile")"
      uv run --project "{{aws_dir}}/python" python -m aws.check --scope "$scope" "$@"
    }

    echo "Checking Python service AWS runtimes..."
    if ! run_python_service_check rig "{{profile}}" --rig-name "{{rig_name}}" --log-group-name "{{log_group_name}}"; then
      failures=$((failures + 1))
    fi
    if ! run_python_service_check device "{{device_profile}}" --thing-name "$device_thing_name"; then
      failures=$((failures + 1))
    fi

    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig "{{region}}" "{{profile}}")"
    region="$AWS_REGION"
    profile="$AWS_SELECTED_PROFILE"
    aws_flags=(--region "$region")
    if [ -n "$profile" ]; then
      aws_flags+=(--profile "$profile")
    fi

    thing_indexing_mode="$(
      aws iot get-indexing-configuration \
        "${aws_flags[@]}" \
        --query "thingIndexingConfiguration.thingIndexingMode" \
        --output text 2>/dev/null || true
    )"
    thing_connectivity_indexing_mode="$(
      aws iot get-indexing-configuration \
        "${aws_flags[@]}" \
        --query "thingIndexingConfiguration.thingConnectivityIndexingMode" \
        --output text 2>/dev/null || true
    )"
    indexing_custom_fields="$(
      aws iot get-indexing-configuration \
        "${aws_flags[@]}" \
        --query "thingIndexingConfiguration.customFields[].name" \
        --output text 2>/dev/null || true
    )"
    if [ "$thing_indexing_mode" = "REGISTRY" ] && [ "$thing_connectivity_indexing_mode" = "OFF" ]; then
      echo "ok: AWS IoT fleet indexing is enabled in REGISTRY mode"
    else
      echo "fail: AWS IoT fleet indexing is not configured as REGISTRY/OFF"
      failures=$((failures + 1))
    fi
    if printf '%s\n' "$indexing_custom_fields" | tr '\t' '\n' | grep -Fx "attributes.name" >/dev/null \
      && printf '%s\n' "$indexing_custom_fields" | tr '\t' '\n' | grep -Fx "attributes.town" >/dev/null \
      && printf '%s\n' "$indexing_custom_fields" | tr '\t' '\n' | grep -Fx "attributes.rig" >/dev/null; then
      echo "ok: AWS IoT fleet indexing custom fields include name, town, and rig"
    else
      echo "fail: AWS IoT fleet indexing custom fields do not include the required txing attributes"
      failures=$((failures + 1))
    fi

    thing_group_query="$(
      aws iot describe-thing-group \
        --thing-group-name "{{rig_name}}" \
        "${aws_flags[@]}" \
        --query "queryString" \
        --output text 2>/dev/null || true
    )"
    expected_thing_group_query="attributes.rig:{{rig_name}} AND attributes.town:*"
    if [ "$thing_group_query" = "$expected_thing_group_query" ]; then
      echo "ok: Dynamic thing group {{rig_name}} query matches the registered-device filter"
    else
      echo "fail: Dynamic thing group {{rig_name}} query is '$thing_group_query' (expected $expected_thing_group_query)"
      failures=$((failures + 1))
    fi

    if group_listing="$(
      aws iot list-things-in-thing-group \
        --thing-group-name "{{rig_name}}" \
        "${aws_flags[@]}" 2>/dev/null
    )"; then
      assigned_count="$(printf '%s' "$group_listing" | jq '.things | length')"
      echo "ok: Dynamic thing group membership query succeeded ($assigned_count assigned thing(s) for {{rig_name}})"
    else
      echo "fail: Dynamic thing group membership query failed"
      failures=$((failures + 1))
    fi

    thing_attributes_json="$(
      aws iot describe-thing \
        --thing-name "$device_thing_name" \
        "${aws_flags[@]}" \
        --query "attributes" \
        --output json 2>/dev/null || true
    )"
    if [ -n "$thing_attributes_json" ] && [ "$thing_attributes_json" != "null" ]; then
      if attribute_payload="$(printf '%s' "$thing_attributes_json" | jq -c '{attributes: ., merge: true}' 2>/dev/null)"; then
        check_cmd \
          "IoT UpdateThing on $device_thing_name" \
          aws iot update-thing \
          --thing-name "$device_thing_name" \
          --attribute-payload "$attribute_payload" \
          "${aws_flags[@]}"
      else
        echo "fail: Could not build no-op attribute payload for $device_thing_name"
        failures=$((failures + 1))
      fi
    else
      echo "fail: Could not read thing attributes for $device_thing_name"
      failures=$((failures + 1))
    fi

    check_stream="aws-check-$(date -u +%Y%m%dT%H%M%SZ)-$$"
    create_stream_output=""
    if create_stream_output="$(
      aws logs create-log-stream \
        --log-group-name "{{log_group_name}}" \
        --log-stream-name "$check_stream" \
        "${aws_flags[@]}" 2>&1
    )"; then
      echo "ok: CloudWatch log group {{log_group_name}} exists"
      echo "ok: CloudWatch CreateLogStream on {{log_group_name}}"
    else
      if printf '%s' "$create_stream_output" | grep -Eq 'ResourceNotFoundException|log group does not exist'; then
        echo "fail: CloudWatch log group {{log_group_name}} not found"
      else
        echo "fail: CloudWatch CreateLogStream on {{log_group_name}}"
        echo "$create_stream_output"
      fi
      failures=$((failures + 1))
      check_stream=""
    fi

    if [ -n "$check_stream" ]; then
      log_event_ts_ms="$(( $(date +%s) * 1000 ))"
      check_cmd \
        "CloudWatch PutLogEvents on {{log_group_name}}" \
        aws logs put-log-events \
        --log-group-name "{{log_group_name}}" \
        --log-stream-name "$check_stream" \
        --log-events "timestamp=${log_event_ts_ms},message=aws-check" \
        "${aws_flags[@]}"
    fi

    echo "Checking AWS IoT Data-ATS endpoint resolution..."
    resolved_endpoint="$(
      aws iot describe-endpoint \
        --endpoint-type iot:Data-ATS \
        "${aws_flags[@]}" \
        --query endpointAddress \
        --output text 2>/dev/null || true
    )"
    if [ -n "$resolved_endpoint" ] && [ "$resolved_endpoint" != "None" ]; then
      echo "ok: IoT DescribeEndpoint returned $resolved_endpoint"
    else
      echo "fail: IoT DescribeEndpoint did not return a valid Data-ATS endpoint"
      failures=$((failures + 1))
    fi

    if [ "$failures" -ne 0 ]; then
      echo "AWS/device check failed with $failures issue(s)."
      exit 1
    fi
    echo "AWS/device check passed. Role-based AWS IoT prerequisites look good."

# Upsert the dynamic rig thing group. Usage: just aws::upsert-rig-group <rig-name> [region] [profile]
@upsert-rig-group rig_name region=region profile=profile:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"

    eval "$(just --justfile "{{root_justfile}}" _project-aws-env town "{{region}}" "{{profile}}")"
    region="$AWS_REGION"
    profile="$AWS_SELECTED_PROFILE"

    if [ -z "$region" ]; then
      echo "region is empty and no default AWS region is configured. Set region=<aws-region>" >&2
      exit 1
    fi

    aws_flags=(--region "$region")
    if [ -n "$profile" ]; then
      aws_flags+=(--profile "$profile")
    fi

    thing_group_properties="$(
      jq -nc \
        --arg rig "{{rig_name}}" \
        '{
           thingGroupDescription: ("Dynamic device membership for rig " + $rig),
           attributePayload: {
             attributes: {
               rig: $rig
             },
             merge: true
           }
         }'
    )"
    query_string="attributes.rig:{{rig_name}} AND attributes.town:*"

    if aws iot describe-thing-group --thing-group-name "{{rig_name}}" "${aws_flags[@]}" >/dev/null 2>&1; then
      aws iot update-dynamic-thing-group \
        --thing-group-name "{{rig_name}}" \
        --thing-group-properties "$thing_group_properties" \
        --index-name "{{thing_index_name}}" \
        --query-string "$query_string" \
        "${aws_flags[@]}" >/dev/null
      echo "Updated dynamic thing group {{rig_name}}"
    else
      aws iot create-dynamic-thing-group \
        --thing-group-name "{{rig_name}}" \
        --thing-group-properties "$thing_group_properties" \
        --index-name "{{thing_index_name}}" \
        --query-string "$query_string" \
        "${aws_flags[@]}" >/dev/null
      echo "Created dynamic thing group {{rig_name}}"
    fi

    aws iot describe-thing-group \
      --thing-group-name "{{rig_name}}" \
      "${aws_flags[@]}" \
      --query "{thingGroupName: thingGroupName, queryString: queryString, thingGroupDescription: thingGroupProperties.thingGroupDescription}" \
      --output table

# Register a new device. Usage: just aws::register-device <town> <rig> <device-type> [region] [profile]
@register-town town region=region profile=profile:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"

    eval "$(just --justfile "{{root_justfile}}" _project-aws-env town "{{region}}" "{{profile}}")"
    region="$AWS_REGION"

    if [ -z "$region" ]; then
      echo "region is empty and no default AWS region is configured. Set region=<aws-region>" >&2
      exit 1
    fi
    if [ -z "{{town}}" ]; then
      echo "town is required. Usage: just aws::register-town <town> [region] [profile]" >&2
      exit 1
    fi

    uv run --project "{{aws_dir}}/python" \
      python -m aws.device_registry \
      --region "$region" \
      register-town \
      --town "{{town}}"

