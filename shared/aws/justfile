set shell := ["bash", "-eu", "-o", "pipefail", "-c"]

aws_dir := source_directory()
project_root := aws_dir + "/../.."
root_justfile := project_root + "/justfile"

stack_name := ""
template_file := "template.yaml"
region := ""
profile := ""
thing_name := "unit-local"
rig_name := "rig"
policy_name := "town-rig-device-policy"
log_group_name := "/town/rig/txing"
local_state_dir := project_root + "/.state/aws"
default_shadow_file := project_root + "/devices/unit/aws/default-sparkplug-shadow.json"
localhost_app_url := "http://localhost:5173"
localhost_alt_app_url := "http://127.0.0.1:5173"
thing_index_name := "AWS_Things"

@create CognitoDomainPrefix='' AdminEmail='' stack_name=stack_name template_file=template_file region=region profile=profile LocalhostAppUrl=localhost_app_url LocalhostAltAppUrl=localhost_alt_app_url:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"

    eval "$(just --justfile "{{root_justfile}}" _project-aws-env town "{{region}}" "{{profile}}" "{{stack_name}}" "{{CognitoDomainPrefix}}" "{{AdminEmail}}")"
    stack_name="$AWS_STACK_NAME"
    region="$AWS_REGION"
    profile="$AWS_SELECTED_PROFILE"
    cognito_domain_prefix="$AWS_COGNITO_DOMAIN_PREFIX"
    admin_email="$AWS_ADMIN_EMAIL"

    if [ -z "$region" ]; then
      echo "region is empty and no default AWS region is configured. Set region=<aws-region>" >&2
      exit 1
    fi

    aws_flags=(--region "$region")
    if [ -n "$profile" ]; then
      aws_flags+=(--profile "$profile")
    fi
    params=(
      ParameterKey=CognitoDomainPrefix,ParameterValue="$cognito_domain_prefix"
      ParameterKey=AdminEmail,ParameterValue="$admin_email"
      ParameterKey=LocalhostAppUrl,ParameterValue="{{LocalhostAppUrl}}"
      ParameterKey=LocalhostAltAppUrl,ParameterValue="{{LocalhostAltAppUrl}}"
    )
    cfn_flags=(--stack-name "$stack_name" --template-body "file://{{template_file}}" --capabilities CAPABILITY_NAMED_IAM --parameters "${params[@]}" "${aws_flags[@]}")

    aws cloudformation create-stack "${cfn_flags[@]}"
    aws cloudformation wait stack-create-complete --stack-name "$stack_name" "${aws_flags[@]}"
    aws cloudformation describe-stacks \
      --stack-name "$stack_name" \
      "${aws_flags[@]}" \
      --query "Stacks[0].Outputs" \
      --output table

@update CognitoDomainPrefix='' AdminEmail='' stack_name=stack_name template_file=template_file region=region profile=profile LocalhostAppUrl=localhost_app_url LocalhostAltAppUrl=localhost_alt_app_url:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"

    eval "$(just --justfile "{{root_justfile}}" _project-aws-env town "{{region}}" "{{profile}}" "{{stack_name}}" "{{CognitoDomainPrefix}}" "{{AdminEmail}}")"
    stack_name="$AWS_STACK_NAME"
    region="$AWS_REGION"
    profile="$AWS_SELECTED_PROFILE"
    cognito_domain_prefix="$AWS_COGNITO_DOMAIN_PREFIX"
    admin_email="$AWS_ADMIN_EMAIL"

    if [ -z "$region" ]; then
      echo "region is empty and no default AWS region is configured. Set region=<aws-region>" >&2
      exit 1
    fi

    aws_flags=(--region "$region")
    if [ -n "$profile" ]; then
      aws_flags+=(--profile "$profile")
    fi
    params=(
      ParameterKey=CognitoDomainPrefix,ParameterValue="$cognito_domain_prefix"
      ParameterKey=AdminEmail,ParameterValue="$admin_email"
      ParameterKey=LocalhostAppUrl,ParameterValue="{{LocalhostAppUrl}}"
      ParameterKey=LocalhostAltAppUrl,ParameterValue="{{LocalhostAltAppUrl}}"
    )
    cfn_flags=(--stack-name "$stack_name" --template-body "file://{{template_file}}" --capabilities CAPABILITY_NAMED_IAM --parameters "${params[@]}" "${aws_flags[@]}")

    output="$(aws cloudformation update-stack "${cfn_flags[@]}" 2>&1)" || {
      if echo "$output" | grep -q "No updates are to be performed"; then
        echo "$output"
        exit 0
      fi
      echo "$output"
      exit 1
    }
    echo "$output"

    aws cloudformation wait stack-update-complete --stack-name "$stack_name" "${aws_flags[@]}"
    aws cloudformation describe-stacks \
      --stack-name "$stack_name" \
      "${aws_flags[@]}" \
      --query "Stacks[0].Outputs" \
      --output table

@deploy CognitoDomainPrefix='' AdminEmail='' stack_name=stack_name template_file=template_file region=region profile=profile LocalhostAppUrl=localhost_app_url LocalhostAltAppUrl=localhost_alt_app_url:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"

    eval "$(just --justfile "{{root_justfile}}" _project-aws-env town "{{region}}" "{{profile}}" "{{stack_name}}" "{{CognitoDomainPrefix}}" "{{AdminEmail}}")"
    stack_name="$AWS_STACK_NAME"
    region="$AWS_REGION"
    profile="$AWS_SELECTED_PROFILE"
    cognito_domain_prefix="$AWS_COGNITO_DOMAIN_PREFIX"
    admin_email="$AWS_ADMIN_EMAIL"

    if [ -z "$region" ]; then
      echo "region is empty and no default AWS region is configured. Set region=<aws-region>" >&2
      exit 1
    fi

    aws_flags=(--region "$region")
    if [ -n "$profile" ]; then
      aws_flags+=(--profile "$profile")
    fi

    deploy_flags=(
      --stack-name "$stack_name"
      --template-file "{{template_file}}"
      --capabilities CAPABILITY_NAMED_IAM
      --parameter-overrides
      "CognitoDomainPrefix=$cognito_domain_prefix"
      "AdminEmail=$admin_email"
      "LocalhostAppUrl={{LocalhostAppUrl}}"
      "LocalhostAltAppUrl={{LocalhostAltAppUrl}}"
      --no-fail-on-empty-changeset
      "${aws_flags[@]}"
    )

    aws cloudformation deploy "${deploy_flags[@]}"

    aws cloudformation describe-stacks \
      --stack-name "$stack_name" \
      "${aws_flags[@]}" \
      --query "Stacks[0].Outputs" \
      --output table

@delete stack_name=stack_name thing_name=thing_name policy_name=policy_name region=region profile=profile:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"

    eval "$(just --justfile "{{root_justfile}}" _project-aws-env town "{{region}}" "{{profile}}" "{{stack_name}}")"
    stack_name="$AWS_STACK_NAME"
    region="$AWS_REGION"
    profile="$AWS_SELECTED_PROFILE"

    if [ -z "$region" ]; then
      echo "region is empty and no default AWS region is configured. Set region=<aws-region>" >&2
      exit 1
    fi

    aws_flags=(--region "$region")
    if [ -n "$profile" ]; then
      aws_flags+=(--profile "$profile")
    fi

    web_bucket_name="$(aws cloudformation describe-stacks \
      --stack-name "$stack_name" \
      "${aws_flags[@]}" \
      --query "Stacks[0].Outputs[?OutputKey=='WebAppBucketName'].OutputValue | [0]" \
      --output text 2>/dev/null || true)"
    if [ -n "$web_bucket_name" ] && [ "$web_bucket_name" != "None" ]; then
      aws s3 rm "s3://$web_bucket_name" --recursive "${aws_flags[@]}" || true
    fi

    principals="$(aws iot list-thing-principals --thing-name "{{thing_name}}" "${aws_flags[@]}" --query principals --output text 2>/dev/null || true)"
    if [ -n "$principals" ] && [ "$principals" != "None" ]; then
      for principal in $principals; do
        aws iot detach-thing-principal --thing-name "{{thing_name}}" --principal "$principal" "${aws_flags[@]}" || true
      done
    fi

    targets="$(aws iot list-targets-for-policy --policy-name "{{policy_name}}" "${aws_flags[@]}" --query targets --output text 2>/dev/null || true)"
    if [ -n "$targets" ] && [ "$targets" != "None" ]; then
      for target in $targets; do
        aws iot detach-policy --policy-name "{{policy_name}}" --target "$target" "${aws_flags[@]}" || true
      done
    fi

    aws cloudformation delete-stack --stack-name "$stack_name" "${aws_flags[@]}"
    aws cloudformation wait stack-delete-complete --stack-name "$stack_name" "${aws_flags[@]}"

