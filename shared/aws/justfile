@create-admin-user AdminPassword AdminEmail='' stack_name=stack_name region=region profile=profile:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"
    source "{{aws_lib}}"
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env aws "{{region}}" "{{profile}}" "{{stack_name}}" "" "{{AdminEmail}}")"
    txing_aws_init
    user_pool_id="$(stack_output "$AWS_STACK_NAME" WebCognitoUserPoolId)"
    if aws cognito-idp admin-get-user \
      --user-pool-id "$user_pool_id" \
      --username "$AWS_ADMIN_EMAIL" \
      "${aws_flags[@]}" >/dev/null 2>&1; then
      echo "Admin user already exists, updating password."
    else
      aws cognito-idp admin-create-user \
        --user-pool-id "$user_pool_id" \
        --username "$AWS_ADMIN_EMAIL" \
        --user-attributes Name=email,Value="$AWS_ADMIN_EMAIL" Name=email_verified,Value=true \
        --message-action SUPPRESS \
        "${aws_flags[@]}" >/dev/null
      echo "Admin user created."
    fi
    aws cognito-idp admin-set-user-password \
      --user-pool-id "$user_pool_id" \
      --username "$AWS_ADMIN_EMAIL" \
      --password "{{AdminPassword}}" \
      --permanent \
      "${aws_flags[@]}" >/dev/null
    echo "Admin user password set."

@check rig_id='' thing_id='' log_group_name='' region=region profile=profile:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"
    source "{{aws_lib}}"
    if [ -n "{{rig_id}}" ]; then
      export TXING_RIG_ID="{{rig_id}}"
    fi
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig "{{region}}" "{{profile}}")"
    txing_aws_init
    failures=0
    for tool in aws jq uv just; do
      if command -v "$tool" >/dev/null 2>&1; then
        echo "ok: tool '$tool' is installed"
      else
        echo "fail: tool '$tool' is not installed"
        failures=$((failures + 1))
      fi
    done
    if ! uv run --project "{{aws_dir}}/python" python -m aws.check --scope rig --rig-id "$TXING_RIG_ID" --log-group-name "${log_group_name:-$CLOUDWATCH_LOG_GROUP}"; then
      failures=$((failures + 1))
    fi
    if [ -n "{{thing_id}}" ] || [ -n "${TXING_THING_ID:-}" ]; then
      if [ -n "{{thing_id}}" ]; then
        export TXING_THING_ID="{{thing_id}}"
      fi
      eval "$(just --justfile "{{root_justfile}}" _project-aws-env device "{{region}}" "{{profile}}")"
      if ! uv run --project "{{aws_dir}}/python" python -m aws.check --scope device --thing-name "$THING_NAME"; then
        failures=$((failures + 1))
      fi
    fi
    thing_indexing_mode="$(aws iot get-indexing-configuration "${aws_flags[@]}" --query "thingIndexingConfiguration.thingIndexingMode" --output text 2>/dev/null || true)"
    thing_connectivity_indexing_mode="$(aws iot get-indexing-configuration "${aws_flags[@]}" --query "thingIndexingConfiguration.thingConnectivityIndexingMode" --output text 2>/dev/null || true)"
    if [ "$thing_indexing_mode" = "REGISTRY" ] && [ "$thing_connectivity_indexing_mode" = "STATUS" ]; then
      echo "ok: AWS IoT fleet indexing is enabled in REGISTRY mode with connectivity status"
    else
      echo "fail: AWS IoT fleet indexing is not configured as REGISTRY/STATUS"
      failures=$((failures + 1))
    fi
    if [ "$failures" -ne 0 ]; then
      echo "AWS check failed with $failures issue(s)." >&2
      exit 1
    fi
    echo "AWS check passed."

@things-for-rig rig_id='' region=region profile=profile:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"
    source "{{aws_lib}}"
    if [ -n "{{rig_id}}" ]; then
      export TXING_RIG_ID="{{rig_id}}"
    fi
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig "{{region}}" "{{profile}}")"
    txing_aws_init
    thing_names="$(
      aws iot search-index \
        --index-name AWS_Things \
        --query-string "attributes.rigId:$TXING_RIG_ID AND attributes.townId:*" \
        "${aws_flags[@]}" \
        --query "things[].thingName" \
        --output text
    )"
    if [ -z "$thing_names" ] || [ "$thing_names" = "None" ]; then
      echo "[]"
      exit 0
    fi
    result="[]"
    for thing in $thing_names; do
      thing_json="$(aws iot describe-thing --thing-name "$thing" "${aws_flags[@]}" --output json)"
      result="$(
        jq -cn \
          --argjson rows "$result" \
          --argjson thing "$thing_json" \
          '$rows + [{
            thingName: $thing.thingName,
            thingType: ($thing.thingTypeName // null),
            name: ($thing.attributes.name // null),
            shortId: ($thing.attributes.shortId // null),
            townId: ($thing.attributes.townId // null),
            rigId: ($thing.attributes.rigId // null)
          }]'
      )"
    done
    jq '.' <<<"$result"

@shadow thing_name='' shadow_name='' region=region profile=profile:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"
    source "{{aws_lib}}"
    if [ -n "{{thing_name}}" ]; then
      export TXING_THING_ID="{{thing_name}}"
    fi
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env device "{{region}}" "{{profile}}")"
    txing_aws_init
    effective_thing_name="${thing_name:-$THING_NAME}"
    endpoint="$(aws iot describe-endpoint --endpoint-type iot:Data-ATS "${aws_flags[@]}" --query endpointAddress --output text)"
    if [ -n "{{shadow_name}}" ]; then
      aws iot-data get-thing-shadow \
        --endpoint-url "https://$endpoint" \
        --thing-name "$effective_thing_name" \
        --shadow-name "{{shadow_name}}" \
        "${aws_flags[@]}" \
        /dev/stdout | jq --arg shadowName "{{shadow_name}}" '{($shadowName): .}'
      exit 0
    fi
    thing_json="$(aws iot describe-thing --thing-name "$effective_thing_name" "${aws_flags[@]}" --output json)"
    thing_type="$(jq -r '.thingTypeName // empty' <<<"$thing_json")"
    if [ "$thing_type" = "town" ]; then
      catalog_path="/txing/town"
    elif [ -n "$(jq -r '.attributes.rigId // empty' <<<"$thing_json")" ]; then
      rig_json="$(aws iot describe-thing --thing-name "$(jq -r '.attributes.rigId' <<<"$thing_json")" "${aws_flags[@]}" --output json)"
      catalog_path="/txing/town/$(jq -r '.thingTypeName' <<<"$rig_json")/$thing_type"
    else
      catalog_path="/txing/town/$thing_type"
    fi
    capabilities_set="$(
      uv run --project "{{aws_dir}}/python" \
        python -m aws.type_catalog \
        --region "$AWS_REGION" \
        describe "$catalog_path" \
        | jq -r '.capabilities | join(",")'
    )"
    result="{}"
    while IFS= read -r current_shadow_name; do
      [ -n "$current_shadow_name" ] || continue
      if payload="$(
        aws iot-data get-thing-shadow \
          --endpoint-url "https://$endpoint" \
          --thing-name "$effective_thing_name" \
          --shadow-name "$current_shadow_name" \
          "${aws_flags[@]}" \
          /dev/stdout 2>/dev/null
      )"; then
        :
      else
        payload='{"missing":true}'
      fi
      result="$(jq --arg shadowName "$current_shadow_name" --argjson shadowPayload "$payload" '. + {($shadowName): $shadowPayload}' <<<"$result")"
    done < <(tr ',' '\n' <<<"$capabilities_set")
    jq '.' <<<"$result"

@shadow-reset thing_name='' shadow_name='sparkplug' region=region profile=profile payload_file='':
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"
    source "{{aws_lib}}"
    if [ -n "{{thing_name}}" ]; then
      export TXING_THING_ID="{{thing_name}}"
    fi
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env device "{{region}}" "{{profile}}")"
    txing_aws_init
    effective_thing_name="${thing_name:-$THING_NAME}"
    endpoint="$(aws iot describe-endpoint --endpoint-type iot:Data-ATS "${aws_flags[@]}" --query endpointAddress --output text)"
    payload_file="{{payload_file}}"
    if [ -z "$payload_file" ]; then
      payload_file="$(mktemp "${TMPDIR:-/tmp}/txing-shadow.XXXXXX")"
      trap 'rm -f "$payload_file"' EXIT
      thing_json="$(aws iot describe-thing --thing-name "$effective_thing_name" "${aws_flags[@]}" --output json)"
      thing_type="$(jq -r '.thingTypeName // empty' <<<"$thing_json")"
      case "$thing_type:{{shadow_name}}" in
        town:sparkplug)
          jq -n '{state: {reported: {payload: {metrics: {redcon: 1}}}}}' >"$payload_file"
          ;;
        raspi:sparkplug|cloud:sparkplug)
          town_json="$(aws iot describe-thing --thing-name "$(jq -r '.attributes.townId' <<<"$thing_json")" "${aws_flags[@]}" --output json)"
          jq \
            -n \
            --arg groupId "$(jq -r '.attributes.name' <<<"$town_json")" \
            --arg edgeNodeId "$(jq -r '.attributes.name' <<<"$thing_json")" \
            '{state: {reported: {topic: {namespace: "spBv1.0", groupId: $groupId, messageType: "NDEATH", edgeNodeId: $edgeNodeId}, payload: {metrics: {redcon: 4}}}}}' \
            >"$payload_file"
          ;;
        *:sparkplug)
          rig_json="$(aws iot describe-thing --thing-name "$(jq -r '.attributes.rigId' <<<"$thing_json")" "${aws_flags[@]}" --output json)"
          town_json="$(aws iot describe-thing --thing-name "$(jq -r '.attributes.townId' <<<"$thing_json")" "${aws_flags[@]}" --output json)"
          jq \
            -n \
            --arg groupId "$(jq -r '.attributes.name' <<<"$town_json")" \
            --arg edgeNodeId "$(jq -r '.attributes.name' <<<"$rig_json")" \
            --arg deviceId "$(jq -r '.thingName' <<<"$thing_json")" \
            '{state: {reported: {topic: {namespace: "spBv1.0", groupId: $groupId, messageType: "DDEATH", edgeNodeId: $edgeNodeId, deviceId: $deviceId}, payload: {metrics: {}}}}}' \
            >"$payload_file"
          ;;
        *)
          default_payload="$(
            uv run --project "{{aws_dir}}/python" \
              python -c 'from pathlib import Path; import sys; from aws.device_catalog import load_device_manifest; print(load_device_manifest(sys.argv[1], repo_root=Path(sys.argv[3])).shadow_contract(sys.argv[2]).default)' \
              "$thing_type" "{{shadow_name}}" "{{project_root}}"
          )"
          if [ ! -f "$default_payload" ]; then
            echo "shadow reset payload $default_payload not found" >&2
            exit 1
          fi
          cp "$default_payload" "$payload_file"
          ;;
      esac
    fi
    aws iot-data delete-thing-shadow \
      --endpoint-url "https://$endpoint" \
      --thing-name "$effective_thing_name" \
      --shadow-name "{{shadow_name}}" \
      "${aws_flags[@]}" \
      /dev/null 2>/dev/null || true
    aws iot-data update-thing-shadow \
      --endpoint-url "https://$endpoint" \
      --thing-name "$effective_thing_name" \
      --shadow-name "{{shadow_name}}" \
      --payload "fileb://$payload_file" \
      "${aws_flags[@]}" \
      /dev/stdout | jq '.'

@cert rig_id='':
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"
    source "{{aws_lib}}"
    if [ -n "{{rig_id}}" ]; then
      export TXING_RIG_ID="{{rig_id}}"
    fi
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env rig)"
    txing_aws_init
    effective_thing_name="$TXING_RIG_ID"
    effective_policy_name="$(stack_output "$AWS_STACK_NAME" PolicyName)"
    cert_dir="{{project_root}}/config/certs/rig"
    cert_path="$cert_dir/rig.cert.pem"
    public_key_path="$cert_dir/rig.public.key"
    private_key_path="$cert_dir/rig.private.key"
    cert_arn_path="$cert_dir/rig.cert.arn"
    root_ca_path="$cert_dir/AmazonRootCA1.pem"
    install -d -m 700 "$cert_dir"
    if [ -e "$cert_path" ] || [ -e "$public_key_path" ] || [ -e "$private_key_path" ] || [ -e "$cert_arn_path" ]; then
      echo "Certificate material already exists under $cert_dir." >&2
      echo "Move or delete those files before issuing a replacement certificate." >&2
      exit 1
    fi
    curl -fsSL https://www.amazontrust.com/repository/AmazonRootCA1.pem -o "$root_ca_path"
    cert_arn="$(
      aws iot create-keys-and-certificate \
        --set-as-active \
        --certificate-pem-outfile "$cert_path" \
        --public-key-outfile "$public_key_path" \
        --private-key-outfile "$private_key_path" \
        "${aws_flags[@]}" \
        --query certificateArn \
        --output text
    )"
    aws iot attach-policy --policy-name "$effective_policy_name" --target "$cert_arn" "${aws_flags[@]}"
    aws iot attach-thing-principal --thing-name "$effective_thing_name" --principal "$cert_arn" "${aws_flags[@]}"
    printf '%s\n' "$cert_arn" >"$cert_arn_path"
    chmod 600 "$cert_path" "$public_key_path" "$private_key_path" "$cert_arn_path"
    chmod 644 "$root_ca_path"
    jq -n \
      --arg thingName "$effective_thing_name" \
      --arg policyName "$effective_policy_name" \
      --arg certificateArn "$cert_arn" \
      --arg certificatePem "$cert_path" \
      --arg publicKey "$public_key_path" \
      --arg privateKey "$private_key_path" \
      --arg certificateArnFile "$cert_arn_path" \
      --arg rootCaFile "$root_ca_path" \
      '{thingName: $thingName, policyName: $policyName, certificateArn: $certificateArn, certificatePem: $certificatePem, publicKey: $publicKey, privateKey: $privateKey, certificateArnFile: $certificateArnFile, rootCaFile: $rootCaFile}'

@init-shadow thing_name='' shadow_name='sparkplug' region=region profile=profile payload_file='' shadow_response_file='':
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"
    source "{{aws_lib}}"
    if [ -n "{{thing_name}}" ]; then
      export TXING_THING_ID="{{thing_name}}"
    fi
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env device "{{region}}" "{{profile}}")"
    txing_aws_init
    effective_thing_name="${thing_name:-$THING_NAME}"
    endpoint="$(aws iot describe-endpoint --endpoint-type iot:Data-ATS "${aws_flags[@]}" --query endpointAddress --output text)"
    payload_file="{{payload_file}}"
    if [ -z "$payload_file" ]; then
      payload_file="$(mktemp "${TMPDIR:-/tmp}/txing-shadow.XXXXXX")"
      trap 'rm -f "$payload_file"' EXIT
      thing_json="$(aws iot describe-thing --thing-name "$effective_thing_name" "${aws_flags[@]}" --output json)"
      thing_type="$(jq -r '.thingTypeName // empty' <<<"$thing_json")"
      thing_kind="$(jq -r '.attributes.kind // empty' <<<"$thing_json")"
      case "$thing_kind:{{shadow_name}}" in
        townType:sparkplug)
          jq -n '{state: {reported: {payload: {metrics: {redcon: 1}}}}}' >"$payload_file"
          ;;
        rigType:sparkplug)
          jq \
            -n \
            --arg groupId "$(jq -r '.attributes.townId' <<<"$thing_json")" \
            --arg edgeNodeId "$(jq -r '.thingName' <<<"$thing_json")" \
            '{state: {reported: {topic: {namespace: "spBv1.0", groupId: $groupId, messageType: "NDEATH", edgeNodeId: $edgeNodeId}, payload: {metrics: {redcon: 4}}}}}' \
            >"$payload_file"
          ;;
        deviceType:sparkplug)
          jq \
            -n \
            --arg groupId "$(jq -r '.attributes.townId' <<<"$thing_json")" \
            --arg edgeNodeId "$(jq -r '.attributes.rigId' <<<"$thing_json")" \
            --arg deviceId "$(jq -r '.thingName' <<<"$thing_json")" \
            '{state: {reported: {topic: {namespace: "spBv1.0", groupId: $groupId, messageType: "DDEATH", edgeNodeId: $edgeNodeId, deviceId: $deviceId}, payload: {metrics: {}}}}}' \
            >"$payload_file"
          ;;
        *)
          default_payload="$(
            uv run --project "{{aws_dir}}/python" \
              python -c 'from pathlib import Path; import sys; from aws.device_catalog import load_device_manifest; print(load_device_manifest(sys.argv[1], repo_root=Path(sys.argv[3])).shadow_contract(sys.argv[2]).default)' \
              "$thing_type" "{{shadow_name}}" "{{project_root}}"
          )"
          if [ ! -f "$default_payload" ]; then
            echo "shadow init payload $default_payload not found" >&2
            exit 1
          fi
          cp "$default_payload" "$payload_file"
          ;;
      esac
    fi
    response_target="{{shadow_response_file}}"
    response_target="${response_target:-/dev/stdout}"
    aws iot-data update-thing-shadow \
      --endpoint-url "https://$endpoint" \
      --thing-name "$effective_thing_name" \
      --shadow-name "{{shadow_name}}" \
      --payload "fileb://$payload_file" \
      "${aws_flags[@]}" \
      "$response_target"

@assign-device device_id rig_id region=region profile=profile:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"
    source "{{aws_lib}}"
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env aws "{{region}}" "{{profile}}")"
    txing_aws_init
    payload_file="$(mktemp "${TMPDIR:-/tmp}/txing-enlist-assign.XXXXXX")"
    trap 'rm -f "$payload_file"' EXIT
    jq -n \
      --arg deviceId "{{device_id}}" \
      --arg rigId "{{rig_id}}" \
      '{action:"assignDevice", deviceId:$deviceId, rigId:$rigId}' >"$payload_file"
    invoke_enlist_payload_file "$payload_file" | jq '.'
