set shell := ["bash", "-eu", "-o", "pipefail", "-c"]
set quiet := true

aws_dir := source_directory()
project_root := aws_dir + "/../.."
root_justfile := project_root + "/justfile"
aws_lib := aws_dir + "/scripts/aws_lib.sh"

stack_name := ""
template_file := "template.yaml"
town_template_file := "templates/town.yaml"
rig_template_file := "templates/rig.yaml"
device_template_file := "templates/device.yaml"
region := ""
profile := ""
localhost_app_url := "http://localhost:5173"
localhost_alt_app_url := "http://127.0.0.1:5173"

@deploy CognitoDomainPrefix='' AdminEmail='' stack_name=stack_name template_file=template_file region=region profile=profile LocalhostAppUrl=localhost_app_url LocalhostAltAppUrl=localhost_alt_app_url:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"
    source "{{aws_lib}}"
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env aws "{{region}}" "{{profile}}" "{{stack_name}}" "{{CognitoDomainPrefix}}" "{{AdminEmail}}")"
    txing_aws_init
    deploy_template \
      "$AWS_STACK_NAME" \
      "{{template_file}}" \
      --parameter-overrides \
      "CognitoDomainPrefix=$AWS_COGNITO_DOMAIN_PREFIX" \
      "AdminEmail=$AWS_ADMIN_EMAIL" \
      "TxingVersion=$TXING_VERSION" \
      "LocalhostAppUrl={{LocalhostAppUrl}}" \
      "LocalhostAltAppUrl={{LocalhostAltAppUrl}}"
    describe_stack_outputs "$AWS_STACK_NAME"

@type-sync CognitoDomainPrefix='' AdminEmail='' stack_name=stack_name template_file=template_file region=region profile=profile:
    #!/usr/bin/env bash
    set -euo pipefail
    just --justfile "{{aws_dir}}/justfile" deploy "{{CognitoDomainPrefix}}" "{{AdminEmail}}" "{{stack_name}}" "{{template_file}}" "{{region}}" "{{profile}}"

@delete stack_name=stack_name region=region profile=profile wait='true' delete_packaging_buckets='true' include_legacy_time_lambda='true':
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{aws_dir}}"
    source "{{aws_lib}}"
    eval "$(just --justfile "{{root_justfile}}" _project-aws-env aws "{{region}}" "{{profile}}" "{{stack_name}}")"
    txing_aws_init
    echo "Deleting CloudFormation stack $AWS_STACK_NAME"
    aws cloudformation delete-stack --stack-name "$AWS_STACK_NAME" "${aws_flags[@]}"
    if [ "{{wait}}" = "true" ]; then
      aws cloudformation wait stack-delete-complete --stack-name "$AWS_STACK_NAME" "${aws_flags[@]}"
      echo "Deleted CloudFormation stack $AWS_STACK_NAME"
    fi
    if [ "{{delete_packaging_buckets}}" = "true" ]; then
      delete_s3_bucket_if_exists "$(artifact_bucket_name)"
      if [ "{{include_legacy_time_lambda}}" = "true" ]; then
        delete_s3_bucket_if_exists "$(legacy_time_lambda_artifact_bucket_name)"
      fi
    fi

