set shell := ["bash", "-eu", "-o", "pipefail", "-c"]

web_dir := source_directory()
project_root := web_dir + "/.."
root_justfile := project_root + "/justfile"
stack_name := ""
region := ""
profile := ""
web_dist_dir := web_dir + "/dist"

@install:
    cd "{{web_dir}}"
    bun install

@dev:
    cd "{{web_dir}}"
    bun run dev

@build:
    cd "{{web_dir}}"
    bun run build

@publish stack_name=stack_name region=region profile=profile web_dist_dir=web_dist_dir:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{web_dir}}"

    eval "$(just --justfile "{{root_justfile}}" _project-aws-env town "{{region}}" "{{profile}}" "{{stack_name}}")"
    stack_name="$AWS_STACK_NAME"
    region="$AWS_REGION"
    profile="$AWS_SELECTED_PROFILE"

    if [ -z "$region" ]; then
      echo "region is empty and no default AWS region is configured. Set region=<aws-region>" >&2
      exit 1
    fi

    if [ ! -d "{{web_dist_dir}}" ]; then
      echo "Web build output {{web_dist_dir}} not found. Run just build first." >&2
      exit 1
    fi

    aws_flags=(--region "$region")
    if [ -n "$profile" ]; then
      aws_flags+=(--profile "$profile")
    fi

    web_bucket_name="$(aws cloudformation describe-stacks \
      --stack-name "$stack_name" \
      "${aws_flags[@]}" \
      --query "Stacks[0].Outputs[?OutputKey=='WebAppBucketName'].OutputValue | [0]" \
      --output text)"

    web_distribution_id="$(aws cloudformation describe-stacks \
      --stack-name "$stack_name" \
      "${aws_flags[@]}" \
      --query "Stacks[0].Outputs[?OutputKey=='WebAppDistributionId'].OutputValue | [0]" \
      --output text)"

    if [ "$web_bucket_name" = "None" ] || [ "$web_distribution_id" = "None" ]; then
      echo "Required web hosting outputs are missing in stack $stack_name. Deploy shared/aws/template.yaml first." >&2
      exit 1
    fi

    aws s3 sync "{{web_dist_dir}}/" "s3://$web_bucket_name/" \
      --delete \
      --exclude "*.html" \
      --cache-control "public,max-age=31536000,immutable" \
      "${aws_flags[@]}"

    while IFS= read -r -d '' html_file; do
      key="${html_file#"{{web_dist_dir}}"/}"
      key="${key#/}"
      aws s3 cp "$html_file" "s3://$web_bucket_name/$key" \
        --cache-control "no-cache, no-store, must-revalidate" \
        "${aws_flags[@]}"
    done < <(find "{{web_dist_dir}}" -type f -name '*.html' -print0)

    aws cloudfront create-invalidation \
      --distribution-id "$web_distribution_id" \
      --paths "/*" \
      "${aws_flags[@]}" >/dev/null

    echo "Published {{web_dist_dir}} to s3://$web_bucket_name and invalidated CloudFront distribution $web_distribution_id."

@lint:
    cd "{{web_dir}}"
    bun run lint

@write-env stack_name=stack_name region=region profile=profile:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{web_dir}}"

    eval "$(just --justfile "{{root_justfile}}" _project-aws-env town "{{region}}" "{{profile}}" "{{stack_name}}")"
    stack_name="$AWS_STACK_NAME"
    region="$AWS_REGION"
    profile="$AWS_SELECTED_PROFILE"

    aws_flags=(--region "$region")
    if [ -n "$profile" ]; then
      aws_flags+=(--profile "$profile")
    fi

    cognito_domain="$(aws cloudformation describe-stacks \
      --stack-name "$stack_name" \
      "${aws_flags[@]}" \
      --query "Stacks[0].Outputs[?OutputKey=='WebCognitoDomain'].OutputValue | [0]" \
      --output text)"

    cognito_client_id="$(aws cloudformation describe-stacks \
      --stack-name "$stack_name" \
      "${aws_flags[@]}" \
      --query "Stacks[0].Outputs[?OutputKey=='WebCognitoUserPoolClientId'].OutputValue | [0]" \
      --output text)"

    cognito_user_pool_id="$(aws cloudformation describe-stacks \
      --stack-name "$stack_name" \
      "${aws_flags[@]}" \
      --query "Stacks[0].Outputs[?OutputKey=='WebCognitoUserPoolId'].OutputValue | [0]" \
      --output text)"

    cognito_identity_pool_id="$(aws cloudformation describe-stacks \
      --stack-name "$stack_name" \
      "${aws_flags[@]}" \
      --query "Stacks[0].Outputs[?OutputKey=='WebCognitoIdentityPoolId'].OutputValue | [0]" \
      --output text)"

    web_iot_policy_name="$(aws cloudformation describe-stacks \
      --stack-name "$stack_name" \
      "${aws_flags[@]}" \
      --query "Stacks[0].Outputs[?OutputKey=='WebIotPolicyName'].OutputValue | [0]" \
      --output text)"

    admin_email="$(aws cloudformation describe-stacks \
      --stack-name "$stack_name" \
      "${aws_flags[@]}" \
      --query "Stacks[0].Outputs[?OutputKey=='WebExpectedAdminEmail'].OutputValue | [0]" \
      --output text)"

    if [ "$cognito_domain" = "None" ] || [ "$cognito_client_id" = "None" ] || [ "$cognito_user_pool_id" = "None" ] || [ "$cognito_identity_pool_id" = "None" ] || [ "$web_iot_policy_name" = "None" ] || [ "$admin_email" = "None" ]; then
      echo "Required web outputs are missing in stack $stack_name. Deploy shared/aws/template.yaml first." >&2
      exit 1
    fi

    printf '%s\n' \
      "VITE_AWS_REGION=$region" \
      "VITE_TXING_THING_NAME=txing" \
      "VITE_SPARKPLUG_GROUP_ID=town" \
      "VITE_SPARKPLUG_EDGE_NODE_ID=rig" \
      "VITE_COGNITO_DOMAIN=$cognito_domain" \
      "VITE_COGNITO_CLIENT_ID=$cognito_client_id" \
      "VITE_COGNITO_USER_POOL_ID=$cognito_user_pool_id" \
      "VITE_COGNITO_IDENTITY_POOL_ID=$cognito_identity_pool_id" \
      "VITE_IOT_POLICY_NAME=$web_iot_policy_name" \
      "VITE_COGNITO_SCOPE=openid email profile" \
      "VITE_ADMIN_EMAIL=$admin_email" \
      > .env.local

    echo "Wrote {{web_dir}}/.env.local from stack $stack_name outputs."
