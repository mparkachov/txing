set shell := ["bash", "-eu", "-o", "pipefail", "-c"]
set quiet := true

zephyr_dir := source_directory()
python_executable := "python3"
uv_cache_dir := zephyr_dir + "/.uv-cache"
toolchain_script := zephyr_dir + "/scripts/toolchain.py"

@sync:
    cd "{{zephyr_dir}}" && UV_CACHE_DIR="{{uv_cache_dir}}" uv sync --python "{{python_executable}}" --no-managed-python --no-python-downloads

@install:
    cd "{{zephyr_dir}}" && UV_CACHE_DIR="{{uv_cache_dir}}" uv sync --python "{{python_executable}}" --no-managed-python --no-python-downloads
    cd "{{zephyr_dir}}" && UV_CACHE_DIR="{{uv_cache_dir}}" uv run --project "{{zephyr_dir}}" --no-sync python "{{toolchain_script}}" install

@check:
    cd "{{zephyr_dir}}" && UV_CACHE_DIR="{{uv_cache_dir}}" uv run --project "{{zephyr_dir}}" --no-sync python "{{toolchain_script}}" check

@check-flash:
    cd "{{zephyr_dir}}" && UV_CACHE_DIR="{{uv_cache_dir}}" uv run --project "{{zephyr_dir}}" --no-sync python "{{toolchain_script}}" check-flash

@clean-build:
    rm -rf "{{zephyr_dir}}/build"

@default:
    @just --list
